---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
import mapSvg from "@/assets/svg/mapa-peru.svg?raw";
import backgroundImageMobile from "@/assets/backgroundImageMobile.webp";
import { rewriteUrl } from "@/lib/utils";

// ====== i18n: Textos de la sección ======
const copy = {
  es: {
    badge: "Guías de Viaje",
    title: "Un Viaje a través de la",
    titleHighlight: "Diversidad Infinita",
    description:
      "Perú no es un país, es un mundo por descubrir. Cada región es un universo único, con paisajes, culturas, gastronomía y tradiciones que desafían la imaginación.",
    description2:
      "Adéntrate en un territorio donde la geografía cambia cada cien kilómetros, donde puedes pasar de glaciares imponentes a selvas exuberantes.",
    mapTitle: "Mapa Interactivo del Perú",
    mapSubtitle: "Haz clic en cualquier punto para explorar ese destino.",
    cta: "Ver tours",
  },
  en: {
    badge: "Travel Guides",
    title: "A Journey through",
    titleHighlight: "Infinite Diversity",
    description:
      "Peru is not just a country — it's a world waiting to be discovered. Each region is a unique universe of landscapes, cultures, cuisine and traditions beyond imagination.",
    description2:
      "Step into a territory where geography shifts every hundred kilometers, from towering glaciers to lush rainforests.",
    mapTitle: "Interactive Peru Map",
    mapSubtitle: "Click any point to explore that destination.",
    cta: "View tours",
  },
  pt: {
    badge: "Guias de Viagem",
    title: "Uma Viagem através da",
    titleHighlight: "Diversidade Infinita",
    description:
      "O Peru não é apenas um país — é um mundo a ser descoberto. Cada região é um universo único de paisagens, culturas, gastronomia e tradições além da imaginação.",
    description2:
      "Adentre um território onde a geografia muda a cada cem quilômetros, de glaciares imponentes a selvas exuberantes.",
    mapTitle: "Mapa Interativo do Peru",
    mapSubtitle: "Clique em qualquer ponto para explorar o destino.",
    cta: "Ver passeios",
  },
} as const;

const t = copy[lang as keyof typeof copy] ?? copy.es;

// ====== Puntos del mapa con slug para linkear a las pages ======
const mapPoints = [
  {
    id: "lima",
    slug: "lima",
    title: { es: "Costa Central", en: "Central Coast", pt: "Costa Central" },
    subtitle: {
      es: "Lima & Paracas",
      en: "Lima & Paracas",
      pt: "Lima & Paracas",
    },
    description: {
      es: "La capital gastronómica y las maravillas del Pacífico.",
      en: "The gastronomic capital and the wonders of the Pacific.",
      pt: "A capital gastronômica e as maravilhas do Pacífico.",
    },
    x: "45%",
    y: "65%",
  },
  {
    id: "cusco",
    slug: "cusco",
    title: {
      es: "Tierras Altas Andinas",
      en: "Andean Highlands",
      pt: "Terras Altas Andinas",
    },
    subtitle: {
      es: "Cusco & Valle Sagrado",
      en: "Cusco & Sacred Valley",
      pt: "Cusco & Vale Sagrado",
    },
    description: {
      es: "El corazón del imperio Inca y maravillas de la ingeniería milenaria.",
      en: "The heart of the Inca empire and wonders of millennial engineering.",
      pt: "O coração do império Inca e maravilhas da engenharia milenar.",
    },
    x: "59%",
    y: "70%",
  },
  {
    id: "iquitos",
    slug: "iquitos",
    title: {
      es: "Cuenca Amazónica",
      en: "Amazon Basin",
      pt: "Bacia Amazônica",
    },
    subtitle: {
      es: "Selva de Iquitos",
      en: "Iquitos Jungle",
      pt: "Selva de Iquitos",
    },
    description: {
      es: "Un ecosistema vibrante, hogar del río más caudaloso del mundo.",
      en: "A vibrant ecosystem, home to the world's mightiest river.",
      pt: "Um ecossistema vibrante, lar do rio mais caudaloso do mundo.",
    },
    x: "55%",
    y: "25%",
  },
  {
    id: "arequipa",
    slug: "arequipa",
    title: { es: "Ruta Volcánica", en: "Volcanic Route", pt: "Rota Vulcânica" },
    subtitle: {
      es: "Arequipa & Colca",
      en: "Arequipa & Colca",
      pt: "Arequipa & Colca",
    },
    description: {
      es: "La Ciudad Blanca custodiada por imponentes volcanes y cañones profundos.",
      en: "The White City guarded by majestic volcanoes and deep canyons.",
      pt: "A Cidade Branca guardada por vulcões majestosos e cânions profundos.",
    },
    x: "55%",
    y: "80%",
  },
  {
    id: "puno",
    slug: "puno",
    title: {
      es: "Altiplano Místico",
      en: "Mystic Altiplano",
      pt: "Altiplano Místico",
    },
    subtitle: {
      es: "Puno & Lago Titicaca",
      en: "Puno & Lake Titicaca",
      pt: "Puno & Lago Titicaca",
    },
    description: {
      es: "El lago navegable más alto del mundo y cuna de civilizaciones.",
      en: "The world's highest navigable lake and cradle of civilizations.",
      pt: "O lago navegável mais alto do mundo e berço de civilizações.",
    },
    x: "68%",
    y: "75%",
  },
];

const leftColumnPoints = mapPoints.slice(0, Math.ceil(mapPoints.length / 2));
const rightColumnPoints = mapPoints.slice(Math.ceil(mapPoints.length / 2));
---

<section
  class="py-16 relative overflow-hidden bg-primary/5 hidden lg:block"
  data-peru-guide
>
  <!-- Fondo sutil usando color neutral -->
  <div
    class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px] opacity-30 pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-4 md:px-6 relative z-10 w-full max-w-8xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <!-- Text Content (Left) -->
      <div class="lg:col-span-5 space-y-8">
        <div
          class="flex items-center justify-center w-fit space-x-2 bg-secondary/10 px-4 py-2 rounded-full mb-2"
        >
          <span class="flex h-2 w-2 rounded-full bg-secondary"></span>
          <span class="text-secondary text-sm font-semibold">{t.badge}</span>
        </div>

        <h2
          class="text-4xl md:text-5xl font-bold text-foreground leading-tight"
        >
          {t.title}
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-primary"
            >{t.titleHighlight}</span
          >
        </h2>

        <div
          class="space-y-6 text-muted-foreground font-medium leading-relaxed"
        >
          <p>{t.description}</p>
          <p>{t.description2}</p>
        </div>
      </div>

      <!-- Interactive Map Area (Right) -->
      <div class="lg:col-span-7 relative w-full perspective-1000">
        <div
          class="bg-white backdrop-blur-sm border border-border rounded-3xl p-8 relative shadow-lg"
        >
          <div class="mb-8">
            <h3 class="text-2xl font-bold text-foreground mb-2">
              {t.mapTitle}
            </h3>
            <p class="text-muted-foreground text-sm max-w-sm">
              {t.mapSubtitle}
            </p>
          </div>

          <!-- Semantic Map Container -->
          <div class="grid grid-cols-12 gap-4 items-start">
            <div class="col-span-3 space-y-3">
              {
                leftColumnPoints.map((point) => {
                  const pointTitle =
                    point.title[lang as keyof typeof point.title] ??
                    point.title.es;
                  const pointSubtitle =
                    point.subtitle[lang as keyof typeof point.subtitle] ??
                    point.subtitle.es;

                  return (
                    <a
                      href={rewriteUrl(`/${point.slug}`, lang as any)}
                      class="guide-card group block rounded-xl border border-border/80 bg-white p-3 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-secondary/40 hover:shadow-lg focus:outline-none"
                      aria-label={`${pointTitle} — ${pointSubtitle}`}
                      data-point-trigger={point.id}
                    >
                      <div class="flex flex-col items-start gap-3">
                        <div class="flex flex-col w-full">
                          <h4 class="font-medium text-foreground text-[0.8rem] leading-tight">
                            {pointTitle}
                          </h4>
                          <img
                            src={backgroundImageMobile.src}
                            alt=""
                            aria-hidden="true"
                            class="mt-2 mb-2 h-14 w-full rounded-lg object-cover"
                            loading="lazy"
                            decoding="async"
                          />
                          <span class="text-[0.68rem] font-semibold text-secondary block">
                            {pointSubtitle}
                          </span>
                        </div>
                      </div>
                    </a>
                  );
                })
              }
            </div>

            <div
              class="relative col-span-6 w-full aspect-square rounded-2xl bg-white border border-gray-100 shadow-inner flex items-center justify-center"
            >
              <!-- Map SVG -->
              <div
                class="absolute inset-0 flex items-center justify-center p-8 opacity-60 mix-blend-multiply pointer-events-none [&>svg]:w-full [&>svg]:h-full [&>svg]:drop-shadow-xl [&>path]:!fill-secondary/20 [&>path]:!stroke-secondary/30"
                set:html={mapSvg}
              />

              <!-- Map Points -->
              {
                mapPoints.map((point) => {
                  const pointTitle =
                    point.title[lang as keyof typeof point.title] ??
                    point.title.es;
                  const pointSubtitle =
                    point.subtitle[lang as keyof typeof point.subtitle] ??
                    point.subtitle.es;

                  return (
                    <a
                      href={rewriteUrl(`/${point.slug}`, lang as any)}
                      class="map-point group absolute transform -translate-x-1/2 -translate-y-1/2 focus:outline-none z-10 transition-transform duration-300 hover:z-50"
                      style={`left: ${point.x}; top: ${point.y};`}
                      aria-label={`${pointTitle} — ${pointSubtitle}`}
                      data-point-id={point.id}
                    >
                      <span class="pulse-ring pulse-ring--outer absolute -inset-1.5 rounded-full bg-secondary/25 animate-ping opacity-0 transition-[opacity,background-color] duration-200" />
                      <span class="pulse-ring pulse-ring--inner absolute -inset-1 rounded-full bg-secondary/30 animate-pulse opacity-0 transition-[opacity,background-color] duration-200" />

                      <span class="point-core relative inline-flex rounded-full h-4 w-4 bg-secondary border-2 border-white shadow-md ring-4 ring-transparent transition-all group-hover:bg-primary" />
                    </a>
                  );
                })
              }
            </div>

            <div class="col-span-3 space-y-3">
              {
                rightColumnPoints.map((point) => {
                  const pointTitle =
                    point.title[lang as keyof typeof point.title] ??
                    point.title.es;
                  const pointSubtitle =
                    point.subtitle[lang as keyof typeof point.subtitle] ??
                    point.subtitle.es;

                  return (
                    <a
                      href={rewriteUrl(`/${point.slug}`, lang as any)}
                      class="guide-card group block rounded-xl border border-border/80 bg-white p-3 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-secondary/40 hover:shadow-lg focus:outline-none"
                      aria-label={`${pointTitle} — ${pointSubtitle}`}
                      data-point-trigger={point.id}
                    >
                      <div class="flex flex-col items-start gap-3">
                        <div class="flex flex-col w-full">
                          <h4 class="font-medium text-foreground text-[0.8rem] leading-tight">
                            {pointTitle}
                          </h4>
                          <img
                            src={backgroundImageMobile.src}
                            alt=""
                            aria-hidden="true"
                            class="mt-2 mb-2 h-14 w-full rounded-lg object-cover"
                            loading="lazy"
                            decoding="async"
                          />
                          <span class="text-[0.68rem] font-semibold text-secondary block">
                            {pointSubtitle}
                          </span>
                        </div>
                      </div>
                    </a>
                  );
                })
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const section = document.querySelector("[data-peru-guide]");
    if (!section || section.dataset.initialized === "true") return;

    section.dataset.initialized = "true";

    const cards = section.querySelectorAll("[data-point-trigger]");
    const points = section.querySelectorAll("[data-point-id]");
    let activeId = null;

    const clearActive = () => {
      cards.forEach((card) => card.classList.remove("is-active"));
      points.forEach((point) => point.classList.remove("is-active"));
    };

    const setActive = (id) => {
      activeId = id;
      clearActive();
      const card = section.querySelector(`[data-point-trigger="${id}"]`);
      const point = section.querySelector(`[data-point-id="${id}"]`);
      card?.classList.add("is-active");
      point?.classList.add("is-active");
    };

    const clearActiveIfCurrent = (id) => {
      if (activeId !== id) return;
      activeId = null;
      clearActive();
    };

    cards.forEach((card) => {
      const id = card.getAttribute("data-point-trigger");
      if (!id) return;

      card.addEventListener("mouseenter", () => setActive(id));
      card.addEventListener("focusin", () => setActive(id));
      card.addEventListener("mouseleave", () => clearActiveIfCurrent(id));
      card.addEventListener("focusout", () => clearActiveIfCurrent(id));
    });

    points.forEach((point) => {
      const id = point.getAttribute("data-point-id");
      if (!id) return;

      point.addEventListener("mouseenter", () => setActive(id));
      point.addEventListener("focusin", () => setActive(id));
      point.addEventListener("mouseleave", () => clearActiveIfCurrent(id));
      point.addEventListener("focusout", () => clearActiveIfCurrent(id));
    });
  });
</script>

<style>
  .guide-card.is-active {
    transform: translateY(-0.25rem);
    border-color: color-mix(in oklab, var(--secondary) 40%, transparent);
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.1),
      0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  .map-point.is-active .pulse-ring,
  .map-point:hover .pulse-ring,
  .map-point:focus-visible .pulse-ring {
    opacity: 1;
  }

  .map-point.is-active .pulse-ring,
  .map-point:hover .pulse-ring,
  .map-point:focus-visible .pulse-ring,
  .map-point.is-active .point-core,
  .map-point:hover .point-core,
  .map-point:focus-visible .point-core {
    background: var(--primary);
  }

  .map-point.is-active .point-core,
  .map-point:hover .point-core,
  .map-point:focus-visible .point-core {
    transform: scale(1.12);
    box-shadow: 0 0 0 0.14rem
      color-mix(in oklab, var(--primary) 20%, transparent);
  }
</style>
