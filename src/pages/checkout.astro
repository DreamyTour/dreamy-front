---
import PageLayout from "@/layouts/PageLayout.astro";
import CheckoutSummary from "@/components/checkout/CheckoutSummary";
import { DEFAULT_LANG } from "@/lib/i18n";

const seoProps = {
  title: "Checkout - Booking",
  description: "Complete your booking securely.",
  type: "website" as "website",
  lang: DEFAULT_LANG,
};
---

<PageLayout seo={seoProps}>
  <div class="bg-gray-50 min-h-[70vh] pt-8 pb-16 border-t border-gray-200">
    <CheckoutSummary client:only="react" />
  </div>
</PageLayout>
