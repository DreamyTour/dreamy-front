---
import DynamicContentPage from "@/components/pages/DynamicContentPage.astro";
import { DEFAULT_LANG } from "@/lib/i18n";
import {
  getDefaultLangDynamicPaths,
  type DynamicPageProps,
} from "@/lib/dynamicPageRoutes";

export async function getStaticPaths() {
  return getDefaultLangDynamicPaths();
}

const props = Astro.props as DynamicPageProps;
const lang = DEFAULT_LANG;
---

<DynamicContentPage
  type={props.type}
  lang={lang}
  tour={props.tour}
  page={props.page}
  slugMap={props.slugMap}
  pageSlugMap={props.pageSlugMap}
  mdxComponent={props.mdxComponent}
  mdxFrontmatter={props.mdxFrontmatter}
  toursRelated={props.toursRelated}
  toursByCategory={props.toursByCategory}
/>
