---
import Layout from "@/layouts/main.astro";
import fetchApi from "@/lib/strapi";
import type { Blog, CategoryBlog } from "@/types/blog";
import type { Logo } from "@/types/common";
import CardPost from "@/components/ui/CardPost.astro";
import BlogAside from "@/components/ui/BlogAside.astro";
import { LANGS, DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import type { Lang } from "@/lib/i18n";
import { getCategoryPostCounts } from "@/lib/blogCategories";
import { getImageSrcSet, getImageUrl } from "@/lib/helpers";
import { buildSEOProps } from "@/lib/seo";
import { serializeJsonForHtml } from "@/lib/html";

type GlobalData = { footer?: { socialLogo?: Logo[] }; socialLogo?: Logo[] };
type PaginatedPage = {
  data: Blog[];
  currentPage: number;
  lastPage: number;
  url: { prev?: string | null; next?: string | null };
};
type BlogCategoryProps = {
  page: PaginatedPage;
  allCategories: CategoryBlog[];
  currentCategory: CategoryBlog;
  categorySlug: string;
  socialLogos: Logo[];
  slugMap: Record<string, string>;
  categoryPostCounts: Record<string, number>;
  totalPostCount: number;
};
type Paginate = (
  data: Blog[],
  options: {
    params?: Record<string, string>;
    pageSize: number;
    props?: Record<string, unknown>;
  },
) => unknown[];

export async function getStaticPaths({ paginate }: { paginate: Paginate }) {
  const allPaths: unknown[] = [];
  const blogsByLang: Record<string, Blog[]> = {};
  const categoriesByLang: Record<string, CategoryBlog[]> = {};
  const socialLogosByLang: Record<string, Logo[]> = {};
  const categorySlugsByDocId: Record<string, Record<string, string>> = {};

  for (const lang of LANGS) {
    const blogs = await fetchApi<Blog[]>({
      endpoint: "posts",
      wrappedByKey: "data",
      locale: lang,
      query: {
        sort: "publishedAt:desc",
      },
    });

    const blogsList = blogs && Array.isArray(blogs) ? blogs : [];
    blogsByLang[lang] = blogsList;

    // Fetch categories; backend middleware already handles the needed data
    const baseUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");
    const catsUrl = new URL(`${baseUrl}/api/category-blogs`);
    catsUrl.searchParams.set("locale", lang);
    const catsRes = await fetch(catsUrl.toString());
    const catsJson = await catsRes.json();
    const allCategories = catsJson?.data || [];
    categoriesByLang[lang] = allCategories;

    // Fetch global data for social logos; backend middleware already populates it
    const globalData = await fetchApi<GlobalData>({
      endpoint: "global",
      wrappedByKey: "data",
      locale: lang,
    });
    socialLogosByLang[lang] =
      globalData?.footer?.socialLogo || globalData?.socialLogo || [];
  }

  for (const lang of LANGS) {
    for (const category of categoriesByLang[lang] || []) {
      if (!categorySlugsByDocId[category.documentId]) {
        categorySlugsByDocId[category.documentId] = {};
      }
      categorySlugsByDocId[category.documentId][lang] = category.slug;
    }
  }

  // Generar paginación para cada categoría
  for (const lang of LANGS) {
    const blogsList = blogsByLang[lang] || [];
    const allCategories = categoriesByLang[lang] || [];
    const socialLogos = socialLogosByLang[lang] || [];
    const categoryPostCounts = getCategoryPostCounts(blogsList);
    const totalPostCount = blogsList.length;

    for (const category of allCategories) {
      const categorySlug = category.slug;

      // Filtrar posts que pertenecen a esta categoría
      const filteredBlogs = blogsList.filter((b: Blog) =>
        b.category_blogs?.some((c: CategoryBlog) => c.slug === categorySlug),
      );

      const sharedProps = {
        allCategories,
        currentCategory: category,
        categorySlug,
        socialLogos,
        slugMap: categorySlugsByDocId[category.documentId] ?? {},
        categoryPostCounts,
        totalPostCount,
      };

      // Si hay posts, usar paginate normal
      if (filteredBlogs.length > 0) {
        const paginatedPaths = paginate(filteredBlogs, {
          params: { lang, category: categorySlug },
          pageSize: 9,
          props: sharedProps,
        });
        allPaths.push(...paginatedPaths);
      } else {
        // Si no hay posts, generar una página vacía
        allPaths.push({
          params: { lang, category: categorySlug },
          props: {
            ...sharedProps,
            page: {
              data: [],
              currentPage: 1,
              lastPage: 1,
              url: { prev: null, next: null },
            },
          },
        });
      }
    }
  }

  return allPaths;
}

const props = Astro.props as BlogCategoryProps;
const {
  page,
  allCategories,
  currentCategory,
  categorySlug,
  socialLogos,
  slugMap,
  categoryPostCounts,
  totalPostCount,
} = props;

const routeParams = Astro.params as { lang?: string };
const lang = isValidLang(routeParams.lang) ? routeParams.lang : DEFAULT_LANG;
const currentLang: Lang = lang;
const blogsList = page.data;
const heroImage = currentCategory?.imagenDestacada
  ? getImageUrl(currentCategory.imagenDestacada, "large")
  : "";
const heroImageSrcSet = currentCategory?.imagenDestacada
  ? getImageSrcSet(currentCategory.imagenDestacada, [
      "small",
      "medium",
      "large",
    ])
  : "";

// SEO props para la categoría
const pageLabelByLang: Record<Lang, string> = {
  en: "Page",
  es: "Pagina",
  pt: "Pagina",
};

const categorySeoProps = buildSEOProps({
  seo: currentCategory?.seo,
  fallbackTitle: currentCategory?.nombre || "Blog",
  fallbackDescription: currentCategory?.descripcion || "",
  type: "website",
  lang,
  slugMap,
});
const seoProps =
  page.currentPage > 1
    ? {
        ...categorySeoProps,
        title: `${categorySeoProps.title} - ${pageLabelByLang[lang]} ${page.currentPage}`,
      }
    : categorySeoProps;
---

<Layout seo={seoProps} lang={lang}>
  {
    slugMap && Object.keys(slugMap).length > 0 && (
      <script
        is:inline
        id="blog-slug-map"
        type="application/json"
        set:html={serializeJsonForHtml(slugMap)}
      />
    )
  }
  {/* Hero con imagen destacada 100% width */}
  {
    currentCategory?.imagenDestacada ? (
      <div class="relative h-[46vh] min-h-[300px] max-h-[460px] w-full overflow-hidden">
        <img
          src={heroImage}
          srcset={heroImageSrcSet || undefined}
          sizes="100vw"
          alt=""
          aria-hidden="true"
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0 bg-black/55" />

        <div class="relative z-10 mx-auto flex h-full max-w-8xl flex-col items-center justify-center px-4 text-center sm:px-6 lg:px-8">
          <p class="mb-3 text-[0.7rem] font-semibold uppercase tracking-[0.3em] text-white/70">
            Dreamy Journal
          </p>
          <h1 class="max-w-3xl text-3xl font-semibold leading-[1.05] text-white drop-shadow-md md:text-5xl lg:text-6xl">
            {currentCategory.nombre}
          </h1>
        </div>
      </div>
    ) : (
      <div class="w-full bg-[color-mix(in_oklab,var(--blog-surface)_80%,white)] py-14 md:py-20">
        <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <p class="mb-3 text-[0.7rem] font-semibold uppercase tracking-[0.3em] text-secondary/70">
              Dreamy Journal
            </p>
            <h1 class="text-3xl font-semibold leading-[1.05] text-primary md:text-5xl lg:text-6xl">
              {currentCategory?.nombre}
            </h1>
          </div>
        </div>
      </div>
    )
  }

  {/* Contenido principal con layout 70/30 */}
  <div class="blog-category-page py-12 lg:py-16">
    <div class="max-w-8xl mx-auto grid gap-12 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-14 lg:px-8 xl:grid-cols-[minmax(0,1fr)_22rem]">
      {/* Grid de Posts */}
      <div class="w-full min-w-0">
        {
          currentCategory?.descripcion && (
            <p class="mb-8 max-w-3xl border-l border-secondary/45 pl-5 text-base leading-7 text-foreground/68 md:text-lg">
              {currentCategory.descripcion}
            </p>
          )
        }
        {
          blogsList.length > 0 ? (
            <div>
              <div class="blog-category-grid">
                {blogsList.map((blog: Blog, index: number) => (
                  <CardPost
                    blog={blog}
                    lang={lang}
                    isFeatured={index === 0}
                    showDescription={index === 0 || index === 1}
                  />
                ))}
              </div>

              {/* Pagination Controls */}
              {page.lastPage > 1 && (
                <div class="flex items-center justify-center gap-4 mt-16 font-medium">
                  {page.url.prev ? (
                    <a
                      href={page.url.prev}
                      class="px-5 py-2.5 rounded-sm border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-colors flex items-center gap-2 bg-white shadow-sm hover:shadow-md"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M15 19l-7-7 7-7"
                        />
                      </svg>
                      {currentLang === "es"
                        ? "Anterior"
                        : currentLang === "pt"
                          ? "Anterior"
                          : "Previous"}
                    </a>
                  ) : (
                    <span class="px-5 py-2.5 rounded-sm border border-gray-100 text-gray-400 bg-gray-50 flex items-center gap-2 cursor-not-allowed">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M15 19l-7-7 7-7"
                        />
                      </svg>
                      {currentLang === "es"
                        ? "Anterior"
                        : currentLang === "pt"
                          ? "Anterior"
                          : "Previous"}
                    </span>
                  )}

                  <span class="text-gray-600 bg-white px-4 py-2.5 rounded-sm border border-gray-100 shadow-sm flex items-center gap-2">
                    {page.currentPage} <span class="text-gray-400">/</span>{" "}
                    {page.lastPage}
                  </span>

                  {page.url.next ? (
                    <a
                      href={page.url.next}
                      class="px-5 py-2.5 rounded-sm border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-colors flex items-center gap-2 bg-white shadow-sm hover:shadow-md"
                    >
                      {currentLang === "es"
                        ? "Siguiente"
                        : currentLang === "pt"
                          ? "Próximo"
                          : "Next"}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </a>
                  ) : (
                    <span class="px-5 py-2.5 rounded-sm border border-gray-100 text-gray-400 bg-gray-50 flex items-center gap-2 cursor-not-allowed">
                      {currentLang === "es"
                        ? "Siguiente"
                        : currentLang === "pt"
                          ? "Próximo"
                          : "Next"}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </span>
                  )}
                </div>
              )}
            </div>
          ) : (
            <p class="text-center text-gray-500">
              No hay blogs disponibles en esta categoría
            </p>
          )
        }
      </div>

      {/* Aside - Categorías */}
      <BlogAside
        categories={allCategories}
        currentSlug={categorySlug}
        lang={lang}
        socialLogos={socialLogos}
        categoryPostCounts={categoryPostCounts}
        totalPostCount={totalPostCount}
      />
    </div>
  </div>
</Layout>

<style>
  .blog-category-page {
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--blog-surface) 88%, white) 0%,
        white 42%,
        color-mix(in oklab, var(--blog-surface) 72%, white) 100%
      );
  }

  .blog-category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19rem), 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
    align-items: stretch;
  }
</style>
