---
import Layout from "@/layouts/main.astro";
import fetchApi from "@/lib/strapi";
import type { Blog, CategoryBlog } from "@/interface/blog";
import CardPost from "@/components/ui/CardPost.astro";
import BlogAside from "@/components/ui/BlogAside.astro";
import { LANGS, DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import { getImageUrl } from "@/lib/helpers";
import { buildSEOProps } from "@/lib/seo";

export async function getStaticPaths({ paginate }: any) {
  const allPaths: any[] = [];
  const blogsByLang: Record<string, Blog[]> = {};
  const categoriesByLang: Record<string, CategoryBlog[]> = {};
  const socialLogosByLang: Record<string, any[]> = {};
  const categorySlugsByDocId: Record<string, Record<string, string>> = {};

  for (const lang of LANGS) {
    const blogs = await fetchApi<Blog[]>({
      endpoint: "posts",
      wrappedByKey: "data",
      locale: lang,
      query: {
        sort: "publishedAt:desc",
      },
    });

    const blogsList = blogs && Array.isArray(blogs) ? blogs : [];
    blogsByLang[lang] = blogsList;

    // Fetch categories; backend middleware already handles the needed data
    const baseUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");
    const catsUrl = new URL(`${baseUrl}/api/category-blogs`);
    catsUrl.searchParams.set("locale", lang);
    const catsRes = await fetch(catsUrl.toString());
    const catsJson = await catsRes.json();
    const allCategories = catsJson?.data || [];
    categoriesByLang[lang] = allCategories;

    // Fetch global data for social logos; backend middleware already populates it
    const globalData = await fetchApi<any>({
      endpoint: "global",
      wrappedByKey: "data",
      locale: lang,
    });
    socialLogosByLang[lang] =
      globalData?.footer?.socialLogo || globalData?.socialLogo || [];
  }

  for (const lang of LANGS) {
    for (const category of categoriesByLang[lang] || []) {
      if (!categorySlugsByDocId[category.documentId]) {
        categorySlugsByDocId[category.documentId] = {};
      }
      categorySlugsByDocId[category.documentId][lang] = category.slug;
    }
  }

  // Generar paginación para cada categoría
  for (const lang of LANGS) {
    const blogsList = blogsByLang[lang] || [];
    const allCategories = categoriesByLang[lang] || [];
    const socialLogos = socialLogosByLang[lang] || [];

    for (const category of allCategories) {
      const categorySlug = category.slug;

      // Filtrar posts que pertenecen a esta categoría
      const filteredBlogs = blogsList.filter((b: Blog) =>
        b.category_blogs?.some((c: CategoryBlog) => c.slug === categorySlug),
      );

      const sharedProps = {
        allCategories,
        currentCategory: category,
        categorySlug,
        socialLogos,
        slugMap: categorySlugsByDocId[category.documentId] ?? {},
      };

      // Si hay posts, usar paginate normal
      if (filteredBlogs.length > 0) {
        const paginatedPaths = paginate(filteredBlogs, {
          params: { lang, category: categorySlug },
          pageSize: 9,
          props: sharedProps,
        });
        allPaths.push(...paginatedPaths);
      } else {
        // Si no hay posts, generar una página vacía
        allPaths.push({
          params: { lang, category: categorySlug },
          props: {
            ...sharedProps,
            page: {
              data: [],
              currentPage: 1,
              lastPage: 1,
              url: { prev: null, next: null },
            },
          },
        });
      }
    }
  }

  return allPaths;
}

const {
  page,
  allCategories,
  currentCategory,
  categorySlug,
  socialLogos,
  slugMap,
} =
  Astro.props;

const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;
const currentLang = lang;
const blogsList = page.data;

// SEO props para la categoría
const seoProps = buildSEOProps({
  seo: currentCategory?.seo,
  fallbackTitle: currentCategory?.nombre || "Blog",
  fallbackDescription: currentCategory?.descripcion || "",
  fallbackImage: currentCategory?.imagenDestacada
    ? getImageUrl(currentCategory.imagenDestacada)
    : "/og-default.jpg",
  type: "website",
  lang,
  slugMap,
});
---

<Layout seo={seoProps} lang={lang}>
  {/* Hero con imagen destacada 100% width */}
  {
    currentCategory?.imagenDestacada ? (
      <div class="relative w-full h-[50vh] min-h-[400px] max-h-[600px] overflow-hidden">
        {/* Imagen de fondo - full width */}
        <div
          class="absolute inset-0 bg-cover bg-center bg-no-repeat"
          style={`background-image: url('${getImageUrl(currentCategory.imagenDestacada)}')`}
        />
        {/* Overlay oscuro */}
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/50 to-black/30" />

        {/* Contenido sobre la imagen */}
        <div class="relative z-10 max-w-8xl h-full mx-auto flex flex-col justify-end pb-16 ">
          {/* Título */}
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white tracking-tight leading-tight mb-4 drop-shadow-lg max-w-4xl">
            {currentCategory.nombre}
          </h1>
        </div>
      </div>
    ) : (
      /* Fallback sin imagen */
      <div class="w-full bg-gray-50 py-16">
        <div class="max-w-8xl mx-auto px-4 md:px-8">
          <div class="text-center">
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 dark:text-white tracking-tight leading-tight mb-4">
              {currentCategory?.nombre}
            </h1>
          </div>
        </div>
      </div>
    )
  }

  {/* Contenido principal con layout 70/30 */}
  <div class="max-w-8xl mx-auto px-4 md:px-8 py-12 lg:py-16">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 justify-between">
      {/* Grid de Posts */}
      <div class="w-full lg:w-[70%] xl:w-[75%] mx-auto lg:mx-0">
        {
          currentCategory?.descripcion && (
            <p class="text-lg text-gray-600 dark:text-gray-400 my-4">
              {currentCategory.descripcion}
            </p>
          )
        }
        {
          blogsList.length > 0 ? (
            <div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-10 md:gap-x-8 md:gap-y-16">
                {blogsList.map((blog: Blog) => (
                  <CardPost blog={blog} lang={lang} />
                ))}
              </div>

              {/* Pagination Controls */}
              {page.lastPage > 1 && (
                <div class="flex items-center justify-center gap-4 mt-16 font-medium">
                  {page.url.prev ? (
                    <a
                      href={page.url.prev}
                      class="px-5 py-2.5 rounded-sm border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-colors flex items-center gap-2 bg-white shadow-sm hover:shadow-md"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M15 19l-7-7 7-7"
                        />
                      </svg>
                      {currentLang === "es"
                        ? "Anterior"
                        : currentLang === "pt"
                          ? "Anterior"
                          : "Previous"}
                    </a>
                  ) : (
                    <span class="px-5 py-2.5 rounded-sm border border-gray-100 text-gray-400 bg-gray-50 flex items-center gap-2 cursor-not-allowed">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M15 19l-7-7 7-7"
                        />
                      </svg>
                      {currentLang === "es"
                        ? "Anterior"
                        : currentLang === "pt"
                          ? "Anterior"
                          : "Previous"}
                    </span>
                  )}

                  <span class="text-gray-600 bg-white px-4 py-2.5 rounded-sm border border-gray-100 shadow-sm flex items-center gap-2">
                    {page.currentPage} <span class="text-gray-400">/</span>{" "}
                    {page.lastPage}
                  </span>

                  {page.url.next ? (
                    <a
                      href={page.url.next}
                      class="px-5 py-2.5 rounded-sm border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-colors flex items-center gap-2 bg-white shadow-sm hover:shadow-md"
                    >
                      {currentLang === "es"
                        ? "Siguiente"
                        : currentLang === "pt"
                          ? "Próximo"
                          : "Next"}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </a>
                  ) : (
                    <span class="px-5 py-2.5 rounded-sm border border-gray-100 text-gray-400 bg-gray-50 flex items-center gap-2 cursor-not-allowed">
                      {currentLang === "es"
                        ? "Siguiente"
                        : currentLang === "pt"
                          ? "Próximo"
                          : "Next"}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </span>
                  )}
                </div>
              )}
            </div>
          ) : (
            <p class="text-center text-gray-500">
              No hay blogs disponibles en esta categoría
            </p>
          )
        }
      </div>

      {/* Aside - Categorías */}
      <BlogAside
        categories={allCategories}
        currentSlug={categorySlug}
        lang={lang}
        socialLogos={socialLogos}
      />
    </div>
  </div>
</Layout>
