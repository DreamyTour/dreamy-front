---
import BlogCategoryPage from "@/components/pages/BlogCategoryPage.astro";
import { DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import {
  getBlogCategoryPaths,
  type BlogCategoryProps,
  type Paginate,
} from "@/lib/blogRoutes";

export async function getStaticPaths({ paginate }: { paginate: Paginate }) {
  return getBlogCategoryPaths({ paginate, localized: true });
}

const props = Astro.props as BlogCategoryProps;
const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;
---

<BlogCategoryPage
  page={props.page}
  allCategories={props.allCategories}
  currentCategory={props.currentCategory}
  categorySlug={props.categorySlug}
  socialLogos={props.socialLogos}
  slugMap={props.slugMap}
  categoryPostCounts={props.categoryPostCounts}
  totalPostCount={props.totalPostCount}
  lang={lang}
/>
