---
import BlogPostPage from "@/components/pages/BlogPostPage.astro";
import { DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import { getBlogPostPaths, type BlogPostProps } from "@/lib/blogRoutes";

export async function getStaticPaths() {
  return getBlogPostPaths({ localized: true });
}

const props = Astro.props as BlogPostProps;
const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;

if (props.isRedirect && props.redirectTo) {
  return Astro.redirect(props.redirectTo, 301);
}
---

<BlogPostPage
  blog={props.blog}
  lang={props.lang ?? lang}
  allCategories={props.allCategories}
  slugMap={props.slugMap}
  globalData={props.globalData}
  relatedBlogs={props.relatedBlogs}
  categoryPostCounts={props.categoryPostCounts}
  totalPostCount={props.totalPostCount}
/>
