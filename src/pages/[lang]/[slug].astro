---
import TourLayout from "@/layouts/TourLayout.astro";
import PageContent from "@/components/content/PageContent.astro";
import Layout from "@/layouts/main.astro";
import { fetchAllStrapi } from "@/lib/strapi";
import { dedupeLocalizedDocuments } from "@/lib/utils";
import type { Category as TourCategory, Tour } from "@/types/tours";
import type { Category as PageCategory, Page } from "@/types/page";
import { LANGS, DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import type { Lang } from "@/lib/i18n";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import type { SEOProps } from "@/components/layout/SEO.astro";
import type { ManualSEO } from "@/lib/seo";
import {
  getImageUrl,
  generateDescription,
} from "@/lib/helpers";
import { buildSEOProps } from "@/lib/seo";

import TourHero from "@/components/tours/TourHero.astro";
import TourTabs from "@/components/tours/TourTabs";
import ContactForm from "@/components/tours/ContactForm.astro";
import BookingForm from "@/components/tours/BookingForm";
import RelatedTours from "@/components/tours/RelatedTours.astro";

interface MdxFrontmatter {
  title: string;
  description?: string;
  lang: Lang;
  seo?: ManualSEO;
  heroImage?: string;
  heroImageAlt?: string;
}

interface Props {
  type: "mdx" | "tour" | "page";
  tour?: Tour;
  page?: Page;
  slugMap?: Record<string, string>;
  pageSlugMap?: Record<string, string>;
  mdxComponent?: { default?: AstroComponentFactory };
  mdxFrontmatter?: MdxFrontmatter;
  isRedirect?: boolean;
  redirectTo?: string;
  toursRelated?: Tour[];
  toursByCategory?: Tour[];
}

export async function getStaticPaths() {
  const paths: Array<{
    params: { lang: string; slug: string };
    props: Partial<Props>;
  }> = [];

  // ✅ MDX PAGES - dynamic imports
  // ✅ MDX PAGES - dynamic globs
  const mdxPages = import.meta.glob("@/content/pages/**/*.mdx");

  for (const path in mdxPages) {
    const mod = (await mdxPages[path]()) as {
      default?: AstroComponentFactory;
      frontmatter?: MdxFrontmatter & { slugs?: Record<string, string> };
    };
    const frontmatter = mod.frontmatter;
    if (!frontmatter) continue;
    const subpath = path.split("/content/pages/")[1].replace(".mdx", "");
    const [lang, slug] = subpath.split("/");

    paths.push({
      params: { lang, slug },
      props: {
        type: "mdx",
        mdxComponent: mod,
        mdxFrontmatter: frontmatter,
        pageSlugMap: frontmatter.slugs || {},
      },
    });
  }

  // ✅ TOURS Y PAGES FROM STRAPI
  const allToursByLang: Record<string, Tour[]> = {};
  const allPagesByLang: Record<string, Page[]> = {};

  for (const lang of LANGS) {
    // El middleware de Strapi ya hace el populate de categories automáticamente
    const tours = await fetchAllStrapi<Tour>({
      endpoint: "tours",
      locale: lang,
    });

    const pages = await fetchAllStrapi<Page>({
      endpoint: "pages",
      locale: lang,
    });

    allToursByLang[lang] =
      tours && Array.isArray(tours) ? dedupeLocalizedDocuments(tours) : [];
    allPagesByLang[lang] =
      pages && Array.isArray(pages) ? dedupeLocalizedDocuments(pages) : [];
  }

  const slugsByDocId: Record<string, Record<string, string>> = {};
  for (const lang of LANGS) {
    for (const tour of allToursByLang[lang]) {
      if (!slugsByDocId[tour.documentId]) {
        slugsByDocId[tour.documentId] = {};
      }
      slugsByDocId[tour.documentId][lang] = tour.slug;
    }
  }

  for (const lang of LANGS) {
    for (const tour of allToursByLang[lang]) {
      const categorySlug = tour?.categories?.[0]?.slug;
      let toursRelated = allToursByLang[lang].filter(t => t.slug !== tour.slug);
      if (categorySlug) {
        toursRelated = toursRelated.filter(t => 
          t.categories?.some((c: TourCategory) => c.slug === categorySlug)
        );
      }
      toursRelated = toursRelated.slice(0, 3);

      paths.push({
        params: { lang, slug: tour.slug },
        props: {
          type: "tour",
          tour,
          slugMap: slugsByDocId[tour.documentId] ?? {},
          toursRelated,
        },
      });
    }
  }

  const pageSlugsByDocId: Record<string, Record<string, string>> = {};
  for (const lang of LANGS) {
    for (const page of allPagesByLang[lang]) {
      if (!pageSlugsByDocId[page.documentId]) {
        pageSlugsByDocId[page.documentId] = {};
      }
      pageSlugsByDocId[page.documentId][lang] = page.slug;
      const pageDestinationCategory = page?.categories?.find((c: PageCategory) => c.slug !== "peru-tours") ??
        (page?.slug ? { slug: page.slug, nombre: page.titulo } : undefined);

      let toursByCategory: Tour[] = [];
      if (pageDestinationCategory?.slug) {
        toursByCategory = allToursByLang[lang].filter(t => 
          t.categories?.some((c: TourCategory) => c.slug === pageDestinationCategory.slug)
        );
      }

      paths.push({
        params: { lang, slug: page.slug },
        props: {
          type: "page",
          page,
          pageSlugMap: pageSlugsByDocId[page.documentId] ?? {},
          toursByCategory,
        },
      });
    }
  }

  // FALLBACK: Redirect para PÁGINAS - cuando alguien usa un slug de otro idioma
  // Para cada página con slugs diferentes entre idiomas, crear redirects para TODAS las combinaciones
  // Ejemplo: pageSlugsByDocId = { docId1: { en: "alternative-treks", es: "treks-alternativos" } }
  // Crea redirects: /es/alternative-treks -> /es/treks-alternativos, /en/treks-alternativos -> /en/alternative-treks

  for (const [docId, slugMap] of Object.entries(pageSlugsByDocId)) {
    const slugs = Object.entries(slugMap) as [string, string][];

    for (const [langA, slugA] of slugs) {
      for (const [langB, slugB] of slugs) {
        if (langA !== langB && slugA !== slugB) {
          // Create redirect: /langA/slugB (lang is A but slug is from B) -> /langA/slugA (lang and slug both correct)
          paths.push({
            params: { lang: langA, slug: slugB },
            props: {
              type: "page",
              isRedirect: true,
              redirectTo: `/${langA}/${slugMap[langA]}`,
              page: allPagesByLang[langA]?.find(
                (p: Page) => p.documentId === docId,
              ),
              pageSlugMap: slugMap,
            },
          });
        }
      }
    }
  }

  // FALLBACK: Redirect a DEFAULT_LANG si el tour no existe en el idioma actual
  const defaultLangTours = allToursByLang[DEFAULT_LANG] || [];
  const allTourPathsBySlug: Record<string, string[]> = {};

  // Mapear qué slugs de tours existen en qué idiomas
  for (const path of paths) {
    if (path.props?.type === "tour") {
      const slug = path.params.slug;
      if (!allTourPathsBySlug[slug]) {
        allTourPathsBySlug[slug] = [];
      }
      allTourPathsBySlug[slug].push(path.params.lang);
    }
  }

  // Agregar redirects para slugs de tours que NO existen en otros idiomas pero SÍ en DEFAULT_LANG
  for (const lang of LANGS) {
    if (lang === DEFAULT_LANG) continue;

    const currentLangTours = allToursByLang[lang] || [];
    const currentSlugs = new Set(currentLangTours.map((t: Tour) => t.slug));

    for (const defaultTour of defaultLangTours) {
      if (!currentSlugs.has(defaultTour.slug)) {
        // Verificar que el slug existe en DEFAULT_LANG
        const slugLanguages = allTourPathsBySlug[defaultTour.slug] || [];
        if (slugLanguages.length > 0 && slugLanguages.includes(DEFAULT_LANG)) {
          // Crear redirect 301 al idioma por defecto
          paths.push({
            params: { lang, slug: defaultTour.slug },
            props: {
              type: "tour",
              isRedirect: true,
              redirectTo: `/${DEFAULT_LANG}/${defaultTour.slug}`,
              tour: defaultTour,
              slugMap: slugsByDocId[defaultTour.documentId] ?? {},
            },
          });
        }
      }
    }
  }

  return paths;
}

const {
  type,
  tour,
  page,
  slugMap,
  pageSlugMap,
  mdxComponent,
  mdxFrontmatter,
  isRedirect,
  redirectTo,
  toursRelated = [],
  toursByCategory = [],
} = Astro.props as Props;
const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;

// Redirect 301 si la página no existe en este idioma
if (isRedirect && redirectTo) {
  return Astro.redirect(redirectTo, 301);
}

// ====== OBTENER TOUR ACTUAL CON CATEGORÍA ======
// El middleware de Strapi ya hace el populate de categories automáticamente
let tourWithCategory = tour;

// Los arrays toursRelated y toursByCategory ahora vienen listos desde getStaticPaths 
// haciendo el filtrado en la memoria y evitando 500+ peticiones a la API durante el build.

// ====== CHECK INCA TRAIL CATEGORY ======
const isIncaTrail = tourWithCategory?.categories?.some(
  (c: TourCategory) =>
    c.slug.includes("inca-trail") ||
    c.slug.includes("camino-inca") ||
    c.slug.includes("trilha-inca"),
);

let seoProps: SEOProps | undefined;

if (type === "mdx" && mdxFrontmatter) {
  seoProps = buildSEOProps({
    seo: mdxFrontmatter.seo,
    fallbackTitle: mdxFrontmatter.title || "Página",
    fallbackDescription: mdxFrontmatter.description || "",
    fallbackImage: "/og-default.jpg",
    type: "website",
    lang: lang,
  });
} else if (type === "tour" && tour) {
  seoProps = buildSEOProps({
    seo: tour.seo,
    fallbackTitle: tour.titulo || "Tour",
    fallbackDescription: generateDescription(tour.content),
    fallbackImage: getImageUrl(tour.imagenDestacada),
    type: "article",
    lang: lang,
    slugMap,
  });
} else if (type === "page" && page) {
  seoProps = buildSEOProps({
    seo: page.seo,
    fallbackTitle: page.titulo || "Página",
    fallbackDescription: generateDescription(page.content),
    fallbackImage: "/og-default.jpg",
    type: "website",
    lang: lang,
    slugMap: pageSlugMap,
  });
}

const mdxUiCopy = {
  es: {
    eyebrow: "Guia Dreamy",
  },
  en: {
    eyebrow: "Dreamy Guide",
  },
  pt: {
    eyebrow: "Guia Dreamy",
  },
} as const;

const mdxCopy = mdxUiCopy[lang] ?? mdxUiCopy[DEFAULT_LANG];

const heroImage =
  (mdxFrontmatter?.heroImage as string | undefined) ||
  "/imagenes/sobre_nosotros.avif";
const heroImageAlt =
  (mdxFrontmatter?.heroImageAlt as string | undefined) || "Dreamy Tours";

---

{
  type === "mdx" && mdxComponent && mdxFrontmatter && (
    <Layout seo={seoProps} lang={lang}>
      <script is:inline
        id="page-slug-map"
        type="application/json"
        set:html={JSON.stringify(pageSlugMap || {})}
      />
      <div class="content-shell content-shell--mdx w-full mx-auto">
        <section class="content-hero content-hero--mdx relative isolate overflow-hidden h-[400px] md:h-[450px] lg:h-[500px] flex flex-col justify-center">
          <img
            src={heroImage}
            alt={heroImageAlt}
            class="hero-bg-img"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent" />

          <div class="relative w-full px-6 py-10 text-center md:px-10 md:py-14 lg:px-14 lg:py-16">
            <div class="mx-auto max-w-4xl">
              <div class="inline-flex items-center gap-3 rounded-sm border border-white/20 bg-black/50 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.34em] text-white shadow-sm backdrop-blur-sm">
                <span class="h-2 w-2 rounded-full bg-secondary shadow-[0_0_0_4px_rgba(220,123,66,0.16)]" />
                <span>{mdxCopy.eyebrow}</span>
              </div>

              <h1 class="content-hero-title mt-6 text-4xl font-semibold tracking-[-0.04em] sm:text-5xl lg:text-[4.1rem] lg:leading-[0.95]">
                {mdxFrontmatter.title}
              </h1>

              {mdxFrontmatter.description && (
                <p class="mx-auto mt-6 max-w-3xl text-base leading-8 text-white/80 md:text-lg lg:text-[1.08rem]">
                  {mdxFrontmatter.description}
                </p>
              )}

              <div class="mt-8 flex items-center justify-center gap-3">
                <div class="h-px w-16 bg-gradient-to-r from-transparent to-secondary/70" />
                <div class="relative h-1.5 w-12 rounded-full bg-secondary">
                  <div class="absolute left-1/2 top-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-secondary" />
                </div>
                <div class="h-px w-16 bg-gradient-to-l from-transparent to-secondary/70" />
              </div>
            </div>
          </div>
        </section>

        <div class="relative mx-auto -mt-4 max-w-7xl md:-mt-8">
          <article class="content-article mdx-text max-w-none sm:px-7 sm:py-8 md:px-10 md:py-10 lg:px-12 lg:py-12">
            {mdxComponent?.default ? <mdxComponent.default /> : null}
          </article>
        </div>
      </div>
    </Layout>
  )
}

{
  type === "tour" && tour && (
    <TourLayout seo={seoProps} slugMap={slugMap} lang={lang}>
      <div class="max-w-8xl mx-auto px-4 md:px-6 lg:px-8 pt-6 md:pt-8 pb-12">
        <TourHero tour={tour} lang={lang} badges={tour.badge} />

        <div class="w-full mt-8">
          <TourTabs tour={tour} client:visible>
            <div class="sticky top-24">
              {isIncaTrail ? (
                <BookingForm
                  client:load
                  tourId={tour.documentId}
                  tourName={tour.titulo}
                  basePrice={tour.priceTour}
                  lang={lang}
                />
              ) : (
                <ContactForm tourName={tour.titulo} />
              )}
            </div>
          </TourTabs>
        </div>

        <RelatedTours tours={toursRelated} lang={lang} />
      </div>
    </TourLayout>
  )
}

{
  type === "page" && page && (
    <PageContent
      page={page}
      toursByCategory={toursByCategory}
      pageSlugMap={pageSlugMap ?? {}}
      lang={lang}
      seoProps={seoProps!}
    />
  )
}
