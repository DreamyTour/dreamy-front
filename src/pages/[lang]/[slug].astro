---
import DynamicContentPage from "@/components/pages/DynamicContentPage.astro";
import { DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import {
  getLocalizedDynamicPaths,
  type DynamicPageProps,
} from "@/lib/dynamicPageRoutes";

export async function getStaticPaths() {
  return getLocalizedDynamicPaths();
}

const props = Astro.props as DynamicPageProps;
const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;

if (props.isRedirect && props.redirectTo) {
  return Astro.redirect(props.redirectTo, 301);
}
---

<DynamicContentPage
  type={props.type}
  lang={lang}
  tour={props.tour}
  page={props.page}
  slugMap={props.slugMap}
  pageSlugMap={props.pageSlugMap}
  mdxComponent={props.mdxComponent}
  mdxFrontmatter={props.mdxFrontmatter}
  toursRelated={props.toursRelated}
  toursByCategory={props.toursByCategory}
/>
