---
import PageLayout from "@/layouts/PageLayout.astro";
import CheckoutSummary from "@/components/checkout/CheckoutSummary";
import { LOCALIZED_LANGS, DEFAULT_LANG, isValidLang } from "@/lib/i18n";

export function getStaticPaths() {
  return LOCALIZED_LANGS.map((lang) => ({
    params: { lang },
  }));
}

const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;

if (lang === DEFAULT_LANG) {
  return Astro.redirect("/checkout");
}

const seoProps = {
  title: "Checkout - Booking",
  description: "Complete your booking securely.",
  type: "website" as "website",
  lang: lang,
};
---

<PageLayout seo={seoProps} lang={lang}>
  <div class="bg-gray-50 min-h-[70vh] pt-8 pb-16 border-t border-gray-200">
    <CheckoutSummary client:only="react" />
  </div>
</PageLayout>
