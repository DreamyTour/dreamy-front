---
import BlogIndexPage from "@/components/pages/BlogIndexPage.astro";
import { DEFAULT_LANG } from "@/lib/i18n";
import {
  getBlogIndexPaths,
  type BlogListProps,
  type Paginate,
} from "@/lib/blogRoutes";

export async function getStaticPaths({ paginate }: { paginate: Paginate }) {
  return getBlogIndexPaths({ paginate, localized: false });
}

const props = Astro.props as BlogListProps;
---

<BlogIndexPage
  page={props.page}
  allCategories={props.allCategories}
  socialLogos={props.socialLogos}
  categoryPostCounts={props.categoryPostCounts}
  totalPostCount={props.totalPostCount}
  lang={DEFAULT_LANG}
/>
