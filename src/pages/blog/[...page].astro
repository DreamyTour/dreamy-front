---
import Layout from "@/layouts/main.astro";
import fetchApi from "@/lib/strapi";
import type { Blog, CategoryBlog } from "@/interface/blog";
import CardPost from "@/components/ui/CardPost.astro";
import { DEFAULT_LANG } from "@/lib/i18n";
import { rewriteUrl } from "@/lib/utils";

export async function getStaticPaths({ paginate }: any) {
  const allPaths: any[] = [];

  for (const lang of [DEFAULT_LANG]) {
    const blogs = await fetchApi<Blog[]>({
      endpoint: "posts",
      wrappedByKey: "data",
      locale: lang,
      query: {
        sort: "publishedAt:desc",
      },
    });

    const blogsList = blogs && Array.isArray(blogs) ? blogs : [];

    const cats = await fetchApi<any[]>({
      endpoint: "category-blogs",
      wrappedByKey: "data",
      locale: lang,
    });
    const allCategories = cats && Array.isArray(cats) ? cats : [];

    const paginatedPaths = paginate(blogsList, {
      pageSize: 9,
      props: { allCategories },
    });

    allPaths.push(...paginatedPaths);
  }

  return allPaths;
}

const { page, allCategories } = Astro.props;
const lang = DEFAULT_LANG;
const currentLang = lang;
const blogsList = page.data;
---

<Layout>
  <div class="w-full py-20 md:py-28">
    <div class="max-w-8xl mx-auto px-6">
      <div class="mb-14 md:mb-20 text-center">
        <h1
          class="text-3xl md:text-5xl lg:text-6xl font-medium text-gray-900 mb-6 relative inline-block"
        >
          <span class="relative z-10">Blog</span>
          <span
            class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-3 bg-secondary/20 z-0 rounded-full blur-sm"
          ></span>
        </h1>
        <div class="flex items-center justify-center gap-3 mt-4">
          <div
            class="h-px w-16 bg-linear-to-r from-transparent to-secondary/50"
          >
          </div>
          <div class="w-12 h-1.5 bg-secondary/50 rounded-full relative">
            <div
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full"
            >
            </div>
          </div>
          <div
            class="h-px w-16 bg-linear-to-l from-transparent to-secondary/50"
          >
          </div>
        </div>
      </div>

      {/* Categorías (Pastillas) */}
      <div class="flex flex-wrap items-center justify-center gap-3 mb-12">
        <a
          href={rewriteUrl("/blog", lang)}
          class="px-5 py-2 rounded-full text-sm font-medium transition-all shadow-sm border
                 bg-primary text-white border-primary shadow-primary/20 scale-105"
        >
          {lang === "es" ? "Todos" : lang === "pt" ? "Todos" : "All"}
        </a>

        {
          allCategories &&
            allCategories.map((cat: any) => (
              <a
                href={rewriteUrl(`/blog/${cat.slug}`, lang)}
                class="px-5 py-2 rounded-full text-sm font-medium transition-all shadow-sm 
                   bg-white text-gray-600 border border-gray-200 hover:border-primary hover:text-primary"
              >
                {cat.nombre}
              </a>
            ))
        }
      </div>

      {
        blogsList.length > 0 ? (
          <div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-x-8 md:gap-y-16">
              {blogsList.map((blog: Blog) => (
                <CardPost blog={blog} lang={lang} />
              ))}
            </div>

            {/* Pagination Controls */}
            {page.lastPage > 1 && (
              <div class="flex items-center justify-center gap-4 mt-16 font-medium">
                {page.url.prev ? (
                  <a
                    href={page.url.prev}
                    class="px-5 py-2.5 rounded-sm border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-colors flex items-center gap-2 bg-white shadow-sm hover:shadow-md"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"
                      />
                    </svg>
                    {currentLang === "es"
                      ? "Anterior"
                      : currentLang === "pt"
                        ? "Anterior"
                        : "Previous"}
                  </a>
                ) : (
                  <span class="px-5 py-2.5 rounded-sm border border-gray-100 text-gray-400 bg-gray-50 flex items-center gap-2 cursor-not-allowed">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"
                      />
                    </svg>
                    {currentLang === "es"
                      ? "Anterior"
                      : currentLang === "pt"
                        ? "Anterior"
                        : "Previous"}
                  </span>
                )}

                <span class="text-gray-600 bg-white px-4 py-2.5 rounded-sm border border-gray-100 shadow-sm flex items-center gap-2">
                  {page.currentPage} <span class="text-gray-400">/</span>{" "}
                  {page.lastPage}
                </span>

                {page.url.next ? (
                  <a
                    href={page.url.next}
                    class="px-5 py-2.5 rounded-sm border border-gray-200 text-gray-700 hover:border-primary hover:text-primary transition-colors flex items-center gap-2 bg-white shadow-sm hover:shadow-md"
                  >
                    {currentLang === "es"
                      ? "Siguiente"
                      : currentLang === "pt"
                        ? "Próximo"
                        : "Next"}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </a>
                ) : (
                  <span class="px-5 py-2.5 rounded-sm border border-gray-100 text-gray-400 bg-gray-50 flex items-center gap-2 cursor-not-allowed">
                    {currentLang === "es"
                      ? "Siguiente"
                      : currentLang === "pt"
                        ? "Próximo"
                        : "Next"}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </span>
                )}
              </div>
            )}
          </div>
        ) : (
          <p class="text-center text-gray-500">No hay blogs disponibles</p>
        )
      }
    </div>
  </div>
</Layout>
