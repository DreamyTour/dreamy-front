---
import Layout from "@/layouts/main.astro";
import fetchApi from "@/lib/strapi";
import type { Blog, CategoryBlog } from "@/types/blog";
import type { Logo } from "@/types/common";
import CardPost from "@/components/ui/CardPost.astro";
import BlogAside from "@/components/ui/BlogAside.astro";
import BlogCategoryRail from "@/components/ui/BlogCategoryRail.astro";
import { DEFAULT_LANG } from "@/lib/i18n";
import { buildSEOProps } from "@/lib/seo";
import { rewriteUrl } from "@/lib/utils";
import { getCategoryPostCounts } from "@/lib/blogCategories";

type GlobalData = { footer?: { socialLogo?: Logo[] }; socialLogo?: Logo[] };
type PaginatedPage = {
  data: Blog[];
  currentPage: number;
  lastPage: number;
  url: { prev?: string | null; next?: string | null };
};
type BlogListProps = {
  page: PaginatedPage;
  allCategories: CategoryBlog[];
  socialLogos: Logo[];
  categoryPostCounts: Record<string, number>;
  totalPostCount: number;
};
type Paginate = (
  data: Blog[],
  options: { pageSize: number; props?: Record<string, unknown> },
) => unknown[];

export async function getStaticPaths({ paginate }: { paginate: Paginate }) {
  const allPaths: unknown[] = [];

  for (const lang of [DEFAULT_LANG]) {
    const blogs = await fetchApi<Blog[]>({
      endpoint: "posts",
      wrappedByKey: "data",
      locale: lang,
      query: {
        sort: "publishedAt:desc",
      },
    });

    const blogsList = blogs && Array.isArray(blogs) ? blogs : [];

    const cats = await fetchApi<CategoryBlog[]>({
      endpoint: "category-blogs",
      wrappedByKey: "data",
      locale: lang,
    });
    const allCategories = cats && Array.isArray(cats) ? cats : [];

    const globalData = await fetchApi<GlobalData>({
      endpoint: "global",
      wrappedByKey: "data",
      locale: lang,
    });
    const socialLogos =
      globalData?.footer?.socialLogo || globalData?.socialLogo || [];

    const categoryPostCounts = getCategoryPostCounts(blogsList);
    const totalPostCount = blogsList.length;

    const paginatedPaths = paginate(blogsList, {
      pageSize: 9,
      props: {
        allCategories,
        socialLogos,
        categoryPostCounts,
        totalPostCount,
      },
    });

    allPaths.push(...paginatedPaths);
  }

  return allPaths;
}

const {
  page,
  allCategories,
  socialLogos,
  categoryPostCounts,
  totalPostCount,
} = Astro.props as BlogListProps;
const lang = DEFAULT_LANG;
const currentLang = lang;
const blogsList = page.data;
const featuredBlog = page.currentPage === 1 ? blogsList[0] : null;
const remainingBlogs = featuredBlog ? blogsList.slice(1) : blogsList;
const seoProps = buildSEOProps({
  fallbackTitle:
    page.currentPage > 1
      ? `Travel Blog - Page ${page.currentPage} | Dreamy Tours`
      : "Travel Blog - Peru and Bolivia Tours | Dreamy Tours",
  fallbackDescription:
    "Travel guides, tips and destination inspiration for Peru, Bolivia, Machu Picchu, Lake Titicaca and Uyuni.",
  type: "website",
  lang,
});
---

<Layout seo={seoProps}>
  <div class="blog-index-page w-full py-16 md:py-24">
    <div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-4xl text-center md:mb-16">
        <p
          class="mb-4 text-[0.72rem] font-semibold uppercase tracking-[0.32em] text-secondary"
        >
          Dreamy Journal
        </p>
        <h1
          class="text-4xl font-semibold leading-[0.98] text-primary md:text-6xl lg:text-7xl"
        >
          Blog
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-7 text-foreground/68 md:text-lg">
          Travel stories, guides and practical inspiration for Peru, Bolivia,
          Machu Picchu, Lake Titicaca and Uyuni.
        </p>
      </div>

      <div class="lg:hidden">
        <BlogCategoryRail
          categories={allCategories}
          lang={lang}
          categoryPostCounts={categoryPostCounts}
          totalPostCount={totalPostCount}
        />
      </div>

      <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-14 xl:grid-cols-[minmax(0,1fr)_22rem]">
        {/* Main content grid */}
        <div class="w-full min-w-0">
          {
            blogsList.length > 0 ? (
              <div>
                <div class="blog-post-grid">
                  {featuredBlog && (
                    <CardPost
                      blog={featuredBlog}
                      lang={lang}
                      isFeatured
                      showDescription
                    />
                  )}
                  {remainingBlogs.map((blog: Blog) => (
                    <CardPost blog={blog} lang={lang} />
                  ))}
                </div>

                {/* Pagination Controls */}
                {page.lastPage > 1 && (
                  <div class="flex flex-wrap items-center justify-center gap-4 mt-16 font-medium">
                    {page.url.prev ? (
                      <a
                        href={page.url.prev}
                        class="px-5 py-2.5 rounded-sm border border-border text-foreground transition-colors flex items-center gap-2 bg-card shadow-sm hover:border-secondary/60 hover:text-secondary hover:shadow-md"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-4 w-4"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"
                          />
                        </svg>
                        {currentLang === "es"
                          ? "Anterior"
                          : currentLang === "pt"
                            ? "Anterior"
                            : "Previous"}
                      </a>
                    ) : (
                      <span class="px-5 py-2.5 rounded-sm border border-border/70 text-muted-foreground/60 bg-muted/60 flex items-center gap-2 cursor-not-allowed">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-4 w-4"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"
                          />
                        </svg>
                        {currentLang === "es"
                          ? "Anterior"
                          : currentLang === "pt"
                            ? "Anterior"
                            : "Previous"}
                      </span>
                    )}

                    <span class="text-muted-foreground bg-card px-4 py-2.5 rounded-sm border border-border shadow-sm flex items-center gap-2">
                      {page.currentPage} <span class="text-muted-foreground/50">/</span>{" "}
                      {page.lastPage}
                    </span>

                    {page.url.next ? (
                      <a
                        href={page.url.next}
                        class="px-5 py-2.5 rounded-sm border border-border text-foreground transition-colors flex items-center gap-2 bg-card shadow-sm hover:border-secondary/60 hover:text-secondary hover:shadow-md"
                      >
                        {currentLang === "es"
                          ? "Siguiente"
                          : currentLang === "pt"
                            ? "Próximo"
                            : "Next"}
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-4 w-4"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"
                          />
                        </svg>
                      </a>
                    ) : (
                      <span class="px-5 py-2.5 rounded-sm border border-border/70 text-muted-foreground/60 bg-muted/60 flex items-center gap-2 cursor-not-allowed">
                        {currentLang === "es"
                          ? "Siguiente"
                          : currentLang === "pt"
                            ? "Próximo"
                            : "Next"}
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-4 w-4"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          class="h-4 w-4"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"
                          />
                        </svg>
                      </span>
                    )}
                  </div>
                )}
              </div>
            ) : (
              <p class="text-center text-muted-foreground">No hay blogs disponibles</p>
            )
          }
        </div>

        {/* Sidebar */}
        <div class="w-full shrink-0">
          <BlogAside
            categories={allCategories}
            lang={lang}
            socialLogos={socialLogos}
            categoryPostCounts={categoryPostCounts}
            totalPostCount={totalPostCount}
          />
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .blog-index-page {
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--blog-surface) 82%, white) 0%,
        white 44%,
        color-mix(in oklab, var(--blog-surface) 70%, white) 100%
      );
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .no-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  .blog-post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 1.5vw, 1.5rem);
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .blog-post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-post-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
