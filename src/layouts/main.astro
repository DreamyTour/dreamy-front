---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

import fetchApi from "@/lib/strapi";
import type { Global } from "@/types/global";
import { DEFAULT_LANG, isValidLang, type Lang } from "@/lib/i18n";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";

import WhatsAppFloatingButton from "@/components/layout/WhatsAppFloatingButton.astro";
import { rewriteMenuUrls } from "@/lib/utils";
import SEO from "@/components/layout/SEO.astro";
import type { SEOProps } from "@/components/layout/SEO.astro";

interface Props {
  seo?: SEOProps;
  lang?: Lang;
  lcpImageUrl?: string;
  lcpImageSrcSet?: string;
  enableClientRouter?: boolean;
}

const {
  seo,
  lang: langProp,
  lcpImageUrl,
  lcpImageSrcSet,
  enableClientRouter = true,
} = Astro.props;

// 1. Detectamos el idioma desde los params de la vista de forma automática
// o desde la prop que se pasa desde la página
let currentLang: Lang = DEFAULT_LANG;

if (langProp && isValidLang(langProp)) {
  currentLang = langProp;
} else if (Astro.params?.lang && isValidLang(Astro.params.lang as string)) {
  currentLang = Astro.params.lang as Lang;
}

// 2. Obtenemos toda la data de la barra superior/footer y se la inyectamos
const globalDataRaw = await fetchApi<Global>({
  endpoint: "global",
  wrappedByKey: "data",
  query: {
    locale: currentLang,
    populate: "*",
  },
});

// 3. Reescribimos las URLs del menú para que coincidan con el idioma actual
const globalData = rewriteMenuUrls(globalDataRaw, currentLang);

// Default SEO values
const defaultTitle = "Turismo Perú Bolivia - Tours y Paquetes Turísticos";
const defaultDescription =
  "Explora los mejores tours y paquetes turísticos en Perú y Bolivia. Machu Picchu, Lago Titicaca, salar de Uyuni y más.";

const seoProps = seo || {
  title: defaultTitle,
  description: defaultDescription,
  type: "website" as const,
  lang: currentLang,
};
---

<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* LCP image preload — emitted only on pages that have a known hero image (e.g. tour pages)
        This hint is placed before ClientRouter/Font so the browser fetches it at highest priority
        during initial HTML parse, cutting ~1-2s from LCP. */}
    {lcpImageUrl && (
      <link
        rel="preload"
        as="image"
        href={lcpImageUrl}
        {...(lcpImageSrcSet ? { imagesrcset: lcpImageSrcSet, imagesizes: "(max-width: 767px) 100vw, (max-width: 1279px) 50vw, 600px" } : {})}
        fetchpriority="high"
      />
    )}
    {enableClientRouter && <ClientRouter />}
    <Font cssVariable="--font-outfit" preload />
    <SEO {...seoProps} />
  </head>
  <body>
    <!-- Skip Link para accesibilidad (WCAG 2.4.1) -->
    <a href="#main-content" class="skip-link">
      Saltar al contenido principal
    </a>

    <Header data={globalData} lang={currentLang} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer data={globalData?.footer} lang={currentLang} />
    <WhatsAppFloatingButton />
  </body>
</html>
