---
import Layout from "@/layouts/main.astro";
import type { SEOProps } from "@/components/layout/SEO.astro";
import type { Lang } from "@/lib/i18n";
import { serializeJsonForHtml } from "@/lib/html";

interface Props {
  slugMap?: Record<string, string>;
  seo?: SEOProps;
  lang?: Lang;
  lcpImageUrl?: string;
  lcpImageSrcSet?: string;
}

const { slugMap, seo, lang, lcpImageUrl, lcpImageSrcSet } = Astro.props;
---

<Layout
  seo={seo}
  lang={lang}
  lcpImageUrl={lcpImageUrl}
  lcpImageSrcSet={lcpImageSrcSet}
>
  <slot />
</Layout>

{
  slugMap && (
    <script
      is:inline
      id="tour-slug-map"
      type="application/json"
      set:html={serializeJsonForHtml(slugMap)}
    />
  )
}
