---
import ToursSlider from "@/components/ui/ToursSlider.astro";
import { useTranslations } from "@/i18n/ui";
import type { Lang } from "@/lib/i18n";
import { fetchToursByCategory } from "@/lib/strapiQueries";
import { rewriteUrl } from "@/lib/utils";
import type { Category } from "@/types/home";

type TourSectionData = {
  id: number;
  titulo: string;
  description?: string;
  limit?: number;
  category?: Category;
};

interface Props {
  data?: TourSectionData;
  lang: Lang;
  titleId: string;
  sectionId?: string;
  defaultLimit?: number;
  href: string;
  highlighted?: boolean;
  surface?: "white";
  ctaLabelKey?: "section.verMas" | "section.verMasPaquetes";
}

const {
  data,
  lang,
  titleId,
  sectionId,
  defaultLimit = 3,
  href,
  highlighted = false,
  surface,
  ctaLabelKey = "section.verMas",
} = Astro.props;

const t = useTranslations(lang);

if (!data) return;

const tours = await fetchToursByCategory({
  categorySlug: data.category?.slug,
  lang,
  limit: data.limit || defaultLimit,
});

const hasTours = tours.length > 0;
const descriptionId = `${titleId.replace(/-title$/, "")}-description`;
const ctaLabel = t(ctaLabelKey);
---

<section
  id={sectionId}
  aria-labelledby={titleId}
  aria-describedby={data.description ? descriptionId : undefined}
  class:list={[
    "content-deferred content-deferred--tall w-full py-16",
    surface === "white" && "bg-white",
    highlighted && "bg-primary/5",
  ]}
>
  <div class="mx-auto max-w-8xl px-6">
    <header class="mb-12 max-w-4xl mx-auto text-left md:mb-16">
      <h2
        id={titleId}
        class="relative mb-2 inline-block text-center w-full text-4xl font-bold leading-tight tracking-tight text-gray-950 md:text-5xl"
      >
        <span class="relative z-10">{data.titulo}</span>
      </h2>

      <span
        class="mb-6 mt-4 flex items-center justify-center gap-3"
        aria-hidden="true"
      >
        <span class="h-px w-16 bg-gradient-to-r from-transparent to-secondary"
        ></span>
        <span class="relative h-1.5 w-12 rounded-full bg-secondary">
          <span
            class="absolute left-1/2 top-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"
          >
          </span>
        </span>
        <span class="h-px w-16 bg-gradient-to-l from-transparent to-secondary"
        ></span>
      </span>

      {
        data.description && (
          <p
            id={descriptionId}
            class="w-full text-base text-center leading-relaxed text-gray-600"
          >
            {data.description}
          </p>
        )
      }
    </header>

    {
      hasTours ? (
        <ToursSlider tours={tours} lang={lang} labelledBy={titleId} />
      ) : (
        <div class="rounded-2xl border border-dashed border-secondary/30 bg-white/60 px-6 py-12 text-center">
          <svg
            class="mx-auto mb-4 h-12 w-12 text-secondary/40"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <p class="text-lg font-medium text-gray-500">
            {t("section.sinTours")}
          </p>
        </div>
      )
    }

    <div class="mt-10 flex justify-center">
      <a
        href={rewriteUrl(href, lang)}
        aria-label={`${ctaLabel}: ${data.titulo}`}
        class="group inline-flex min-h-12 w-full max-w-xs items-center justify-center gap-3 rounded-xl border border-secondary bg-secondary px-8 py-3 text-sm font-bold text-white shadow-[0_18px_36px_-18px_color-mix(in_oklab,var(--secondary)_90%,black)] transition duration-200 hover:-translate-y-0.5 hover:bg-secondary/90 hover:shadow-[0_22px_44px_-20px_color-mix(in_oklab,var(--secondary)_95%,black)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-secondary sm:w-auto sm:min-w-56"
      >
        <span>{ctaLabel}</span>
        <span
          class="text-base leading-none transition-transform duration-200 group-hover:translate-x-1"
          aria-hidden="true"
        >
          &rarr;
        </span>
      </a>
    </div>
  </div>
</section>
