---
import ToursSlider from "@/components/ui/ToursSlider.astro";
import { useTranslations } from "@/i18n/ui";
import type { Lang } from "@/lib/i18n";
import { fetchToursByCategory } from "@/lib/strapiQueries";
import { rewriteUrl } from "@/lib/utils";
import type { Category } from "@/types/home";

type TourSectionData = {
  id: number;
  titulo: string;
  description?: string;
  limit?: number;
  category?: Category;
};

interface Props {
  data?: TourSectionData;
  lang: Lang;
  titleId: string;
  sectionId?: string;
  defaultLimit?: number;
  href: string;
  highlighted?: boolean;
  surface?: "white";
  ctaLabelKey?: "section.verMas" | "section.verMasPaquetes";
}

const {
  data,
  lang,
  titleId,
  sectionId,
  defaultLimit = 3,
  href,
  highlighted = false,
  surface,
  ctaLabelKey = "section.verMas",
} = Astro.props;

const t = useTranslations(lang);

if (!data) return;

const tours = await fetchToursByCategory({
  categorySlug: data.category?.slug,
  lang,
  limit: data.limit || defaultLimit,
});

const hasTours = tours.length > 0;
const availabilityTitleId = `${titleId.replace(/-title$/, "")}-availability-title`;
const badgeText =
  {
    en: "Adventure Awaits",
    es: "La Aventura te Espera",
    pt: "A Aventura te Espera",
  }[lang] || "Adventure Awaits";

const availabilityText = {
  en: { title: "Check Availability", subtitle: "Book your adventure" },
  es: { title: "Consultar Disponibilidad", subtitle: "Reserva tu aventura" },
  pt: { title: "Verificar Disponibilidade", subtitle: "Reserve sua aventura" },
}[lang] || { title: "Check Availability", subtitle: "Book your adventure" };
---

<section
  id={sectionId}
  aria-labelledby={titleId}
  class:list={[
    "content-deferred content-deferred--tall w-full py-16",
    surface === "white" && "bg-white",
    highlighted && "bg-primary/5",
  ]}
>
  <div class="mx-auto max-w-8xl px-6">
    <div
      class="mb-14 flex flex-col items-start justify-between gap-8 md:mb-20 lg:flex-row lg:gap-12"
    >
      <header class="max-w-3xl flex-1 text-left">
        <p
          class="mb-4 flex w-fit items-center gap-2 rounded-full bg-secondary/15 px-3 py-1 text-sm font-semibold text-secondary"
        >
          <svg
            class="h-4 w-4"
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
              clip-rule="evenodd"></path>
          </svg>
          {badgeText}
        </p>

        <h2
          id={titleId}
          class="relative mb-2 inline-block text-3xl font-bold text-gray-900 md:text-4xl"
        >
          <span class="relative z-10">{data.titulo}</span>
          <span
            class="absolute bottom-0 left-0 -z-0 h-3 w-24 rounded-full bg-secondary/30 blur-sm"
          ></span>
        </h2>

        <span
          class="mb-6 mt-4 flex items-center justify-start gap-3"
          aria-hidden="true"
        >
          <span class="h-px w-16 bg-gradient-to-r from-transparent to-secondary"
          ></span>
          <span class="relative h-1.5 w-12 rounded-full bg-secondary">
            <span
              class="absolute left-1/2 top-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"
            >
            </span>
          </span>
          <span class="h-px w-16 bg-gradient-to-l from-transparent to-secondary"
          ></span>
        </span>

        <p class="text-base leading-relaxed text-gray-600">
          {
            data.description ||
              "The ancestral trails of the Andes are waiting for you to live a transforming experience. Each route is a unique adventure, designed for different levels of experience and physical condition. Our guides will accompany you every step of the way, sharing stories, knowledge and guaranteeing a safe and memorable experience."
          }
        </p>
      </header>

      {
        data.category?.slug && (
          <aside
            aria-labelledby={availabilityTitleId}
            class="flex w-full shrink-0 flex-col justify-center rounded-2xl border-l-[6px] border-secondary bg-white p-6 shadow-[0_8px_30px_rgb(0,0,0,0.08)] lg:w-[380px]"
          >
            <header class="mb-5 flex items-center gap-4">
              <span class="flex h-12 w-12 items-center justify-center rounded-full bg-secondary text-white shadow-md">
                <svg
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  />
                </svg>
              </span>
              <hgroup>
                <h3
                  id={availabilityTitleId}
                  class="text-[1.05rem] font-bold text-gray-900"
                >
                  {availabilityText.title}
                </h3>
                <p class="text-[0.85rem] text-gray-500">
                  {availabilityText.subtitle}
                </p>
              </hgroup>
            </header>
            <a
              href={rewriteUrl(href, lang)}
              aria-label={t("aria.verMasSeccion")}
              class="flex w-full items-center justify-between rounded-xl border border-secondary bg-secondary/10 px-5 py-3.5 font-semibold text-secondary shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:border-transparent hover:bg-secondary hover:text-white hover:shadow-lg"
            >
              <span class="flex items-center gap-2">
                <svg
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  />
                </svg>
                <span>{t(ctaLabelKey)}</span>
              </span>
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                />
              </svg>
            </a>
          </aside>
        )
      }
    </div>

    {
      hasTours ? (
        <ToursSlider tours={tours} lang={lang} />
      ) : (
        <div class="rounded-2xl border border-dashed border-secondary/30 bg-white/60 px-6 py-12 text-center">
          <svg
            class="mx-auto mb-4 h-12 w-12 text-secondary/40"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <p class="text-lg font-medium text-gray-500">
            {t("section.sinTours")}
          </p>
        </div>
      )
    }
  </div>
</section>
