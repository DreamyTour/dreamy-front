---
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = [
	{
		value: 15,
		suffix: "",
		label: t("homeStats.experience"),
	},
	{
		value: 200,
		suffix: "+",
		label: t("homeStats.collaborators"),
	},
	{
		value: 6000,
		suffix: "+",
		label: t("homeStats.adventures"),
	},
	{
		value: 70000,
		suffix: "+",
		label: t("homeStats.clients"),
	},
];

const formatValue = (value: number, suffix: string) =>
	`${new Intl.NumberFormat("en-US").format(value)}${suffix}`;
---

<section
	class="home-stats relative isolate overflow-hidden bg-muted py-12 sm:py-14 lg:py-16"
	aria-label={t("homeStats.ariaLabel")}
	data-home-stats
>
	<div
		class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-primary/25 to-transparent"
		aria-hidden="true"
	>
	</div>
	<div
		class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-linear-to-r from-transparent via-secondary/25 to-transparent"
		aria-hidden="true"
	>
	</div>

	<ul class="mx-auto grid max-w-8xl grid-cols-1 gap-y-10 px-6 text-center sm:grid-cols-2 lg:grid-cols-4 lg:gap-y-0">
		{
			stats.map((stat, index) => (
				<li
					class="home-stat-item relative flex flex-col items-center justify-start px-4"
					style={`--stat-delay: ${index * 90}ms`}
					aria-label={`${formatValue(stat.value, stat.suffix)} ${stat.label}`}
				>
					<span
						class="home-stat-number text-4xl font-extrabold leading-none tracking-tight text-secondary sm:text-5xl"
						data-stat-number
						data-target={stat.value}
						data-suffix={stat.suffix}
						aria-hidden="true"
					>
						{formatValue(stat.value, stat.suffix)}
					</span>
					<span class="mt-4 max-w-[18rem] text-sm font-extrabold uppercase leading-7 text-foreground sm:text-base">
						{stat.label}
					</span>
				</li>
			))
		}
	</ul>
</section>

<script>
	const numberFormatter = new Intl.NumberFormat("en-US");
	let homeStatsObserver: IntersectionObserver | undefined;

	const setFinalValues = (root: HTMLElement) => {
		root.querySelectorAll<HTMLElement>("[data-stat-number]").forEach((node) => {
			const target = Number(node.dataset.target || "0");
			const suffix = node.dataset.suffix || "";
			node.textContent = `${numberFormatter.format(target)}${suffix}`;
		});
		root.classList.add("is-visible");
	};

	const animateRoot = (root: HTMLElement) => {
		root.classList.add("is-visible");

		root.querySelectorAll<HTMLElement>("[data-stat-number]").forEach((node) => {
			const target = Number(node.dataset.target || "0");
			const suffix = node.dataset.suffix || "";
			const duration = 1200;
			const startTime = performance.now();

			const tick = (now: number) => {
				const progress = Math.min((now - startTime) / duration, 1);
				const eased = 1 - (1 - progress) ** 3;
				const value = Math.round(target * eased);
				node.textContent = `${numberFormatter.format(value)}${suffix}`;

				if (progress < 1) {
					requestAnimationFrame(tick);
				}
			};

			node.textContent = suffix ? `0${suffix}` : "0";
			requestAnimationFrame(tick);
		});
	};

	const initHomeStats = () => {
		const roots = document.querySelectorAll<HTMLElement>("[data-home-stats]");
		const reduceMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		homeStatsObserver?.disconnect();

		if (reduceMotion || !("IntersectionObserver" in window)) {
			roots.forEach(setFinalValues);
			return;
		}

		homeStatsObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					const root = entry.target as HTMLElement;
					animateRoot(root);
					homeStatsObserver?.unobserve(root);
				});
			},
			{ threshold: 0.35 },
		);

		roots.forEach((root) => homeStatsObserver?.observe(root));
	};

	document.addEventListener("astro:page-load", initHomeStats);
	initHomeStats();
</script>

<style>
	.home-stats {
		background:
			linear-gradient(
				180deg,
				color-mix(in oklab, var(--muted) 72%, white 28%),
				var(--muted)
			);
	}

	.home-stat-item {
		opacity: 0;
		transform: translateY(18px);
	}

	.home-stat-item:not(:last-child)::after {
		content: "";
		position: absolute;
		inset-block: 0.25rem;
		inset-inline-end: 0;
		width: 1px;
		background: linear-gradient(
			to bottom,
			transparent,
			color-mix(in oklab, var(--border) 80%, var(--primary) 20%),
			transparent
		);
		opacity: 0;
	}

	.home-stats.is-visible .home-stat-item {
		animation: stat-rise 700ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
		animation-delay: var(--stat-delay);
	}

	.home-stats.is-visible .home-stat-item::after {
		animation: stat-rule 700ms ease-out both;
		animation-delay: calc(var(--stat-delay) + 180ms);
	}

	.home-stat-number {
		text-shadow: 0 12px 30px color-mix(in oklab, var(--secondary) 18%, transparent);
	}

	@keyframes stat-rise {
		from {
			opacity: 0;
			transform: translateY(18px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes stat-rule {
		from {
			opacity: 0;
			transform: scaleY(0.2);
		}
		to {
			opacity: 1;
			transform: scaleY(1);
		}
	}

	@media (max-width: 1023px) {
		.home-stat-item:not(:last-child)::after {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-stat-item {
			opacity: 1;
			transform: none;
		}

		.home-stats.is-visible .home-stat-item,
		.home-stats.is-visible .home-stat-item::after {
			animation: none;
		}
	}
</style>
