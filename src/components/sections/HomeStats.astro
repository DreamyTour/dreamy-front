---
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = [
  {
    value: 15,
    suffix: "",
    label: t("homeStats.experience"),
  },
  {
    value: 200,
    suffix: "+",
    label: t("homeStats.collaborators"),
  },
  {
    value: 6000,
    suffix: "+",
    label: t("homeStats.adventures"),
  },
  {
    value: 70000,
    suffix: "+",
    label: t("homeStats.clients"),
  },
];

const formatValue = (value: number, suffix: string) =>
  `${new Intl.NumberFormat("en-US").format(value)}${suffix}`;
---

<section
  class="home-stats relative z-20 -mt-[3.25rem] px-4 sm:-mt-14 sm:px-6 lg:-mt-16"
  aria-label={t("homeStats.ariaLabel")}
  data-home-stats
>
  <div class="home-stats-shell mx-auto max-w-8xl">
    <ul class="home-stats-grid grid grid-cols-2 text-center lg:grid-cols-4">
      {
        stats.map((stat, index) => (
          <li
            class="home-stat-item relative flex min-h-28 flex-col items-center justify-center px-4 py-5 sm:min-h-32 lg:min-h-36"
            style={`--stat-delay: ${index * 90}ms`}
            aria-label={`${formatValue(stat.value, stat.suffix)} ${stat.label}`}
          >
            <span
              class="home-stat-number font-black leading-none tracking-tight"
              data-stat-number
              data-target={stat.value}
              data-suffix={stat.suffix}
              aria-hidden="true"
            >
              {formatValue(stat.value, stat.suffix)}
            </span>
            <span class="home-stat-label mt-3 max-w-[12rem] text-[0.62rem] font-bold uppercase leading-4 tracking-[0.14em] sm:text-[0.7rem]">
              {stat.label}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  const numberFormatter = new Intl.NumberFormat("en-US");
  let homeStatsObserver: IntersectionObserver | undefined;

  const setFinalValues = (root: HTMLElement) => {
    root.querySelectorAll<HTMLElement>("[data-stat-number]").forEach((node) => {
      const target = Number(node.dataset.target || "0");
      const suffix = node.dataset.suffix || "";
      node.textContent = `${numberFormatter.format(target)}${suffix}`;
    });
    root.classList.add("is-visible");
  };

  const animateRoot = (root: HTMLElement) => {
    root.classList.add("is-visible");

    root.querySelectorAll<HTMLElement>("[data-stat-number]").forEach((node) => {
      const target = Number(node.dataset.target || "0");
      const suffix = node.dataset.suffix || "";
      const duration = 1200;
      const startTime = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - (1 - progress) ** 3;
        const value = Math.round(target * eased);
        node.textContent = `${numberFormatter.format(value)}${suffix}`;

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      };

      node.textContent = suffix ? `0${suffix}` : "0";
      requestAnimationFrame(tick);
    });
  };

  const initHomeStats = () => {
    const roots = document.querySelectorAll<HTMLElement>("[data-home-stats]");
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const compactViewport = window.matchMedia("(max-width: 767px)").matches;

    homeStatsObserver?.disconnect();

    if (
      reduceMotion ||
      compactViewport ||
      !("IntersectionObserver" in window)
    ) {
      roots.forEach(setFinalValues);
      return;
    }

    homeStatsObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const root = entry.target as HTMLElement;
          animateRoot(root);
          homeStatsObserver?.unobserve(root);
        });
      },
      { threshold: 0.35 },
    );

    roots.forEach((root) => homeStatsObserver?.observe(root));
  };

  document.addEventListener("astro:page-load", initHomeStats);
  initHomeStats();
</script>

<style>
  .home-stats {
    --stats-line: color-mix(in oklab, var(--primary) 12%, var(--border));
    container: home-stats / inline-size;
  }

  .home-stats-shell {
    position: relative;
    z-index: 1;
    overflow: clip;
    border: 1px solid color-mix(in oklab, var(--primary) 10%, var(--border));
    border-radius: 1.35rem;
    background: linear-gradient(
      112deg,
      white 0%,
      color-mix(in oklab, white 97%, var(--accent-warm)) 55%,
      color-mix(in oklab, white 96%, var(--primary)) 100%
    );
    box-shadow:
      0 30px 70px -42px color-mix(in oklab, var(--foreground) 28%, transparent),
      0 1px 0 white inset;
  }

  .home-stats-shell::before {
    position: absolute;
    pointer-events: none;
    content: "";
  }

  .home-stats-shell::before {
    inset: 0;
    background:
      radial-gradient(
        circle at 8% 0%,
        color-mix(in oklab, var(--primary) 7%, transparent),
        transparent 30%
      ),
      radial-gradient(
        circle at 94% 120%,
        color-mix(in oklab, var(--secondary) 7%, transparent),
        transparent 34%
      );
    opacity: 0.9;
  }

  .home-stats-grid {
    position: relative;
    z-index: 1;
  }

  .home-stat-item {
    opacity: 0;
    transform: translateY(18px);
    transition:
      background-color 240ms ease,
      transform 240ms ease;
  }

  .home-stat-item::before {
    content: "";
    position: absolute;
    inset-block-start: 1.15rem;
    inset-inline-start: 50%;
    inline-size: 1.65rem;
    block-size: 2px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--secondary) 78%, white);
    opacity: 0.9;
    transform: translateX(-50%);
  }

  .home-stat-item:not(:last-child)::after {
    content: "";
    position: absolute;
    inset-block: 1.5rem;
    inset-inline-end: 0;
    width: 1px;
    background: var(--stats-line);
  }

  .home-stat-item:hover {
    background-color: color-mix(in oklab, var(--primary) 3.5%, transparent);
  }

  .home-stats.is-visible .home-stat-item {
    animation: stat-rise 700ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    animation-delay: var(--stat-delay);
  }

  .home-stats.is-visible .home-stat-item::after {
    animation: stat-rule 700ms ease-out both;
    animation-delay: calc(var(--stat-delay) + 180ms);
  }

  .home-stat-number {
    position: relative;
    z-index: 1;
    color: color-mix(in oklab, var(--primary) 82%, black);
    font-size: clamp(1.7rem, 2.65cqi, 2.65rem);
    font-variant-numeric: tabular-nums;
    text-shadow: none;
  }

  .home-stat-label {
    position: relative;
    z-index: 1;
    color: color-mix(in oklab, var(--foreground) 72%, var(--primary));
    text-wrap: balance;
  }

  @keyframes stat-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes stat-rule {
    from {
      opacity: 0;
      transform: scaleY(0.2);
    }
    to {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  @media (max-width: 1023px) {
    .home-stat-item::after {
      display: block;
    }

    .home-stat-item:nth-child(2n)::after {
      display: none;
    }

    .home-stat-item:nth-child(-n + 2) {
      border-block-end: 1px solid var(--stats-line);
    }
  }

  @container home-stats (max-width: 520px) {
    .home-stats-shell {
      border-radius: 1rem;
    }

    .home-stat-item {
      min-block-size: 7rem;
      padding-block: 1.25rem;
    }

    .home-stat-number {
      font-size: clamp(1.5rem, 8.5cqi, 2.15rem);
    }

    .home-stat-label {
      letter-spacing: 0.1em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-stat-item {
      opacity: 1;
      transform: none;
    }

    .home-stats.is-visible .home-stat-item,
    .home-stats.is-visible .home-stat-item::after {
      animation: none;
    }
  }

  @media (max-width: 767px) {
    .home-stat-item {
      opacity: 1;
      transform: none;
    }

    .home-stats.is-visible .home-stat-item,
    .home-stats.is-visible .home-stat-item::after {
      animation: none;
    }
  }
</style>
