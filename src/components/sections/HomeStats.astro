---
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = [
  {
    value: 15,
    suffix: "",
    label: t("homeStats.experience"),
  },
  {
    value: 200,
    suffix: "+",
    label: t("homeStats.collaborators"),
  },
  {
    value: 6000,
    suffix: "+",
    label: t("homeStats.adventures"),
  },
  {
    value: 70000,
    suffix: "+",
    label: t("homeStats.clients"),
  },
];

const formatValue = (value: number, suffix: string) =>
  `${new Intl.NumberFormat("en-US").format(value)}${suffix}`;
---

<section
  class="home-stats relative z-20 -mt-[3.25rem] px-4 sm:-mt-14 sm:px-6 lg:-mt-16"
  aria-label={t("homeStats.ariaLabel")}
  data-home-stats
>
  <div class="home-stats-shell mx-auto max-w-8xl">
    <ul
      class="home-stats-grid grid gap-2.5 text-center grid-cols-2 lg:grid-cols-4"
    >
      {
        stats.map((stat, index) => (
          <li
            class="home-stat-item relative flex min-h-26 flex-col items-center justify-center overflow-hidden px-4 py-4 sm:min-h-28 lg:min-h-32"
            style={`--stat-delay: ${index * 90}ms`}
            aria-label={`${formatValue(stat.value, stat.suffix)} ${stat.label}`}
          >
            <span
              class="home-stat-number text-xl font-black leading-none tracking-tight lg:text-3xl"
              data-stat-number
              data-target={stat.value}
              data-suffix={stat.suffix}
              aria-hidden="true"
            >
              {formatValue(stat.value, stat.suffix)}
            </span>
            <span class="home-stat-label mt-2.5 max-w-[12rem] text-[0.62rem] font-extrabold uppercase leading-4 tracking-[0.12em] sm:text-[0.7rem]">
              {stat.label}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  const numberFormatter = new Intl.NumberFormat("en-US");
  let homeStatsObserver: IntersectionObserver | undefined;

  const setFinalValues = (root: HTMLElement) => {
    root.querySelectorAll<HTMLElement>("[data-stat-number]").forEach((node) => {
      const target = Number(node.dataset.target || "0");
      const suffix = node.dataset.suffix || "";
      node.textContent = `${numberFormatter.format(target)}${suffix}`;
    });
    root.classList.add("is-visible");
  };

  const animateRoot = (root: HTMLElement) => {
    root.classList.add("is-visible");

    root.querySelectorAll<HTMLElement>("[data-stat-number]").forEach((node) => {
      const target = Number(node.dataset.target || "0");
      const suffix = node.dataset.suffix || "";
      const duration = 1200;
      const startTime = performance.now();

      const tick = (now: number) => {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - (1 - progress) ** 3;
        const value = Math.round(target * eased);
        node.textContent = `${numberFormatter.format(value)}${suffix}`;

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      };

      node.textContent = suffix ? `0${suffix}` : "0";
      requestAnimationFrame(tick);
    });
  };

  const initHomeStats = () => {
    const roots = document.querySelectorAll<HTMLElement>("[data-home-stats]");
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const compactViewport = window.matchMedia("(max-width: 767px)").matches;

    homeStatsObserver?.disconnect();

    if (
      reduceMotion ||
      compactViewport ||
      !("IntersectionObserver" in window)
    ) {
      roots.forEach(setFinalValues);
      return;
    }

    homeStatsObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const root = entry.target as HTMLElement;
          animateRoot(root);
          homeStatsObserver?.unobserve(root);
        });
      },
      { threshold: 0.35 },
    );

    roots.forEach((root) => homeStatsObserver?.observe(root));
  };

  document.addEventListener("astro:page-load", initHomeStats);
  initHomeStats();
</script>

<style>
  .home-stats {
    --stats-line: color-mix(in oklab, var(--secondary) 18%, transparent);
    container: home-stats / inline-size;
  }

  .home-stats-shell {
    position: relative;
    z-index: 1;
    overflow: visible;
  }

  .home-stats-grid {
    position: relative;
    z-index: 1;
  }

  .home-stat-item {
    border: 1px solid color-mix(in oklab, var(--secondary) 14%, white);
    border-radius: 0.875rem;
    background: color-mix(in oklab, white 96%, var(--background) 4%);
    box-shadow:
      0 18px 40px -30px color-mix(in oklab, black 20%, transparent),
      0 1px 0 color-mix(in oklab, white 88%, transparent) inset;
    opacity: 0;
    transform: translateY(18px);
    transition:
      background 240ms ease,
      box-shadow 240ms ease,
      transform 240ms ease;
  }

  .home-stat-item::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 0%,
      color-mix(in oklab, var(--secondary) 12%, transparent),
      transparent 58%
    );
    opacity: 0.20;
    transition: opacity 240ms ease;
  }

  .home-stat-item:not(:last-child)::after {
    content: "";
    position: absolute;
    inset-block: 1.25rem;
    inset-inline-end: 0;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--stats-line),
      transparent
    );
    opacity: 0;
  }

  .home-stat-item:hover {
    background: white;
    box-shadow: 0 28px 58px -34px
      color-mix(in oklab, var(--secondary) 30%, var(--primary) 20%);
    transform: translateY(-1px);
  }

  .home-stat-item:hover::before {
    opacity: 1;
  }

  .home-stats.is-visible .home-stat-item {
    animation: stat-rise 700ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    animation-delay: var(--stat-delay);
  }

  .home-stats.is-visible .home-stat-item::after {
    animation: stat-rule 700ms ease-out both;
    animation-delay: calc(var(--stat-delay) + 180ms);
  }

  .home-stat-number {
    position: relative;
    z-index: 1;
    color: color-mix(in oklab, var(--primary) 72%, black 28%);
    font-size: clamp(1.55rem, 2.35cqi, 2.35rem);
    font-variant-numeric: tabular-nums;
  }

  .home-stat-label {
    position: relative;
    z-index: 1;
    color: color-mix(in oklab, var(--foreground) 76%, var(--secondary));
    text-wrap: balance;
  }

  @keyframes stat-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes stat-rule {
    from {
      opacity: 0;
      transform: scaleY(0.2);
    }
    to {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  @media (max-width: 1023px) {
    .home-stat-item:not(:last-child)::after {
      display: none;
    }
  }

  @container home-stats (max-width: 520px) {
    .home-stats-shell {
      border-radius: 1.1rem;
    }

    .home-stat-item {
      min-block-size: 6.5rem;
      padding-block: 1rem;
    }

    .home-stat-number {
      font-size: clamp(1.45rem, 8.5cqi, 2rem);
    }

    .home-stat-label {
      letter-spacing: 0.1em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-stat-item {
      opacity: 1;
      transform: none;
    }

    .home-stats.is-visible .home-stat-item,
    .home-stats.is-visible .home-stat-item::after {
      animation: none;
    }
  }

  @media (max-width: 767px) {
    .home-stat-item {
      opacity: 1;
      transform: none;
    }

    .home-stats.is-visible .home-stat-item,
    .home-stats.is-visible .home-stat-item::after {
      animation: none;
    }
  }
</style>
