---
import type { Lang } from "@/lib/i18n";
import type { Page } from "@/types/page";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
import mapSvg from "@/assets/svg/mapa-peru.svg?raw";
import backgroundImageMobile from "@/assets/backgroundImageMobile.webp";
import fetchApi from "@/lib/strapi";
import { getImageAlt, getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

// ====== i18n: Textos de la sección ======
const copy = {
  es: {
    title: "Un Viaje a través de la",
    titleHighlight: "Diversidad Infinita",
    description:
      "Perú no es un país, es un mundo por descubrir. Cada región es un universo único, con paisajes, culturas, gastronomía y tradiciones que desafían la imaginación.",
    description2:
      "Adéntrate en un territorio donde la geografía cambia cada cien kilómetros, donde puedes pasar de glaciares imponentes a selvas exuberantes.",
    mapTitle: "Mapa Interactivo del Perú",
    mapSubtitle:
      "Pasa el cursor por un punto o elige una tarjeta para explorar ese destino.",
    mapPointLabel: (name: string) => `Ver ${name} en el mapa`,
  },
  en: {
    title: "A Journey through",
    titleHighlight: "Infinite Diversity",
    description:
      "Peru is not just a country — it's a world waiting to be discovered. Each region is a unique universe of landscapes, cultures, cuisine and traditions beyond imagination.",
    description2:
      "Step into a territory where geography shifts every hundred kilometers, from towering glaciers to lush rainforests.",
    mapTitle: "Interactive Peru Map",
    mapSubtitle: "Hover a point or choose a card to explore that destination.",
    mapPointLabel: (name: string) => `View ${name} on the map`,
  },
  pt: {
    title: "Uma Viagem através da",
    titleHighlight: "Diversidade Infinita",
    description:
      "O Peru não é apenas um país — é um mundo a ser descoberto. Cada região é um universo único de paisagens, culturas, gastronomia e tradições além da imaginação.",
    description2:
      "Adentre um território onde a geografia muda a cada cem quilômetros, de glaciares imponentes a selvas exuberantes.",
    mapTitle: "Mapa Interativo do Peru",
    mapSubtitle:
      "Passe o cursor por um ponto ou escolha um cartão para explorar o destino.",
    mapPointLabel: (name: string) => `Ver ${name} no mapa`,
  },
} as const;

const t = copy[lang as keyof typeof copy] ?? copy.es;

const destinationSlugs = [
  "lima",
  "cusco",
  "iquitos",
  "arequipa",
  "puno",
  "ica",
  "puerto-maldonado",
] as const;

const pageSlugFilters = Object.fromEntries(
  destinationSlugs.map((slug, index) => [`filters[slug][$in][${index}]`, slug]),
);

const destinationPages = await fetchApi<Page[]>({
  endpoint: "pages",
  wrappedByKey: "data",
  locale: lang,
  query: {
    ...pageSlugFilters,
    populate: "*",
    "pagination[pageSize]": destinationSlugs.length,
  },
});

const destinationPagesBySlug = new Map(
  (Array.isArray(destinationPages) ? destinationPages : []).map((page) => [
    page.slug,
    page,
  ]),
);

// ====== Posiciones de los puntos del mapa ======
const mapPointConfig = [
  { id: "lima", slug: "lima", x: "45%", y: "74%" },
  { id: "cusco", slug: "cusco", x: "59%", y: "70%" },
  { id: "iquitos", slug: "iquitos", x: "51%", y: "25%" },
  { id: "arequipa", slug: "arequipa", x: "62%", y: "85%" },
  { id: "puno", slug: "puno", x: "79%", y: "80%" },
  { id: "ica", slug: "ica", x: "53%", y: "82%" },
  {
    id: "puerto-maldonado",
    slug: "puerto-maldonado",
    x: "71%",
    y: "64%",
  },
];

const destinationIcons: Record<string, string> = {
  lima: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M6 20V9l6-4 6 4v11" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 20v-6h6v6M9 10h.01M15 10h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  cusco:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 18 9.5 7l3.2 6 2.2-3.5L20 18H4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9.5 7 11 18M14.9 9.5 14 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>',
  iquitos:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 19c5-1 9-5 10-12 3 2 4 5 4 8 0 3-2 5-5 5H5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M5 19c4-3 7-6 10-12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>',
  arequipa:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 18h16L15 7l-3 5-2-3-6 9Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M15 7c1.2-.8 2.6-.8 3.8 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>',
  puno: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 16c2-2 4-2 6 0s4 2 6 0 3-2 4-1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M5 19c2-1.4 4-1.4 6 0s4 1.4 6 0 2.3-1.2 3-.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M8 12h8l-2-4h-4l-2 4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>',
  ica: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 17c2.5-4 5.5-5.5 9-4.5 2 .6 4.3.5 7-1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M6 19c3-2 6-2.2 9-1 1.6.6 3 .6 4.5-.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M8 8h4l-2 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  "puerto-maldonado":
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20V7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M12 10c-3.5 0-6-1.8-7-5 3.8-.4 6.2 1.1 7 5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M12 13c3.8-.3 6.1-2.4 7-6-3.9.2-6.2 2.2-7 6Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>',
  default:
    '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M12 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" stroke="currentColor" stroke-width="1.8"/></svg>',
};

const mapPoints = mapPointConfig
  .map((point) => {
    const page = destinationPagesBySlug.get(point.slug);
    if (!page?.titulo) return null;

    const image = page.seo?.metaImage;

    return {
      ...point,
      page,
      resolvedTitle: page.titulo,
      resolvedSlug: page.slug || point.slug,
      imageUrl: image ? getImageUrl(image, "small") : backgroundImageMobile.src,
      imageAlt: image ? getImageAlt(image, page.titulo) : "",
    };
  })
  .filter((point) => point !== null);

const leftColumnPoints = mapPoints.slice(0, Math.ceil(mapPoints.length / 2));
const rightColumnPoints = mapPoints.slice(Math.ceil(mapPoints.length / 2));
---

<section
  class="w-full overflow-hidden bg-primary/5 py-12 lg:hidden"
  aria-labelledby="peru-guide-mobile-title"
>
  <div class="max-w-8xl mx-auto px-4">
    <header class="mb-7 max-w-3xl text-left md:mb-9">
      <h2
        id="peru-guide-mobile-title"
        class="relative inline-block mb-2 text-3xl font-bold leading-tight tracking-tight text-gray-900 sm:text-4xl md:text-5xl"
      >
        <span class="relative z-10">
          {t.title}
          {" "}
          <span class="text-secondary">{t.titleHighlight}</span>
        </span>
        <span
          class="absolute bottom-0 left-0 h-3 w-24 rounded-full bg-secondary/30 -z-0 blur-sm"
        ></span>
      </h2>

      <span
        class="mt-4 mb-6 flex items-center justify-start gap-3"
        aria-hidden="true"
      >
        <span
          class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary"
        ></span>
        <span class="relative h-1.5 w-12 rounded-full bg-secondary">
          <span
            class="absolute top-1/2 left-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"
          >
          </span>
        </span>
        <span
          class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary"
        ></span>
      </span>

      <p class="text-sm leading-relaxed text-gray-600 sm:text-base">
        {t.description}
      </p>
    </header>

    <ul class="grid list-none grid-cols-12 gap-[0.35rem] p-0">
      {
        mapPoints.map((point, index) => {
          const pointTitle = point.resolvedTitle;
          const patternPosition = index % 4;
          const spanClass =
            patternPosition === 0 || patternPosition === 3
              ? "col-span-7"
              : "col-span-5";
          const isOddLast =
            index === mapPoints.length - 1 && mapPoints.length % 2 !== 0;
          const shouldFillRow = isOddLast;

          return (
            <li class:list={[shouldFillRow ? "col-span-12" : spanClass]}>
              <a
                href={rewriteUrl(`/${point.resolvedSlug}`, lang)}
                class:list={[
                  "mobile-bento-card group relative block overflow-hidden rounded-[5px] border border-white/80 bg-white shadow-[0_8px_22px_rgb(15,23,42,0.10)] ring-1 ring-black/[0.03] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgb(15,23,42,0.14)]",
                  "h-[150px] sm:h-[172px]",
                ]}
                aria-label={pointTitle}
              >
                <img
                  src={point.imageUrl}
                  alt={point.imageAlt}
                  aria-hidden={point.imageAlt ? undefined : "true"}
                  class="bento-card-image absolute inset-0 h-full w-full object-cover transition-[filter] duration-300"
                  width={shouldFillRow ? "640" : "320"}
                  height="360"
                  loading="lazy"
                  decoding="async"
                />
                <span
                  class:list={[
                    "absolute inset-0 bg-gradient-to-t from-black/68 via-black/14 to-transparent",
                  ]}
                  aria-hidden="true"
                />
                <article
                  class:list={[
                    "relative z-10 flex h-full flex-col items-center justify-center text-center",
                    shouldFillRow ? "p-4" : "p-2.5",
                  ]}
                >
                  <span
                    class="mobile-bento-icon grid size-10 place-items-center text-white/92 transition-transform duration-300 sm:size-11"
                    aria-hidden="true"
                    set:html={
                      destinationIcons[point.id] ?? destinationIcons.default
                    }
                  />
                  <h3 class="mt-2.5 line-clamp-2 text-[0.78rem] font-semibold leading-tight text-white drop-shadow-[0_1px_8px_rgb(0,0,0,0.55)] sm:text-[0.95rem]">
                    {pointTitle}
                  </h3>
                </article>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<section
  class="py-16 relative overflow-hidden bg-primary/5 hidden lg:block"
  aria-labelledby="peru-guide-desktop-title"
  data-peru-guide
>
  <!-- Fondo sutil usando color neutral -->
  <span
    class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px] opacity-30 pointer-events-none"
    aria-hidden="true"
  >
  </span>

  <div class="container mx-auto px-4 md:px-6 relative z-10 w-full max-w-8xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <!-- Text Content (Left) -->
      <article class="lg:col-span-5 space-y-8">
        <h2
          id="peru-guide-desktop-title"
          class="text-4xl md:text-5xl font-bold text-foreground leading-tight"
        >
          {t.title}
          {" "}
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-primary"
            >{t.titleHighlight}</span
          >
        </h2>

        <p class="text-muted-foreground font-medium leading-relaxed">
          {t.description}
        </p>
        <p class="text-muted-foreground font-medium leading-relaxed">
          {t.description2}
        </p>
      </article>

      <!-- Interactive Map Area (Right) -->
      <aside
        class="lg:col-span-7 relative w-full perspective-1000"
        aria-labelledby="peru-guide-map-title"
      >
        <article
          class="bg-white backdrop-blur-sm border border-border rounded-3xl p-8 relative shadow-lg"
        >
          <header class="mb-8">
            <h3
              id="peru-guide-map-title"
              class="text-2xl font-bold text-foreground mb-2"
            >
              {t.mapTitle}
            </h3>
            <p class="text-muted-foreground text-sm max-w-sm">
              {t.mapSubtitle}
            </p>
          </header>

          <!-- Semantic Map Container -->
          <div class="grid grid-cols-12 gap-4 items-start">
            <ul class="col-span-3 m-0 list-none space-y-3 p-0">
              {
                leftColumnPoints.map((point) => {
                  const pointTitle = point.resolvedTitle;
                  return (
                    <li>
                      <a
                        href={rewriteUrl(`/${point.resolvedSlug}`, lang)}
                        class="guide-card mobile-bento-card desktop-guide-card group relative block h-[104px] overflow-hidden rounded-[5px] border border-white/80 bg-white shadow-[0_8px_22px_rgb(15,23,42,0.10)] ring-1 ring-black/[0.03] transition-shadow duration-300 hover:shadow-[0_12px_28px_rgb(15,23,42,0.14)] focus:outline-none"
                        aria-label={pointTitle}
                        data-point-trigger={point.id}
                      >
                        <img
                          src={point.imageUrl}
                          alt={point.imageAlt}
                          aria-hidden={point.imageAlt ? undefined : "true"}
                          class="bento-card-image absolute inset-0 h-full w-full object-cover transition-[filter] duration-300"
                          loading="lazy"
                          decoding="async"
                        />
                        <span
                          class="desktop-card-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-black/18 to-transparent"
                          aria-hidden="true"
                        />
                        <article class="desktop-card-content relative z-10 flex h-full flex-col items-center justify-center p-2 text-center text-white">
                          <span
                            class="mobile-bento-icon grid size-9 place-items-center text-white/92 transition-transform duration-300"
                            aria-hidden="true"
                            set:html={
                              destinationIcons[point.id] ??
                              destinationIcons.default
                            }
                          />
                          <h4 class="mt-2 line-clamp-2 text-[0.76rem] font-semibold leading-tight drop-shadow-[0_1px_8px_rgb(0,0,0,0.55)]">
                            {pointTitle}
                          </h4>
                        </article>
                      </a>
                    </li>
                  );
                })
              }
            </ul>

            <div
              class="relative col-span-6 w-full aspect-square rounded-2xl bg-white border border-gray-100 shadow-inner flex items-center justify-center"
            >
              <!-- Map SVG -->
              <div
                class="absolute inset-0 flex items-center justify-center p-2 opacity-60 mix-blend-multiply pointer-events-none [&>svg]:w-full [&>svg]:h-full [&>svg]:drop-shadow-xl [&>path]:!fill-secondary/20 [&>path]:!stroke-secondary/30"
                aria-hidden="true"
                set:html={mapSvg}
              />

              <!-- Map Points -->
              <ul class="absolute inset-0 m-0 list-none p-0" aria-hidden="true">
                {
                  mapPoints.map((point) => {
                    return (
                      <li>
                        <span
                          class="map-point group absolute transform -translate-x-1/2 -translate-y-1/2 focus:outline-none z-10 transition-transform duration-300 hover:z-50"
                          style={`left: ${point.x}; top: ${point.y};`}
                          data-point-id={point.id}
                        >
                          <span class="point-halo absolute -inset-2 rounded-full bg-primary/18 opacity-0 transition-all duration-300 ease-out" />
                          <span class="point-halo point-halo--delay absolute -inset-2 rounded-full bg-primary/16 opacity-0 transition-all duration-300 ease-out" />
                          <span class="point-ring absolute -inset-1 rounded-full border border-primary/35 opacity-0 transition-all duration-300 ease-out" />

                          <span class="point-core relative inline-flex h-4 w-4 rounded-full border-2 border-white bg-primary/80 shadow-[0_4px_12px_rgb(0,0,0,0.16)] ring-2 ring-primary/18 transition-all duration-300 ease-out group-hover:bg-primary" />
                        </span>
                      </li>
                    );
                  })
                }
              </ul>
            </div>

            <ul class="col-span-3 m-0 list-none space-y-3 p-0">
              {
                rightColumnPoints.map((point) => {
                  const pointTitle = point.resolvedTitle;
                  return (
                    <li>
                      <a
                        href={rewriteUrl(`/${point.resolvedSlug}`, lang)}
                        class="guide-card mobile-bento-card desktop-guide-card group relative block h-[104px] overflow-hidden rounded-[5px] border border-white/80 bg-white shadow-[0_8px_22px_rgb(15,23,42,0.10)] ring-1 ring-black/[0.03] transition-shadow duration-300 hover:shadow-[0_12px_28px_rgb(15,23,42,0.14)] focus:outline-none"
                        aria-label={pointTitle}
                        data-point-trigger={point.id}
                      >
                        <img
                          src={point.imageUrl}
                          alt={point.imageAlt}
                          aria-hidden={point.imageAlt ? undefined : "true"}
                          class="bento-card-image absolute inset-0 h-full w-full object-cover transition-[filter] duration-300"
                          loading="lazy"
                          decoding="async"
                        />
                        <span
                          class="desktop-card-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-black/18 to-transparent"
                          aria-hidden="true"
                        />
                        <article class="desktop-card-content relative z-10 flex h-full flex-col items-center justify-center p-2 text-center text-white">
                          <span
                            class="mobile-bento-icon grid size-9 place-items-center text-white/92 transition-transform duration-300"
                            aria-hidden="true"
                            set:html={
                              destinationIcons[point.id] ??
                              destinationIcons.default
                            }
                          />
                          <h4 class="mt-2 line-clamp-2 text-[0.76rem] font-semibold leading-tight drop-shadow-[0_1px_8px_rgb(0,0,0,0.55)]">
                            {pointTitle}
                          </h4>
                        </article>
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </div>
        </article>
      </aside>
    </div>
  </div>
</section>

<script>
  const initPeruGuideMapHover = () => {
    const section = document.querySelector<HTMLElement>("[data-peru-guide]");
    if (!section || section.dataset.initialized === "true") return;

    section.dataset.initialized = "true";

    const cards = section.querySelectorAll<HTMLElement>("[data-point-trigger]");
    const points = section.querySelectorAll<HTMLElement>("[data-point-id]");
    const cardsById = new Map<string, HTMLElement>();
    const pointsById = new Map<string, HTMLElement>();
    let activeId: string | null = null;

    cards.forEach((card) => {
      const id = card.dataset.pointTrigger;
      if (id) cardsById.set(id, card);
    });

    points.forEach((point) => {
      const id = point.dataset.pointId;
      if (id) pointsById.set(id, point);
    });

    const clearActive = () => {
      cards.forEach((card) => card.classList.remove("is-active"));
      points.forEach((point) => point.classList.remove("is-active"));
    };

    const setActive = (id: string) => {
      activeId = id;
      clearActive();
      const card = cardsById.get(id);
      const point = pointsById.get(id);
      card?.classList.add("is-active");
      point?.classList.add("is-active");
    };

    const clearActiveIfCurrent = (id: string) => {
      if (activeId !== id) return;
      activeId = null;
      clearActive();
    };

    cards.forEach((card) => {
      const id = card.dataset.pointTrigger;
      if (!id) return;

      card.addEventListener("pointerenter", () => setActive(id));
      card.addEventListener("focusin", () => setActive(id));
      card.addEventListener("pointerleave", () => clearActiveIfCurrent(id));
      card.addEventListener("focusout", () => clearActiveIfCurrent(id));
    });

    points.forEach((point) => {
      const id = point.dataset.pointId;
      if (!id) return;

      point.addEventListener("pointerenter", () => setActive(id));
      point.addEventListener("focusin", () => setActive(id));
      point.addEventListener("pointerleave", () => clearActiveIfCurrent(id));
      point.addEventListener("focusout", () => clearActiveIfCurrent(id));
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPeruGuideMapHover, {
      once: true,
    });
  } else {
    initPeruGuideMapHover();
  }

  document.addEventListener("astro:page-load", initPeruGuideMapHover);
</script>

<style>
  .guide-card.is-active {
    transform: translateY(-0.25rem);
    border-color: color-mix(in oklab, var(--secondary) 40%, transparent);
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.1),
      0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  .guide-card.is-active h4 {
    color: var(--secondary);
  }

  .guide-card.mobile-bento-card.is-active h4 {
    color: white;
  }

  .guide-card.desktop-guide-card.is-active {
    transform: none;
  }

  .desktop-guide-card .desktop-card-overlay {
    opacity: 0;
    transition: opacity 220ms ease;
  }

  .desktop-guide-card .desktop-card-content {
    opacity: 0;
    transform: translateY(0.35rem);
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .desktop-guide-card:hover .desktop-card-overlay,
  .desktop-guide-card:focus-visible .desktop-card-overlay,
  .desktop-guide-card.is-active .desktop-card-overlay,
  .desktop-guide-card:hover .desktop-card-content,
  .desktop-guide-card:focus-visible .desktop-card-content,
  .desktop-guide-card.is-active .desktop-card-content {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-bento-card:hover .bento-card-image,
  .mobile-bento-card:focus-visible .bento-card-image,
  .mobile-bento-card.is-active .bento-card-image {
    filter: saturate(0.98) brightness(0.9);
  }

  .mobile-bento-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 20;
    border: 1px solid rgb(255 255 255 / 0.28);
    border-radius: 5px;
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.16);
    pointer-events: none;
  }

  .mobile-bento-icon {
    position: relative;
    z-index: 0;
    line-height: 0;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--primary) 46%, white 28%);
    background: linear-gradient(
      145deg,
      color-mix(in oklab, var(--primary) 88%, white 10%),
      color-mix(in oklab, var(--primary) 82%, black 12%)
