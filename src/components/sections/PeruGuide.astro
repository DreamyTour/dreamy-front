---
import type { Lang } from "@/lib/i18n";
import type { Page } from "@/types/page";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
import mapSvg from "@/assets/svg/mapa-peru.svg?raw";
import backgroundImageMobile from "@/assets/backgroundImageMobile.webp";
import fetchApi from "@/lib/strapi";
import { getImageAlt, getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

// ====== i18n: Textos de la sección ======
const copy = {
  es: {
    title: "Un Viaje a través de la",
    titleHighlight: "Diversidad Infinita",
    description:
      "Perú no es un país, es un mundo por descubrir. Cada región es un universo único, con paisajes, culturas, gastronomía y tradiciones que desafían la imaginación.",
    description2:
      "Adéntrate en un territorio donde la geografía cambia cada cien kilómetros, donde puedes pasar de glaciares imponentes a selvas exuberantes.",
    mapTitle: "Mapa Interactivo del Perú",
    mapSubtitle: "Pasa el cursor por un punto o elige una tarjeta para explorar ese destino.",
    mapPointLabel: (name: string) => `Ver ${name} en el mapa`,
  },
  en: {
    title: "A Journey through",
    titleHighlight: "Infinite Diversity",
    description:
      "Peru is not just a country — it's a world waiting to be discovered. Each region is a unique universe of landscapes, cultures, cuisine and traditions beyond imagination.",
    description2:
      "Step into a territory where geography shifts every hundred kilometers, from towering glaciers to lush rainforests.",
    mapTitle: "Interactive Peru Map",
    mapSubtitle: "Hover a point or choose a card to explore that destination.",
    mapPointLabel: (name: string) => `View ${name} on the map`,
  },
  pt: {
    title: "Uma Viagem através da",
    titleHighlight: "Diversidade Infinita",
    description:
      "O Peru não é apenas um país — é um mundo a ser descoberto. Cada região é um universo único de paisagens, culturas, gastronomia e tradições além da imaginação.",
    description2:
      "Adentre um território onde a geografia muda a cada cem quilômetros, de glaciares imponentes a selvas exuberantes.",
    mapTitle: "Mapa Interativo do Peru",
    mapSubtitle: "Passe o cursor por um ponto ou escolha um cartão para explorar o destino.",
    mapPointLabel: (name: string) => `Ver ${name} no mapa`,
  },
} as const;

const t = copy[lang as keyof typeof copy] ?? copy.es;

const destinationSlugs = [
  "lima",
  "cusco",
  "iquitos",
  "arequipa",
  "puno",
  "ica",
  "puerto-maldonado",
] as const;

const pageSlugFilters = Object.fromEntries(
  destinationSlugs.map((slug, index) => [`filters[slug][$in][${index}]`, slug]),
);

const destinationPages = await fetchApi<Page[]>({
  endpoint: "pages",
  wrappedByKey: "data",
  locale: lang,
  query: {
    ...pageSlugFilters,
    populate: "*",
    "pagination[pageSize]": destinationSlugs.length,
  },
});

const destinationPagesBySlug = new Map(
  (Array.isArray(destinationPages) ? destinationPages : []).map((page) => [
    page.slug,
    page,
  ]),
);

// ====== Posiciones de los puntos del mapa ======
const mapPointConfig = [
  { id: "lima", slug: "lima", x: "45%", y: "65%" },
  { id: "cusco", slug: "cusco", x: "59%", y: "70%" },
  { id: "iquitos", slug: "iquitos", x: "55%", y: "25%" },
  { id: "arequipa", slug: "arequipa", x: "55%", y: "80%" },
  { id: "puno", slug: "puno", x: "68%", y: "75%" },
  { id: "ica", slug: "ica", x: "47%", y: "72%" },
  {
    id: "puerto-maldonado",
    slug: "puerto-maldonado",
    x: "68%",
    y: "67%",
  },
];

const mapPoints = mapPointConfig
  .map((point) => {
    const page = destinationPagesBySlug.get(point.slug);
    if (!page?.titulo) return null;

    const image = page.seo?.metaImage;

    return {
      ...point,
      page,
      resolvedTitle: page.titulo,
      resolvedSlug: page.slug || point.slug,
      imageUrl: image ? getImageUrl(image, "small") : backgroundImageMobile.src,
      imageAlt: image ? getImageAlt(image, page.titulo) : "",
    };
  })
  .filter((point) => point !== null);

const leftColumnPoints = mapPoints.slice(0, Math.ceil(mapPoints.length / 2));
const rightColumnPoints = mapPoints.slice(Math.ceil(mapPoints.length / 2));
---

<section
  class="w-full overflow-hidden bg-primary/5 py-16 lg:hidden"
  aria-labelledby="peru-guide-mobile-title"
>
  <div class="max-w-8xl mx-auto px-6">
    <header class="mb-10 max-w-3xl text-left md:mb-12">
      <h2
        id="peru-guide-mobile-title"
        class="relative inline-block mb-2 text-4xl font-bold leading-tight tracking-tight text-gray-900 md:text-5xl"
      >
        <span class="relative z-10">
          {t.title}
          {" "}
          <span class="text-secondary">{t.titleHighlight}</span>
        </span>
        <span
          class="absolute bottom-0 left-0 h-3 w-24 rounded-full bg-secondary/30 -z-0 blur-sm"
        ></span>
      </h2>

      <span
        class="mt-4 mb-6 flex items-center justify-start gap-3"
        aria-hidden="true"
      >
        <span
          class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary"
        ></span>
        <span class="relative h-1.5 w-12 rounded-full bg-secondary">
          <span
            class="absolute top-1/2 left-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"
          >
          </span>
        </span>
        <span
          class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary"
        ></span>
      </span>

      <p class="text-base leading-relaxed text-gray-600">{t.description}</p>
    </header>

    <ul class="grid list-none grid-cols-1 gap-4 p-0 md:grid-cols-2">
      {
        mapPoints.map((point, index) => {
          const pointTitle = point.resolvedTitle;
          const isFeatured = index === 0;

          return (
            <li class:list={[isFeatured && "md:col-span-2"]}>
              <a
                href={rewriteUrl(`/${point.resolvedSlug}`, lang)}
                class:list={[
                  "group relative overflow-hidden rounded-xl border border-white/80 bg-white shadow-[0_10px_35px_rgb(0,0,0,0.06)] transition-all duration-300 hover:-translate-y-1 hover:border-secondary/25",
                  isFeatured ? "block min-h-[210px]" : "flex min-h-[104px] p-2",
                ]}
                aria-label={pointTitle}
              >
                {isFeatured ? (
                  <article>
                    <img
                      src={point.imageUrl}
                      alt={point.imageAlt}
                      aria-hidden={point.imageAlt ? undefined : "true"}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                      width="640"
                      height="420"
                      loading="lazy"
                      decoding="async"
                    />
                    <span
                      class="absolute inset-0 bg-gradient-to-t from-black/78 via-black/30 to-black/5"
                      aria-hidden="true"
                    />
                    <span class="relative z-10 flex h-full min-h-[210px] flex-col justify-end p-5">
                      <h3 class="text-2xl font-bold leading-tight text-white">
                        {pointTitle}
                      </h3>
                    </span>
                  </article>
                ) : (
                  <>
                    <span class="relative w-[88px] shrink-0 overflow-hidden rounded-lg">
                      <img
                        src={point.imageUrl}
                        alt={point.imageAlt}
                        aria-hidden={point.imageAlt ? undefined : "true"}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                        width="96"
                        height="124"
                        loading="lazy"
                        decoding="async"
                      />
                    </span>

                    <article class="flex min-w-0 flex-1 flex-col justify-center px-3 py-2 sm:px-4">
                      <h3 class="line-clamp-2 text-[1rem] font-bold leading-tight text-gray-950 transition-colors duration-300 group-hover:text-secondary">
                        {pointTitle}
                      </h3>
                    </article>
                  </>
                )}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<section
  class="py-16 relative overflow-hidden bg-primary/5 hidden lg:block"
  aria-labelledby="peru-guide-desktop-title"
  data-peru-guide
>
  <!-- Fondo sutil usando color neutral -->
  <span
    class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px] opacity-30 pointer-events-none"
    aria-hidden="true"
  >
  </span>

  <div class="container mx-auto px-4 md:px-6 relative z-10 w-full max-w-8xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <!-- Text Content (Left) -->
      <article class="lg:col-span-5 space-y-8">
        <h2
          id="peru-guide-desktop-title"
          class="text-4xl md:text-5xl font-bold text-foreground leading-tight"
        >
          {t.title}
          {" "}
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-primary"
            >{t.titleHighlight}</span
          >
        </h2>

        <p class="text-muted-foreground font-medium leading-relaxed">
          {t.description}
        </p>
        <p class="text-muted-foreground font-medium leading-relaxed">
          {t.description2}
        </p>
      </article>

      <!-- Interactive Map Area (Right) -->
      <aside
        class="lg:col-span-7 relative w-full perspective-1000"
        aria-labelledby="peru-guide-map-title"
      >
        <article
          class="bg-white backdrop-blur-sm border border-border rounded-3xl p-8 relative shadow-lg"
        >
          <header class="mb-8">
            <h3
              id="peru-guide-map-title"
              class="text-2xl font-bold text-foreground mb-2"
            >
              {t.mapTitle}
            </h3>
            <p class="text-muted-foreground text-sm max-w-sm">
              {t.mapSubtitle}
            </p>
          </header>

          <!-- Semantic Map Container -->
          <div class="grid grid-cols-12 gap-4 items-start">
            <ul class="col-span-3 m-0 list-none space-y-3 p-0">
              {
                leftColumnPoints.map((point) => {
                  const pointTitle = point.resolvedTitle;
                  return (
                    <li>
                      <a
                        href={rewriteUrl(`/${point.resolvedSlug}`, lang)}
                        class="guide-card group block rounded-xl border border-border/80 bg-white p-2.5 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-secondary/40 hover:shadow-lg focus:outline-none"
                        aria-label={pointTitle}
                        data-point-trigger={point.id}
                      >
                        <article class="flex w-full flex-col gap-2">
                          <img
                            src={point.imageUrl}
                            alt={point.imageAlt}
                            aria-hidden={point.imageAlt ? undefined : "true"}
                            class="h-16 w-full rounded-lg object-cover"
                            loading="lazy"
                            decoding="async"
                          />
                          <h4 class="line-clamp-2 text-[0.8rem] font-semibold leading-tight text-foreground transition-colors duration-300 group-hover:text-secondary">
                            {pointTitle}
                          </h4>
                        </article>
                      </a>
                    </li>
                  );
                })
              }
            </ul>

            <div
              class="relative col-span-6 w-full aspect-square rounded-2xl bg-white border border-gray-100 shadow-inner flex items-center justify-center"
            >
              <!-- Map SVG -->
              <div
                class="absolute inset-0 flex items-center justify-center p-8 opacity-60 mix-blend-multiply pointer-events-none [&>svg]:w-full [&>svg]:h-full [&>svg]:drop-shadow-xl [&>path]:!fill-secondary/20 [&>path]:!stroke-secondary/30"
                aria-hidden="true"
                set:html={mapSvg}
              />

              <!-- Map Points -->
              <ul
                class="absolute inset-0 m-0 list-none p-0"
                aria-hidden="true"
              >
                {
                  mapPoints.map((point) => {
                    return (
                      <li>
                        <span
                          class="map-point group absolute transform -translate-x-1/2 -translate-y-1/2 focus:outline-none z-10 transition-transform duration-300 hover:z-50"
                          style={`left: ${point.x}; top: ${point.y};`}
                          data-point-id={point.id}
                        >
                          <span class="point-halo absolute -inset-2 rounded-full bg-primary/18 opacity-0 transition-all duration-300 ease-out" />
                          <span class="point-halo point-halo--delay absolute -inset-2 rounded-full bg-primary/16 opacity-0 transition-all duration-300 ease-out" />
                          <span class="point-ring absolute -inset-1 rounded-full border border-primary/35 opacity-0 transition-all duration-300 ease-out" />

                          <span class="point-core relative inline-flex h-4 w-4 rounded-full border-2 border-white bg-primary/80 shadow-[0_4px_12px_rgb(0,0,0,0.16)] ring-2 ring-primary/18 transition-all duration-300 ease-out group-hover:bg-primary" />
                        </span>
                      </li>
                    );
                  })
                }
              </ul>
            </div>

            <ul class="col-span-3 m-0 list-none space-y-3 p-0">
              {
                rightColumnPoints.map((point) => {
                  const pointTitle = point.resolvedTitle;
                  return (
                    <li>
                      <a
                        href={rewriteUrl(`/${point.resolvedSlug}`, lang)}
                        class="guide-card group block rounded-xl border border-border/80 bg-white p-2.5 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-secondary/40 hover:shadow-lg focus:outline-none"
                        aria-label={pointTitle}
                        data-point-trigger={point.id}
                      >
                        <article class="flex w-full flex-col gap-2">
                          <img
                            src={point.imageUrl}
                            alt={point.imageAlt}
                            aria-hidden={point.imageAlt ? undefined : "true"}
                            class="h-16 w-full rounded-lg object-cover"
                            loading="lazy"
                            decoding="async"
                          />
                          <h4 class="line-clamp-2 text-[0.8rem] font-semibold leading-tight text-foreground transition-colors duration-300 group-hover:text-secondary">
                            {pointTitle}
                          </h4>
                        </article>
                      </a>
                    </li>
                  );
                })
              }
            </ul>
          </div>
        </article>
      </aside>
    </div>
  </div>
</section>

<script>
  const initPeruGuideMapHover = () => {
    const section = document.querySelector<HTMLElement>("[data-peru-guide]");
    if (!section || section.dataset.initialized === "true") return;

    section.dataset.initialized = "true";

    const cards = section.querySelectorAll<HTMLElement>("[data-point-trigger]");
    const points = section.querySelectorAll<HTMLElement>("[data-point-id]");
    const cardsById = new Map<string, HTMLElement>();
    const pointsById = new Map<string, HTMLElement>();
    let activeId: string | null = null;

    cards.forEach((card) => {
      const id = card.dataset.pointTrigger;
      if (id) cardsById.set(id, card);
    });

    points.forEach((point) => {
      const id = point.dataset.pointId;
      if (id) pointsById.set(id, point);
    });

    const clearActive = () => {
      cards.forEach((card) => card.classList.remove("is-active"));
      points.forEach((point) => point.classList.remove("is-active"));
    };

    const setActive = (id: string) => {
      activeId = id;
      clearActive();
      const card = cardsById.get(id);
      const point = pointsById.get(id);
      card?.classList.add("is-active");
      point?.classList.add("is-active");
    };

    const clearActiveIfCurrent = (id: string) => {
      if (activeId !== id) return;
      activeId = null;
      clearActive();
    };

    cards.forEach((card) => {
      const id = card.dataset.pointTrigger;
      if (!id) return;

      card.addEventListener("pointerenter", () => setActive(id));
      card.addEventListener("focusin", () => setActive(id));
      card.addEventListener("pointerleave", () => clearActiveIfCurrent(id));
      card.addEventListener("focusout", () => clearActiveIfCurrent(id));
    });

    points.forEach((point) => {
      const id = point.dataset.pointId;
      if (!id) return;

      point.addEventListener("pointerenter", () => setActive(id));
      point.addEventListener("focusin", () => setActive(id));
      point.addEventListener("pointerleave", () => clearActiveIfCurrent(id));
      point.addEventListener("focusout", () => clearActiveIfCurrent(id));
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPeruGuideMapHover, {
      once: true,
    });
  } else {
    initPeruGuideMapHover();
  }

  document.addEventListener("astro:page-load", initPeruGuideMapHover);
</script>

<style>
  .guide-card.is-active {
    transform: translateY(-0.25rem);
    border-color: color-mix(in oklab, var(--secondary) 40%, transparent);
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.1),
      0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  .guide-card.is-active h4 {
    color: var(--secondary);
  }

  /* WCAG 2.5.5 – minimum 44×44px touch target.
     The visible dot is 16px; we use a transparent hit-area that fills
     the required size while keeping the visual unchanged. */
  .map-point {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
  }

  .map-point.is-active {
    z-index: 50;
  }

  .map-point.is-active .point-halo,
  .map-point:hover .point-halo,
  .map-point:focus-visible .point-halo {
    opacity: 1;
    transform: scale(1.15);
    animation: peru-guide-point-pulse 0.95s ease-out infinite;
  }

  .map-point.is-active .point-halo--delay,
  .map-point:hover .point-halo--delay,
  .map-point:focus-visible .point-halo--delay {
    animation-delay: 0.38s;
  }

  .map-point.is-active .point-ring,
  .map-point:hover .point-ring,
  .map-point:focus-visible .point-ring {
    opacity: 1;
    transform: scale(1.25);
  }

  .map-point.is-active .point-core,
  .map-point:hover .point-core,
  .map-point:focus-visible .point-core {
    background: var(--primary);
    transform: scale(1.18);
    box-shadow:
      0 7px 18px rgb(0 0 0 / 0.18),
      0 0 0 0.28rem color-mix(in oklab, var(--primary) 18%, transparent);
  }

  @keyframes peru-guide-point-pulse {
    0% {
      opacity: 0.75;
      transform: scale(0.85);
    }

    70% {
      opacity: 0.22;
      transform: scale(1.55);
    }

    100% {
      opacity: 0;
      transform: scale(1.75);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .map-point.is-active .point-halo,
    .map-point:hover .point-halo,
    .map-point:focus-visible .point-halo {
      animation: none;
      opacity: 0.7;
      transform: scale(1.25);
    }
  }
</style>
