---
import type { About } from "@/types/home";
import type { Lang } from "@/lib/i18n";
import { getImageAlt, getImageSrcSet, getImageUrl } from "@/lib/helpers";
import type { SvgComponent } from "astro/types";
import AwardIcon from "@/assets/svg/about/award.svg";
import LeafIcon from "@/assets/svg/about/leaf.svg";
import ShieldIcon from "@/assets/svg/about/shield.svg";
import StarIcon from "@/assets/svg/about/star.svg";
import UserIcon from "@/assets/svg/about/user.svg";

interface Props {
  data?: About;
  lang: Lang;
}

const { data, lang } = Astro.props;
if (!data) return;

const imagenUrl = getImageUrl(data.imagen, "small");
const imageSrcSet = getImageSrcSet(data.imagen, ["small", "medium", "large"]);
const imageAlt = getImageAlt(data.imagen, data.titulo);
const contentParagraphs = data.content
  .split(/\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
const emphasisPattern = /(DREAMY TOURS|Peru and Bolivia|responsible tourism)/;

const featureIcons = {
  award: AwardIcon,
  user: UserIcon,
  shield: ShieldIcon,
  leaf: LeafIcon,
} satisfies Record<string, SvgComponent>;

const travelerStatByLang: Record<Lang, { count: string; label: string }> = {
  en: {
    count: "+500",
    label: "Happy travelers",
  },
  es: {
    count: "+500",
    label: "Viajeros felices",
  },
  pt: {
    count: "+500",
    label: "Viajantes felizes",
  },
};

type FeatureIcon = keyof typeof featureIcons;
type Feature = {
  title: string;
  desc: string;
  icon: FeatureIcon;
  color: "green" | "yellow";
};

const features: Record<Lang, Feature[]> = {
  en: [
    {
      title: "Excellence Service",
      desc: "Highest quality standards",
      icon: "award",
      color: "green",
    },
    {
      title: "Personalized Attention",
      desc: "Customized experiences",
      icon: "user",
      color: "yellow",
    },
    {
      title: "Safety & Reliability",
      desc: "Operational excellence",
      icon: "shield",
      color: "green",
    },
    {
      title: "Responsible Tourism",
      desc: "Protecting environment",
      icon: "leaf",
      color: "yellow",
    },
  ],
  es: [
    {
      title: "Servicio de Excelencia",
      desc: "Los más altos estándares",
      icon: "award",
      color: "green",
    },
    {
      title: "Atención Personalizada",
      desc: "Experiencias a medida",
      icon: "user",
      color: "yellow",
    },
    {
      title: "Seguridad y Confianza",
      desc: "Excelencia operativa",
      icon: "shield",
      color: "green",
    },
    {
      title: "Turismo Responsable",
      desc: "Protección ambiental",
      icon: "leaf",
      color: "yellow",
    },
  ],
  pt: [
    {
      title: "Serviço de Excelência",
      desc: "Padrões de alta qualidade",
      icon: "award",
      color: "green",
    },
    {
      title: "Atenção Personalizada",
      desc: "Experiências sob medida",
      icon: "user",
      color: "yellow",
    },
    {
      title: "Segurança e Confiança",
      desc: "Excelência operacional",
      icon: "shield",
      color: "green",
    },
    {
      title: "Turismo Responsável",
      desc: "Proteção ambiental",
      icon: "leaf",
      color: "yellow",
    },
  ],
};
---

<section
  aria-labelledby="about-title"
  class="about-section content-deferred relative w-full overflow-hidden bg-[#fafqfa] py-16"
>
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-16 px-6 lg:grid-cols-2 lg:gap-24 lg:px-8"
  >
    {/* Lado de texto */}
    <div class="relative z-10 w-full max-w-2xl">
      <h2
        id="about-title"
        class="font-bold tracking-tight text-[#181311] text-4xl md:text-5xl"
      >
        {data.titulo}
      </h2>

      <div class="mt-8 space-y-4">
        {
          contentParagraphs.length > 0 ? (
            contentParagraphs.map((paragraph) => (
              <p class="text-base leading-relaxed text-[#181311]/70">
                {paragraph
                  .split(emphasisPattern)
                  .map((part) =>
                    emphasisPattern.test(part) ? (
                      <strong class="font-bold text-primary">{part}</strong>
                    ) : (
                      part
                    ),
                  )}
              </p>
            ))
          ) : (
            <p class="text-base leading-relaxed text-[#181311]/70">
              {data.content}
            </p>
          )
        }
      </div>

      {/* Features en grid 2x2 */}
      <ul class="mt-10 grid list-none gap-6 p-0 sm:grid-cols-2">
        {
          features[lang].map((act) => {
            const Icon = featureIcons[act.icon];

            return (
              <li class="flex items-start gap-4">
                <span
                  class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-sm border bg-white shadow-sm ${act.color === "green" ? "border-primary/15 text-primary" : "border-secondary/15 text-secondary"}`}
                  aria-hidden="true"
                >
                  <Icon class="h-5 w-5" aria-hidden="true" />
                </span>
                <div class="pt-0.5">
                  <h3 class="text-sm font-bold text-[#181311]">{act.title}</h3>
                  <p class="mt-1 text-xs text-[#181311]/70">{act.desc}</p>
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>

    {/* Lado de imagen */}
    {
      imagenUrl !== "/og-default.jpg" && (
        <div class="about-figure relative z-10 mx-auto w-full max-w-xl pt-4 pr-4 lg:mr-0 lg:ml-auto">
          <picture class="about-picture relative z-10 block overflow-hidden rounded-3xl border-4 border-white bg-white shadow-xl">
            <source
              media="(min-width: 768px)"
              srcset={imageSrcSet || undefined}
              sizes="(max-width: 1023px) calc(100vw - 3rem), 50vw"
            />
            <img
              src={imagenUrl}
              sizes="(max-width: 1023px) calc(100vw - 3rem), 50vw"
              alt={imageAlt}
              class="aspect-[4/3] w-full object-cover object-center"
              loading="lazy"
              decoding="async"
            />
          </picture>

          {/* Widget flotante +500 Happy Travelers */}
          <div class="absolute -bottom-6 -left-6 z-20 flex items-center gap-4 rounded-xl bg-white p-4 pr-6 shadow-xl ring-1 ring-black/5">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white">
              <StarIcon class="h-6 w-6" aria-hidden="true" />
            </span>
            <p class="flex flex-col">
              <span class="text-sm font-bold leading-tight text-[#181311]">
                {travelerStatByLang[lang].count}
              </span>
              <span class="text-xs font-medium text-[#181311]/60">
                {travelerStatByLang[lang].label}
              </span>
            </p>
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .about-picture {
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .about-picture:hover {
    transform: rotate(1.5deg) scale(1.01);
  }

  .about-figure::before {
    position: absolute;
    inset: 1rem 1rem 0 0;
    width: 100%;
    height: 100%;
    border-radius: 1.5rem;
    background: rgb(16 185 129 / 15%);
    content: "";
    transform: rotate(-3deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .about-picture {
      transition: none;
    }

    .about-picture:hover {
      transform: none;
    }
  }
</style>
