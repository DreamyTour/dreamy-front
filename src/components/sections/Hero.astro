---
import Button from "@/components/ui/button.astro";
import type { Hero } from "@/types/home";
import type { Lang } from "@/lib/i18n";
import { getImageUrl } from "@/lib/helpers";
import backgroundImageMobile from "@/assets/backgroundImageMobile.webp";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  data?: Hero;
  lang: Lang;
}

const { data, lang } = Astro.props;
if (!data) return;

const videoUrl = getImageUrl(data.backgroundVideo);

function getButtonUrl(btnUrl: string, btnLabel: string) {
  const urlLower = (btnUrl || "").toLowerCase();
  const labelLower = (btnLabel || "").toLowerCase();

  // "ver paquetes" button
  if (
    urlLower.includes("paquete") ||
    urlLower.includes("package") ||
    urlLower.includes("pacote") ||
    labelLower.includes("paquete") ||
    labelLower.includes("package") ||
    labelLower.includes("pacote")
  ) {
    return rewriteUrl("/#machupicchu", lang);
  }

  // contact button
  if (
    urlLower.includes("contact") ||
    urlLower.includes("contat") ||
    urlLower.includes("viaje") ||
    urlLower.includes("trip") ||
    urlLower.includes("viagem") ||
    labelLower.includes("contact") ||
    labelLower.includes("contat") ||
    labelLower.includes("viaje") ||
    labelLower.includes("trip") ||
    labelLower.includes("viagem") ||
    labelLower.includes("planea") ||
    labelLower.includes("plan") ||
    labelLower.includes("planeje")
  ) {
    const contactSlugMap = {
      es: "planea-tu-viaje",
      en: "plan-your-trip",
      pt: "planeje-sua-viagem",
    };
    const contactSlug = contactSlugMap[lang] || "plan-your-trip";
    return rewriteUrl(`/${contactSlug}`, lang);
  }

  return rewriteUrl(btnUrl, lang);
}
---

<section
  aria-labelledby="home-hero-title"
  class="hero-section relative isolate flex min-h-[60vh] w-full items-end overflow-hidden md:min-h-[80vh]"
>
  {/* Background media */}
  {
    videoUrl !== "/og-default.jpg" ? (
      <>
        <img
          src={backgroundImageMobile.src}
          alt=""
          aria-hidden="true"
          class="absolute inset-0 h-full w-full object-cover md:hidden"
          width={backgroundImageMobile.width}
          height={backgroundImageMobile.height}
          loading="eager"
          decoding="sync"
          fetchpriority="high"
        />
        <video
          class="hero-video absolute inset-0 hidden h-full w-full object-cover md:block"
          width={backgroundImageMobile.width}
          height={backgroundImageMobile.height}
          autoplay
          muted
          loop
          playsinline
          preload="none"
          poster={backgroundImageMobile.src}
          data-src={videoUrl}
          aria-hidden="true"
        />
      </>
    ) : (
      <img
        src={backgroundImageMobile.src}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 h-full w-full object-cover"
        width={backgroundImageMobile.width}
        height={backgroundImageMobile.height}
        loading="eager"
        decoding="sync"
        fetchpriority="high"
      />
    )
  }

  {/* Content */}
  <header
    class="relative z-10 mx-auto w-full max-w-8xl px-6 pb-32 md:pb-36 lg:pb-40"
  >

    <h1
      id="home-hero-title"
      class="hero-title mb-5 max-w-5xl font-bold leading-[1.05] tracking-tight text-white"
    >
      {data.titulo}
    </h1>

    {
      data.contenido && (
        <p class="hero-subtitle mb-8 max-w-lg leading-relaxed text-white/80">
          {data.contenido}
        </p>
      )
    }

    {
      data.button && data.button.length > 0 && (
        <nav class="hero-actions" aria-label="Acciones destacadas">
          <ul class="flex flex-wrap gap-3">
            {data.button.map((btn) => (
              <li>
                <Button
                  label={btn.label}
                  href={getButtonUrl(btn.url, btn.label)}
                  type={btn.type}
                  isExternal={btn.isExternal}
                />
              </li>
            ))}
          </ul>
        </nav>
      )
    }
  </header>
</section>

<script>
  const loadHeroVideo = () => {
    const video = document.querySelector(".hero-video");
    if (!(video instanceof HTMLVideoElement) || video.dataset.loaded === "true") {
      return;
    }

    const sourceUrl = video.dataset.src;
    const shouldLoadVideo = window.matchMedia("(min-width: 768px)").matches;
    const connection = (
      navigator as Navigator & { connection?: { saveData?: boolean } }
    ).connection;
    const saveData = connection?.saveData === true;

    if (!sourceUrl || !shouldLoadVideo || saveData) {
      return;
    }

    const source = document.createElement("source");
    source.src = sourceUrl;
    source.type = "video/mp4";
    video.append(source);
    video.dataset.loaded = "true";
    video.load();
    video.play().catch(() => {});
  };

  const scheduleHeroVideo = () => {
    const requestIdleCallback =
      "requestIdleCallback" in window
        ? (window.requestIdleCallback as (
            callback: IdleRequestCallback,
            options?: IdleRequestOptions,
          ) => number)
        : undefined;

    if (requestIdleCallback) {
      requestIdleCallback(loadHeroVideo, { timeout: 1600 });
      return;
    }

    window.setTimeout(loadHeroVideo, 900);
  };

  scheduleHeroVideo();
</script>

<style>
  .hero-section::before,
  .hero-section::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero-subtitle {
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
  }

  /* Entry animations */
  .hero-badge,
  .hero-title,
  .hero-subtitle,
  .hero-actions {
    animation: hero-fade-up 0.8s ease-out both;
  }
  .hero-title {
    animation-delay: 0.15s;
  }
  .hero-subtitle {
    animation-delay: 0.3s;
  }
  .hero-actions {
    animation-delay: 0.45s;
  }

  @media (max-width: 767px) {
    .hero-badge,
    .hero-title,
    .hero-subtitle,
    .hero-actions {
      animation: none;
    }
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
