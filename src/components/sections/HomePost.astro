---
import fetchApi from "@/lib/strapi";
import type { Blog } from "@/types/blog";
import type { Lang } from "@/lib/i18n";
import type { sectionCardPost } from "@/types/home";
import { useTranslations } from "@/i18n/ui";
import CardPost from "@/components/ui/CardPost.astro";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  data: sectionCardPost;
  lang: Lang;
}

const { data, lang } = Astro.props;

const t = useTranslations(lang);

if (!data || !data.titulo) return;

// Fetch posts más recientes
const posts = await fetchApi<Blog[]>({
  endpoint: "posts",
  wrappedByKey: "data",
  locale: lang,
  query: {
    sort: "publishedAt:desc",
    "pagination[limit]": 5,
    populate: "*",
  },
});

const postsList = posts && Array.isArray(posts) ? posts : [];
---

{
  postsList.length > 0 && (
    <section
      aria-labelledby="home-posts-title"
      class="content-deferred content-deferred--tall w-full bg-primary/5 py-16"
    >
      <div class="max-w-8xl mx-auto px-6">
        {/* Header */}
        <header class="mb-12 md:mb-16 max-w-4xl mx-auto text-center">
          {data.titulo && (
            <h2
              id="home-posts-title"
              class="text-4xl md:text-5xl font-bold leading-tight tracking-tight text-foreground mb-6 relative inline-block"
            >
              <span class="relative z-10">{data.titulo}</span>
            </h2>
          )}
          <div
            class="flex items-center justify-center gap-3 mt-4"
            aria-hidden="true"
          >
            <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary" />
            <div class="w-12 h-1.5 bg-secondary rounded-full relative">
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-background rounded-full" />
            </div>
            <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary" />
          </div>
          {data.description && (
            <p class="mt-6 text-muted-foreground max-w-2xl mx-auto">
              {data.description}
            </p>
          )}
        </header>

        {/* ── Editorial grid ──────────────────────────────────────────
            Mobile  : stacked column
            Tablet  : 2-col uniform grid
            Desktop : [  FEATURED (tall left)  ] [ Card 2 (top-right) ]
                      [ Card 3 ] [ Card 4 ] [ Card 5 ]
        ────────────────────────────────────────────────────────────── */}
        <ul class="posts-mosaic list-none p-0 m-0">
          {postsList.slice(0, 1).map((blog: Blog) => (
            <li class="posts-mosaic__featured">
              <CardPost blog={blog} lang={lang} isFeatured={true} showDescription={true} />
            </li>
          ))}
          {postsList.slice(1, 2).map((blog: Blog) => (
            <li class="posts-mosaic__secondary">
              <CardPost blog={blog} lang={lang} showDescription={true} />
            </li>
          ))}
          {postsList.slice(2, 5).map((blog: Blog) => (
            <li class="posts-mosaic__bottom">
              <CardPost blog={blog} lang={lang} />
            </li>
          ))}
        </ul>

        {/* Botón ver más */}
        <div class="mt-12 flex justify-center">
          <a
            href={rewriteUrl("/blog", lang)}
            aria-label={t("aria.verMasSeccion")}
            class="group inline-flex items-center justify-center gap-2 rounded-full bg-secondary px-6 py-3 text-sm font-semibold text-white shadow-md shadow-secondary/20 transition-all duration-300 hover:-translate-y-0.5 hover:bg-secondary/90 hover:shadow-lg hover:shadow-secondary/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/40 focus-visible:ring-offset-2"
          >
            {t("section.verTodoArticulos")}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )
}

<style>
  /* ── Posts mosaic layout ─────────────────────────────────────── */
  .posts-mosaic {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  /* Every cell is a flex column so h-full propagates into CardPost */
  .posts-mosaic__featured,
  .posts-mosaic__secondary,
  .posts-mosaic__bottom {
    display: flex;
    flex-direction: column;
  }

  /* Pierce CardPost scope: article must fill the li cell */
  .posts-mosaic__featured :global(article),
  .posts-mosaic__secondary :global(article),
  .posts-mosaic__bottom :global(article) {
    flex: 1;
    height: 100%;
  }

  /* Tablet: 2-col grid — featured spans 2 cols, rest 1 each */
  @media (min-width: 768px) {
    .posts-mosaic {
      grid-template-columns: repeat(2, 1fr);
    }

    .posts-mosaic__featured {
      grid-column: 1 / -1;
    }

    .posts-mosaic__bottom:nth-child(5) {
      grid-column: 1 / -1;
    }
  }

  /* Desktop: editorial mosaic
     Row 1: [featured tall — col 1-2] [secondary — col 3]
     Row 2: [card] [card] [card]
  */
  @media (min-width: 1024px) {
    .posts-mosaic {
      grid-template-columns: repeat(3, 1fr);
      /* Row 1 height is driven by content; both cells stretch to match */
      grid-template-rows: auto auto;
      align-items: stretch;
    }

    /* Featured: spans 2 columns, row 1 */
    .posts-mosaic__featured {
      grid-column: 1 / 3;
      grid-row: 1;
    }

    /* Secondary: right column, row 1 — same row height as featured */
    .posts-mosaic__secondary {
      grid-column: 3;
      grid-row: 1;
    }

    /* Override CardPost's fixed lg:h-[360px] so the grid row controls height.
       Specificity of this selector (0-2-1) beats Tailwind class (0-1-0). */
    .posts-mosaic__featured :global(article > a),
    .posts-mosaic__secondary :global(article > a) {
      height: 100%;
      min-height: 0;
    }

    /* Bottom 3: each takes 1 col in row 2, equal height */
    .posts-mosaic__bottom {
      grid-row: 2;
    }

    .posts-mosaic__bottom:nth-child(3) { grid-column: 1; }
    .posts-mosaic__bottom:nth-child(4) { grid-column: 2; }
    .posts-mosaic__bottom:nth-child(5) { grid-column: 3; }

    /* Pierce CardPost scope for bottom cards — enforce equal height */
    .posts-mosaic__bottom :global(article > a) {
      height: 100%;
    }
  }
</style>

