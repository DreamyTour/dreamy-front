---
import fetchApi from "@/lib/strapi";
import type { Blog } from "@/types/blog";
import type { Lang } from "@/lib/i18n";
import type { sectionCardPost } from "@/types/home";
import { useTranslations } from "@/i18n/ui";
import CardPostHome from "@/components/ui/CardPostHome.astro";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  data: sectionCardPost;
  lang: Lang;
}

const { data, lang } = Astro.props;

const t = useTranslations(lang);

if (!data || !data.titulo) return;

const posts = await fetchApi<Blog[]>({
  endpoint: "posts",
  wrappedByKey: "data",
  locale: lang,
  query: {
    sort: "publishedAt:desc",
    "pagination[limit]": 5,
    populate: "*",
  },
});

const postsList = posts && Array.isArray(posts) ? posts : [];
---

{
  postsList.length > 0 && (
    <section
      aria-labelledby="home-posts-title"
      class="content-deferred content-deferred--tall w-full bg-primary/5 py-16"
    >
      <div class="max-w-8xl mx-auto px-6">
        <header class="mb-12 max-w-4xl mx-auto text-center md:mb-16">
          {data.titulo && (
            <h2
              id="home-posts-title"
              class="relative mb-6 inline-block text-4xl font-bold leading-tight tracking-tight text-foreground md:text-5xl"
            >
              <span class="relative z-10">{data.titulo}</span>
            </h2>
          )}
          <div
            class="mt-4 flex items-center justify-center gap-3"
            aria-hidden="true"
          >
            <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary" />
            <div class="relative h-1.5 w-12 rounded-full bg-secondary">
              <div class="absolute top-1/2 left-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-background" />
            </div>
            <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary" />
          </div>
          {data.description && (
            <p class="mx-auto mt-6 max-w-2xl text-muted-foreground">
              {data.description}
            </p>
          )}
        </header>

        <ul class="posts-mosaic m-0 list-none p-0">
          {postsList.slice(0, 1).map((blog: Blog) => (
            <li class="posts-mosaic__featured">
              <CardPostHome
                blog={blog}
                lang={lang}
              />
            </li>
          ))}
          {postsList.slice(1, 2).map((blog: Blog) => (
            <li class="posts-mosaic__secondary">
              <CardPostHome blog={blog} lang={lang} variant="tall" />
            </li>
          ))}
          {postsList.slice(2, 5).map((blog: Blog) => (
            <li class="posts-mosaic__bottom">
              <CardPostHome blog={blog} lang={lang} />
            </li>
          ))}
        </ul>

        <div class="mt-12 flex justify-center">
          <a
            href={rewriteUrl("/blog", lang)}
            aria-label={t("aria.verMasSeccion")}
            class="group inline-flex items-center justify-center gap-2 rounded-full bg-secondary px-6 py-3 text-sm font-semibold text-white shadow-md shadow-secondary/20 transition-all duration-300 hover:-translate-y-0.5 hover:bg-secondary/90 hover:shadow-lg hover:shadow-secondary/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/40 focus-visible:ring-offset-2"
          >
            {t("section.verTodoArticulos")}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )
}

<style>
  .posts-mosaic {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem;
  }

  .posts-mosaic__featured,
  .posts-mosaic__secondary,
  .posts-mosaic__bottom {
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .posts-mosaic {
      grid-template-columns: repeat(2, 1fr);
    }

    .posts-mosaic__featured {
      grid-column: 1 / -1;
    }

    .posts-mosaic__bottom:nth-child(5) {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .posts-mosaic {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      grid-template-rows: repeat(2, minmax(250px, 1fr));
      align-items: stretch;
    }

    .posts-mosaic__featured {
      grid-column: 1 / 3;
      grid-row: 1;
    }

    .posts-mosaic__secondary {
      grid-column: 3 / 5;
      grid-row: 1 / 3;
    }

    .posts-mosaic__bottom {
      grid-row: 2;
    }

    .posts-mosaic__bottom:nth-child(3) {
      grid-column: 1;
    }

    .posts-mosaic__bottom:nth-child(4) {
      grid-column: 2;
    }

    .posts-mosaic__bottom:nth-child(5) {
      display: none;
    }

  }
</style>
