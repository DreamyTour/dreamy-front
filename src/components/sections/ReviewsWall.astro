---
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import TripAdvisorLogo from "@/assets/certification/certificado-tripadvisor.svg?url";
import LocationPinIcon from "@/assets/svg/reviews/location-pin.svg";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type ReviewSource = "tripadvisor" | "google";
type Review = {
  source: ReviewSource;
  author: string;
  title?: string;
  text: string;
  rating: number;
  date?: string;
  url?: string;
};
type SourceSummary = {
  rating: number;
  reviewCount: number;
  url: string;
};

const sourceOrder: ReviewSource[] = ["tripadvisor", "google"];
const sourceLabels = {
  tripadvisor: {
    name: "Tripadvisor",
    panelClass: "review-source-panel--tripadvisor",
    cardClass: "review-card--tripadvisor",
  },
  google: {
    name: "Google Reviews",
    panelClass: "review-source-panel--google",
    cardClass: "review-card--google",
  },
} as const;

const reviewCopy = {
  es: {
    brandTour: "Dreamy Tours",
    basedOn: "Basado en",
    reviews: "opiniones",
    of: "De 5 estrellas",
    full: "Ver la opinion completa",
  },
  en: {
    brandTour: "Dreamy Tours",
    basedOn: "Based on",
    reviews: "reviews",
    of: "Out of 5 stars",
    full: "Read full review",
  },
  pt: {
    brandTour: "Dreamy Tours",
    basedOn: "Baseado em",
    reviews: "avaliacoes",
    of: "De 5 estrelas",
    full: "Ver avaliacao completa",
  },
};

const reviewLabels =
  reviewCopy[lang as keyof typeof reviewCopy] || reviewCopy.es;
const tripadvisorUrl =
  "https://www.tripadvisor.com.pe/Attraction_Review-g294314-d17325827-Reviews-Dreamy_Tours-Cusco_Cusco_Region.html";
const googleUrl =
  "https://www.google.com/maps/place/Dreamy+Tours/@-13.524429,-71.9506049,1057m/data=!3m2!1e3!4b1!4m6!3m5!1s0x916dd587b52c49c5:0xdaa973fe4585e28a!8m2!3d-13.5244342!4d-71.94803!16s%2Fg%2F11fkv9g6rk";

const sourceSummaries: Record<ReviewSource, SourceSummary> = {
  tripadvisor: {
    rating: 4.9,
    reviewCount: 12910,
    url: tripadvisorUrl,
  },
  google: {
    rating: 4.9,
    reviewCount: 552,
    url: googleUrl,
  },
};

const reviews: Review[] = [
  {
    source: "tripadvisor",
    author: "Cliente Tripadvisor",
    title: "Estuvo todo excelente",
    text: "Fue una experiencia increible. Mucho mas de lo que imaginaba. El guia llevo un ritmo acorde para llegar bien, la comida fue variada y abundante. Todo de 10.",
    rating: 5,
    date: "2026-05-04",
    url: "https://www.tripadvisor.com.pe/ShowUserReviews-g294318-d26448780-r1059010011-Inca_Trail_Machu_Picchu_4_Days-Machu_Picchu_Sacred_Valley_Cusco_Region.html",
  },
  {
    source: "tripadvisor",
    author: "Cliente Tripadvisor",
    title: "Excelente experiencia visitando Valle Sagrado y Machu Picchu",
    text: "Excelente agencia. Super responsables, puntuales y serviciales.",
    rating: 5,
    date: "2026-05-04",
    url: "https://www.tripadvisor.com.pe/ShowUserReviews-g294314-d23904536-r1059015163-2_Day_Guided_Tour_to_Sacred_Valley_and_Machu_Picchu_by_Train-Cusco_Cusco_Regio.html",
  },
  {
    source: "tripadvisor",
    author: "Cliente Tripadvisor",
    title: "Experiencia muy gratificante",
    text: "Fue una experiencia unica, la atencion fue genial, muy amigables y cumplieron con todo. Me voy satisfecho.",
    rating: 5,
    date: "2026-04-29",
    url: "https://www.tripadvisor.com.pe/ShowUserReviews-g294314-d28270483-r1058317381-5_day_adventure_Trek_Salkantay_to_Machu_Picchu-Cusco_Cusco_Region.html",
  },
  {
    source: "google",
    author: "Victor Jean Pierrr Parimango Alvarez",
    text: "Nuestro viaje familiar a Cusco y Machu Picchu con Dreamy Tours fue increible. La agencia organizo todo perfectamente: traslados puntuales, un guia excelente y recomendaciones geniales.",
    rating: 5,
    date: "2025-09-15",
    url: googleUrl,
  },
  {
    source: "google",
    author: "Johanna Nava Hayden",
    text: "Contratamos la agencia desde Argentina, y de principio a fin la experiencia fue excelente. Muy buena atencion, siempre estan en contacto para lo que necesites.",
    rating: 5,
    date: "2024-06-15",
    url: googleUrl,
  },
  {
    source: "google",
    author: "Carla Miguez",
    text: "Me gusto mucho el tour, pude disfrutar hermosos paisajes y aprender sobre la forma de vida local. Excelente guia y buen manejo de los horarios.",
    rating: 5,
    date: "2022-06-15",
    url: googleUrl,
  },
];

const formatDate = (date: string | undefined) => {
  if (!date) return "";
  const parsed = new Date(date);
  if (Number.isNaN(parsed.getTime())) return "";
  return new Intl.DateTimeFormat(lang, {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(parsed);
};

const getSourceReviews = (source: ReviewSource) =>
  reviews
    .filter((review) => review.source === source)
    .sort((a, b) => Date.parse(b.date || "") - Date.parse(a.date || ""))
    .slice(0, 3);
---

<section
  class="reviews-wall bg-white py-14 sm:py-16"
  aria-labelledby="reviews-wall-title"
>
  <div class="mx-auto max-w-8xl px-6">
    <header class="mb-12 max-w-3xl">
      <p
        class="mb-4 flex w-fit items-center gap-2 rounded-full bg-secondary/15 px-3 py-1 text-sm font-semibold text-secondary"
      >
        <LocationPinIcon class="h-4 w-4" aria-hidden="true" />
        {t("reviews.kicker")}
      </p>
      <h2
        id="reviews-wall-title"
        class="relative mb-2 inline-block text-4xl font-bold leading-tight tracking-tight text-gray-900 md:text-5xl"
      >
        <span class="relative z-10">{t("reviews.title")}</span>
        <span
          class="absolute bottom-0 left-0 -z-0 h-3 w-24 rounded-full bg-secondary/30 blur-sm"
        ></span>
      </h2>
      <div
        class="mb-6 mt-4 flex items-center justify-start gap-3"
        aria-hidden="true"
      >
        <div class="h-px w-16 bg-gradient-to-r from-transparent to-secondary">
        </div>
        <div class="relative h-1.5 w-12 rounded-full bg-secondary">
          <div
            class="absolute left-1/2 top-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"
          >
          </div>
        </div>
        <div class="h-px w-16 bg-gradient-to-l from-transparent to-secondary">
        </div>
      </div>
      <p class="text-base leading-relaxed text-gray-600">
        {t("reviews.description")}
      </p>
    </header>
    <div class="reviews-rows">
      {
        sourceOrder.map((source) => {
          const summary = sourceSummaries[source];
          const label = sourceLabels[source];

          return (
            <div class={`review-source-row review-source-row--${source}`}>
              <a
                class={`review-source-panel ${label.panelClass}`}
                href={summary.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span
                  class={`review-brand-logo review-brand-logo--${source}`}
                  role="img"
                  aria-label={label.name}
                >
                  {source === "google" ? (
                    <>
                      <span class="g-blue" aria-hidden="true">
                        G
                      </span>
                      <span class="g-red" aria-hidden="true">
                        o
                      </span>
                      <span class="g-yellow" aria-hidden="true">
                        o
                      </span>
                      <span class="g-blue" aria-hidden="true">
                        g
                      </span>
                      <span class="g-green" aria-hidden="true">
                        l
                      </span>
                      <span class="g-red" aria-hidden="true">
                        e
                      </span>
                      <span class="review-google-word" aria-hidden="true">
                        Reviews
                      </span>
                    </>
                  ) : (
                    <img
                      class="tripadvisor-logo-img"
                      src={TripAdvisorLogo}
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </span>
                <span class="review-source-tour">{reviewLabels.brandTour}</span>
                <span class="review-score-line">
                  <span class="review-score">{summary.rating.toFixed(1)}</span>
                  <span class="review-score-descriptor">{reviewLabels.of}</span>
                  <span
                    class={`review-stars review-stars--${source}`}
                    role="img"
                    aria-label={`${summary.rating} / 5`}
                  >
                    {Array.from({ length: 5 }).map((_, index) => (
                      <span
                        aria-hidden="true"
                        class:list={{
                          "is-filled": index < Math.round(summary.rating),
                        }}
                      />
                    ))}
                  </span>
                </span>
                <span class="review-total">
                  {reviewLabels.basedOn}{" "}
                  {new Intl.NumberFormat(lang).format(summary.reviewCount)}{" "}
                  {reviewLabels.reviews}
                </span>
              </a>
              <div class="review-row-cards">
                {getSourceReviews(source).map((review) => (
                  <article class={`review-card ${label.cardClass}`}>
                    <span
                      class={`review-platform-badge review-platform-badge--${source}`}
                      role="img"
                      aria-label={label.name}
                    >
                      {source === "google" ? (
                        <span class="g-blue" aria-hidden="true">
                          G
                        </span>
                      ) : (
                        <img
                          class="review-platform-badge-img"
                          src={TripAdvisorLogo}
                          alt=""
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                    </span>
                    <div class="review-card__header">
                      <span
                        class="review-avatar review-avatar--initials"
                        aria-hidden="true"
                      >
                        {review.author.slice(0, 2).toUpperCase()}
                      </span>
                      <div class="review-card__author">
                        <h3 class="review-author">{review.author}</h3>
                        <p class="review-date">{formatDate(review.date)}</p>
                      </div>
                    </div>
                    <p class="review-title">{review.title || label.name}</p>
                    <span
                      class={`review-stars review-stars--${source}`}
                      role="img"
                      aria-label={`${review.rating} / 5`}
                    >
                      {Array.from({ length: 5 }).map((_, index) => (
                        <span
                          aria-hidden="true"
                          class:list={{
                            "is-filled": index < Math.round(review.rating),
                          }}
                        />
                      ))}
                    </span>
                    <p class="review-text">{review.text}</p>
                    {review.url && (
                      <a
                        class="review-link"
                        href={review.url}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {reviewLabels.full}
                      </a>
                    )}
                  </article>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style is:global>
  .reviews-wall {
    position: relative;
    overflow: clip;
    background: linear-gradient(
      180deg,
      #fff 0%,
      color-mix(in oklab, var(--muted) 68%, white) 100%
    );
    color: var(--foreground);
  }

  .reviews-wall::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(
        color-mix(in oklab, var(--border) 32%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in oklab, var(--border) 32%, transparent) 1px,
        transparent 1px
      );
    background-size: 42px 42px;
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      black 22%,
      black 72%,
      transparent 100%
    );
    opacity: 0.4;
  }

  .reviews-wall > div {
    position: relative;
  }

  .reviews-rows {
    display: grid;
    gap: 1.2rem;
    container-type: inline-size;
  }

  .review-source-row {
    display: grid;
    grid-template-columns: minmax(16rem, 22rem) minmax(0, 1fr);
    gap: 1.15rem;
    align-items: stretch;
  }

  .review-source-panel {
    position: relative;
    display: flex;
    min-height: 18rem;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--border) 74%, white);
    border-radius: 8px;
    background:
      linear-gradient(
        145deg,
        rgba(255, 255, 255, 0.98),
        rgba(255, 255, 255, 0.9)
      ),
      radial-gradient(
        circle at 16% 10%,
        color-mix(in oklab, var(--secondary) 14%, transparent),
        transparent 34%
      );
    padding: 2rem 1.8rem;
    color: inherit;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.07);
    text-decoration: none;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .review-source-panel::before {
    content: "";
    position: absolute;
    inset-block: 1rem;
    inset-inline-start: 0;
    width: 0.22rem;
    border-radius: 999px;
    background: var(--secondary);
  }

  .review-source-panel--tripadvisor::before {
    background: #19c89c;
  }

  .review-source-panel--google::before {
    background: linear-gradient(
      180deg,
      #4285f4 0%,
      #34a853 48%,
      #fbbc04 72%,
      #ea4335 100%
    );
  }

  .review-source-panel:hover .review-brand-logo {
    transform: translateY(-2px);
  }

  .review-source-panel:hover {
    border-color: color-mix(in oklab, var(--secondary) 44%, var(--border));
    box-shadow: 0 22px 52px rgba(15, 23, 42, 0.1);
    transform: translateY(-1px);
  }

  .review-brand-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.62rem;
    width: max-content;
    max-width: 100%;
    font-weight: 900;
    letter-spacing: 0;
    transition: transform 180ms ease;
  }

  .review-brand-logo--tripadvisor {
    display: block;
    width: min(100%, 14.6rem);
  }

  .tripadvisor-logo-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .review-brand-logo--google {
    gap: 0;
    font-size: clamp(1.95rem, 3vw, 2.75rem);
    line-height: 1;
  }

  .review-google-word {
    margin-left: 0.55rem;
    align-self: flex-end;
    padding-bottom: 0.18rem;
    color: #5f6368;
    font-size: 1.03rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .g-blue {
    color: #4285f4;
  }

  .g-red {
    color: #ea4335;
  }

  .g-yellow {
    color: #fbbc04;
  }

  .g-green {
    color: #34a853;
  }

  .review-source-tour {
    margin-top: 1.75rem;
    font-size: 1rem;
    font-weight: 800;
    color: color-mix(in oklab, var(--foreground) 84%, white);
  }

  .review-score-line {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.7rem;
    flex-wrap: wrap;
  }

  .review-score {
    font-size: 2.95rem;
    font-weight: 900;
    line-height: 0.95;
    color: color-mix(in oklab, var(--foreground) 80%, black);
  }

  .review-score-descriptor {
    max-width: 4rem;
    font-size: 0.95rem;
    line-height: 1.05;
    color: color-mix(in oklab, var(--foreground) 62%, white);
  }

  .review-total {
    margin-top: 0.65rem;
    font-size: 0.95rem;
    color: color-mix(in oklab, var(--foreground) 62%, white);
  }

  .review-link {
    color: var(--secondary);
  }

  .review-row-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .review-card {
    position: relative;
    min-height: 18rem;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--border) 70%, white);
    border-radius: 8px;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.98),
        color-mix(in oklab, var(--muted) 42%, white)
      ),
      white;
    padding: 1.35rem 1.35rem 3rem;
    opacity: 0;
    transform: translateY(14px);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
    animation: review-rise 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .review-card::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    height: 0.22rem;
    background: var(--secondary);
    opacity: 0.95;
  }

  .review-card--tripadvisor::before {
    background: #19c89c;
  }

  .review-card--google::before {
    background: linear-gradient(
      90deg,
      #4285f4 0%,
      #34a853 38%,
      #fbbc04 66%,
      #ea4335 100%
    );
  }

  .review-card:hover {
    border-color: color-mix(in oklab, var(--secondary) 45%, var(--border));
    box-shadow: 0 22px 46px rgba(15, 23, 42, 0.1);
    transform: translateY(-3px);
  }

  .review-card:nth-child(2) {
    animation-delay: 70ms;
  }

  .review-card:nth-child(3) {
    animation-delay: 140ms;
  }

  .review-card__header {
    display: flex;
    align-items: center;
    gap: 0.78rem;
    padding-right: 2.8rem;
  }

  .review-card__author {
    min-width: 0;
  }

  .review-avatar {
    display: inline-flex;
    width: 3.85rem;
    height: 3.85rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    object-fit: cover;
    background: linear-gradient(
      135deg,
      color-mix(in oklab, var(--primary) 28%, white),
      color-mix(in oklab, var(--secondary) 22%, white)
    );
    color: var(--primary);
    font-size: 1.15rem;
    font-weight: 800;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.78),
      0 8px 18px rgba(15, 23, 42, 0.08);
  }

  .review-avatar--initials {
    color: color-mix(in oklab, var(--primary) 80%, black);
  }

  .review-author {
    position: relative;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 1.02rem;
    font-weight: 800;
    color: color-mix(in oklab, var(--foreground) 84%, black);
  }

  .review-author::before {
    content: "";
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    margin-right: 0.25rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--muted-foreground) 34%, white);
    box-shadow:
      0 0.62rem 0 -0.16rem
        color-mix(in oklab, var(--muted-foreground) 34%, white),
      0.54rem 0.62rem 0 -0.16rem
        color-mix(in oklab, var(--muted-foreground) 34%, white);
  }

  .review-date {
    margin-top: 0.2rem;
    font-size: 0.82rem;
    font-style: italic;
    color: color-mix(in oklab, var(--foreground) 54%, white);
  }

  .review-title {
    margin-top: 1.15rem;
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1.25;
    color: color-mix(in oklab, var(--foreground) 84%, black);
  }

  .review-stars {
    display: flex;
    align-items: center;
    gap: 0.28rem;
    margin-top: 0.65rem;
    margin-bottom: 0.8rem;
    line-height: 1;
  }

  .review-stars--tripadvisor span {
    width: 0.82rem;
    height: 0.82rem;
    border-radius: 999px;
    border: 1px solid #21c89d;
    background: transparent;
  }

  .review-stars--tripadvisor span.is-filled {
    background: #21c89d;
  }

  .review-stars--google span {
    width: 1rem;
    height: 1rem;
    background: color-mix(in oklab, #fbbc04 18%, var(--border));
    clip-path: polygon(
      50% 0%,
      61% 34%,
      98% 34%,
      68% 55%,
      79% 90%,
      50% 68%,
      21% 90%,
      32% 55%,
      2% 34%,
      39% 34%
    );
  }

  .review-stars--google span.is-filled {
    background: #fbbc04;
  }

  .review-text {
    display: -webkit-box;
    min-height: 6.95rem;
    overflow: clip;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 5;
    line-clamp: 5;
    font-size: 0.97rem;
    line-height: 1.5;
    color: color-mix(in oklab, var(--foreground) 62%, white);
  }

  .review-link {
    position: absolute;
    right: 1.25rem;
    bottom: 1.05rem;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .review-link:hover {
    transform: translateX(-0.1rem);
  }

  .review-platform-badge {
    position: absolute;
    top: 0.62rem;
    right: 0.62rem;
    display: inline-flex;
    width: 2.15rem;
    height: 2.15rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 900;
    box-shadow: 0 8px 16px rgba(15, 23, 42, 0.08);
  }

  .review-platform-badge--tripadvisor {
    width: 4.15rem;
    height: auto;
    min-height: 2.15rem;
    padding: 0.28rem 0.35rem;
    border-radius: 999px;
    background: white;
    box-shadow:
      inset 0 0 0 1px color-mix(in oklab, var(--border) 65%, white),
      0 8px 16px rgba(15, 23, 42, 0.08);
  }

  .review-platform-badge-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .review-platform-badge--google {
    background: white;
    color: #4285f4;
    font-size: 1.28rem;
    box-shadow:
      inset 0 0 0 1px color-mix(in oklab, var(--border) 70%, white),
      0 8px 16px rgba(15, 23, 42, 0.08);
  }

  @keyframes review-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

