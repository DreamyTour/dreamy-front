---
import BookingForm from "@/components/tours/BookingForm";
import type { Lang } from "@/lib/i18n";
import { getIncaTrailBookingConfig } from "@/lib/incaTrailBooking";
import {
  fetchIncaTrailTickets,
  type TicketsByDate,
} from "@/lib/incaTrailAvailability";

interface Props {
  tourId: string | number;
  tourName: string;
  basePrice?: number;
  tourSlug?: string;
  lang: Lang;
}

const { tourId, tourName, basePrice = 620.0, tourSlug, lang } = Astro.props;
const now = new Date();
const year = now.getFullYear();
const initialMonth = now.getMonth() + 1;
const bookingConfig = getIncaTrailBookingConfig(tourSlug);
const initialRoad = bookingConfig?.road ?? "1";
const lockedRoads = bookingConfig ? [bookingConfig.road] : undefined;
const selectionDurationDays = bookingConfig?.durationDays ?? 1;

let initialTickets: TicketsByDate = {};

try {
  initialTickets = await fetchIncaTrailTickets({
    road: initialRoad,
    year,
    month: initialMonth,
  });
} catch {
  initialTickets = {};
}
---

<BookingForm
  client:load
  tourId={tourId}
  tourName={tourName}
  basePrice={basePrice}
  lang={lang}
  year={year}
  initialMonth={initialMonth}
  initialRoad={initialRoad}
  allowedRoads={lockedRoads}
  selectionDurationDays={selectionDurationDays}
  initialTickets={initialTickets}
/>
