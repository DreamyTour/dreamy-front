<div
  class="mb-8 flex w-full flex-col overflow-hidden rounded-sm border border-gray-100 bg-white font-sans shadow-lg"
  aria-hidden="true"
>
  <div class="bg-[#3a3a3a] py-4 text-center">
    <div class="mx-auto h-7 w-28 rounded bg-white/20"></div>
  </div>

  <div class="flex flex-col items-center px-6 py-6 md:px-8">
    <div class="mb-3 h-6 w-3/4 rounded bg-gray-200"></div>
    <div class="mb-6 h-8 w-32 rounded bg-[#8f3513]/15"></div>
    <div class="mb-6 h-px w-full bg-gray-200"></div>
    <div class="mb-8 h-4 w-52 rounded bg-gray-200"></div>

    <div class="mb-8 w-full">
      <div class="mb-4 flex items-center gap-3">
        <div class="h-6 w-6 rounded-full bg-[#db5b24]/25"></div>
        <div class="h-5 w-36 rounded bg-gray-200"></div>
      </div>

      <div class="overflow-hidden rounded-lg border border-gray-200 bg-white">
        <div
          class="grid grid-cols-1 gap-3 border-b border-gray-100 bg-[#faf8f5] p-4 sm:grid-cols-2"
        >
          <div class="h-10 rounded-sm bg-gray-200"></div>
          <div class="h-10 rounded-sm bg-gray-200"></div>
        </div>
        <div class="flex items-center justify-between px-3 py-3">
          <div class="h-9 w-9 rounded-full bg-gray-100"></div>
          <div class="h-5 w-32 rounded bg-gray-200"></div>
          <div class="h-9 w-9 rounded-full bg-gray-100"></div>
        </div>
        <div class="grid grid-cols-7 gap-px bg-gray-100">
          {
            Array.from({ length: 35 }).map(() => (
              <div class="h-14 bg-gray-50" />
            ))
          }
        </div>
      </div>
    </div>

    <div class="mb-8 w-full">
      <div class="mb-4 flex items-center gap-3">
        <div class="h-6 w-6 rounded-full bg-[#db5b24]/25"></div>
        <div class="h-5 w-28 rounded bg-gray-200"></div>
      </div>
      <div class="mt-6 flex items-center justify-between">
        <div class="h-6 w-10 rounded bg-gray-200"></div>
        <div class="flex items-center gap-4">
          <div class="h-10 w-10 rounded-full bg-gray-100"></div>
          <div class="h-6 w-5 rounded bg-gray-200"></div>
          <div class="h-10 w-10 rounded-full bg-gray-100"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-100 bg-[#f9f9f9] p-6 md:p-8">
    <div class="mb-3 flex items-center justify-between">
      <div class="h-6 w-28 rounded bg-gray-200"></div>
      <div class="h-7 w-24 rounded bg-gray-200"></div>
    </div>
    <div class="mb-6 flex items-center justify-between">
      <div class="h-5 w-36 rounded bg-gray-200"></div>
      <div class="h-5 w-20 rounded bg-gray-200"></div>
    </div>
    <div class="h-14 w-full rounded-sm bg-[#20b26b]/30"></div>
  </div>
</div>
