---
import { countriesWithPhoneCode } from "@/data/countries";

interface Props {
  tourName?: string;
  lang?: "es" | "en" | "pt";
}

const { tourName, lang = "es" } = Astro.props;

const contactCopy = {
  es: {
    title: "Reserva tu aventura",
    whatsapp: "WhatsApp Directo",
    divider: "o por correo",
    name: "Tu nombre",
    namePlaceholder: "Ingresa tu nombre completo",
    email: "Correo electrónico",
    emailPlaceholder: "tu@email.com",
    country: "País",
    countryPlaceholder: "Selecciona tu país",
    otherCountry: "Otro",
    whatsappLabel: "WhatsApp",
    message: "Mensaje",
    messagePlaceholder:
      "¿En qué fechas te gustaría reservar? ¿Cuántas personas?",
    required: "(requerido)",
    submit: "Enviar solicitud",
    submitting: "Enviando...",
    success: "Formulario enviado correctamente. Te contactaremos pronto.",
    error:
      "No se pudo enviar el formulario. Inténtalo nuevamente o escríbenos por WhatsApp.",
    genericError: "No se pudo enviar el formulario.",
  },
  en: {
    title: "Book your adventure",
    whatsapp: "Direct WhatsApp",
    divider: "or by email",
    name: "Your name",
    namePlaceholder: "Enter your full name",
    email: "Email address",
    emailPlaceholder: "you@email.com",
    country: "Country",
    countryPlaceholder: "Select your country",
    otherCountry: "Other",
    whatsappLabel: "WhatsApp",
    message: "Message",
    messagePlaceholder:
      "Which dates would you like to book? How many people?",
    required: "(required)",
    submit: "Send request",
    submitting: "Sending...",
    success: "Form sent successfully. We will contact you soon.",
    error:
      "The form could not be sent. Please try again or message us on WhatsApp.",
    genericError: "The form could not be sent.",
  },
  pt: {
    title: "Reserve sua aventura",
    whatsapp: "WhatsApp direto",
    divider: "ou por e-mail",
    name: "Seu nome",
    namePlaceholder: "Digite seu nome completo",
    email: "E-mail",
    emailPlaceholder: "voce@email.com",
    country: "País",
    countryPlaceholder: "Selecione seu país",
    otherCountry: "Outro",
    whatsappLabel: "WhatsApp",
    message: "Mensagem",
    messagePlaceholder:
      "Em quais datas gostaria de reservar? Quantas pessoas?",
    required: "(obrigatório)",
    submit: "Enviar solicitação",
    submitting: "Enviando...",
    success: "Formulario enviado corretamente. Entraremos em contato em breve.",
    error:
      "Não foi possível enviar o formulário. Tente novamente ou escreva pelo WhatsApp.",
    genericError: "Não foi possível enviar o formulário.",
  },
} as const;

const copy = contactCopy[lang] ?? contactCopy.es;

// Prepare countries sorted by name, filter out empty phone codes
const countries = [...countriesWithPhoneCode].sort((a, b) =>
  (lang === "en" ? a.nameEN : a.nameES).localeCompare(
    lang === "en" ? b.nameEN : b.nameES,
  ),
);
---

<section
  data-contact-form-root
  data-submit-label={copy.submit}
  data-submitting-label={copy.submitting}
  data-success-message={copy.success}
  data-error-message={copy.error}
  data-generic-error-message={copy.genericError}
  aria-labelledby="contact-form-title"
  class="bg-white rounded-sm p-6 md:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-gray-100 flex flex-col relative overflow-hidden"
>
  <div
    class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-primary to-secondary"
  >
  </div>

  <header class="mb-6 mt-2">
    <span
      id="contact-form-title"
      class="text-secondary font-bold tracking-wider uppercase text-xs inline-block mb-1"
      >{copy.title}</span
    >
    {
      tourName && (
        <h3 class="text-xl font-extrabold text-gray-900 leading-tight">
          {tourName}
        </h3>
      )
    }
  </header>

  <a
    id="contact-whatsapp-btn"
    href="https://wa.me/51969787221"
    target="_blank"
    rel="noopener noreferrer"
    class="group relative flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#20bd5a] text-white w-full py-3.5 rounded-sm font-bold transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5 mb-6 overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-white/20 translate-y-[100%] group-hover:translate-y-0 transition-transform duration-300 ease-in-out"
    >
    </div>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-5 h-5 relative z-10"
      fill="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false"
    >
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
      ></path>
    </svg>
    <span class="relative z-10 text-[15px]">{copy.whatsapp}</span>
  </a>

  <div class="flex items-center gap-4 mb-6">
    <div class="h-px bg-gray-200 flex-1"></div>
    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"
      >{copy.divider}</span
    >
    <div class="h-px bg-gray-200 flex-1"></div>
  </div>

  <form
    action="/api/planea-tu-viaje"
    method="POST"
    class="space-y-4"
    id="contact-tour-form"
    data-contact-tour-form
  >
    {tourName && <input type="hidden" name="tourName" value={tourName} />}
    <input
      type="hidden"
      id="contact-phone-code-value"
      name="codigoPais"
      value="51"
      data-contact-phone-code-value
    />

    <div>
      <label
        for="contact-name"
        class="block text-sm font-semibold text-gray-700 mb-1.5"
      >
        {copy.name} <span class="text-red-500" aria-hidden="true">*</span>
        <span class="sr-only">{copy.required}</span>
      </label>
      <input
        type="text"
        id="contact-name"
        name="nombres"
        required
        autocomplete="name"
        enterkeyhint="next"
        class="w-full px-4 py-3 bg-gray-50/50 border border-gray-200 rounded-sm focus:bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-gray-400 text-sm"
        placeholder={copy.namePlaceholder}
      />
    </div>

    <div>
      <label
        for="contact-email"
        class="block text-sm font-semibold text-gray-700 mb-1.5"
      >
        {copy.email} <span class="text-red-500" aria-hidden="true">*</span>
        <span class="sr-only">{copy.required}</span>
      </label>
      <input
        type="email"
        id="contact-email"
        name="email"
        required
        autocomplete="email"
        inputmode="email"
        enterkeyhint="next"
        class="w-full px-4 py-3 bg-gray-50/50 border border-gray-200 rounded-sm focus:bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-gray-400 text-sm"
        placeholder={copy.emailPlaceholder}
      />
    </div>

    {/* Country selector */}
    <div>
      <label
        for="contact-country"
        class="block text-sm font-semibold text-gray-700 mb-1.5"
      >
        {copy.country}
        <span class="text-red-500" aria-hidden="true">*</span>
        <span class="sr-only">{copy.required}</span>
      </label>
      <select
        id="contact-country"
        name="pais"
        autocomplete="country-name"
        required
        class="w-full px-4 py-3 bg-gray-50/50 border border-gray-200 rounded-sm focus:bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-sm"
      >
        <option value="">{copy.countryPlaceholder}</option>
        {
          countries.map((c) => (
            <option
              value={lang === "en" ? c.nameEN : c.nameES}
              data-code={c.phoneCode}
            >
              {lang === "en" ? c.nameEN : c.nameES}
            </option>
          ))
        }
        <option value={copy.otherCountry} data-code="">{copy.otherCountry}</option>
      </select>
    </div>

    {/* WhatsApp number field */}
    <div>
      <label
        for="contact-whatsapp"
        class="block text-sm font-semibold text-gray-700 mb-1.5"
      >
        {copy.whatsappLabel}
      </label>
      <div class="flex">
        <span
          id="contact-phone-code"
          class="px-3 py-3 bg-gray-100 border border-r-0 border-gray-200 rounded-l-sm flex items-center text-sm font-medium text-gray-600 min-w-[60px] justify-center select-none"
        >
          +51
        </span>
        <input
          type="tel"
          id="contact-whatsapp"
          name="telefono"
          autocomplete="tel-national"
          inputmode="tel"
          enterkeyhint="next"
          class="w-full px-4 py-3 bg-gray-50/50 border border-gray-200 rounded-r-sm focus:bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-gray-400 text-sm"
          placeholder="999 999 999"
        />
      </div>
    </div>

    <div>
      <label
        for="contact-message"
        class="block text-sm font-semibold text-gray-700 mb-1.5"
      >
        {copy.message} <span class="text-red-500" aria-hidden="true">*</span>
        <span class="sr-only">{copy.required}</span>
      </label>
      <textarea
        id="contact-message"
        name="mensaje"
        rows={4}
        required
        enterkeyhint="send"
        class="w-full px-4 py-3 bg-gray-50/50 border border-gray-200 rounded-sm focus:bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-gray-400 resize-none text-sm"
        placeholder={copy.messagePlaceholder}
      ></textarea>
    </div>

    <button
      type="submit"
      data-contact-submit
      class="w-full flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white px-8 py-3.5 rounded-sm font-bold transition-all duration-200 hover:shadow-lg hover:shadow-primary/30 active:scale-[0.98] mt-2 group"
    >
      <span data-contact-submit-label>{copy.submit}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
        focusable="false"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
      </svg>
    </button>

    <p
      class="hidden rounded-sm border px-4 py-3 text-sm font-semibold"
      data-contact-status
      aria-live="polite"
    >
    </p>
  </form>
</section>

<script>
  type ContactFormRoot = HTMLElement & {
    __dreamyContactFormController?: AbortController;
  };

  const windowWithContactForm = window as Window & {
    __dreamyContactFormPageLoadController?: AbortController;
  };

  function initContactForms() {
    document
      .querySelectorAll<ContactFormRoot>("[data-contact-form-root]")
      .forEach((root) => {
        root.__dreamyContactFormController?.abort();

        const countrySelect =
          root.querySelector<HTMLSelectElement>("#contact-country");
        const phoneCodeSpan = root.querySelector<HTMLElement>(
          "#contact-phone-code",
        );
        const phoneCodeInput = root.querySelector<HTMLInputElement>(
          "[data-contact-phone-code-value]",
        );
        const whatsappBtn = root.querySelector<HTMLAnchorElement>(
          "#contact-whatsapp-btn",
        );
        const whatsappInput =
          root.querySelector<HTMLInputElement>("#contact-whatsapp");
        const form = root.querySelector<HTMLFormElement>("#contact-tour-form");
        const submitButton = root.querySelector<HTMLButtonElement>(
          "[data-contact-submit]",
        );
        const submitLabel = root.querySelector<HTMLElement>(
          "[data-contact-submit-label]",
        );
        const statusMessage = root.querySelector<HTMLElement>(
          "[data-contact-status]",
        );
        const submitText = root.dataset.submitLabel || "Send request";
        const submittingText = root.dataset.submittingLabel || "Sending...";
        const successText =
          root.dataset.successMessage ||
          "Form sent successfully. We will contact you soon.";
        const errorText =
          root.dataset.errorMessage ||
          "The form could not be sent. Please try again or message us on WhatsApp.";
        const genericErrorText =
          root.dataset.genericErrorMessage || "The form could not be sent.";

        if (!countrySelect || !phoneCodeSpan) return;
        const phoneCodeDisplay = phoneCodeSpan;

        const controller = new AbortController();
        root.__dreamyContactFormController = controller;

        function getSelectedCode() {
          const selected = countrySelect?.options[countrySelect.selectedIndex];
          return selected?.dataset.code || "";
        }

        function updateWhatsAppLink() {
          if (!whatsappBtn || !whatsappInput) return;

          const codeText =
            phoneCodeInput?.value ||
            phoneCodeDisplay.textContent?.replace("+", "").replace(/\s/g, "") ||
            "51";
          const phone = whatsappInput.value
            .replace(/\s/g, "")
            .replace(/[^0-9]/g, "");

          whatsappBtn.href = phone
            ? `https://wa.me/${codeText}${phone}`
            : "https://wa.me/51969787221";
        }

        function updatePhoneCode() {
          const code = getSelectedCode();
          phoneCodeDisplay.textContent = code ? `+${code}` : "+";
          if (phoneCodeInput) {
            phoneCodeInput.value = code || "51";
          }
          updateWhatsAppLink();
        }

        function setStatus(type: "success" | "error", message: string) {
          if (!statusMessage) return;

          statusMessage.textContent = message;
          statusMessage.classList.remove(
            "hidden",
            "border-green-200",
            "bg-green-50",
            "text-green-700",
            "border-red-200",
            "bg-red-50",
            "text-red-700",
          );
          statusMessage.classList.add(
            ...(type === "success"
              ? ["border-green-200", "bg-green-50", "text-green-700"]
              : ["border-red-200", "bg-red-50", "text-red-700"]),
          );
          statusMessage.setAttribute(
            "role",
            type === "success" ? "status" : "alert",
          );
          statusMessage.setAttribute(
            "aria-live",
            type === "success" ? "polite" : "assertive",
          );
        }

        function setSubmitting(isSubmitting: boolean) {
          if (submitButton) {
            submitButton.disabled = isSubmitting;
            submitButton.classList.toggle("cursor-not-allowed", isSubmitting);
            submitButton.classList.toggle("opacity-75", isSubmitting);
          }

          if (submitLabel) {
            submitLabel.textContent = isSubmitting
              ? submittingText
              : submitText;
          }
        }

        async function handleSubmit(event: SubmitEvent) {
          if (!form) return;

          event.preventDefault();

          if (!form.reportValidity()) return;

          setSubmitting(true);
          statusMessage?.classList.add("hidden");

          try {
            const response = await fetch(form.action, {
              method: form.method || "POST",
              body: new FormData(form),
              headers: {
                Accept: "application/json",
              },
            });
            const result = await response.json().catch(() => ({}));

            if (!response.ok || !result.success) {
              throw new Error(result.error || genericErrorText);
            }

            form.reset();
            updatePhoneCode();
            setStatus("success", successText);
          } catch (error) {
            console.error("Error al enviar formulario de tour:", error);
            setStatus("error", errorText);
          } finally {
            setSubmitting(false);
          }
        }

        countrySelect.addEventListener("change", updatePhoneCode, {
          signal: controller.signal,
        });
        whatsappInput?.addEventListener("input", updateWhatsAppLink, {
          signal: controller.signal,
        });
        form?.addEventListener("submit", handleSubmit, {
          signal: controller.signal,
        });

        updatePhoneCode();
      });
  }

  document.addEventListener("submit", async (event) => {
    if (event.defaultPrevented) return;

    const form = (event.target as HTMLElement | null)?.closest<HTMLFormElement>(
      "[data-contact-tour-form]",
    );

    if (!form) return;

    event.preventDefault();

    if (!form.reportValidity()) return;

    const submitButton = form.querySelector<HTMLButtonElement>(
      "[data-contact-submit]",
    );
    const submitLabel = form.querySelector<HTMLElement>(
      "[data-contact-submit-label]",
    );
    const statusMessage = form.querySelector<HTMLElement>(
      "[data-contact-status]",
    );
    const root = form.closest<HTMLElement>("[data-contact-form-root]");
    const submitText = root?.dataset.submitLabel || "Send request";
    const submittingText = root?.dataset.submittingLabel || "Sending...";
    const successText =
      root?.dataset.successMessage ||
      "Form sent successfully. We will contact you soon.";
    const errorText =
      root?.dataset.errorMessage ||
      "The form could not be sent. Please try again or message us on WhatsApp.";
    const genericErrorText =
      root?.dataset.genericErrorMessage || "The form could not be sent.";

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.classList.add("cursor-not-allowed", "opacity-75");
    }
    if (submitLabel) submitLabel.textContent = submittingText;
    statusMessage?.classList.add("hidden");

    try {
      const response = await fetch(form.action, {
        method: form.method || "POST",
        body: new FormData(form),
        headers: {
          Accept: "application/json",
        },
      });
      const result = await response.json().catch(() => ({}));

      if (!response.ok || !result.success) {
        throw new Error(result.error || genericErrorText);
      }

      form.reset();

      if (statusMessage) {
        statusMessage.textContent = successText;
        statusMessage.classList.remove(
          "hidden",
          "border-red-200",
          "bg-red-50",
          "text-red-700",
        );
        statusMessage.classList.add(
          "border-green-200",
          "bg-green-50",
          "text-green-700",
        );
        statusMessage.setAttribute("role", "status");
        statusMessage.setAttribute("aria-live", "polite");
      }
    } catch (error) {
      console.error("Error al enviar formulario de tour:", error);

      if (statusMessage) {
        statusMessage.textContent = errorText;
        statusMessage.classList.remove(
          "hidden",
          "border-green-200",
          "bg-green-50",
          "text-green-700",
        );
        statusMessage.classList.add(
          "border-red-200",
          "bg-red-50",
          "text-red-700",
        );
        statusMessage.setAttribute("role", "alert");
        statusMessage.setAttribute("aria-live", "assertive");
      }
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.classList.remove("cursor-not-allowed", "opacity-75");
      }
      if (submitLabel) submitLabel.textContent = submitText;
    }
  });

  windowWithContactForm.__dreamyContactFormPageLoadController?.abort();
  windowWithContactForm.__dreamyContactFormPageLoadController =
    new AbortController();

  document.addEventListener("astro:page-load", initContactForms, {
    signal: windowWithContactForm.__dreamyContactFormPageLoadController.signal,
  });

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initContactForms, {
      once: true,
    });
  } else {
    initContactForms();
  }
</script>
