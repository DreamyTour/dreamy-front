---
import type { Tour, Badge } from "@/types/tours";
import type { Lang } from "@/lib/i18n";
import BadgeIcon from "@/components/ui/BadgeIcon.astro";
import {
  getImageAlt,
  getImageSrcSet,
  getImageUrl,
  extractTextFromBlocks,
} from "@/lib/helpers";

interface Props {
  tour: Tour;
  lang: Lang;
  badges?: Badge[];
}

const { tour, lang, badges } = Astro.props;
if (!tour) return;

const images = Array.isArray(tour.imagenDestacada)
  ? tour.imagenDestacada
      .map((img) => {
        const originalUrl = getImageUrl(img);
        const responsiveSrcSet = getImageSrcSet(img, [
          "small",
          "medium",
          "large",
        ]);
        const originalSrcSet = img.width ? `${originalUrl} ${img.width}w` : "";
        const heroSrcSet = [responsiveSrcSet, originalSrcSet]
          .filter(Boolean)
          .join(", ");

        return {
          heroUrl: originalUrl,
          heroSrcSet,
          alt: getImageAlt(img, tour.titulo),
        };
      })
      .filter((img) => img.heroUrl && img.heroUrl !== "/og-default.jpg")
  : [];

if (images.length === 0) {
  images.push({
    heroUrl: "/og-default.jpg",
    heroSrcSet: "",
    alt: tour.titulo,
  });
}

const heroImage = images[images.length - 1];
const categoryName = tour.categories?.[0]?.nombre;
const hasBadges = badges && badges.length > 0;
const description = extractTextFromBlocks(tour.content);

const ctaLabels = {
  en: {
    book: "Book online",
    whatsapp: "Ask now",
    contactTitle: "Contact us",
    contactText:
      "Tell us your travel date and we will help you plan the next step.",
    benefits: [
      "No hidden fees",
      "Instant confirmation",
      "Discover and Join the adventure today",
      "Local expert guides",
    ],
  },
  es: {
    book: "Reservar online",
    whatsapp: "Consultar ahora",
    contactTitle: "Contactanos",
    contactText:
      "Cuentanos tu fecha de viaje y te ayudamos con el siguiente paso.",
    benefits: [
      "Sin cargos ocultos",
      "Confirmación instantánea",
      "Descubre y únete a la aventura hoy",
      "Guías expertos locales",
    ],
  },
  pt: {
    book: "Reservar online",
    whatsapp: "Consultar agora",
    contactTitle: "Fale conosco",
    contactText: "Conte-nos sua data de viagem e ajudamos com o proximo passo.",
    benefits: [
      "Sem taxas ocultas",
      "Confirmação instantânea",
      "Descubra e junte-se à aventura hoje",
      "Guias especialistas locais",
    ],
  },
};
const ctaLabel = ctaLabels[lang] || ctaLabels.en;
---

<!--
  HERO ANTERIOR COMENTADO:
  La version previa tenia grid de galeria desktop, slider mobile, card lateral
  de badges/CTAs y modal de fotos. Queda retirada temporalmente mientras se
  valida el nuevo diseno con una sola imagen destacada.
-->
<section
  class="tour-hero-container w-full pt-0 pb-8 lg:pb-12"
  aria-labelledby="tour-title"
>
  <div
    class="tour-hero-shell relative left-1/2 isolate min-h-[500px] w-screen -translate-x-1/2 overflow-hidden bg-slate-950 text-white shadow-[0_28px_80px_-48px_rgba(2,6,23,0.85)] md:min-h-[560px] lg:min-h-[700px]"
  >
    <img
      src={heroImage.heroUrl}
      srcset={heroImage.heroSrcSet || undefined}
      sizes="100vw"
      alt={heroImage.alt}
      class="tour-hero-image absolute inset-0 -z-20 h-full w-full object-cover"
      width="1440"
      height="760"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div
      class="absolute inset-x-0 bottom-0 -z-10 h-2/3 bg-gradient-to-t from-slate-950/90 via-slate-950/46 to-transparent"
    >
    </div>

    <div
      class="mx-auto flex min-h-[500px] max-w-8xl flex-col justify-end px-4 pb-6 pt-0 sm:px-6 md:min-h-[560px] md:px-9 md:pb-9 lg:min-h-[620px] lg:px-12 lg:pb-0 lg:pt-12"
    >
      <div class="w-full max-w-8xl">
        {
          categoryName && (
            <span class="tour-category-chip mb-4 inline-flex rounded-full px-4 py-2 text-[0.68rem] uppercase tracking-[0.18em] text-secondary-foreground shadow-lg">
              {categoryName}
            </span>
          )
        }

        <h1
          id="tour-title"
          class="max-w-3xl text-3xl font-extrabold leading-[1.08] text-white md:text-5xl lg:text-6xl"
        >
          {tour.titulo}
        </h1>

        {
          hasBadges && (
            <dl class="tour-badges mt-6 flex max-w-4xl flex-wrap items-stretch gap-2 md:flex-nowrap">
              {badges.map((badge, index) => (
                <div
                  class="tour-badge group grid w-fit max-w-[calc(50%-0.25rem)] min-w-0 grid-cols-[1.75rem_minmax(0,1fr)] items-center gap-x-1.5 rounded-sm border border-white/18 bg-white/12 px-2 py-1.5 text-white shadow-[0_18px_42px_-30px_rgba(0,0,0,0.9)] backdrop-blur-md transition duration-300 hover:-translate-y-0.5 hover:bg-white/18 md:min-h-[54px] md:w-auto md:max-w-none md:flex-1 md:basis-0 md:grid-cols-[2rem_minmax(0,1fr)] md:gap-x-2 md:px-2.5 md:py-2 xl:min-w-[150px] xl:shrink-0"
                  style={`animation-delay: ${index * 90}ms;`}
                >
                  <dt class="contents">
                    <span class="tour-badge-icon row-span-2 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-sm bg-secondary/90 text-secondary-foreground shadow-lg shadow-black/20 md:h-8 md:w-8">
                      <BadgeIcon
                        title={badge.titulo}
                        content={badge.content}
                        className="h-3 w-3 transition-transform duration-300 group-hover:scale-110 md:h-3.5 md:w-3.5"
                      />
                    </span>
                    <span class="min-w-0 text-[0.56rem] uppercase tracking-[0.1em] text-white/68 md:text-[0.58rem] md:tracking-[0.12em]">
                      {badge.titulo}
                    </span>
                  </dt>
                  <dd class="col-start-2 mt-0.5 text-[0.7rem] font-medium leading-tight text-white md:text-xs">
                    {badge.content}
                  </dd>
                </div>
              ))}
            </dl>
          )
        }
      </div>
    </div>
  </div>

  <div
    class="tour-hero-content mx-auto mt-10 grid max-w-8xl items-stretch gap-5 lg:mt-12 lg:grid-cols-[minmax(0,1fr)_340px]"
  >
    <div
      class="h-full rounded-sm border border-primary/30 bg-background p-4 lg:p-5"
    >
      <p
        class="max-w-4xl text-base leading-relaxed text-slate-800 md:text-[1.05rem]"
      >
        {description}
      </p>
    </div>

    <aside
      class="tour-contact-card rounded-sm border border-border bg-background p-4 shadow-sm lg:p-5"
    >
      <p
        class="text-xs font-extrabold uppercase tracking-[0.16em] text-primary"
      >
        {ctaLabel.contactTitle}
      </p>
      <p class="mt-2 text-sm leading-relaxed text-slate-700">
        {ctaLabel.contactText}
      </p>

      <div class="mt-4 grid gap-3">
        <a
          href="https://wa.me/51969787221"
          target="_blank"
          rel="noopener noreferrer"
          class="hero-cta-whatsapp inline-flex min-h-11 items-center justify-center gap-2 rounded-full px-4 py-2.5 text-xs font-extrabold uppercase tracking-[0.08em] transition duration-300 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 active:scale-[0.98]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          {ctaLabel.whatsapp}
        </a>
        <a
          href="#tour-contact-form"
          class="hero-cta-book inline-flex min-h-11 items-center justify-center rounded-full px-4 py-2.5 text-xs font-extrabold uppercase tracking-[0.08em] transition duration-300 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 active:scale-[0.98]"
        >
          {ctaLabel.book}
        </a>
      </div>

      <ul class="mt-5 space-y-2 border-t border-border pt-4">
        {
          ctaLabel.benefits.map((benefit) => (
            <li class="flex items-start gap-2 text-xs text-slate-700">
              <svg
                class="mt-0.5 h-3.5 w-3.5 shrink-0 text-primary"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span>{benefit}</span>
            </li>
          ))
        }
      </ul>
    </aside>
  </div>
</section>

<style is:inline>
  .tour-hero-container .tour-hero-image {
    animation: tour-hero-slow-zoom 26s ease-in-out infinite alternate;
    transform-origin: center;
  }

  .tour-hero-container .tour-category-chip {
    background: var(--secondary);
    color: var(--secondary-foreground);
  }

  .tour-hero-container .tour-badge {
    animation: tour-badge-in 0.55s ease-out both;
  }

  .tour-hero-container .hero-cta-whatsapp {
    background: var(--primary);
    color: var(--primary-foreground);
    box-shadow: 0 18px 36px -28px var(--primary);
  }

  .tour-hero-container .hero-cta-whatsapp:hover {
    background: color-mix(in oklab, var(--primary) 88%, black);
  }

  .tour-hero-container .hero-cta-book {
    background: var(--secondary);
    color: var(--secondary-foreground);
    box-shadow: 0 18px 36px -28px var(--secondary);
  }

  .tour-hero-container .hero-cta-book:hover {
    background: color-mix(in oklab, var(--secondary) 88%, black);
  }

  @keyframes tour-hero-slow-zoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }

  @keyframes tour-badge-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tour-hero-container .tour-hero-image,
    .tour-hero-container .tour-badge {
      animation: none;
    }

    .tour-hero-container .tour-badge {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('a[href="#tour-contact-form"]');
    if (!link) return;

    e.preventDefault();
    const isMobile = window.innerWidth < 1024;
    const targetId = isMobile
      ? "tour-contact-form-mobile"
      : "tour-contact-form";
    const scrollTarget = document.getElementById(targetId);
    if (scrollTarget) {
      scrollTarget.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  });
</script>
