---
import { LANGS, type Lang } from "@/lib/i18n";
import { rewriteUrl } from "@/lib/utils";
import type { Link, MenuItem, Menu as MenuType } from "@/types/global";

interface Props {
  menu: MenuType;
  quickActions?: Link[];
  logoUrl: string;
  lang: Lang;
}

const { menu, quickActions = [], logoUrl, lang } = Astro.props;
const languageNames: Record<Lang, string> = {
  en: "English",
  es: "Español",
  pt: "Português",
};
const languageFlags: Record<Lang, string> = {
  en: "/imagenes/flag/um.svg",
  es: "/imagenes/flag/es.svg",
  pt: "/imagenes/flag/br.svg",
};
---

<section
  class="relative xl:hidden"
  data-mobile-menu-root
  data-current-lang={lang}
>
  <nav
    class="relative z-50 bg-background/95 px-4 py-3 backdrop-blur-md"
    aria-label="Controles móviles"
  >
    <ul class="flex list-none items-center gap-4 p-0">
      <li class="min-w-0 shrink-0">
        <a href={logoUrl} class="block" aria-label="Dreamy Tours - inicio">
          <img
            src="/logo-dreamytours.svg"
            alt=""
            class="h-10 w-auto"
            width="110"
            height="40"
            fetchpriority="high"
          />
        </a>
      </li>

      <li class="relative ml-auto" data-language-switcher>
        <button
          type="button"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="language-menu-mobile"
          aria-label="Cambiar idioma"
          data-language-toggle
          class="inline-flex h-9 min-w-[124px] items-center justify-between gap-2 rounded-md border border-border bg-white px-2.5 text-sm font-semibold text-slate-800 shadow-sm transition-colors duration-200 hover:border-slate-300 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-700 focus-visible:ring-offset-2"
        >
          <span class="inline-flex items-center gap-2">
            <span
              class="grid size-6 shrink-0 place-items-center overflow-hidden rounded-full border border-slate-200 bg-slate-100 shadow-[0_1px_2px_rgba(15,23,42,0.12)]"
            >
              <img
                src={languageFlags[lang]}
                alt=""
                aria-hidden="true"
                class="h-full w-full object-cover"
                loading="eager"
              />
            </span>
            <span>{languageNames[lang]}</span>
          </span>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="size-4 text-slate-500 transition-transform duration-200"
            aria-hidden="true"
            data-language-chevron><path d="m6 9 6 6 6-6"></path></svg
          >
        </button>

        <div
          id="language-menu-mobile"
          role="menu"
          hidden
          data-language-menu
          class="absolute right-0 z-50 mt-2 min-w-[170px] overflow-hidden rounded-md border border-border bg-white p-1 shadow-lg"
        >
          {
            LANGS.map((optionLang) => {
              const selected = optionLang === lang;
              return (
                <button
                  type="button"
                  role="menuitemradio"
                  aria-checked={selected}
                  data-language={optionLang}
                  class:list={[
                    "flex w-full items-center justify-between gap-3 rounded-sm px-3 py-2 text-left text-sm transition-colors duration-150 focus-visible:outline-none",
                    selected
                      ? "bg-primary/10 font-semibold text-primary ring-1 ring-inset ring-primary/15 hover:bg-primary/12 focus-visible:bg-primary/12"
                      : "text-slate-700 hover:bg-slate-100 focus-visible:bg-slate-100",
                  ]}
                >
                  <span class="inline-flex items-center gap-2.5">
                    <span class="grid size-6 shrink-0 place-items-center overflow-hidden rounded-full border border-slate-200 bg-slate-100 shadow-[0_1px_2px_rgba(15,23,42,0.12)]">
                      <img
                        src={languageFlags[optionLang]}
                        alt=""
                        aria-hidden="true"
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    </span>
                    <span>{languageNames[optionLang]}</span>
                  </span>
                  {selected && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      class="size-4 text-primary"
                      aria-hidden="true"
                    >
                      <path d="m5 12 4 4L19 6" />
                    </svg>
                  )}
                </button>
              );
            })
          }
        </div>
      </li>

      <li>
        <button
          type="button"
          data-menu-toggle
          class="inline-flex h-[42px] w-[42px] items-center justify-center rounded-full border border-primary/25 bg-white text-primary shadow-sm transition-all duration-200 hover:border-primary/45 hover:bg-primary/5 active:scale-90"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            data-menu-open-icon
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="size-[25px]"
            aria-hidden="true"
          >
            <path d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            data-menu-close-icon
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="hidden size-[25px]"
            aria-hidden="true"
          >
            <path d="M18 6 6 18M6 6l12 12"></path>
          </svg>
        </button>
      </li>
    </ul>
  </nav>

  <div
    hidden
    data-menu-overlay
    class="fixed inset-0 z-40 bg-foreground/12 backdrop-blur-sm"
    aria-hidden="true"
  >
  </div>

  <nav
    id="mobile-menu"
    data-mobile-menu
    hidden
    class="absolute left-3 right-3 top-full z-50 mt-3 max-h-[calc(100dvh-92px)] overflow-y-auto rounded-2xl border border-border bg-white p-3 shadow-[0_24px_70px_-44px_var(--foreground)] animate-in fade-in slide-in-from-top-2 duration-300 ease-out"
    aria-label="Menú principal"
  >
    <ul class="flex flex-col gap-2 px-0.5 pb-1 pt-0.5">
      {
        menu?.menuItems?.map((item: MenuItem) => {
          const hasChildren = Boolean(item.item?.length);
          const submenuId = `mobile-submenu-${item.id}`;
          return (
            <li>
              {hasChildren ? (
                <>
                  <button
                    type="button"
                    data-accordion-toggle
                    class="group relative inline-flex w-full items-center rounded-xl px-3.5 py-3.5 text-base font-semibold text-foreground transition-colors duration-200 hover:bg-primary/6 hover:text-primary"
                    aria-expanded="false"
                    aria-controls={submenuId}
                  >
                    <span
                      aria-hidden="true"
                      class="pointer-events-none absolute inset-x-4 bottom-0 h-px bg-linear-to-r from-transparent via-primary/25 to-transparent group-hover:via-primary/45"
                    />
                    <span class="inline-flex items-center gap-2">
                      <span>{item.link.label}</span>
                      {item.link.badge && (
                        <span class="rounded-full bg-secondary px-2 py-0.5 text-[10px] font-semibold leading-none text-secondary-foreground">
                          {item.link.badge}
                        </span>
                      )}
                    </span>
                    <svg
                      data-accordion-chevron
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      class="ml-auto size-[18px] text-muted-foreground/50 transition-transform duration-200"
                      aria-hidden="true"
                    >
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </button>
                  <ul
                    id={submenuId}
                    hidden
                    data-accordion-panel
                    class="mb-2 mt-1 flex animate-in fade-in slide-in-from-top-1 flex-col gap-0.5 px-2 duration-200"
                  >
                    {item.item.map((subItem: Link) => (
                      <li>
                        <a
                          href={rewriteUrl(subItem.url, lang)}
                          data-menu-link
                          class="group relative flex min-w-0 items-center gap-2 rounded-lg px-3.5 py-2.5 text-sm font-medium text-foreground/70 transition-colors duration-200 hover:text-primary"
                        >
                          <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.2"
                            class="size-3.5 shrink-0 text-primary/45 transition-transform group-hover:translate-x-0.5 group-hover:text-primary"
                            aria-hidden="true"
                          >
                            <path d="m9 18 6-6-6-6" />
                          </svg>
                          <span class="min-w-0 truncate">{subItem.label}</span>
                          {subItem.badge && (
                            <span class="shrink-0 rounded-full bg-secondary px-2 py-0.5 text-[10px] font-semibold leading-none text-secondary-foreground">
                              {subItem.badge}
                            </span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  href={rewriteUrl(item.link.url, lang)}
                  data-menu-link
                  class="group relative inline-flex w-full min-w-0 items-center rounded-xl px-3.5 py-3.5 text-base font-semibold text-foreground transition-colors duration-200 hover:bg-primary/6 hover:text-primary"
                >
                  <span
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-x-4 bottom-0 h-px bg-linear-to-r from-transparent via-primary/25 to-transparent group-hover:via-primary/45"
                  />
                  <span class="inline-flex items-center gap-2">
                    <span>{item.link.label}</span>
                    {item.link.badge && (
                      <span class="rounded-full bg-secondary px-2 py-0.5 text-[10px] font-semibold leading-none text-secondary-foreground">
                        {item.link.badge}
                      </span>
                    )}
                  </span>
                </a>
              )}
            </li>
          );
        })
      }
    </ul>

    {
      quickActions.length > 0 && (
        <ul class="mt-3 grid gap-2 border-t border-border/70 px-0.5 pb-1 pt-3">
          {quickActions.map((action) => (
            <li>
              <a
                href={rewriteUrl(action.url, lang)}
                target={action.isExternal ? "_blank" : "_self"}
                rel={action.isExternal ? "noopener noreferrer" : undefined}
                data-menu-link
                class:list={[
                  "inline-flex min-h-12 w-full min-w-0 items-center justify-center rounded-xl border px-4 py-3 text-center text-sm font-bold leading-snug transition-colors duration-200",
                  action.type === "PRIMARY"
                    ? "border-secondary bg-secondary text-white shadow-[0_16px_34px_-24px_color-mix(in_oklab,var(--secondary)_80%,transparent)] hover:bg-secondary/90"
                    : "border-primary/20 bg-primary/6 text-primary hover:border-primary/35 hover:bg-primary/10",
                ]}
              >
                <span class="min-w-0 break-words text-wrap-pretty [overflow-wrap:anywhere]">
                  {action.label}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </nav>
</section>

<script>
  import {
    localizePath,
    stripLangPrefix,
    translatePathForSlug,
    type Lang,
  } from "@/lib/i18n";

  function resolveLocalizedPath(nextLang: Lang) {
    const normalizedPath = stripLangPrefix(window.location.pathname);
    for (const id of ["tour-slug-map", "page-slug-map"]) {
      const element = document.getElementById(id);
      if (!element) continue;
      try {
        const slugMap = JSON.parse(element.textContent ?? "{}") as Record<
          string,
          string
        >;
        if (slugMap[nextLang])
          return localizePath(`/${slugMap[nextLang]}`, nextLang);
      } catch {}
    }
    const blogMap = document.getElementById("blog-slug-map");
    if (blogMap) {
      try {
        const slugMap = JSON.parse(blogMap.textContent ?? "{}") as Record<
          string,
          string
        >;
        if (slugMap[nextLang]) {
          return localizePath(
            translatePathForSlug(normalizedPath, slugMap[nextLang]),
            nextLang,
          );
        }
      } catch {}
    }
    return localizePath(normalizedPath, nextLang);
  }

  function initMobileMenus() {
    document
      .querySelectorAll<HTMLElement>("[data-mobile-menu-root]")
      .forEach((root) => {
        if (root.dataset.initialized) return;
        root.dataset.initialized = "true";

        const toggle =
          root.querySelector<HTMLButtonElement>("[data-menu-toggle]");
        const menu = root.querySelector<HTMLElement>("[data-mobile-menu]");
        const overlay = root.querySelector<HTMLElement>("[data-menu-overlay]");
        const openIcon = root.querySelector<SVGElement>(
          "[data-menu-open-icon]",
        );
        const closeIcon = root.querySelector<SVGElement>(
          "[data-menu-close-icon]",
        );
        const languageSwitcher = root.querySelector<HTMLElement>(
          "[data-language-switcher]",
        );
        const languageToggle = root.querySelector<HTMLButtonElement>(
          "[data-language-toggle]",
        );
        const languageMenu = root.querySelector<HTMLElement>(
          "[data-language-menu]",
        );
        const languageChevron = root.querySelector<SVGElement>(
          "[data-language-chevron]",
        );
        if (!toggle || !menu || !overlay) return;

        const setMenuOpen = (open: boolean, restoreFocus = false) => {
          toggle.setAttribute("aria-expanded", String(open));
          toggle.setAttribute(
            "aria-label",
            open ? "Cerrar menú" : "Abrir menú",
          );
          menu.hidden = !open;
          overlay.hidden = !open;
          openIcon?.classList.toggle("hidden", open);
          closeIcon?.classList.toggle("hidden", !open);
          document.body.style.overflow = open ? "hidden" : "";
          if (open) {
            requestAnimationFrame(() =>
              menu
                .querySelector<HTMLElement>("a[href], button:not([disabled])")
                ?.focus(),
            );
          } else if (restoreFocus) {
            toggle.focus();
          }
        };

        const setLanguageOpen = (open: boolean) => {
          if (!languageToggle || !languageMenu) return;
          languageToggle.setAttribute("aria-expanded", String(open));
          languageMenu.hidden = !open;
          languageChevron?.classList.toggle("rotate-180", open);
        };

        toggle.addEventListener("click", () =>
          setMenuOpen(toggle.getAttribute("aria-expanded") !== "true"),
        );
        overlay.addEventListener("click", () => setMenuOpen(false, true));
        menu
          .querySelectorAll<HTMLElement>("[data-menu-link]")
          .forEach((link) =>
            link.addEventListener("click", () => setMenuOpen(false)),
          );
        root
          .querySelectorAll<HTMLButtonElement>("[data-accordion-toggle]")
          .forEach((button) => {
            button.addEventListener("click", () => {
              const open = button.getAttribute("aria-expanded") !== "true";
              button.setAttribute("aria-expanded", String(open));
              const panel = document.getElementById(
                button.getAttribute("aria-controls") ?? "",
              );
              if (panel) panel.hidden = !open;
              button
                .querySelector("[data-accordion-chevron]")
                ?.classList.toggle("rotate-180", open);
              button.classList.toggle("text-primary", open);
            });
          });

        languageToggle?.addEventListener("click", () =>
          setLanguageOpen(
            languageToggle.getAttribute("aria-expanded") !== "true",
          ),
        );
        languageMenu
          ?.querySelectorAll<HTMLButtonElement>("[data-language]")
          .forEach((button) => {
            button.addEventListener("click", () => {
              const nextLang = button.dataset.language as Lang;
              if (nextLang === root.dataset.currentLang)
                return setLanguageOpen(false);
              window.location.href = resolveLocalizedPath(nextLang);
            });
          });

        document.addEventListener("pointerdown", (event) => {
          if (
            languageSwitcher &&
            !languageSwitcher.contains(event.target as Node)
          ) {
            setLanguageOpen(false);
          }
        });
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            setLanguageOpen(false);
            if (toggle.getAttribute("aria-expanded") === "true")
              setMenuOpen(false, true);
            return;
          }
          if (
            event.key !== "Tab" ||
            toggle.getAttribute("aria-expanded") !== "true"
          )
            return;
          const focusable = menu.querySelectorAll<HTMLElement>(
            'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
          );
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (event.shiftKey && document.activeElement === first) {
            event.preventDefault();
            last?.focus();
          } else if (!event.shiftKey && document.activeElement === last) {
            event.preventDefault();
            first?.focus();
          }
        });
      });
  }

  initMobileMenus();
  document.addEventListener("astro:page-load", initMobileMenus);
</script>
