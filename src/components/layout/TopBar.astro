---
import type { TopBar } from "@/types/global";
import type { Lang } from "@/lib/i18n";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  data?: TopBar;
  lang: Lang;
}

const { data, lang } = Astro.props;

// Si no existe o no está visible, no renderiza nada
if (!data || !data.isVisible) return;

// Seguridad para links externos
const isExternal = data.link?.isExternal;
const target = isExternal ? "_blank" : "_self";
const rel = isExternal ? "noopener noreferrer" : undefined;
---

<div class="w-full bg-primary text-white hidden md:block">
  <div
    class="max-w-8xl mx-auto px-4 py-1.5 flex items-center justify-center gap-3 text-sm"
  >
    <!-- Texto -->
    <p class="font-medium leading-tight tracking-wide">
      {data.text}
    </p>

    <!-- Link / Botón -->
    {
      data.link?.label && data.link?.url && (
        <a
          href={rewriteUrl(data.link.url, lang)}
          target={target}
          rel={rel}
          class="font-semibold underline underline-offset-4 decoration-white/45 transition-colors duration-200 hover:decoration-white"
        >
          {data.link.label}
        </a>
      )
    }
  </div>
</div>
