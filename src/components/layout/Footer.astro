---
import Certification from "@/components/layout/Certification.astro";
import {
  EmailIcon,
  WhatsAppIcon,
  PhoneIcon,
  LocationIcon,
} from "@/components/icons/SocialContactIcons";
import type { Footer as FooterType } from "@/types/global";
import type { Lang } from "@/lib/i18n";
import { getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";
import { normalizeWhatsAppUrl } from "@/lib/socialLinks";

interface Props {
  data?: FooterType;
  lang: Lang;
}

const { data, lang } = Astro.props;
---

<footer
  class="dreamy-footer relative overflow-hidden bg-[#081711] pt-8 pb-10 text-white"
>
  <div class="pointer-events-none absolute inset-0 z-0">
    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,_#0b1d15_0%,_#081711_58%,_#050907_100%)]"
    >
    </div>
    <div class="dreamy-footer-pattern absolute inset-0"></div>
    <div
      class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/30 to-transparent"
    >
    </div>
    <div
      class="absolute left-0 top-0 h-full w-full bg-[radial-gradient(circle_at_50%_0%,_rgba(255,255,255,0.08),_transparent_38%)]"
    >
    </div>
  </div>

  <div class="relative z-10">
    <Certification lang={lang} />

    <div class="max-w-8xl mx-auto px-6 pt-14 md:px-10 lg:pt-16">
      <div class="border-b border-white/10 py-10 lg:py-12">
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
          <div
            class="flex flex-col border-b border-white/10 pb-10 lg:col-span-5 lg:border-b-0 lg:border-r lg:pr-12"
          >
            <a
              href="/"
              class="group mb-7 inline-block w-max focus:outline-hidden"
            >
              <img
                src="/logo-dreamytours.svg"
                alt="Logo Dreamy Tours"
                class="h-16 w-auto brightness-0 invert drop-shadow-sm transition-opacity duration-300 group-hover:opacity-85 md:h-[72px]"
                width="220"
                height="80"
                loading="lazy"
                decoding="async"
              />
            </a>
            {
              data?.content && (
                <p class="max-w-md text-base leading-8 text-white/64">
                  {data.content}
                </p>
              )
            }
          </div>

          <div
            class="grid grid-cols-1 gap-9 md:grid-cols-2 lg:col-span-4 lg:gap-10"
          >
            <div class="flex flex-col gap-5">
              {
                data?.destination?.titulo && (
                  <h3 class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/82">
                    {data.destination.titulo}
                  </h3>
                )
              }
              {
                data?.destination?.link && data.destination.link.length > 0 && (
                  <ul class="flex flex-col gap-3">
                    {data.destination.link.map((link) => (
                      <li>
                        <a
                          href={rewriteUrl(
                            normalizeWhatsAppUrl(link.label, link.url) || "",
                            lang,
                          )}
                          class="group inline-flex items-center text-[0.95rem] text-white/62 transition-colors duration-300 hover:text-white"
                          target={link.isExternal ? "_blank" : "_self"}
                          rel={link.isExternal ? "noopener noreferrer" : ""}
                        >
                          <span class="mr-0 h-px w-0 bg-white/70 transition-all duration-300 ease-out group-hover:mr-2 group-hover:w-3" />
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )
              }
            </div>

            <div class="flex flex-col gap-5">
              {
                data?.dreamyAbout?.titulo && (
                  <h3 class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/82">
                    {data.dreamyAbout.titulo}
                  </h3>
                )
              }
              {
                data?.dreamyAbout?.link && data.dreamyAbout.link.length > 0 && (
                  <ul class="flex flex-col gap-3">
                    {data.dreamyAbout.link.map((link) => (
                      <li>
                        <a
                          href={rewriteUrl(
                            normalizeWhatsAppUrl(link.label, link.url) || "",
                            lang,
                          )}
                          class="group inline-flex items-center text-[0.95rem] text-white/62 transition-colors duration-300 hover:text-white"
                          target={link.isExternal ? "_blank" : "_self"}
                          rel={link.isExternal ? "noopener noreferrer" : ""}
                        >
                          <span class="mr-0 h-px w-0 bg-white/70 transition-all duration-300 ease-out group-hover:mr-2 group-hover:w-3" />
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )
              }
            </div>
          </div>

          <div class="flex flex-col gap-5 lg:col-span-3">
            {
              data?.contact?.titulo && (
                <h3 class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/82">
                  {data.contact.titulo}
                </h3>
              )
            }
            {
              data?.contact?.link && data.contact.link.length > 0 && (
                <ul class="flex flex-col gap-3.5">
                  {data.contact.link.map((link, index) => {
                    const isLink = index < 2;
                    const content = (
                      <>
                        <span
                          class={`mt-0.5 shrink-0 text-emerald-50/75 transition-all duration-300 ${isLink ? "group-hover:scale-110 group-hover:text-emerald-400" : ""}`}
                        >
                          {index === 0 && <EmailIcon className="size-5" />}
                          {index === 1 && <WhatsAppIcon className="size-5" />}
                          {index === 2 && <PhoneIcon className="size-5" />}
                          {(index === 3 || index === 4) && (
                            <LocationIcon className="size-5" />
                          )}
                        </span>
                        <span class="leading-relaxed">{link.label}</span>
                      </>
                    );

                    return (
                      <li>
                        {isLink ? (
                          <a
                            href={rewriteUrl(
                              normalizeWhatsAppUrl(link.label, link.url) || "",
                              lang,
                            )}
                            class="group flex items-start gap-3 text-[0.92rem] text-white/62 transition-colors duration-300 hover:text-emerald-400"
                            target={link.isExternal ? "_blank" : "_self"}
                            rel={link.isExternal ? "noopener noreferrer" : ""}
                          >
                            {content}
                          </a>
                        ) : (
                          <span class="flex items-start gap-3 text-[0.92rem] text-white/62">
                            {content}
                          </span>
                        )}
                      </li>
                    );
                  })}
                </ul>
              )
            }
          </div>
        </div>
      </div>

      <div
        class="flex flex-col items-center justify-between gap-6 pt-7 md:flex-row"
      >
        <p class="text-center text-sm text-white/55 md:text-left">
          &copy; {new Date().getFullYear()} Dreamy Tours. Todos los derechos reservados.
        </p>

        {
          data?.socialLogo && data.socialLogo.length > 0 && (
            <div class="flex items-center gap-3">
              {data?.socialTitle && (
                <span class="mr-2 hidden text-xs font-semibold uppercase tracking-[0.18em] text-white/45 sm:block">
                  {data.socialTitle}
                </span>
              )}
              {data.socialLogo.map((social) => (
                <a
                  href={normalizeWhatsAppUrl(social.label, social.url)}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Siguenos en ${social.label || "red social"}`}
                  class="group relative flex h-11 w-11 items-center justify-center overflow-hidden rounded-full border border-white/10 bg-white/[0.04] transition-all duration-300 hover:-translate-y-0.5 hover:border-emerald-50/35 hover:bg-white/10"
                >
                  <div class="absolute inset-0 bg-emerald-50/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
                  {social.imagen?.url && (
                    <img
                      src={getImageUrl(social.imagen)}
                      alt=""
                      aria-hidden="true"
                      class="relative z-10 h-5 w-auto opacity-85 transition-all duration-300 group-hover:scale-105 group-hover:opacity-100"
                      width="24"
                      height="24"
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</footer>

<style>
  .dreamy-footer {
    isolation: isolate;
  }

  .dreamy-footer-pattern {
    background-image: url("/fondo.svg");
    background-position: center top;
    background-repeat: repeat;
    background-size: clamp(26rem, 38vw, 38rem) clamp(26rem, 38vw, 38rem);
    filter: invert(1) sepia(0.2) saturate(0.45) contrast(1.08);
    opacity: 0.2;
    mix-blend-mode: soft-light;
  }

  .dreamy-footer-pattern::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at 82% 8%,
        color-mix(in oklab, var(--accent-warm) 18%, transparent),
        transparent 32%
      ),
      radial-gradient(
        circle at 18% 88%,
        color-mix(in oklab, var(--primary) 16%, transparent),
        transparent 34%
      ),
      linear-gradient(
        180deg,
        color-mix(in oklab, black 8%, transparent),
        transparent 36%,
        color-mix(in oklab, black 36%, transparent)
      );
  }

  @media (max-width: 767px) {
    .dreamy-footer-pattern {
      background-position: center top;
      background-size: 24rem 24rem;
      opacity: 0.07;
    }
  }

  @media (forced-colors: active) {
    .dreamy-footer-pattern {
      display: none;
    }
  }
</style>
