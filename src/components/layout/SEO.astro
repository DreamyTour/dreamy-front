---
import type { Lang } from "@/lib/i18n";
import {
  LANGS,
  DEFAULT_LANG,
  localizePath,
  stripLangPrefix,
  translatePathForSlug,
} from "@/lib/i18n";
import { serializeJsonForHtml } from "@/lib/html";

const DEFAULT_SEO_IMAGE_ALT =
  "Dreamy Tours - tours y paquetes turisticos en Peru y Bolivia";
const OG_LOCALE_BY_LANG: Record<Lang, string> = {
  en: "en_US",
  es: "es_PE",
  pt: "pt_BR",
};
const HREFLANG_BY_LANG: Record<Lang, string> = {
  en: "en",
  es: "es-PE",
  pt: "pt-BR",
};

export interface SEOProps {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  keywords?: string;
  type?: "website" | "article";
  lang?: Lang;
  canonicalUrl?: string;
  robots?: string;
  publishedTime?: string;
  author?: string;
  slugMap?: Record<string, string>; // Para traducciones de slug en hreflang
  schemas?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description: rawDescription,
  image,
  imageAlt = DEFAULT_SEO_IMAGE_ALT,
  keywords,
  type = "website",
  lang = DEFAULT_LANG,
  canonicalUrl,
  robots = "index, follow",
  publishedTime,
  author,
  slugMap,
  schemas = [],
} = Astro.props;

const defaultDescriptionByLang: Record<Lang, string> = {
  en: "Explore tours and travel packages in Peru and Bolivia with Dreamy Tours. Machu Picchu, Cusco, Lake Titicaca, Uyuni Salt Flat, and more unique destinations.",
  es: "Explora tours y paquetes turísticos en Perú y Bolivia con Dreamy Tours. Machu Picchu, Cusco, Lago Titicaca, Salar de Uyuni y más destinos únicos.",
  pt: "Explore passeios e pacotes turísticos no Peru e na Bolívia com a Dreamy Tours. Machu Picchu, Cusco, Lago Titicaca, Salar de Uyuni e mais destinos únicos.",
};

const description = rawDescription || defaultDescriptionByLang[lang as Lang] || defaultDescriptionByLang[DEFAULT_LANG];

//Get site URL from astro.config
const siteUrl = Astro.site?.origin || "https://dreamy.tours";

// Generate canonical URL
const currentPath = stripLangPrefix(Astro.url.pathname);
const canonical =
  canonicalUrl || `${siteUrl}${localizePath(currentPath, lang)}`;
const ogLocale =
  OG_LOCALE_BY_LANG[lang as Lang] || OG_LOCALE_BY_LANG[DEFAULT_LANG];
const schemaLanguageByLang: Record<Lang, string> = {
  en: "en-US",
  es: "es-PE",
  pt: "pt-BR",
};
const schemaLanguage =
  schemaLanguageByLang[lang as Lang] || schemaLanguageByLang.en;
const homeLabelByLang: Record<Lang, string> = {
  en: "Home",
  es: "Inicio",
  pt: "Início",
};
const homeLabel = homeLabelByLang[lang as Lang] || homeLabelByLang.en;

// Generate full image URL
const fullImageUrl = image
  ? image.startsWith("http")
    ? image
    : `${siteUrl}${image}`
  : undefined;

// Get alternate language URLs for hreflang
const alternateUrls = LANGS.map((alternateLang) => {
  let urlPath = currentPath;

  // Si hay un slugMap, usarlo para traducir el slug
  if (slugMap && slugMap[alternateLang]) {
    urlPath = translatePathForSlug(urlPath, slugMap[alternateLang]);
  }

  return {
    lang: alternateLang,
    locale: OG_LOCALE_BY_LANG[alternateLang],
    hreflang: HREFLANG_BY_LANG[alternateLang] || alternateLang,
    url: `${siteUrl}${localizePath(urlPath, alternateLang)}`,
  };
});

// Calcular x-default (versión inglés sin prefijo de idioma)
let xDefaultPath = currentPath;
if (slugMap && slugMap["en"]) {
  xDefaultPath = translatePathForSlug(xDefaultPath, slugMap["en"]);
}
const xDefaultUrl = `${siteUrl}${localizePath(xDefaultPath, DEFAULT_LANG)}`;

const orgDescriptionByLang: Record<Lang, string> = {
  en: "Dreamy Tours is a travel agency in Peru specialized in tours and travel packages to Machu Picchu, Cusco, Lake Titicaca, Bolivia, and other destinations in Latin America.",
  es: "Dreamy Tours es una agencia de viajes en Perú especializada en tours y paquetes turísticos a Machu Picchu, Cusco, Lago Titicaca, Bolivia y otros destinos de Latinoamérica.",
  pt: "A Dreamy Tours é uma agência de viagens no Peru especializada em passeios e pacotes turísticos para Machu Picchu, Cusco, Lago Titicaca, Bolívia e outros destinos na América Latina.",
};
const orgDescription = orgDescriptionByLang[lang as Lang] || orgDescriptionByLang[DEFAULT_LANG];

// Schema.org JSON-LD
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  url: `${siteUrl}/`,
  name: "Dreamy Tours",
  alternateName: [
    "Dreamy Tours Peru",
  ],
  description: orgDescription,
  inLanguage: schemaLanguage,
  publisher: {
    "@id": `${siteUrl}/#organization`,
  },
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "TravelAgency"],
  "@id": `${siteUrl}/#organization`,
  name: "Dreamy Tours",
  alternateName: ["Dreamy Tours Peru", "Dreamy Tours Bolivia"],
  description: orgDescription,
  url: siteUrl,
  logo: `${siteUrl}/logo-dreamytours.svg`,
  ...(fullImageUrl ? { image: fullImageUrl } : {}),
  address: {
    "@type": "PostalAddress",
    addressCountry: "PE",
    addressLocality: "Cusco",
    addressRegion: "Cusco",
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+51969787221",
    contactType: "reservations",
    availableLanguage: ["Spanish", "English", "Portuguese"],
  },
  sameAs: [
    "https://www.facebook.com/dreamytours/",
    "https://www.instagram.com/dreamy_tours",
    "https://wa.me/51969787221",
  ],
};

// Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: homeLabel,
      item: siteUrl,
    },
  ],
};

// Add current page to breadcrumb if not home
if (currentPath !== "/") {
  const currentPage = title.split(" - ")[0] || title;
  breadcrumbSchema.itemListElement.push({
    "@type": "ListItem",
    position: 2,
    name: currentPage,
    item: canonical,
  });
}

// Article schema for blog posts
const articleSchema =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        "@id": `${canonical}#article`,
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonical,
        },
        headline: title,
        description: description,
        ...(fullImageUrl ? { image: fullImageUrl } : {}),
        datePublished: publishedTime,
        author: {
          "@type": "Organization",
          "@id": `${siteUrl}/#organization`,
          name: author || "Dreamy Tours",
        },
        publisher: {
          "@type": "Organization",
          "@id": `${siteUrl}/#organization`,
          name: "Dreamy Tours",
          logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/logo-dreamytours.svg`,
          },
        },
      }
    : null;

const additionalSchemas = (Array.isArray(schemas) ? schemas : [schemas]).filter(
  Boolean,
) as Record<string, unknown>[];
---

<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Alternate Languages (hreflang) -->
{
  alternateUrls.map((alt) => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.url} />
  ))
}

<!-- Default to English if no hreflang matches -->
<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
{description && <meta name="description" content={description} />}
{keywords && <meta name="keywords" content={keywords} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{
  fullImageUrl && (
    <>
      <meta property="og:image" content={fullImageUrl} />
      <meta property="og:image:secure_url" content={fullImageUrl} />
      <meta property="og:image:alt" content={imageAlt} />
    </>
  )
}
<meta property="og:locale" content={ogLocale} />

{/* Alternate locales for OG */}
{
  alternateUrls
    .filter((alt) => alt.lang !== lang)
    .map((alt) => (
      <meta property="og:locale:alternate" content={alt.locale} />
    ))
}

{/* Article specific meta tags */}
{
  type === "article" && (
    <>
      {publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )}
      {author && <meta property="article:author" content={author} />}
    </>
  )
}

<!-- Twitter -->
<meta
  name="twitter:card"
  content={fullImageUrl ? "summary_large_image" : "summary"}
/>
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{
  fullImageUrl && (
    <>
      <meta name="twitter:image" content={fullImageUrl} />
      <meta name="twitter:image:alt" content={imageAlt} />
    </>
  )
}

<!-- Additional SEO -->
<meta name="author" content={author || "Dreamy Tours"} />
<meta name="robots" content={robots} />
<meta name="googlebot" content={robots} />


<!-- Schema.org JSON-LD -->
<script
  is:inline
  type="application/ld+json"
  set:html={serializeJsonForHtml(websiteSchema)}
/>
<script
  is:inline
  type="application/ld+json"
  set:html={serializeJsonForHtml(organizationSchema)}
/>
<script
  is:inline
  type="application/ld+json"
  set:html={serializeJsonForHtml(breadcrumbSchema)}
/>
{
  articleSchema && (
    <script
      is:inline
      type="application/ld+json"
      set:html={serializeJsonForHtml(articleSchema)}
    />
  )
}
{
  additionalSchemas.map((schema) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={serializeJsonForHtml(schema)}
    />
  ))
}
