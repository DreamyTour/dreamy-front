---
import type { Global } from "@/types/global";

import TopBar from "@/components/layout/TopBar.astro";
import HeaderTop from "@/components/layout/HeaderTop.astro";
import Menu from "@/components/layout/Menu.tsx";
import type { Lang } from "@/lib/i18n";

interface Props {
  data: Global;
  lang: Lang;
}

const { data, lang } = Astro.props;
---

<header class="w-full border-solid border-b border-border shadow-sm">
  <TopBar data={data?.topBar} lang={lang} />
  <HeaderTop data={data?.headerTop} lang={lang} />
  <div class="border-t border-primary/20 mt-2"></div>
  <Menu
    menu={data?.menu}
    logo={data?.headerTop?.logo}
    lang={lang}
    client:load
    transition:persist
  />
</header>
