---
import type { Global, Link } from "@/types/global";

import TopBar from "@/components/layout/TopBar.astro";
import HeaderTop from "@/components/layout/HeaderTop.astro";
import DesktopMenu from "@/components/layout/DesktopMenu.tsx";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import type { Lang } from "@/lib/i18n";
import { localizePath } from "@/lib/i18n";

interface Props {
  data: Global;
  lang: Lang;
}

const { data, lang } = Astro.props;
const mobileLogoUrl = localizePath("/", lang);
const isBlogLink = (link: Link) =>
  link.url?.includes("/blog") || link.label?.toLowerCase().includes("blog");
const isContactLink = (link: Link) => {
  const content = `${link.label ?? ""} ${link.url ?? ""}`.toLowerCase();
  return (
    content.includes("contact") ||
    content.includes("contacto") ||
    content.includes("contato")
  );
};
const blogLink = data?.headerTop?.headerLink?.find(isBlogLink) ?? {
  id: -1,
  label: "Blog",
  url: "/blog",
  isButton: true,
  isExternal: false,
  type: "SECONDARY",
};
const mobileQuickActions = [
  blogLink,
  ...(data?.headerTop?.button ?? []).filter(
    (link) => !isContactLink(link) && !isBlogLink(link),
  ),
];
---

<header class="w-full shadow-sm">
  <TopBar data={data?.topBar} lang={lang} />
  <HeaderTop data={data?.headerTop} lang={lang} />
  <hr class="border-t border-primary/20" aria-hidden="true" />
  <DesktopMenu
    menu={data?.menu}
    lang={lang}
    client:media="(min-width: 1280px)"
    transition:persist
  />
  <MobileMenu
    menu={data?.menu}
    quickActions={mobileQuickActions}
    logoUrl={mobileLogoUrl}
    lang={lang}
    transition:persist
  />
</header>
