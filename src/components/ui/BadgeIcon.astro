---
import {
  DurationIcon,
  DifficultyIcon,
  GroupIcon,
  AltitudeIcon,
  GuideIcon,
  TransportIcon,
  MealsIcon,
  DefaultBadgeIcon
} from "@/components/icons/BadgeIcons";

interface Props {
  title?: string;
  content?: string;
  className?: string;
}

const { title = "", content = "", className = "size-6" } = Astro.props;

const searchStr = `${title} ${content}`
  .toLowerCase()
  .normalize("NFD")
  .replace(/[\u0300-\u036f]/g, "");

let iconType = "default";
if (
  searchStr.includes("duracion") ||
  searchStr.includes("duration") ||
  searchStr.includes("tiempo") ||
  searchStr.includes("dia") ||
  searchStr.includes("day") ||
  searchStr.includes("hora") ||
  searchStr.includes("hour")
)
  iconType = "duration";
else if (
  searchStr.includes("dificultad") ||
  searchStr.includes("difficulty") ||
  searchStr.includes("nivel") ||
  searchStr.includes("level")
)
  iconType = "difficulty";
else if (
  searchStr.includes("grupo") ||
  searchStr.includes("group") ||
  searchStr.includes("tamano") ||
  searchStr.includes("persona") ||
  searchStr.includes("pax")
)
  iconType = "group";
else if (
  searchStr.includes("altitud") ||
  searchStr.includes("altura") ||
  searchStr.includes("altitude") ||
  searchStr.includes("msnm")
)
  iconType = "altitude";
else if (
  searchStr.includes("guia") ||
  searchStr.includes("guide") ||
  searchStr.includes("idioma") ||
  searchStr.includes("language")
)
  iconType = "guide";
else if (
  searchStr.includes("transporte") ||
  searchStr.includes("transport") ||
  searchStr.includes("bus") ||
  searchStr.includes("tren") ||
  searchStr.includes("vuelo")
)
  iconType = "transport";
else if (
  searchStr.includes("comida") ||
  searchStr.includes("meal") ||
  searchStr.includes("alimentacion") ||
  searchStr.includes("desayuno") ||
  searchStr.includes("almuerzo") ||
  searchStr.includes("cena")
)
  iconType = "meals";
---

{
  iconType === "duration" && <DurationIcon className={className} />
}
{
  iconType === "difficulty" && <DifficultyIcon className={className} />
}
{
  iconType === "group" && <GroupIcon className={className} />
}
{
  iconType === "altitude" && <AltitudeIcon className={className} />
}
{
  iconType === "guide" && <GuideIcon className={className} />
}
{
  iconType === "transport" && <TransportIcon className={className} />
}
{
  iconType === "meals" && <MealsIcon className={className} />
}
{
  iconType === "default" && <DefaultBadgeIcon className={className} />
}
