---
import type { Tour } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";
import TourCard from "@/components/ui/TourCard.astro";

interface Props {
  tours: Tour[];
  lang: Lang;
}

const { tours, lang } = Astro.props;
const loopedTours = tours.length > 1 ? [...tours, ...tours, ...tours] : tours;
---

<div class="relative" data-tours-slider>
  <div class="px-4 md:px-14">
    <div class="overflow-hidden">
    <!-- Slider Container - horizontal scroll -->
      <div
        class="flex gap-6 overflow-x-auto py-4 snap-x snap-mandatory items-stretch scrollbar-hide"
        id={`slider-${Math.random().toString(36).substr(2, 9)}`}
        data-slider-track
        data-original-count={tours.length}
      >
        {
          loopedTours.map((tour) => (
            <div class="flex-shrink-0 w-full md:w-[calc((100%-24px)/2)] lg:w-[calc((100%-72px)/4)] snap-start">
              <TourCard tour={tour} lang={lang} />
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Navigation Arrows -->
  <button
    class="slider-prev absolute left-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-gray-50 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
    aria-label="Ver tours anteriores"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-6 h-6 text-gray-700"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"
      ></path>
    </svg>
  </button>

  <button
    class="slider-next absolute right-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center hover:bg-gray-50 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
    aria-label="Ver siguientes tours"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-6 h-6 text-gray-700"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
      ></path>
    </svg>
  </button>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const sliderRoots = document.querySelectorAll("[data-tours-slider]");

    sliderRoots.forEach((root) => {
      const sliderRoot = root as HTMLElement;
      const container = sliderRoot.querySelector("[data-slider-track]") as HTMLElement | null;
      const prevBtn = sliderRoot.querySelector(".slider-prev") as HTMLButtonElement | null;
      const nextBtn = sliderRoot.querySelector(".slider-next") as HTMLButtonElement | null;

      if (!container || !prevBtn || !nextBtn || container.dataset.sliderInitialized === "true") return;

      container.dataset.sliderInitialized = "true";

      const slides = Array.from(container.children) as HTMLElement[];
      const originalSlidesCount = Number(container.dataset.originalCount || slides.length);
      const autoPlayDelay = 3500;
      let autoPlay: ReturnType<typeof window.setInterval> | undefined;
      let scrollAmount = 0;
      let loopWidth = 0;
      let isAdjustingScroll = false;

      const calculateMetrics = () => {
        const slideWidth = slides[0]?.getBoundingClientRect().width ?? container.offsetWidth;
        const styles = window.getComputedStyle(container);
        const gapValue = styles.columnGap || styles.gap || "0";
        const gap = Number.parseFloat(gapValue);

        scrollAmount = slideWidth + gap;
        loopWidth = originalSlidesCount * scrollAmount;
      };

      const setScrollPosition = (left: number) => {
        isAdjustingScroll = true;
        container.scrollTo({ left, behavior: "auto" });
        window.setTimeout(() => {
          isAdjustingScroll = false;
        }, 0);
      };

      const normalizeScroll = () => {
        if (slides.length <= 1 || isAdjustingScroll) return;

        if (container.scrollLeft >= loopWidth * 2 - scrollAmount / 2) {
          setScrollPosition(container.scrollLeft - loopWidth);
        } else if (container.scrollLeft < loopWidth - scrollAmount / 2) {
          setScrollPosition(container.scrollLeft + loopWidth);
        }
      };

      const moveSlider = (direction: 1 | -1) => {
        normalizeScroll();
        container.scrollBy({ left: scrollAmount * direction, behavior: "smooth" });
        window.setTimeout(normalizeScroll, 450);
      };

      const stopAutoPlay = () => {
        if (!autoPlay) return;
        window.clearInterval(autoPlay);
        autoPlay = undefined;
      };

      const startAutoPlay = () => {
        if (slides.length <= 1 || autoPlay) return;
        autoPlay = window.setInterval(() => {
          moveSlider(1);
        }, autoPlayDelay);
      };

      const handleResize = () => {
        const currentIndex = scrollAmount > 0 ? Math.round(container.scrollLeft / scrollAmount) : 0;
        calculateMetrics();
        setScrollPosition(currentIndex * scrollAmount);
        normalizeScroll();
      };

      calculateMetrics();

      if (slides.length > 1) {
        requestAnimationFrame(() => {
          calculateMetrics();
          setScrollPosition(loopWidth);
        });
      }

      prevBtn.addEventListener("click", () => {
        stopAutoPlay();
        moveSlider(-1);
        startAutoPlay();
      });

      nextBtn.addEventListener("click", () => {
        stopAutoPlay();
        moveSlider(1);
        startAutoPlay();
      });

      container.addEventListener("scroll", normalizeScroll, { passive: true });
      container.addEventListener("mouseenter", stopAutoPlay);
      container.addEventListener("mouseleave", startAutoPlay);
      container.addEventListener("focusin", stopAutoPlay);
      container.addEventListener("focusout", startAutoPlay);
      window.addEventListener("resize", handleResize);

      startAutoPlay();
    });
  });
</script>
