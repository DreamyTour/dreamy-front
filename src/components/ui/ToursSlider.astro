---
import type { Tour } from "@/types/tours";
import type { Lang } from "@/lib/i18n";
import TourCard from "@/components/ui/TourCard.astro";
import {
  ArrowLeftIcon,
  ArrowRightIcon,
} from "@/components/icons/NavigationIcons";

interface Props {
  tours: Tour[];
  lang: Lang;
  labelledBy?: string;
}

const { tours, lang, labelledBy } = Astro.props;
const shouldLoop = tours.length > 3;
const sliderId = `slider-${Math.random().toString(36).slice(2, 11)}`;
const sliderLabels = {
  en: {
    section: "Featured tours",
    previous: "Show previous tours",
    next: "Show next tours",
  },
  es: {
    section: "Tours destacados",
    previous: "Ver tours anteriores",
    next: "Ver siguientes tours",
  },
  pt: {
    section: "Tours em destaque",
    previous: "Ver tours anteriores",
    next: "Ver próximos tours",
  },
}[lang];
---

<section
  class="relative"
  data-tours-slider
  aria-labelledby={labelledBy}
  aria-label={labelledBy ? undefined : sliderLabels.section}
>
  <div class="overflow-hidden">
    <ul
      class="flex list-none gap-6 overflow-x-auto px-0 py-4 snap-x snap-mandatory items-stretch scrollbar-hide"
      id={sliderId}
      data-slider-track
      data-original-count={tours.length}
      data-is-looped={shouldLoop ? "true" : "false"}
    >
      {
        tours.map((tour) => (
          <li class="flex-shrink-0 w-full md:w-[calc((100%-24px)/2)] lg:w-[calc((100%-48px)/3)] snap-start">
            <TourCard tour={tour} lang={lang} />
          </li>
        ))
      }
    </ul>
  </div>

  <button
    class="slider-prev absolute -left-3 top-[calc((100vw-3rem)*0.75+1rem)] z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border-4 border-background bg-primary text-primary-foreground shadow-[0_18px_40px_-18px_color-mix(in_oklab,var(--primary)_72%,transparent)] transition-shadow duration-200 hover:shadow-[0_22px_48px_-18px_color-mix(in_oklab,var(--primary)_82%,transparent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary md:-left-7 md:top-1/2 md:h-14 md:w-14"
    aria-label={sliderLabels.previous}
    aria-controls={sliderId}
  >
    <ArrowLeftIcon className="w-6 h-6 text-current" aria-hidden="true" />
  </button>

  <button
    class="slider-next absolute -right-3 top-[calc((100vw-3rem)*0.75+1rem)] z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border-4 border-background bg-primary text-primary-foreground shadow-[0_18px_40px_-18px_color-mix(in_oklab,var(--primary)_72%,transparent)] transition-shadow duration-200 hover:shadow-[0_22px_48px_-18px_color-mix(in_oklab,var(--primary)_82%,transparent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary md:-right-7 md:top-1/2 md:h-14 md:w-14"
    aria-label={sliderLabels.next}
    aria-controls={sliderId}
  >
    <ArrowRightIcon className="w-6 h-6 text-current" aria-hidden="true" />
  </button>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  const initAllSliders = () => {
    const sliderRoots = document.querySelectorAll("[data-tours-slider]");

    const initializeSlider = (root: Element) => {
      const sliderRoot = root as HTMLElement;
      const container = sliderRoot.querySelector(
        "[data-slider-track]",
      ) as HTMLElement | null;
      const prevBtn = sliderRoot.querySelector(
        ".slider-prev",
      ) as HTMLButtonElement | null;
      const nextBtn = sliderRoot.querySelector(
        ".slider-next",
      ) as HTMLButtonElement | null;

      if (
        !container ||
        !prevBtn ||
        !nextBtn ||
        container.dataset.sliderInitialized === "true"
      )
        return;

      container.dataset.sliderInitialized = "true";

      const slides = Array.from(container.children) as HTMLElement[];
      const isLooped = container.dataset.isLooped === "true";
      const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
      const autoPlayDelay = 2000;
      let autoPlay: number | undefined;
      let scrollAmount = 0;

      const calculateMetrics = () => {
        const slideWidth =
          slides[0]?.getBoundingClientRect().width ?? container.offsetWidth;
        const styles = window.getComputedStyle(container);
        const gapValue = styles.columnGap || styles.gap || "0";
        const gap = Number.parseFloat(gapValue);

        scrollAmount = slideWidth + gap;
      };

      const setScrollPosition = (left: number) => {
        container.scrollTo({ left, behavior: "auto" });
      };

      const moveSlider = (direction: 1 | -1) => {
        const maxScrollLeft = container.scrollWidth - container.clientWidth;
        const atEnd = container.scrollLeft >= maxScrollLeft - scrollAmount / 2;
        const atStart = container.scrollLeft <= scrollAmount / 2;

        if (isLooped && direction === 1 && atEnd) {
          setScrollPosition(0);
          return;
        }

        if (isLooped && direction === -1 && atStart) {
          setScrollPosition(maxScrollLeft);
          return;
        }

        container.scrollBy({
          left: scrollAmount * direction,
          behavior: motionQuery.matches ? "auto" : "smooth",
        });
      };

      const stopAutoPlay = () => {
        if (!autoPlay) return;
        window.clearInterval(autoPlay);
        autoPlay = undefined;
      };

      const startAutoPlay = () => {
        if (!isLooped || slides.length <= 1 || autoPlay || motionQuery.matches)
          return;
        autoPlay = window.setInterval(() => {
          moveSlider(1);
        }, autoPlayDelay);
      };

      const handleResize = () => {
        const currentIndex =
          scrollAmount > 0
            ? Math.round(container.scrollLeft / scrollAmount)
            : 0;
        calculateMetrics();
        setScrollPosition(currentIndex * scrollAmount);
      };

      requestAnimationFrame(calculateMetrics);

      prevBtn.addEventListener("click", () => {
        if (scrollAmount === 0) calculateMetrics();
        stopAutoPlay();
        moveSlider(-1);
        startAutoPlay();
      });

      nextBtn.addEventListener("click", () => {
        if (scrollAmount === 0) calculateMetrics();
        stopAutoPlay();
        moveSlider(1);
        startAutoPlay();
      });

      container.addEventListener("mouseenter", stopAutoPlay);
      container.addEventListener("mouseleave", startAutoPlay);
      container.addEventListener("focusin", stopAutoPlay);
      container.addEventListener("focusout", startAutoPlay);
      window.addEventListener("resize", handleResize);
      motionQuery.addEventListener("change", () => {
        stopAutoPlay();
        startAutoPlay();
      });

      startAutoPlay();
    };

    if (!("IntersectionObserver" in window)) {
      sliderRoots.forEach(initializeSlider);
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          initializeSlider(entry.target);
        });
      },
      { rootMargin: "400px 0px" },
    );

    sliderRoots.forEach((root) => observer.observe(root));
  };

  // Works with ClientRouter (astro:page-load) AND without it (DOMContentLoaded)
  document.addEventListener("astro:page-load", initAllSliders);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAllSliders, {
      once: true,
    });
  } else {
    // DOM already ready (script runs after parse on pages without ClientRouter)
    initAllSliders();
  }
</script>
