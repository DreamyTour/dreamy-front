---
interface Props {
  certificates: { src: string; title: string }[];
}

const { certificates } = Astro.props;
---

<div class="certificates-gallery">
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      certificates.map((certificate) => (
        <button
          type="button"
          class="certificate-trigger group overflow-hidden rounded-xl border border-border bg-muted/30 text-left transition-all duration-300 hover:-translate-y-0.5 hover:border-secondary/40 hover:shadow-lg"
          data-certificate-src={certificate.src}
          data-certificate-title={certificate.title}
          aria-label={`Open ${certificate.title}`}
        >
          <div class="aspect-[4/3] overflow-hidden bg-white">
            <img
              src={certificate.src}
              alt={certificate.title}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
            />
          </div>
          <div class="flex items-center justify-between gap-3 p-4">
            <p class="text-sm font-medium tracking-[-0.01em] text-foreground">
              {certificate.title}
            </p>
            <span class="text-xs font-semibold uppercase tracking-[0.24em] text-secondary">
              View
            </span>
          </div>
        </button>
      ))
    }
  </div>

  <div
    id="certificate_lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/20 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-labelledby="certificate_lightbox_title"
  >
    <div class="relative w-full max-w-3xl">
      <button
        type="button"
        id="certificate_lightbox_close"
        class="absolute right-3 top-3 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-red-500 text-white shadow-lg transition-colors hover:bg-red-600"
        aria-label="Close certifications popup"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>

      <div class="overflow-hidden rounded-2xl bg-white shadow-2xl">
        <div class="border-b border-border px-6 py-4">
          <p
            id="certificate_lightbox_title"
            class="text-center text-sm font-semibold uppercase tracking-[0.24em] text-foreground"
          >
            Certification
          </p>
        </div>
        <div class="bg-muted/40 p-4 md:p-6 flex items-center justify-center">
          <img
            id="certificate_lightbox_image"
            src=""
            alt=""
            class="max-h-[70vh] w-auto rounded-xl object-contain bg-white"
          />
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const certificateTriggers = document.querySelectorAll(
      ".certificate-trigger",
    );
    const certificateLightbox = document.getElementById("certificate_lightbox");
    const certificateLightboxImage = document.getElementById(
      "certificate_lightbox_image",
    );
    const certificateLightboxTitle = document.getElementById(
      "certificate_lightbox_title",
    );
    const certificateLightboxClose = document.getElementById(
      "certificate_lightbox_close",
    );

    const closeCertificateLightbox = () => {
      if (!certificateLightbox) return;
      certificateLightbox.classList.add("hidden");
      certificateLightbox.classList.remove("flex");
    };

    certificateTriggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        if (
          !certificateLightbox ||
          !certificateLightboxImage ||
          !certificateLightboxTitle
        )
          return;

        const src = trigger.getAttribute("data-certificate-src");
        const title =
          trigger.getAttribute("data-certificate-title") || "Certification";

        if (!src) return;

        certificateLightboxImage.setAttribute("src", src);
        certificateLightboxImage.setAttribute("alt", title);
        certificateLightboxTitle.textContent = title;

        certificateLightbox.classList.remove("hidden");
        certificateLightbox.classList.add("flex");
      });
    });

    certificateLightboxClose?.addEventListener(
      "click",
      closeCertificateLightbox,
    );

    certificateLightbox?.addEventListener("click", (event) => {
      if (event.target === certificateLightbox) {
        closeCertificateLightbox();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeCertificateLightbox();
      }
    });
  });
</script>
