---
interface Props {
  certificates: { src: string; title: string }[];
  actionLabel?: string;
  dialogLabel?: string;
  closeLabel?: string;
}

const {
  certificates,
  actionLabel = "View",
  dialogLabel = "Certification",
  closeLabel = "Close certifications popup",
} = Astro.props;
---

<div class="certificates-gallery not-prose">
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      certificates.map((certificate) => (
        <button
          type="button"
          class="certificate-trigger group relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white text-left shadow-sm ring-1 ring-transparent transition-all duration-300 ease-out hover:-translate-y-1 hover:border-primary/35 hover:shadow-xl hover:shadow-slate-900/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
          data-certificate-src={certificate.src}
          data-certificate-title={certificate.title}
          aria-label={`Open ${certificate.title}`}
        >
          <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-slate-50 to-white">
            <img
              src={certificate.src}
              alt={certificate.title}
              class="h-full w-full object-contain p-6 transition-transform duration-500 ease-out group-hover:scale-[1.035]"
              loading="lazy"
            />

            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-slate-950/55 via-slate-950/10 to-transparent opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-100"></div>

            <div class="absolute bottom-4 left-1/2 flex -translate-x-1/2 translate-y-3 items-center gap-2 rounded-full bg-primary px-4 py-2 text-xs font-semibold text-white opacity-0 shadow-lg shadow-primary/25 ring-1 ring-white/20 backdrop-blur transition-all duration-300 ease-out group-hover:translate-y-0 group-hover:opacity-100">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.3"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>

              <span>{actionLabel}</span>
            </div>
          </div>

          <div class="border-t border-slate-100 px-4 py-4">
            <h3 class="line-clamp-2 text-sm font-semibold leading-snug text-slate-900 transition-colors duration-300 group-hover:text-primary">
              {certificate.title}
            </h3>
          </div>
        </button>
      ))
    }
  </div>

  <div
    id="certificate_lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label={dialogLabel}
  >
    <div class="relative flex max-h-[86vh] max-w-[min(92vw,72rem)] items-center justify-center">
      <button
        type="button"
        id="certificate_lightbox_close"
        class="absolute -right-3 -top-3 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-primary text-white shadow-lg ring-2 ring-white/80 transition-all duration-300 hover:scale-105 hover:bg-red-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
        aria-label={closeLabel}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>

      <img
        id="certificate_lightbox_image"
        src=""
        alt=""
        class="max-h-[86vh] w-auto max-w-full rounded-xl bg-white object-contain shadow-2xl"
      />
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const certificateTriggers = document.querySelectorAll<HTMLButtonElement>(
      ".certificate-trigger",
    );

    const certificateLightbox = document.getElementById("certificate_lightbox");

    const certificateLightboxImage = document.getElementById(
      "certificate_lightbox_image",
    ) as HTMLImageElement | null;

    const certificateLightboxClose = document.getElementById(
      "certificate_lightbox_close",
    ) as HTMLButtonElement | null;

    let lastCertificateTrigger: HTMLButtonElement | null = null;

    const closeCertificateLightbox = () => {
      if (!certificateLightbox || !certificateLightboxImage) return;

      certificateLightbox.classList.add("hidden");
      certificateLightbox.classList.remove("flex");

      certificateLightboxImage.setAttribute("src", "");
      certificateLightboxImage.setAttribute("alt", "");

      document.body.style.overflow = "";

      if (lastCertificateTrigger) {
        lastCertificateTrigger.focus();
      }
    };

    certificateTriggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        if (!certificateLightbox || !certificateLightboxImage) return;

        const src = trigger.getAttribute("data-certificate-src");
        const title =
          trigger.getAttribute("data-certificate-title") || "Certification";

        if (!src) return;

        lastCertificateTrigger = trigger;

        certificateLightboxImage.setAttribute("src", src);
        certificateLightboxImage.setAttribute("alt", title);

        certificateLightbox.classList.remove("hidden");
        certificateLightbox.classList.add("flex");

        document.body.style.overflow = "hidden";

        certificateLightboxClose?.focus();
      });
    });

    certificateLightboxClose?.addEventListener(
      "click",
      closeCertificateLightbox,
    );

    certificateLightbox?.addEventListener("click", (event) => {
      if (event.target === certificateLightbox) {
        closeCertificateLightbox();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (
        !certificateLightbox ||
        certificateLightbox.classList.contains("hidden")
      ) {
        return;
      }

      if (event.key === "Escape") {
        closeCertificateLightbox();
      }

      if (event.key === "Tab") {
        const focusable = certificateLightbox.querySelectorAll<HTMLElement>(
          'button:not([disabled]), [href], [tabindex]:not([tabindex="-1"])',
        );

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (!first || !last) return;

        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });
  });
</script>