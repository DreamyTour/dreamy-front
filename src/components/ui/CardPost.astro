---
import type { Blog } from "@/types/blog";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import { getImageAlt, getImageSrcSet, getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  blog: Blog;
  lang: Lang;
  isFeatured?: boolean;
  showDescription?: boolean;
  headingLevel?: "h2" | "h3";
}

const {
  blog,
  lang,
  showDescription = false,
  headingLevel = "h2",
} = Astro.props;

if (!blog) return null;

const t = useTranslations(lang);
const mainImage = getImageUrl(blog.portadaImage, "medium");
const imageSrcSet = getImageSrcSet(blog.portadaImage, [
  "thumbnail",
  "small",
  "medium",
]);
const imageAlt = getImageAlt(blog.portadaImage, blog.titulo);
const category = blog.category_blogs?.[0]?.nombre || null;
const publishedDate = blog.publishedAt || blog.createdAt;
const formattedDate = publishedDate
  ? new Date(publishedDate).toLocaleDateString(
      lang === "es" ? "es-ES" : lang === "pt" ? "pt-BR" : "en-US",
      { day: "numeric", month: "short", year: "numeric" },
    )
  : null;

function extractPlainText(value: unknown): string {
  if (!value) return "";
  if (typeof value === "string") {
    return value
      .replace(/<[^>]+>/g, " ")
      .replace(/&[^;]+;/g, " ")
      .replace(/\s+/g, " ")
      .trim();
  }
  if (Array.isArray(value)) {
    return value
      .map(extractPlainText)
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }
  if (typeof value === "object") {
    const record = value as Record<string, unknown>;
    return [
      typeof record.text === "string" ? record.text : "",
      extractPlainText(record.children),
    ]
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }
  return "";
}

const plainContent = extractPlainText(blog.contenido);
const excerpt =
  showDescription && plainContent
    ? plainContent.length > 132
      ? `${plainContent.slice(0, 129).trimEnd()}...`
      : plainContent
    : null;
const wordCount = plainContent.split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 210));
const readingText = `${readingMinutes} min`;
const Heading = headingLevel;
---

<article class="group h-full min-w-0">
  <a
    href={rewriteUrl(`/blog/${blog.slug}`, lang)}
    aria-label={`${t("aria.leerArticulo")}: ${blog.titulo}`}
    class="flex h-full min-h-[25rem] flex-col overflow-hidden rounded-xl border border-border bg-card text-foreground shadow-[0_14px_34px_-24px_rgba(15,32,23,0.45)] transition duration-300 hover:-translate-y-1 hover:border-secondary/30 hover:shadow-[0_22px_46px_-24px_rgba(15,32,23,0.55)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/45 motion-reduce:transform-none"
  >
    <div class="relative aspect-[4/2.7] shrink-0 overflow-hidden bg-muted">
      {
        mainImage && mainImage !== "/og-default.jpg" ? (
          <img
            src={mainImage}
            srcset={imageSrcSet || undefined}
            sizes="(max-width: 639px) 100vw, (max-width: 1023px) 50vw, (max-width: 1279px) 33vw, 25vw"
            alt={imageAlt}
            width="640"
            height="432"
            class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.045] motion-reduce:transform-none"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="grid h-full place-items-center bg-[linear-gradient(145deg,color-mix(in_oklab,var(--primary)_13%,white),color-mix(in_oklab,var(--secondary)_12%,white))]">
            <span class="text-xs font-semibold uppercase tracking-[0.16em] text-primary/70">
              Dreamy Tours
            </span>
          </div>
        )
      }

      {
        category && (
          <span class="absolute bottom-3 left-3 max-w-[calc(100%-1.5rem)] truncate rounded-full bg-secondary px-3 py-1 text-[0.64rem] font-bold uppercase tracking-[0.08em] text-secondary-foreground shadow-sm">
            {category}
          </span>
        )
      }
    </div>

    <div class="flex flex-1 flex-col gap-3 p-4 sm:p-5">
      <Heading
        class="line-clamp-3 text-lg font-semibold leading-[1.12] tracking-[-0.01em] text-foreground"
      >
        {blog.titulo}
      </Heading>

      {
        excerpt && (
          <p class="line-clamp-3 text-sm leading-5 text-muted-foreground">
            {excerpt}
          </p>
        )
      }

      <div
        class="mt-auto flex flex-wrap items-center justify-between gap-3 border-t border-border pt-3.5 text-xs text-muted-foreground"
      >
        {
          formattedDate && (
            <span class="inline-flex items-center gap-1.5">
              <svg
                class="size-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14H3V6a2 2 0 0 1 2-2Z" />
              </svg>
              {formattedDate}
            </span>
          )
        }
        <span class="inline-flex items-center gap-1.5">
          <svg
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 7v5l3 2"></path>
          </svg>
          {readingText}
        </span>
      </div>
    </div>
  </a>
</article>
