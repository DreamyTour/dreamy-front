---
import type { Blog } from "@/interface/blog";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import { getImageAlt, getImageSrcSet, getImageUrl } from "@/lib/helpers";

interface Props {
  blog: Blog;
  lang: Lang;
  isFeatured?: boolean;
  showDescription?: boolean;
}

const { blog, lang, isFeatured = false, showDescription = false } = Astro.props;

if (!blog) return null;

const t = useTranslations(lang);
const mainImage = getImageUrl(blog.portadaImage, isFeatured ? "large" : "medium");
const imageSrcSet = getImageSrcSet(blog.portadaImage, [
  "thumbnail",
  "small",
  "medium",
  "large",
]);
const imageAlt = getImageAlt(blog.portadaImage, blog.titulo);

const category = blog.category_blogs?.[0]?.nombre || null;

const publishedDate = blog.publishedAt || blog.createdAt;
const formattedDate = publishedDate
  ? new Date(publishedDate).toLocaleDateString(
      lang === "es" ? "es-ES" : lang === "pt" ? "pt-BR" : "en-US",
      {
        month: "short",
        day: "numeric",
        year: "numeric",
      },
    )
  : null;

function extractPlainText(value: unknown): string {
  if (!value) return "";

  if (typeof value === "string") {
    return value
      .replace(/<[^>]+>/g, " ")
      .replace(/&[^;]+;/g, " ")
      .replace(/\s+/g, " ")
      .trim();
  }

  if (Array.isArray(value)) {
    return value
      .map((item) => extractPlainText(item))
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }

  if (typeof value === "object") {
    const record = value as Record<string, unknown>;
    const ownText =
      typeof record.text === "string" ? record.text : "";
    const childrenText = extractPlainText(record.children);

    return [ownText, childrenText]
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }

  return "";
}

const plainContent = extractPlainText(blog.contenido);

const excerpt =
  showDescription && plainContent
    ? plainContent.length > 138
      ? `${plainContent.slice(0, 135).trimEnd()}...`
      : plainContent
    : null;

const cardHeight = isFeatured ? "min-h-[500px]" : "min-h-[440px]";
const imageHeight = isFeatured ? "aspect-[16/9]" : "aspect-[4/3]";
---

<article class:list={["group h-full", isFeatured && "lg:col-span-2"]}>
  <a
    href={`/${lang}/blog/${blog.slug}`}
    aria-label={`${t("aria.leerArticulo")}: ${blog.titulo}`}
    class:list={[
      "relative flex h-full flex-col overflow-hidden rounded-sm border border-primary/10 bg-white/95 text-slate-900 shadow-[0_18px_60px_rgba(7,25,23,0.08)] transition-all duration-500 ease-out hover:-translate-y-2 hover:border-secondary/30 hover:shadow-[0_30px_70px_rgba(7,25,23,0.16)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/40",
      cardHeight,
    ]}
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-[radial-gradient(circle_at_top,_rgba(205,166,94,0.2),_transparent_65%)] opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    >
    </div>

    <div class:list={["relative overflow-hidden", imageHeight]}>
      {
        mainImage && mainImage !== "/og-default.jpg" ? (
          <img
            src={mainImage}
            srcset={imageSrcSet || undefined}
            sizes={isFeatured ? "(max-width: 1023px) 100vw, 66vw" : "(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw"}
            alt={imageAlt}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="flex h-full items-center justify-center bg-gradient-to-br from-primary/10 via-secondary/10 to-primary/5">
            <span class="rounded-sm border border-primary/10 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-primary/60">
              No image
            </span>
          </div>
        )
      }

      <div
        class="absolute inset-0 bg-gradient-to-t from-[#081815]/85 via-[#081815]/18 to-transparent"
      >
      </div>
      <div
        class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#081815]/70 to-transparent"
      >
      </div>

      <div class="absolute left-5 top-5 flex items-center gap-3">
        {
          category && (
            <span class="inline-flex items-center rounded-sm border border-white/20 bg-white/14 px-4 py-2 text-[0.65rem] font-semibold uppercase tracking-[0.34em] text-white/92 shadow-[0_10px_30px_rgba(0,0,0,0.18)] backdrop-blur-md">
              {category}
            </span>
          )
        }
      </div>
    </div>

    <div
      class="relative flex flex-1 flex-col gap-5 px-6 pb-6 pt-6 md:px-7 md:pb-7"
    >
      <div
        class="flex items-center justify-between gap-4 text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-primary/55"
      >
        {
          formattedDate ? (
            <span class="inline-flex items-center gap-2 text-primary/55">
              <span class="h-1.5 w-1.5 rounded-full bg-secondary" />
              {formattedDate}
            </span>
          ) : (
            <span class="inline-flex items-center gap-2 text-primary/45">
              <span class="h-1.5 w-1.5 rounded-full bg-secondary/60" />
              Journal
            </span>
          )
        }
        <span
          class="text-secondary transition-transform duration-300 group-hover:translate-x-1"
        >
          ↗
        </span>
      </div>

      <div class="space-y-3">
        <h3
          class="max-w-[18ch] text-[1.45rem] font-semibold leading-[1.15] text-slate-950 transition-colors duration-300 group-hover:text-secondary md:text-[1.7rem]"
        >
          {blog.titulo}
        </h3>

        {
          excerpt && (
            <p class="max-w-[34ch] text-sm leading-6 text-slate-600/95 line-clamp-3 md:text-[0.96rem]">
              {excerpt}
            </p>
          )
        }
      </div>

      <div class="mt-auto flex items-center border-t border-primary/8 pt-5">
        <span
          class="inline-flex items-center gap-2 rounded-sm border border-secondary/18 bg-secondary/10 px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary transition-all duration-300 group-hover:border-secondary/30 group-hover:bg-secondary group-hover:text-white"
        >
          {t("blog.leerMas")}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
