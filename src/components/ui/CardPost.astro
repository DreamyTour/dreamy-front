---
import type { Blog } from "@/types/blog";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import { getImageAlt, getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  blog: Blog;
  lang: Lang;
  isFeatured?: boolean;
  showDescription?: boolean;
}

const { blog, lang, isFeatured = false, showDescription = false } = Astro.props;

if (!blog) return null;

const t = useTranslations(lang);
const mainImage = getImageUrl(blog.portadaImage, "small");
const imageAlt = getImageAlt(blog.portadaImage, blog.titulo);

const category = blog.category_blogs?.[0]?.nombre || null;

const publishedDate = blog.publishedAt || blog.createdAt;
const formattedDate = publishedDate
  ? new Date(publishedDate).toLocaleDateString(
      lang === "es" ? "es-ES" : lang === "pt" ? "pt-BR" : "en-US",
      {
        month: "short",
        day: "numeric",
        year: "numeric",
      },
    )
  : null;

function extractPlainText(value: unknown): string {
  if (!value) return "";

  if (typeof value === "string") {
    return value
      .replace(/<[^>]+>/g, " ")
      .replace(/&[^;]+;/g, " ")
      .replace(/\s+/g, " ")
      .trim();
  }

  if (Array.isArray(value)) {
    return value
      .map((item) => extractPlainText(item))
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }

  if (typeof value === "object") {
    const record = value as Record<string, unknown>;
    const ownText = typeof record.text === "string" ? record.text : "";
    const childrenText = extractPlainText(record.children);

    return [ownText, childrenText]
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }

  return "";
}

const plainContent = extractPlainText(blog.contenido);

const excerpt =
  showDescription && plainContent
    ? plainContent.length > 138
      ? `${plainContent.slice(0, 135).trimEnd()}...`
      : plainContent
    : null;

const cardHeight = isFeatured ? "min-h-[500px]" : "min-h-[420px]";
const imageHeight = isFeatured ? "aspect-[16/9]" : "aspect-[5/4]";
---

<article class:list={["group h-full", isFeatured && "lg:col-span-2"]}>
  <a
    href={rewriteUrl(`/blog/${blog.slug}`, lang)}
    aria-label={`${t("aria.leerArticulo")}: ${blog.titulo}`}
    class:list={[
      "relative flex h-full flex-col overflow-hidden rounded-lg border border-slate-200/80 bg-white text-slate-900 shadow-[0_18px_45px_rgba(15,23,42,0.08)] transition-all duration-500 ease-out hover:-translate-y-1.5 hover:border-secondary/40 hover:shadow-[0_28px_70px_rgba(15,23,42,0.16)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/45",
      cardHeight,
    ]}
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 z-10 h-40 bg-[radial-gradient(circle_at_top,_rgba(205,166,94,0.18),_transparent_68%)] opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    >
    </div>

    <div class:list={["relative overflow-hidden", imageHeight]}>
      {
        mainImage && mainImage !== "/og-default.jpg" ? (
          <img
            src={mainImage}
            sizes={
              isFeatured
                ? "(max-width: 1023px) 92vw, 640px"
                : "(max-width: 767px) 92vw, (max-width: 1023px) 46vw, 320px"
            }
            alt={imageAlt}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="flex h-full items-center justify-center bg-[linear-gradient(135deg,_rgba(20,83,45,0.1),_rgba(205,166,94,0.16),_rgba(15,23,42,0.06))]">
            <span class="rounded-full border border-primary/10 bg-white/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-primary/65 shadow-sm">
              No image
            </span>
          </div>
        )
      }

      <div
        class="absolute inset-0 bg-gradient-to-t from-[#07130f]/78 via-[#07130f]/14 to-transparent"
      >
      </div>
      <div
        class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-[#07130f]/78 to-transparent"
      >
      </div>

      <div
        class="absolute left-4 top-4 flex max-w-[calc(100%-2rem)] items-center gap-3"
      >
        {
          category && (
            <span class="line-clamp-1 inline-flex max-w-full items-center rounded-full border border-white/25 bg-white/18 px-3.5 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-white shadow-[0_10px_30px_rgba(0,0,0,0.2)] backdrop-blur-md">
              {category}
            </span>
          )
        }
      </div>

      <span
        class="absolute bottom-4 right-4 grid h-10 w-10 place-items-center rounded-full border border-white/25 bg-white/16 text-white shadow-[0_12px_32px_rgba(0,0,0,0.22)] backdrop-blur-md transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:bg-secondary"
        aria-hidden="true"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M7 17 17 7"></path>
          <path d="M9 7h8v8"></path>
        </svg>
      </span>
    </div>

    <div
      class="relative flex flex-1 flex-col gap-5 px-5 pb-5 pt-5 md:px-6 md:pb-6"
    >
      <div
        class="flex items-center gap-4 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-slate-500"
      >
        {
          formattedDate ? (
            <span class="inline-flex min-w-0 items-center gap-2">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" />
              {formattedDate}
            </span>
          ) : (
            <span class="inline-flex min-w-0 items-center gap-2">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-secondary/60" />
              Journal
            </span>
          )
        }
      </div>

      <div class="space-y-3.5">
        <h2
          class="line-clamp-3 text-[1.28rem] font-semibold leading-[1.18] text-slate-950 md:text-[1.45rem]"
        >
          {blog.titulo}
        </h2>

        {
          excerpt && (
            <p class="line-clamp-3 text-sm leading-6 text-slate-600/95 md:text-[0.96rem]">
              {excerpt}
            </p>
          )
        }
      </div>

      <div class="mt-auto flex items-center border-t border-slate-200 pt-4">
        <span
          class="inline-flex items-center gap-2 text-[0.76rem] font-bold uppercase tracking-[0.16em] text-secondary"
        >
          {t("blog.leerMas")}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
