---
import type { Blog } from "@/types/blog";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import { getImageAlt, getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  blog: Blog;
  lang: Lang;
  isFeatured?: boolean;
  showDescription?: boolean;
}

const { blog, lang, isFeatured = false, showDescription = false } = Astro.props;

if (!blog) return null;

const t = useTranslations(lang);
const mainImage = getImageUrl(blog.portadaImage, "small");
const imageAlt = getImageAlt(blog.portadaImage, blog.titulo);

const category = blog.category_blogs?.[0]?.nombre || null;

const publishedDate = blog.publishedAt || blog.createdAt;
const formattedDate = publishedDate
  ? new Date(publishedDate).toLocaleDateString(
      lang === "es" ? "es-ES" : lang === "pt" ? "pt-BR" : "en-US",
      {
        month: "short",
        day: "numeric",
        year: "numeric",
      },
    )
  : null;

function extractPlainText(value: unknown): string {
  if (!value) return "";

  if (typeof value === "string") {
    return value
      .replace(/<[^>]+>/g, " ")
      .replace(/&[^;]+;/g, " ")
      .replace(/\s+/g, " ")
      .trim();
  }

  if (Array.isArray(value)) {
    return value
      .map((item) => extractPlainText(item))
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }

  if (typeof value === "object") {
    const record = value as Record<string, unknown>;
    const ownText = typeof record.text === "string" ? record.text : "";
    const childrenText = extractPlainText(record.children);

    return [ownText, childrenText]
      .filter(Boolean)
      .join(" ")
      .replace(/\s+/g, " ")
      .trim();
  }

  return "";
}

const plainContent = extractPlainText(blog.contenido);

const excerptLimit = isFeatured ? 700 : 138;
const excerpt =
  showDescription && plainContent
    ? plainContent.length > excerptLimit
      ? `${plainContent.slice(0, excerptLimit - 3).trimEnd()}...`
      : plainContent
    : null;

const cardHeight = isFeatured
  ? "min-h-[500px] lg:min-h-[360px] lg:h-[360px]"
  : "min-h-[360px]";
const imageHeight = isFeatured
  ? "aspect-[16/8.4] lg:aspect-auto lg:h-full"
  : "aspect-[16/10]";
---

<article class:list={["group h-full", isFeatured && "md:col-span-2 lg:col-span-3"]}>
  <a
    href={rewriteUrl(`/blog/${blog.slug}`, lang)}
    aria-label={`${t("aria.leerArticulo")}: ${blog.titulo}`}
    class:list={[
      "relative flex h-full flex-col overflow-hidden rounded-sm border border-[color-mix(in_oklab,var(--primary)_9%,var(--border))] bg-white text-foreground shadow-[0_18px_44px_var(--blog-card-shadow)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-secondary/32 hover:shadow-[0_24px_60px_var(--blog-card-shadow-strong)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary/45",
      isFeatured && "lg:flex-row",
      cardHeight,
    ]}
  >
    <div
      class="pointer-events-none absolute inset-x-0 top-0 z-10 h-px bg-[linear-gradient(90deg,transparent,var(--secondary),transparent)] opacity-45"
    >
    </div>

    <div class:list={["relative overflow-hidden shrink-0", isFeatured ? "w-full lg:w-[55%]" : "w-full", imageHeight]}>
      {
        mainImage && mainImage !== "/og-default.jpg" ? (
          <img
            src={mainImage}
            sizes={
              isFeatured
                ? "(max-width: 1023px) 92vw, 768px"
                : "(max-width: 767px) 92vw, (max-width: 1023px) 46vw, 380px"
            }
            alt={imageAlt}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="flex h-full items-center justify-center bg-[linear-gradient(135deg,_color-mix(in_oklab,var(--primary)_14%,white),_color-mix(in_oklab,var(--secondary)_16%,white))]">
            <span class="rounded-[3px] border border-primary/10 bg-card/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-primary/65 shadow-sm">
              No image
            </span>
          </div>
        )
      }

      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.18)_0%,transparent_42%,color-mix(in_oklab,var(--blog-image-shade)_58%,transparent)_100%)]"
      >
      </div>
      <div
        class="absolute inset-x-0 bottom-0 h-24 bg-[linear-gradient(0deg,color-mix(in_oklab,var(--blog-image-shade)_68%,transparent),transparent)]"
      >
      </div>

      <div
        class="absolute left-4 top-4 flex max-w-[calc(100%-2rem)] items-center gap-3"
      >
        {
          category && (
            <span class="line-clamp-1 inline-flex max-w-full items-center rounded-xs bg-secondary px-3.5 py-1.5 text-[0.6rem] uppercase tracking-[0.16em] text-white shadow-[0_10px_30px_color-mix(in_oklab,var(--blog-image-shade)_36%,transparent)]">
              {category}
            </span>
          )
        }
      </div>

      <span
        class="absolute bottom-4 right-4 grid h-10 w-10 place-items-center rounded-full border border-white/25 bg-white/16 text-white shadow-[0_12px_32px_rgba(0,0,0,0.22)] backdrop-blur-md transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:bg-secondary"
        aria-hidden="true"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M7 17 17 7"></path>
          <path d="M9 7h8v8"></path>
        </svg>
      </span>
    </div>

    <div
      class:list={[
        "relative flex flex-1 flex-col gap-4 px-5 pb-5 pt-5 md:px-6 md:pb-6",
        isFeatured && "lg:w-[45%] lg:p-7 lg:justify-between"
      ]}
    >
      <div
        class="flex items-center gap-4 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-muted-foreground"
      >
        {
          formattedDate ? (
            <span class="inline-flex min-w-0 items-center gap-2">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" />
              {formattedDate}
            </span>
          ) : (
            <span class="inline-flex min-w-0 items-center gap-2">
              <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-secondary/60" />
              Journal
            </span>
          )
        }
      </div>

      <div class="space-y-3.5">
        <h3
          class:list={[
            "line-clamp-3 font-semibold leading-[1.16] text-foreground",
            isFeatured
              ? "text-[1.38rem] md:text-[1.68rem]"
              : "text-[1.08rem] md:text-[1.24rem]",
          ]}
        >
          {blog.titulo}
        </h3>

        {
          excerpt && (
            <p class:list={[
              "text-sm leading-6 text-muted-foreground md:text-[0.96rem]",
              isFeatured
                ? "flex-1 overflow-hidden line-clamp-[12]"
                : "line-clamp-2"
            ]}>
              {excerpt}
            </p>
          )
        }
      </div>

      <div class="mt-auto flex items-center border-t border-border pt-4">
        <span
          class="relative inline-flex items-center gap-2 text-[0.76rem] font-bold uppercase tracking-[0.16em] text-secondary after:absolute after:-bottom-1 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-secondary after:transition-transform after:duration-300 group-hover:after:scale-x-100"
        >
          {t("blog.leerMas")}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
