---
import type { Tour } from "@/types/tours";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import BadgeIcon from "@/components/ui/BadgeIcon.astro";
import { getImageAlt, getImageUrl, extractTextFromBlocks } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  tour: Tour;
  lang: Lang;
}

const { tour, lang } = Astro.props;

if (!tour) return null;

const t = useTranslations(lang);
const metaImage = tour.seo?.metaImage;
const mainImage = getImageUrl(metaImage, "small");
const imageAlt = getImageAlt(metaImage, tour.titulo);
const cardBadge =
  tour.cardBadge === "best_seller"
    ? {
        label: t("tour.cardBadge.bestSeller"),
        variant: "best-seller",
      }
    : tour.cardBadge === "promocion"
      ? {
          label: t("tour.cardBadge.promotion"),
          variant: "promotion",
        }
      : null;
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-sm border border-slate-200/80 bg-white transition-all duration-500 hover:-translate-y-1 hover:border-primary/15"
>
  {/* Image Container */}
  <a
    href={rewriteUrl(`/${tour.slug}`, lang)}
    tabindex="-1"
    aria-hidden="true"
    class="relative block w-full shrink-0 overflow-hidden border-b border-slate-200/70 aspect-[4/3]"
  >
    {
      cardBadge && (
        <div
          class:list={[
            "tour-card-badge",
            `tour-card-badge--${cardBadge.variant}`,
          ]}
        >
          {cardBadge.variant === "best-seller" ? (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m12 2.75 2.62 5.3 5.85.85-4.24 4.13 1 5.83L12 16.11l-5.23 2.75 1-5.83L3.53 8.9l5.85-.85L12 2.75Z" />
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.6 13.6 13.7 20.5a2 2 0 0 1-2.8 0l-7.4-7.4a2 2 0 0 1 0-2.8V4.5a1 1 0 0 1 1-1h5.8a2 2 0 0 1 1.4.6l6.9 6.7a2 2 0 0 1 0 2.8Z" />
              <circle cx="7.5" cy="7.5" r="1.35" />
            </svg>
          )}
          <span>{cardBadge.label}</span>
        </div>
      )
    }
    {
      mainImage && mainImage !== "/og-default.jpg" ? (
        <img
          src={mainImage}
          sizes="(max-width: 767px) 92vw, (max-width: 1023px) calc((100vw - 24px) / 2), 320px"
          alt={imageAlt}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.035]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-slate-100 text-sm font-medium text-slate-400">
          No Image
        </div>
      )
    }
    <div
      class="absolute inset-0 bg-linear-to-t from-slate-950/30 via-slate-950/5 to-transparent opacity-60 transition-opacity duration-300 group-hover:opacity-70"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-black/18 via-black/0 to-transparent"
    >
    </div>
  </a>

  {/* Content Container */}
  <div
    class="relative z-10 flex grow flex-col bg-white px-4 py-4 md:px-5 md:py-5"
  >
    <h3
      class="mb-3 line-clamp-2 text-[1.26rem] font-semibold leading-[1.15] tracking-[-0.02em] text-slate-950 transition-colors duration-300 group-hover:text-secondary md:text-[1.42rem]"
    >
      <a href={rewriteUrl(`/${tour.slug}`, lang)} class="focus:outline-hidden">
        {tour.titulo}
      </a>
    </h3>

    {
      tour.content && (
        <p class="mb-5 text-[0.85rem] text-slate-600 line-clamp-2 leading-relaxed">
          {extractTextFromBlocks(tour.content)}
        </p>
      )
    }

    {/* Badges paralelos en Flex - Texto Multilínea */}
    {
      tour.badge && tour.badge.length > 0 && (
        <dl class="mb-5 mt-auto flex w-full items-start justify-between gap-1 border-t border-b border-slate-200 pt-4 pb-4">
          {tour.badge.slice(-3).map((b) => (
            <div class="flex flex-1 min-w-0" title={b.content}>
              <dt class="sr-only">{b.titulo}</dt>
              <dd class="flex min-w-0 items-center gap-1.5 text-xs font-medium text-slate-700 leading-[1.1]">
                <span
                  class="flex-shrink-0 w-7 h-7 sm:w-8 sm:h-8 rounded-md bg-gradient-to-br from-primary/10 to-secondary/5 flex items-center justify-center transition-transform duration-300 group-hover:scale-105"
                  aria-hidden="true"
                >
                  <BadgeIcon
                    title={b.titulo}
                    content={b.content}
                    className="h-3.5 w-3.5 sm:h-4 sm:w-4 text-gray-700"
                  />
                </span>
                <span class="min-w-0 break-words line-clamp-2">
                  {b.content}
                </span>
              </dd>
            </div>
          ))}
        </dl>
      )
    }
    <div class="mt-auto pt-1">
      <a
        href={rewriteUrl(`/${tour.slug}`, lang)}
        class="group/btn inline-flex w-full items-center justify-between gap-3 rounded-sm border border-primary/15 bg-primary px-4 py-2.5 text-sm font-medium text-white transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-primary/95 active:scale-[0.995]"
      >
        <span class="tracking-[0.05em]">{t("tour.verItinerario")}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 shrink-0 transition-transform duration-300 group-hover/btn:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .tour-card-badge {
    position: absolute;
    inset-block-start: 1rem;
    inset-inline-start: 1rem;
    z-index: 20;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    overflow: hidden;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    padding: 0.56rem 0.78rem;
    font-size: 0.69rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    box-shadow: 0 10px 24px -12px rgb(0 0 0 / 55%);
    transition: transform 300ms ease;
  }

  .group:hover .tour-card-badge {
    transform: translateY(-2px);
  }

  .tour-card-badge svg {
    inline-size: 0.85rem;
    block-size: 0.85rem;
    flex: none;
    fill: currentColor;
  }

  .tour-card-badge--best-seller {
    inset-inline-start: 0;
    inset-inline-end: auto;
    border-color: #ffe8a3;
    border-inline-start: 0;
    border-radius: 0 0.5rem 0.5rem 0;
    padding-inline: 1rem 1.25rem;
    background: linear-gradient(
      115deg,
      #fff6c9 0%,
      #e2a92e 38%,
      #ffd86a 66%,
      #fff1ad 100%
    );
    color: #4b2d00;
    clip-path: polygon(
      0 0,
      calc(100% - 0.55rem) 0,
      100% 50%,
      calc(100% - 0.55rem) 100%,
      0 100%
    );
    box-shadow:
      0 12px 30px -10px rgb(65 38 0 / 78%),
      0 0 0 2px rgb(98 58 0 / 18%) inset,
      0 1px 0 rgb(255 255 255 / 88%) inset;
  }

  .tour-card-badge--best-seller svg {
    inline-size: 1.35rem;
    block-size: 1.35rem;
    border: 1px solid rgb(255 237 170 / 65%);
    border-radius: 50%;
    background: #603b00;
    color: #ffdd72;
    padding: 0.25rem;
    box-shadow: 0 2px 7px rgb(74 42 0 / 35%);
  }

  .tour-card-badge--best-seller::after {
    position: absolute;
    inset-block: -60%;
    inset-inline-start: -45%;
    inline-size: 32%;
    background: linear-gradient(
      90deg,
      transparent,
      rgb(255 255 255 / 55%),
      transparent
    );
    content: "";
    transform: rotate(18deg);
    transition: inset-inline-start 600ms ease;
  }

  .group:hover .tour-card-badge--best-seller::after {
    inset-inline-start: 115%;
  }

  .tour-card-badge--promotion {
    inset-inline-start: 0;
    border-color: color-mix(in oklab, var(--secondary) 84%, white);
    border-inline-start: 0;
    border-radius: 0 0.5rem 0.5rem 0;
    padding-inline: 1rem 1.25rem;
    background:
      repeating-linear-gradient(
        125deg,
        transparent 0 8px,
        rgb(255 255 255 / 7%) 8px 12px
      ),
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--secondary) 74%, black),
        var(--secondary) 62%,
        color-mix(in oklab, var(--secondary) 88%, white)
      );
    color: var(--secondary-foreground);
    clip-path: polygon(
      0 0,
      calc(100% - 0.55rem) 0,
      100% 50%,
      calc(100% - 0.55rem) 100%,
      0 100%
    );
    box-shadow:
      0 12px 28px -10px color-mix(in oklab, var(--secondary) 84%, black),
      0 1px 0 color-mix(in oklab, white 35%, transparent) inset;
  }

  .tour-card-badge--promotion svg {
    inline-size: 1rem;
    block-size: 1rem;
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 22%));
  }

  @media (prefers-reduced-motion: reduce) {
    .tour-card-badge,
    .tour-card-badge--best-seller::after {
      transition: none;
    }
  }
</style>
