---
interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = "" } = Astro.props;
---

<div class={`text-center mb-10 ${className}`}>
  <h2
    class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 relative inline-block"
  >
    <span class="relative z-10">{title}</span>
    <span
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-3 bg-secondary/30 -z-0 rounded-full blur-sm"
    ></span>
  </h2>
  <div class="flex items-center justify-center gap-3 mt-4">
    <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary">
    </div>
    <div class="w-12 h-1.5 bg-secondary rounded-full relative">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full"
      >
      </div>
    </div>
    <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary">
    </div>
  </div>
  {subtitle && <p class="mt-4 text-gray-600 max-w-2xl mx-auto">{subtitle}</p>}
</div>
