---
import TeamCard from "./TeamCard.astro";
import { ArrowLeftIcon, ArrowRightIcon } from "@/components/icons/NavigationIcons";

interface TeamMember {
  name: string;
  role: string;
  department: string;
  image?: string;
}

interface Props {
  members: TeamMember[];
  department: string;
}

const { members, department } = Astro.props;
const sliderId = `team-slider-${department.replace(/\s/g, "-").toLowerCase()}`;
---

<div class="relative group" data-slider-id={sliderId}>
  <!-- Slider Container -->
  <div
    id={sliderId}
    class="flex gap-6 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4 px-2"
    style="scrollbar-width: none; -ms-overflow-style: none; height: 420px;"
  >
    {
      members.map((member) => (
        <div class="shrink-0 snap-start w-[280px] md:w-[300px] h-full">
          <TeamCard
            name={member.name}
            role={member.role}
            department={member.department}
            image={member.image}
          />
        </div>
      ))
    }
  </div>

  <!-- Navigation Arrows -->
  <button
    class="team-prev opacity-0 group-hover:opacity-100 transition-opacity absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 w-12 h-12 bg-white rounded-full shadow-lg border border-border flex items-center justify-center hover:bg-muted transition-colors z-10"
    aria-label="Previous slide"
  >
    <ArrowLeftIcon className="w-5 h-5 text-current" />
  </button>

  <button
    class="team-next opacity-0 group-hover:opacity-100 transition-opacity absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 w-12 h-12 bg-white rounded-full shadow-lg border border-border flex items-center justify-center hover:bg-muted transition-colors z-10"
    aria-label="Next slide"
  >
    <ArrowRightIcon className="w-5 h-5 text-current" />
  </button>
</div>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-slider-id]").forEach((slider) => {
      if (slider.dataset.initialized) return;
      slider.dataset.initialized = "true";

      const container = slider.querySelector(".overflow-x-auto");
      const prevBtn = slider.querySelector(".team-prev");
      const nextBtn = slider.querySelector(".team-next");

      if (container && prevBtn && nextBtn) {
        prevBtn.addEventListener("click", () => {
          container.scrollBy({ left: -320, behavior: "smooth" });
        });

        nextBtn.addEventListener("click", () => {
          container.scrollBy({ left: 320, behavior: "smooth" });
        });
      }
    });
  });
</script>
