---
import type { Lang } from "@/lib/i18n";
import { getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Category {
  slug: string;
  nombre: string;
}

interface SocialLogo {
  url: string;
  label?: string;
  imagen?: {
    url: string;
  };
}

interface Props {
  categories: Category[];
  currentSlug?: string;
  lang: Lang;
  socialLogos?: SocialLogo[];
  categoryPostCounts?: Record<string, number>;
  totalPostCount?: number;
}

const {
  categories,
  currentSlug,
  lang,
  socialLogos = [],
  categoryPostCounts = {},
  totalPostCount = 0,
} = Astro.props;

const formatUrl = (url: string) =>
  url?.startsWith("http") ? url : `https://${url}`;

const getSocialHoverClass = (label: string = "", url: string = "") => {
  const text = `${label} ${url}`.toLowerCase();
  if (text.includes("youtube")) {
    return "hover:bg-red-600 hover:shadow-[0_8px_20px_rgba(16,185,129,0.3)]";
  }
  if (text.includes("facebook")) {
    return "hover:bg-blue-600 hover:shadow-[0_8px_20px_rgba(37,99,235,0.3)]";
  }
  if (text.includes("instagram") || text.includes("insta")) {
    return "hover:bg-gradient-to-tr hover:from-purple-600 hover:to-pink-500 hover:shadow-[0_8px_20px_rgba(236,72,153,0.3)]";
  }
  if (text.includes("pinterest") || text.includes(" pint ")) {
    return "hover:bg-red-600 hover:shadow-[0_8px_20px_rgba(0,0,0,0.3)]";
  }
  return "hover:bg-primary hover:shadow-[0_8px_20px_rgba(34,197,94,0.3)]";
};
---

<aside class="w-full shrink-0 lg:w-[30%] xl:w-[25%]">
  <div
    class="mt-10 rounded-lg border border-gray-100 bg-white p-5 shadow-[0_8px_28px_rgba(0,0,0,0.04)] transition-shadow duration-300 hover:shadow-[0_8px_28px_rgba(0,0,0,0.07)] lg:sticky lg:top-10 lg:mt-0 lg:border-t-4 lg:border-t-primary lg:p-6"
  >
    {/* Categorías */}
    <h2
      class="mb-4 text-[0.7rem] font-bold uppercase tracking-wider text-slate-800"
    >
      {
        lang === "es"
          ? "Categorías"
          : lang === "pt"
            ? "Categorias"
            : "Categories"
      }
    </h2>
    <div class="flex flex-col gap-1.5">
      <a
        href={rewriteUrl("/blog", lang)}
        class={`flex items-center justify-between gap-4 rounded-md border border-transparent px-3.5 py-2.5 text-sm font-medium transition-colors duration-200
          ${
            !currentSlug
              ? "bg-primary/10 text-primary font-semibold"
              : "text-slate-700 hover:text-primary hover:bg-primary/5"
          }`}
      >
        <span class="min-w-0 truncate">
          {
            lang === "es"
              ? "Ver Todos"
              : lang === "pt"
                ? "Ver Todos"
                : "View All"
          }
        </span>
        <span
          class={`shrink-0 rounded-full px-2 py-0.5 text-xs font-semibold ${
            !currentSlug ? "bg-primary text-white" : "bg-gray-100 text-slate-700"
          }`}
        >
          {totalPostCount}
        </span>
      </a>

      {
        categories.map((cat: Category) => {
          const isActive = currentSlug === cat.slug;
          const count = categoryPostCounts[cat.slug] ?? 0;
          return (
            <a
              href={rewriteUrl(`/blog/${cat.slug}`, lang)}
              class={`flex items-center justify-between gap-4 rounded-md border border-transparent px-3.5 py-2.5 text-sm font-medium transition-colors duration-200
                ${
                  isActive
                    ? "bg-primary/10 text-primary font-semibold"
                    : "text-slate-700 hover:text-primary hover:bg-primary/5"
                }`}
            >
              <span class="min-w-0 truncate">{cat.nombre}</span>
              <span
                class={`shrink-0 rounded-full px-2 py-0.5 text-xs font-semibold ${
                  isActive
                    ? "bg-primary text-white"
                    : "bg-gray-100 text-slate-700"
                }`}
              >
                {count}
              </span>
            </a>
          );
        })
      }
    </div>

    {/* Redes Sociales */}
    {
      Array.isArray(socialLogos) && socialLogos.length > 0 && (
        <div class="mt-6 border-t border-gray-100 pt-6">
          <h2 class="mb-4 text-[0.7rem] font-bold uppercase tracking-wider text-slate-800">
            {lang === "es"
              ? "Compartir"
              : lang === "pt"
                ? "Compartilhar"
                : "Share"}
          </h2>
          <div class="flex flex-wrap gap-3">
            {socialLogos.map((social: SocialLogo) => (
              <a
                href={formatUrl(social.url)}
                target="_blank"
                rel="noopener noreferrer"
                title={social.label || "Social"}
                class={`group flex h-10 w-10 items-center justify-center rounded-lg border border-gray-100 bg-gray-50 shadow-xs transition-all duration-300 hover:-translate-y-1 hover:scale-105 hover:border-transparent ${getSocialHoverClass(social.label, social.url)}`}
              >
                {social.imagen?.url && (
                  <img
                    src={getImageUrl(social.imagen)}
                    alt={social.label || "Social"}
                    class="h-5 w-5 object-contain brightness-0 opacity-50 transition-all duration-300 group-hover:brightness-100 group-hover:opacity-100"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</aside>
