---
import type { Lang } from "@/lib/i18n";
import { getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Category {
  slug: string;
  nombre: string;
}

interface SocialLogo {
  url: string;
  label?: string;
  imagen?: {
    url: string;
  };
}

interface Props {
  categories: Category[];
  currentSlug?: string;
  lang: Lang;
  socialLogos?: SocialLogo[];
  categoryPostCounts?: Record<string, number>;
  totalPostCount?: number;
}

const {
  categories,
  currentSlug,
  lang,
  socialLogos = [],
  categoryPostCounts = {},
  totalPostCount = 0,
} = Astro.props;

const formatUrl = (url: string) =>
  url?.startsWith("http") ? url : `https://${url}`;

const getSocialHoverClass = (label: string = "", url: string = "") => {
  const text = `${label} ${url}`.toLowerCase();
  if (text.includes("youtube")) return "hover:border-red-200 hover:bg-red-50";
  if (text.includes("facebook"))
    return "hover:border-blue-200 hover:bg-blue-50";
  if (text.includes("instagram") || text.includes("insta"))
    return "hover:border-pink-200 hover:bg-pink-50";
  if (text.includes("pinterest") || text.includes(" pint "))
    return "hover:border-red-200 hover:bg-red-50";
  return "hover:border-primary/30 hover:bg-primary/5";
};
---

<aside class="w-full shrink-0 lg:w-[30%] xl:w-[25%]">
  <div
    class="mt-10 overflow-hidden rounded-lg border border-border bg-white shadow-[0_12px_34px_rgba(15,23,42,0.06)] lg:sticky lg:top-10 lg:mt-0"
  >
    <div class="border-t-4 border-primary p-5 lg:p-6">
      <h2 class="mb-4 text-base font-bold tracking-tight text-foreground">
        {
          lang === "es"
            ? "Categorias"
            : lang === "pt"
              ? "Categorias"
              : "Categories"
        }
      </h2>

      <nav class="flex flex-col gap-1.5" aria-label="Blog categories">
        <a
          href={rewriteUrl("/blog", lang)}
          class={`flex items-center justify-between gap-4 rounded-md border px-3.5 py-2.5 text-sm font-medium transition-colors duration-200 ${
            !currentSlug
              ? "border-primary/20 bg-primary/10 text-primary"
              : "border-transparent text-foreground/75 hover:border-primary/10 hover:bg-primary/5 hover:text-primary"
          }`}
        >
          <span class="min-w-0 truncate">
            {
              lang === "es"
                ? "Ver todos"
                : lang === "pt"
                  ? "Ver todos"
                  : "View all"
            }
          </span>
          <span
            class={`shrink-0 rounded-full px-2 py-0.5 text-xs font-semibold ${
              !currentSlug
                ? "bg-primary text-white"
                : "bg-muted text-foreground/70"
            }`}
          >
            {totalPostCount}
          </span>
        </a>

        {
          categories.map((cat: Category) => {
            const isActive = currentSlug === cat.slug;
            const count = categoryPostCounts[cat.slug] ?? 0;
            return (
              <a
                href={rewriteUrl(`/blog/${cat.slug}`, lang)}
                class={`flex items-center justify-between gap-4 rounded-md border px-3.5 py-2.5 text-sm font-medium transition-colors duration-200 ${
                  isActive
                    ? "border-primary/20 bg-primary/10 text-primary"
                    : "border-transparent text-foreground/75 hover:border-primary/10 hover:bg-primary/5 hover:text-primary"
                }`}
              >
                <span class="min-w-0 truncate">{cat.nombre}</span>
                <span
                  class={`shrink-0 rounded-full px-2 py-0.5 text-xs font-semibold ${
                    isActive
                      ? "bg-primary text-white"
                      : "bg-muted text-foreground/70"
                  }`}
                >
                  {count}
                </span>
              </a>
            );
          })
        }
      </nav>
    </div>

    {
      Array.isArray(socialLogos) && socialLogos.length > 0 && (
        <div class="border-t border-border bg-muted/25 p-5 lg:p-6">
          <h2 class="mb-4 text-sm font-bold tracking-tight text-foreground">
            {lang === "es"
              ? "Síguenos"
              : lang === "pt"
                ? "Siga-nos"
                : "Follow us"}
          </h2>
          <div class="flex flex-wrap gap-2.5">
            {socialLogos.map((social: SocialLogo) => (
              <a
                href={formatUrl(social.url)}
                target="_blank"
                rel="noopener noreferrer"
                title={social.label || "Social"}
                aria-label={social.label || "Social"}
                class={`group flex size-10 items-center justify-center rounded-md border border-border bg-white transition-all duration-200 hover:-translate-y-0.5 ${getSocialHoverClass(social.label, social.url)}`}
              >
                {social.imagen?.url ? (
                  <img
                    src={getImageUrl(social.imagen)}
                    alt={social.label || "Social"}
                    class="h-5 w-5 object-contain brightness-0 opacity-70 transition-opacity duration-200 group-hover:opacity-100"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="text-xs font-bold uppercase text-foreground/70">
                    {(social.label || "S").charAt(0)}
                  </span>
                )}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</aside>
