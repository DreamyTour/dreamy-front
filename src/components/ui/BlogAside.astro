---
import type { Lang } from "@/lib/i18n";
import { getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";
import { getCategoryIcon } from "@/lib/blogCategories";

interface Category {
  slug: string;
  nombre: string;
}

interface SocialLogo {
  url: string;
  label?: string;
  imagen?: {
    url: string;
  };
}

interface Props {
  categories: Category[];
  currentSlug?: string;
  lang: Lang;
  socialLogos?: SocialLogo[];
  categoryPostCounts?: Record<string, number>;
  totalPostCount?: number;
}

const {
  categories,
  currentSlug,
  lang,
  socialLogos = [],
  categoryPostCounts = {},
  totalPostCount = 0,
} = Astro.props;

const formatUrl = (url: string) =>
  url?.startsWith("http") ? url : `https://${url}`;

const copy = {
  categories:
    lang === "es" ? "Categorías" : lang === "pt" ? "Categorias" : "Categories",
  viewAll:
    lang === "es"
      ? `Ver todo (${totalPostCount})`
      : lang === "pt"
        ? `Ver todos (${totalPostCount})`
        : `View all (${totalPostCount})`,
  followUs:
    lang === "es" ? "Síguenos" : lang === "pt" ? "Siga-nos" : "Follow us",
  navLabel:
    lang === "es"
      ? "Categorías del blog"
      : lang === "pt"
        ? "Categorias do blog"
        : "Blog categories",
};

const getSocialBrandStyle = (label: string = "", url: string = "") => {
  const text = `${label} ${url}`.toLowerCase();
  if (text.includes("youtube")) return "--social-brand: #FF0000;";
  if (text.includes("facebook")) return "--social-brand: #1877F2;";
  if (text.includes("instagram") || text.includes("insta"))
    return "--social-brand: #E4405F;";
  if (text.includes("pinterest") || text.includes("pint"))
    return "--social-brand: #BD081C;";
  if (text.includes("tiktok")) return "--social-brand: #000000;";
  if (text.includes("twitter") || text.includes("x.com"))
    return "--social-brand: #1DA1F2;";
  return "--social-brand: var(--primary);";
};
---

<aside class="w-full shrink-0 lg:w-80 xl:w-[21rem]">
  <div
    class="overflow-hidden rounded-[3px] border border-[var(--blog-aside-border)] bg-[var(--blog-aside-surface)] p-5 shadow-[0_18px_55px_var(--blog-card-shadow)] lg:sticky lg:top-10"
  >
    <div class="mb-5 flex items-center justify-between gap-4 border-b border-[var(--blog-aside-border)] pb-4">
      <h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-primary">
        {copy.categories}
      </h2>
      <a
        href={rewriteUrl("/blog", lang)}
        class={`shrink-0 text-xs font-semibold transition-colors duration-200 ${
          !currentSlug
            ? "text-secondary font-bold"
            : "text-secondary/90 hover:text-secondary"
        }`}
      >
        {copy.viewAll}
      </a>
    </div>

    <nav class="flex flex-col gap-1.5" aria-label={copy.navLabel}>
      {
        categories.map((cat: Category) => {
          const isActive = currentSlug === cat.slug;
          const count = categoryPostCounts[cat.slug] ?? 0;
          return (
            <a
              href={rewriteUrl(`/blog/${cat.slug}`, lang)}
              class={`flex items-center justify-between gap-3 rounded-[3px] border px-3 py-2.5 text-[14px] transition-all duration-200 ${
                isActive
                  ? "border-secondary/25 bg-secondary/8 text-primary font-bold shadow-sm"
                  : "border-transparent text-foreground hover:border-[#d6beaa] hover:bg-white/75 hover:text-primary"
              }`}
            >
              <div class="flex items-center gap-3 min-w-0">
                <span 
                  class={`shrink-0 flex items-center justify-center transition-colors duration-200 ${
                    isActive ? "text-primary" : "text-foreground/75"
                  }`}
                  set:html={getCategoryIcon(cat.slug)}
                />
                <span class="truncate">{cat.nombre}</span>
              </div>
              <span
                class={`shrink-0 text-xs transition-colors duration-200 ${
                  isActive ? "text-primary font-bold" : "text-foreground/75"
                }`}
              >
                ({count})
              </span>
            </a>
          );
        })
      }
    </nav>

    {
      Array.isArray(socialLogos) && socialLogos.length > 0 && (
        <div class="mt-6 border-t border-[var(--blog-aside-border)] pt-6">
          <h2 class="mb-4 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-primary">
            {copy.followUs}
          </h2>
          <div class="flex flex-wrap gap-2.5">
            {socialLogos.map((social: SocialLogo) => (
              <a
                href={formatUrl(social.url)}
                target="_blank"
                rel="noopener noreferrer"
                title={social.label || "Social"}
                aria-label={social.label || "Social"}
                class="social-brand-link group flex size-11 items-center justify-center rounded-[3px] border border-[var(--blog-aside-border)] bg-card transition-all duration-300 ease-out hover:-translate-y-1"
                style={getSocialBrandStyle(social.label, social.url)}
              >
                {social.imagen?.url ? (
                  <img
                    src={getImageUrl(social.imagen)}
                    alt={social.label || "Social"}
                    class="h-6 w-6 object-contain brightness-0 opacity-70 transition-all duration-300 ease-out group-hover:brightness-0 group-hover:invert group-hover:opacity-100"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="text-xs font-bold uppercase text-foreground/70 transition-colors duration-300 ease-out group-hover:text-white">
                    {(social.label || "S").charAt(0)}
                  </span>
                )}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</aside>

<style>
  .social-brand-link:hover {
    background-color: var(--social-brand) !important;
    border-color: var(--social-brand) !important;
  }
</style>
