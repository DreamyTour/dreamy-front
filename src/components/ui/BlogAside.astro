---
import type { Lang } from "@/lib/i18n";
import { getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Category {
  slug: string;
  nombre: string;
}

interface SocialLogo {
  url: string;
  label?: string;
  imagen?: {
    url: string;
  };
}

interface Props {
  categories: Category[];
  currentSlug?: string;
  lang: Lang;
  socialLogos?: SocialLogo[];
}

const { categories, currentSlug, lang, socialLogos = [] } = Astro.props;

const formatUrl = (url: string) =>
  url?.startsWith("http") ? url : `https://${url}`;

const getSocialHoverClass = (label: string = "", url: string = "") => {
  const text = `${label} ${url}`.toLowerCase();
  if (text.includes("youtube")) {
    return "hover:bg-red-600 hover:shadow-[0_8px_20px_rgba(16,185,129,0.3)]";
  }
  if (text.includes("facebook")) {
    return "hover:bg-blue-600 hover:shadow-[0_8px_20px_rgba(37,99,235,0.3)]";
  }
  if (text.includes("instagram") || text.includes("insta")) {
    return "hover:bg-gradient-to-tr hover:from-purple-600 hover:to-pink-500 hover:shadow-[0_8px_20px_rgba(236,72,153,0.3)]";
  }
  if (text.includes("pinterest") || text.includes(" pint ")) {
    return "hover:bg-red-600 hover:shadow-[0_8px_20px_rgba(0,0,0,0.3)]";
  }
  return "hover:bg-primary hover:shadow-[0_8px_20px_rgba(34,197,94,0.3)]";
};
---

<aside class="hidden lg:block lg:w-[30%] xl:w-[25%] shrink-0">
  <div
    class="sticky top-10 bg-white/95 backdrop-blur-md border border-gray-100/80 rounded-2xl p-6 shadow-[0_8px_30px_rgba(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-all duration-300 border-t-4 border-t-primary"
  >
    {/* Categorías */}
    <h2 class="font-bold text-gray-900 mb-4 uppercase tracking-wider text-[0.7rem] opacity-75">
      {
        lang === "es"
          ? "Categorías"
          : lang === "pt"
            ? "Categorias"
            : "Categories"
      }
    </h2>
    <div class="flex flex-col space-y-1 max-h-[300px] overflow-y-auto custom-scrollbar pr-1">
      <a
        href={rewriteUrl("/blog", lang)}
        class={`px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-300 flex items-center justify-between border border-transparent
          ${
            !currentSlug
              ? "bg-primary/10 text-primary font-semibold"
              : "text-gray-600 hover:text-primary hover:bg-primary/5"
          }`}
      >
        <span>
          {
            lang === "es"
              ? "Ver Todos"
              : lang === "pt"
                ? "Ver Todos"
                : "View All"
          }
        </span>
        {!currentSlug && <div class="w-1.5 h-1.5 rounded-full bg-primary" />}
      </a>

      {
        categories.map((cat: Category) => {
          const isActive = currentSlug === cat.slug;
          return (
            <a
              href={rewriteUrl(`/blog/${cat.slug}`, lang)}
              class={`px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-300 flex items-center justify-between border border-transparent
                ${
                  isActive
                    ? "bg-primary/10 text-primary font-semibold"
                    : "text-gray-600 hover:text-primary hover:bg-primary/5"
                }`}
            >
              <span>{cat.nombre}</span>
              {isActive && <div class="w-1.5 h-1.5 rounded-full bg-primary" />}
            </a>
          );
        })
      }
    </div>

    {/* Redes Sociales */}
    {
      Array.isArray(socialLogos) && socialLogos.length > 0 && (
        <div class="pt-6 mt-6 border-t border-gray-100/80">
          <h2 class="font-bold text-gray-900 mb-4 uppercase tracking-wider text-[0.7rem] opacity-75">
            {lang === "es"
              ? "Compartir"
              : lang === "pt"
                ? "Compartilhar"
                : "Share"}
          </h2>
          <div class="flex flex-wrap gap-3">
            {socialLogos.map((social: SocialLogo) => (
              <a
                href={formatUrl(social.url)}
                target="_blank"
                rel="noopener noreferrer"
                title={social.label || "Social"}
                class={`group flex items-center justify-center h-11 w-11 rounded-2xl bg-gray-50 border border-gray-100/50 hover:border-transparent hover:scale-110 hover:-translate-y-1 hover:rotate-6 transition-all duration-300 shadow-xs ${getSocialHoverClass(social.label, social.url)}`}
              >
                {social.imagen?.url && (
                  <img
                    src={getImageUrl(social.imagen)}
                    alt={social.label || "Social"}
                    class="h-5 w-5 object-contain brightness-0 opacity-50 group-hover:brightness-100 group-hover:opacity-100 transition-all duration-300"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</aside>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: var(--color-primary, #cbd5e1);
    border-radius: 4px;
    opacity: 0.5;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-secondary, #94a3b8);
  }
</style>
