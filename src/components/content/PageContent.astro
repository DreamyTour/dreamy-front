---
import PageLayout from "@/layouts/PageLayout.astro";
import TourCard from "@/components/ui/TourCard.astro";
import LiteYouTube from "@/components/content/LiteYouTube.astro";
import type { SEOProps } from "@/components/layout/SEO.astro";
import type {
  Category,
  Page,
  Pregunta,
  StrapiBlock,
  StrapiBlockChild,
} from "@/types/page";
import type { Tour } from "@/types/tours";
import type { Lang } from "@/lib/i18n";
import { getYouTubeVideoId, getThumbnailUrl } from "@/lib/helpers";
import { DEFAULT_LANG } from "@/lib/i18n";
import { serializeJsonForHtml } from "@/lib/html";

interface Props {
  page: Page;
  toursByCategory: Tour[];
  pageSlugMap: Record<string, string>;
  lang: Lang;
  seoProps: SEOProps;
}

const { page, toursByCategory, pageSlugMap, lang, seoProps } = Astro.props;

const pageVideoId = page?.video?.videoUrl
  ? getYouTubeVideoId(page.video.videoUrl)
  : null;

const pageVideoThumbnail = page?.video?.thumbnail
  ? getThumbnailUrl(page.video.thumbnail)
  : null;

const pageUiCopy = {
  es: {
    eyebrow: "Colección destacada",
    exploreCta: "Ver experiencias",
    toursStat: "experiencias",
  },
  en: {
    eyebrow: "Featured collection",
    exploreCta: "View experiences",
    toursStat: "experiences",
  },
  pt: {
    eyebrow: "Coleção em destaque",
    exploreCta: "Ver experiências",
    toursStat: "experiências",
  },
} as const;

const pageCopy = pageUiCopy[lang] ?? pageUiCopy[DEFAULT_LANG];

const pageStats =
  toursByCategory.length > 0
    ? [
        {
          value: `${toursByCategory.length}`,
          label: pageCopy.toursStat,
        },
      ]
    : [];
---

<PageLayout seo={seoProps} lang={lang}>
  <script
    is:inline
    id="page-slug-map"
    type="application/json"
    set:html={serializeJsonForHtml(pageSlugMap)}
  />
  <div
    class="content-shell max-w-8xl mx-auto px-4 md:px-6 lg:px-8 py-8 md:py-10 lg:py-12"
  >
    <section
      class="content-hero relative isolate overflow-hidden rounded-sm border border-border/70 bg-[#fbf7f1] px-4 py-8 md:px-8 md:py-10 lg:px-10 lg:py-12"
    >
      <div
        class="relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(420px,0.82fr)] lg:items-center lg:gap-12"
      >
        <div class="max-w-3xl">
          <span
            class="inline-flex items-center gap-2 text-[0.72rem] font-bold uppercase tracking-[0.22em] text-primary"
          >
            <span class="h-px w-8 bg-primary/55"></span>
            {pageCopy.eyebrow}
          </span>
          <div class="mt-5 space-y-5">
            <h1
              class="content-hero-title max-w-3xl text-4xl font-semibold leading-[1.04] tracking-[-0.03em] text-foreground sm:text-5xl lg:text-[3.6rem]"
            >
              {page.titulo}
            </h1>
            {
              page.content && (
                <p class="max-w-2xl text-base leading-8 text-[#4f473e] md:pt-1 lg:text-[1.04rem]">
                  {page.content}
                </p>
              )
            }
          </div>

          <div
            class="mt-8 flex w-full max-w-xl flex-col gap-4 border-t border-[#e4d8ca] pt-6 sm:flex-row sm:items-center"
          >
            <a
              href="#category-tours"
              class="group inline-flex items-center justify-center gap-3 rounded-sm bg-primary px-5 py-3 text-sm font-semibold text-white shadow-[0_14px_34px_-24px_var(--primary)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary/90 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-[#fbf7f1]"
            >
              {pageCopy.exploreCta}
              <span
                class="flex h-7 w-7 items-center justify-center rounded-sm bg-white/14 transition-transform duration-300 group-hover:translate-x-0.5"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </span>
            </a>

            {
              pageStats.map((stat) => (
                <div class="flex items-center gap-3 text-left sm:border-l sm:border-[#d7cabc] sm:pl-5">
                  <span class="text-2xl font-semibold leading-none tracking-[-0.03em] text-foreground">
                    {stat.value}
                  </span>
                  <span class="max-w-28 text-sm font-medium leading-tight text-[#655b51] capitalize">
                    {stat.label}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="relative">
          {
            pageVideoId ? (
              <div
                id="category-video"
                class="relative overflow-hidden rounded-sm shadow-[0_24px_60px_-46px_color-mix(in_oklab,var(--foreground)_42%,transparent)]"
              >
                <div class="overflow-hidden rounded-sm bg-background">
                  <LiteYouTube
                    videoId={pageVideoId}
                    title={page.titulo || "Video"}
                    backgroundImage={pageVideoThumbnail || undefined}
                    withShadowImage={!!pageVideoThumbnail}
                  />
                </div>
              </div>
            ) : (
              <div class="relative overflow-hidden rounded-sm border border-[#dfd2c3] bg-white p-8 shadow-[0_22px_55px_-42px_color-mix(in_oklab,var(--foreground)_36%,transparent)]">
                <div class="rounded-sm border border-dashed border-primary/20 bg-[#fbf7f1] px-8 py-14 text-center">
                  <p class="text-base leading-7 text-[#4f473e]">
                    {page.content}
                  </p>
                </div>
              </div>
            )
          }
        </div>
      </div>
    </section>

    {
      toursByCategory.length > 0 && (
        <section id="category-tours" class="w-full py-10 md:py-12">
          <div class="max-w-8xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-x-2 gap-y-8 ">
              {toursByCategory.map((tour) => (
                <TourCard tour={tour} lang={lang} />
              ))}
            </div>
          </div>
        </section>
      )
    }

    {
      page.tituloPreguntas &&
        page.preguntasAcordeon &&
        page.preguntasAcordeon.length > 0 && (
          <section class="w-full py-16">
            <div class="max-w-8xl mx-auto px-6">
              <div class="mx-auto mb-10 max-w-3xl text-center">
                <h2 class="text-3xl font-semibold tracking-[-0.04em] text-foreground md:text-4xl">
                  {page.tituloPreguntas}
                </h2>
                <div class="mx-auto mt-4 h-px w-24 bg-gradient-to-r from-transparent via-primary/45 to-transparent" />
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {page.preguntasAcordeon.map((pregunta: Pregunta) => (
                  <details class="group overflow-hidden rounded-sm border border-border/80 bg-background shadow-[0_22px_50px_-38px_color-mix(in_oklab,var(--foreground)_24%,transparent)] transition-colors duration-300 open:border-primary/20 open:bg-primary/[0.02]">
                    <summary class="flex w-full cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 transition-colors duration-200 hover:bg-primary/[0.03] [&::-webkit-details-marker]:hidden md:px-6">
                      <span class="text-left text-sm font-semibold text-foreground md:text-base">
                        {pregunta.titulo}
                      </span>
                      <span class="flex h-10 w-10 items-center justify-center rounded-sm border border-primary/10 bg-primary/[0.06] text-primary transition-transform duration-200 group-open:rotate-180">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-5 w-5"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width={2}
                            d="M19 9l-7 7-7-7"
                          />
                        </svg>
                      </span>
                    </summary>
                    <div class="border-t border-primary/10 px-5 pb-5 pt-4 md:px-6 md:pb-6">
                      {pregunta.contenido &&
                        Array.isArray(pregunta.contenido) && (
                          <div class="space-y-3">
                            {pregunta.contenido.map((block: StrapiBlock) => {
                              if (block.type === "paragraph") {
                                return (
                                  <p class="text-base leading-7 text-muted-foreground">
                                    {(block.children || [])
                                      .map(
                                        (child: StrapiBlockChild) =>
                                          child.text || "",
                                      )
                                      .join("")}
                                  </p>
                                );
                              }
                              if (block.type === "heading") {
                                const level = block.level;
                                const headingText = (block.children || [])
                                  .map(
                                    (child: StrapiBlockChild) =>
                                      child.text || "",
                                  )
                                  .join("");
                                if (level === 1) {
                                  return (
                                    <h2 class="text-xl font-bold text-foreground">
                                      {headingText}
                                    </h2>
                                  );
                                }
                                if (level === 2) {
                                  return (
                                    <h2 class="text-lg font-bold text-foreground">
                                      {headingText}
                                    </h2>
                                  );
                                }
                                return (
                                  <h3 class="text-base font-semibold text-foreground">
                                    {headingText}
                                  </h3>
                                );
                              }
                              if (block.type === "list") {
                                const format = block.format;
                                const ListTag =
                                  format === "ordered" ? "ol" : "ul";
                                return (
                                  <ListTag
                                    class={`${format === "ordered" ? "list-decimal" : "list-disc"} ml-4 space-y-1 text-muted-foreground`}
                                  >
                                    {(block.children || []).map(
                                      (listItem: StrapiBlockChild) => (
                                        <li class="text-muted-foreground">
                                          {(listItem.children || [])
                                            .map(
                                              (child: StrapiBlockChild) =>
                                                child.text || "",
                                            )
                                            .join("")}
                                        </li>
                                      ),
                                    )}
                                  </ListTag>
                                );
                              }
                              return null;
                            })}
                          </div>
                        )}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          </section>
        )
    }
  </div>
</PageLayout>
