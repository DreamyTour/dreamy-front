---
import PageLayout from "@/layouts/PageLayout.astro";
import TourCard from "@/components/ui/TourCard.astro";
import LiteYouTube from "@/components/content/LiteYouTube.astro";
import type { SEOProps } from "@/components/layout/SEO.astro";
import type {
  Page,
  Pregunta,
  StrapiBlock,
  StrapiBlockChild,
} from "@/types/page";
import type { Tour } from "@/types/tours";
import type { Lang } from "@/lib/i18n";
import { getYouTubeVideoId, getThumbnailUrl } from "@/lib/helpers";
import { serializeJsonForHtml } from "@/lib/html";

interface Props {
  page: Page;
  toursByCategory: Tour[];
  pageSlugMap: Record<string, string>;
  lang: Lang;
  seoProps: SEOProps;
}

const { page, toursByCategory, pageSlugMap, lang, seoProps } = Astro.props;

const pageVideoId = page?.video?.videoUrl
  ? getYouTubeVideoId(page.video.videoUrl)
  : null;

const pageVideoThumbnail = page?.video?.thumbnail
  ? getThumbnailUrl(page.video.thumbnail)
  : null;

const pageContent = page.content?.trim() || "";
---

<PageLayout seo={seoProps} lang={lang}>
  <script
    is:inline
    id="page-slug-map"
    type="application/json"
    set:html={serializeJsonForHtml(pageSlugMap)}
  />
  <div class="page-content-shell relative isolate overflow-hidden">
    <div
      class="content-shell max-w-8xl mx-auto px-4 py-6 md:px-6 md:py-8 lg:px-8 lg:py-10"
    >
      <section class="content-hero page-hero-agency text-foreground">
        <div class="relative py-8 md:py-10 lg:py-12">
          <div
            class="grid gap-8 lg:grid-cols-[minmax(0,0.64fr)_minmax(520px,1fr)] lg:items-start lg:gap-12"
          >
            <div class="max-w-2xl self-start">
              <h1
                class="content-hero-title max-w-xl text-4xl font-semibold leading-[1.02] tracking-[-0.04em] text-foreground sm:text-5xl lg:text-[3.2rem]"
              >
                {page.titulo}
              </h1>

              {
                pageContent && (
                  <p class="page-hero-summary mt-7 text-[0.96rem] leading-7 text-muted-foreground">
                    {pageContent}
                  </p>
                )
              }
            </div>

            <div class="relative self-start">
              {
                pageVideoId ? (
                  <div
                    id="category-video"
                    class="page-hero-media relative overflow-hidden rounded-sm border border-border bg-card shadow-[0_30px_80px_-58px_color-mix(in_oklab,var(--foreground)_62%,transparent)]"
                  >
                    <div class="overflow-hidden bg-black">
                      <LiteYouTube
                        videoId={pageVideoId}
                        title={page.titulo || "Video"}
                        backgroundImage={pageVideoThumbnail || undefined}
                        withShadowImage={!!pageVideoThumbnail}
                      />
                    </div>
                  </div>
                ) : (
                  <div class="page-hero-media relative overflow-hidden rounded-sm border border-border bg-muted/25 px-8 py-14 shadow-[0_30px_80px_-58px_color-mix(in_oklab,var(--foreground)_52%,transparent)]">
                    <div class="mx-auto max-w-lg text-center">
                      <p class="text-base leading-7 text-muted-foreground">
                        {page.content}
                      </p>
                    </div>
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </section>

      {
        toursByCategory.length > 0 && (
          <section id="category-tours" class="w-full py-10 md:py-12">
            <div class="grid grid-cols-1 gap-x-2 gap-y-8 md:grid-cols-3 lg:grid-cols-4">
              {toursByCategory.map((tour) => (
                <TourCard tour={tour} lang={lang} />
              ))}
            </div>
          </section>
        )
      }

      {
        page.tituloPreguntas &&
          page.preguntasAcordeon &&
          page.preguntasAcordeon.length > 0 && (
            <section class="w-full py-16">
              <div class="w-full">
                <div class="mx-auto mb-10 max-w-3xl text-center">
                  <h2 class="text-3xl font-semibold tracking-[-0.04em] text-foreground md:text-4xl">
                    {page.tituloPreguntas}
                  </h2>
                  <div class="mx-auto mt-4 h-px w-24 bg-gradient-to-r from-transparent via-primary/45 to-transparent" />
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {page.preguntasAcordeon.map((pregunta: Pregunta) => (
                    <details class="group overflow-hidden rounded-sm border border-border/80 bg-background shadow-[0_22px_50px_-38px_color-mix(in_oklab,var(--foreground)_24%,transparent)] transition-colors duration-300 open:border-primary/20 open:bg-primary/[0.02]">
                      <summary class="flex w-full cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 transition-colors duration-200 hover:bg-primary/[0.03] [&::-webkit-details-marker]:hidden md:px-6">
                        <span class="text-left text-sm font-semibold text-foreground md:text-base">
                          {pregunta.titulo}
                        </span>
                        <span class="flex h-10 w-10 items-center justify-center rounded-sm border border-primary/10 bg-primary/[0.06] text-primary transition-transform duration-200 group-open:rotate-180">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width={2}
                              d="M19 9l-7 7-7-7"
                            />
                          </svg>
                        </span>
                      </summary>
                      <div class="border-t border-primary/10 px-5 pb-5 pt-4 md:px-6 md:pb-6">
                        {pregunta.contenido &&
                          Array.isArray(pregunta.contenido) && (
                            <div class="space-y-3">
                              {pregunta.contenido.map((block: StrapiBlock) => {
                                if (block.type === "paragraph") {
                                  return (
                                    <p class="text-base leading-7 text-muted-foreground">
                                      {(block.children || [])
                                        .map(
                                          (child: StrapiBlockChild) =>
                                            child.text || "",
                                        )
                                        .join("")}
                                    </p>
                                  );
                                }
                                if (block.type === "heading") {
                                  const level = block.level;
                                  const headingText = (block.children || [])
                                    .map(
                                      (child: StrapiBlockChild) =>
                                        child.text || "",
                                    )
                                    .join("");
                                  if (level === 1) {
                                    return (
                                      <h2 class="text-xl font-bold text-foreground">
                                        {headingText}
                                      </h2>
                                    );
                                  }
                                  if (level === 2) {
                                    return (
                                      <h2 class="text-lg font-bold text-foreground">
                                        {headingText}
                                      </h2>
                                    );
                                  }
                                  return (
                                    <h3 class="text-base font-semibold text-foreground">
                                      {headingText}
                                    </h3>
                                  );
                                }
                                if (block.type === "list") {
                                  const format = block.format;
                                  const ListTag =
                                    format === "ordered" ? "ol" : "ul";
                                  return (
                                    <ListTag
                                      class={`${format === "ordered" ? "list-decimal" : "list-disc"} ml-4 space-y-1 text-muted-foreground`}
                                    >
                                      {(block.children || []).map(
                                        (listItem: StrapiBlockChild) => (
                                          <li class="text-muted-foreground">
                                            {(listItem.children || [])
                                              .map(
                                                (child: StrapiBlockChild) =>
                                                  child.text || "",
                                              )
                                              .join("")}
                                          </li>
                                        ),
                                      )}
                                    </ListTag>
                                  );
                                }
                                return null;
                              })}
                            </div>
                          )}
                      </div>
                    </details>
                  ))}
                </div>
              </div>
            </section>
          )
      }
    </div>
  </div>
</PageLayout>

<style is:inline>
  .page-content-shell::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: url("/fondo.svg");
    background-position: top center;
    background-repeat: repeat;
    background-size: 520px 520px;
    content: "";
    opacity: 0.035;
    pointer-events: none;
  }

  .page-hero-summary {
    max-inline-size: 68ch;
    text-wrap: pretty;
  }
</style>
