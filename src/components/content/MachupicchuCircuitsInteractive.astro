---
import {
  machupicchuCircuitsContent,
  type MachupicchuCircuitsLang,
} from "@/data/machupicchuCircuitsContent";

interface Props {
  lang?: MachupicchuCircuitsLang;
}

const mapImage =
  "https://dreamy.tours/wp-content/uploads/Ruta-1-A-2048x1448.webp";

const selectedLang = Astro.props.lang ?? "es";
const content =
  machupicchuCircuitsContent[selectedLang] ?? machupicchuCircuitsContent.es;
const { circuits, routes, ui, compareRows, booking, cta, ctaHref } = content;

const dialogs = [
  ...circuits.map((circuit) => ({
    id: circuit.dialogId,
    tone: circuit.tone,
    title: `${ui.officialMap} · ${ui.circuit} ${circuit.number} ${circuit.name}`,
    alt: circuit.alt,
    caption: `© Dreamy Tours · ${ui.officialMap} · ${ui.circuit} ${circuit.number} ${circuit.name} (${circuit.routes.join(", ")})`,
  })),
  ...routes.map((route) => ({
    id: route.modalId,
    tone: route.tone,
    title: `${ui.map} · ${route.title}`,
    alt: `${ui.officialMap} ${route.title}`,
    caption:
      route.id === "ruta-1a"
        ? `© Dreamy Tours · ${ui.officialMap} · ${route.title}`
        : `${ui.replaceImage} · ${route.title}`,
  })),
];
---

<section class="mpc" data-mpc-circuits aria-labelledby="mpc-heading">
  <div class="mpc-decree">
    <span class="mpc-decree-icon" aria-hidden="true">!</span>
    <p>{ui.decree}</p>
  </div>

  <section class="mpc-map-section" aria-labelledby="mpc-heading">
    <p class="mpc-label">{ui.mapsLabel}</p>
    <h2 id="mpc-heading">{ui.mapsTitle}</h2>
    <p class="mpc-desc">{ui.mapsDescription}</p>

    <div class="mpc-circuit-grid">
      {
        circuits.map((circuit) => (
          <article class={`mpc-circuit-card ${circuit.tone}`}>
            <button
              class="mpc-map-trigger"
              type="button"
              data-mpc-dialog={circuit.dialogId}
              aria-label={`${ui.viewFullMap}: ${ui.circuit} ${circuit.number} ${circuit.name}`}
            >
              <img
                src={mapImage}
                alt={circuit.alt}
                width="1024"
                height="724"
                loading="lazy"
              />
              <span class="mpc-card-badge">
                {ui.circuit} {circuit.number}
              </span>
              <span class="mpc-card-overlay">{ui.viewFullMap}</span>
            </button>
            <div class="mpc-card-body">
              <span class="mpc-card-num">
                {ui.circuit} {circuit.number}
              </span>
              <h3>{circuit.name}</h3>
              <ul
                class="mpc-route-tags"
                aria-label={`${ui.routesAria} ${circuit.number}`}
              >
                {circuit.routes.map((route) => (
                  <li>{route}</li>
                ))}
              </ul>
              <button
                class="mpc-card-cta"
                type="button"
                data-mpc-dialog={circuit.dialogId}
              >
                {ui.viewCircuitMap}
              </button>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <nav class="mpc-tabs" aria-label={ui.navLabel}>
    {
      circuits.map((circuit) => (
        <a class={`mpc-tab ${circuit.tone}`} href={`#${circuit.id}`}>
          {ui.circuit} {circuit.number} - {circuit.name} (
          {circuit.routes.length} {ui.routes})
        </a>
      ))
    }
  </nav>

  <div class="mpc-routes">
    {
      circuits.map((circuit) => (
        <section
          id={circuit.id}
          class="mpc-circuit-section"
          aria-labelledby={`${circuit.id}-title`}
        >
          <header class={`mpc-circuit-header ${circuit.tone}`}>
            <span class="mpc-circuit-number" aria-hidden="true">
              {circuit.number}
            </span>
            <div>
              <h2 id={`${circuit.id}-title`}>
                {ui.circuit} {circuit.number} - {circuit.name}
              </h2>
              <p>{circuit.summary}</p>
            </div>
          </header>

          <div class="mpc-route-list">
            {routes
              .filter((route) => route.circuitId === circuit.id)
              .map((route) => (
                <article id={route.id} class={`mpc-route-card ${route.tone}`}>
                  <header class="mpc-route-head">
                    <div>
                      <h3>{route.title}</h3>
                      {route.seasonal && (
                        <span class="mpc-seasonal">{route.seasonal}</span>
                      )}
                    </div>
                    <button
                      class="mpc-route-map"
                      type="button"
                      data-mpc-dialog={route.modalId}
                      aria-label={`${ui.viewRouteMap}: ${route.title}`}
                    >
                      {ui.viewRouteMap}
                    </button>
                  </header>

                  <div class="mpc-route-body">
                    <p class="mpc-route-intro">{route.intro}</p>
                    <dl class="mpc-details">
                      {route.details.map(([label, value]) => (
                        <div class="mpc-detail">
                          <dt>{label}</dt>
                          <dd>{value}</dd>
                        </div>
                      ))}
                    </dl>
                    <div class="mpc-ideal">
                      <h4>{ui.idealTitle}</h4>
                      <ul>
                        {route.ideal.map(([lead, text]) => (
                          <li>
                            <strong>{lead}</strong> - {text}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </article>
              ))}
          </div>
        </section>
      ))
    }
  </div>

  <section class="mpc-compare" aria-labelledby="mpc-compare-title">
    <h2 id="mpc-compare-title">{ui.compareTitle}</h2>
    <div class="mpc-table-wrap">
      <table>
        <caption>{ui.compareCaption}</caption>
        <thead>
          <tr>
            <th scope="col">{ui.detailHeader}</th>
            {
              circuits.map((circuit) => (
                <th scope="col">
                  {ui.circuit} {circuit.number}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            compareRows.map(
              ([detail, circuitOne, circuitTwo, circuitThree]) => (
                <tr>
                  <th scope="row">{detail}</th>
                  <td>{circuitOne}</td>
                  <td>{circuitTwo}</td>
                  <td>{circuitThree}</td>
                </tr>
              ),
            )
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="mpc-booking" aria-labelledby="mpc-booking-title">
    <h2 id="mpc-booking-title">{ui.bookingTitle}</h2>
    <div class="mpc-booking-grid">
      {
        booking.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <div class="mpc-cta">
    <h2>{cta.title}</h2>
    <p>{cta.text}</p>
    <a href={ctaHref}>{cta.label}</a>
  </div>

  {
    dialogs.map((dialog) => (
      <dialog
        id={dialog.id}
        class={`mpc-dialog ${dialog.tone}`}
        aria-labelledby={`${dialog.id}-title`}
        closedby="any"
      >
        <div class="mpc-dialog-panel">
          <header>
            <h2 id={`${dialog.id}-title`}>{dialog.title}</h2>
            <form method="dialog">
              <button type="submit" aria-label={ui.closeMap}>
                ×
              </button>
            </form>
          </header>
          <figure>
            <img
              src={mapImage}
              alt={dialog.alt}
              width="1024"
              height="724"
              loading="lazy"
            />
            <figcaption>{dialog.caption}</figcaption>
          </figure>
        </div>
      </dialog>
    ))
  }
</section>

<script>
  /**
   * @typedef {HTMLElement & { __mpcCircuitController?: AbortController }} CircuitRoot
   */

  const initMachupicchuCircuitDialogs = () => {
    document.querySelectorAll("[data-mpc-circuits]").forEach((root) => {
      const circuitRoot = /** @type {CircuitRoot} */ (root);
      const existingController = circuitRoot.__mpcCircuitController;
      existingController?.abort();

      const controller = new AbortController();
      circuitRoot.__mpcCircuitController = controller;

      circuitRoot.querySelectorAll("[data-mpc-dialog]").forEach((trigger) => {
        trigger.addEventListener(
          "click",
          () => {
            const dialogId = trigger.getAttribute("data-mpc-dialog");
            if (!dialogId) return;

            const dialog = circuitRoot.querySelector(
              `#${CSS.escape(dialogId)}`,
            );
            if (dialog instanceof HTMLDialogElement && !dialog.open) {
              dialog.showModal();
            }
          },
          { signal: controller.signal },
        );
      });

      circuitRoot.querySelectorAll("dialog").forEach((dialog) => {
        if (!("closedBy" in HTMLDialogElement.prototype)) {
          dialog.addEventListener(
            "click",
            (event) => {
              if (event.target !== dialog) return;

              const rect = dialog.getBoundingClientRect();
              const clickedInside =
                rect.top <= event.clientY &&
                event.clientY <= rect.top + rect.height &&
                rect.left <= event.clientX &&
                event.clientX <= rect.left + rect.width;

              if (!clickedInside) dialog.close();
            },
            { signal: controller.signal },
          );
        }
      });
    });
  };

  document.addEventListener("astro:page-load", initMachupicchuCircuitDialogs);

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      initMachupicchuCircuitDialogs,
      {
        once: true,
      },
    );
  } else {
    initMachupicchuCircuitDialogs();
  }
</script>

<style>
  .mpc {
    --mpc-ink: #102019;
    --mpc-muted: #5d6a62;
    --mpc-line: rgba(16, 32, 25, 0.12);
    --mpc-paper: #ffffff;
    --mpc-soft: #f4f7f4;
    --c1: #007a3d;
    --c1-soft: #e8f7ef;
    --c2: #1463a5;
    --c2-soft: #e7f1fb;
    --c3: #7a3db8;
    --c3-soft: #f0e8fb;
    --gold: #b06a00;
    --gold-soft: #fff4d9;
    color: var(--mpc-ink);
    margin-top: 2rem;
  }

  .mpc :where(h2, h3, h4, p, ul, dl, figure) {
    margin: 0;
  }

  .mpc :where(button, a):focus-visible {
    outline: 3px solid #f2b84b;
    outline-offset: 3px;
  }

  .mpc-decree {
    align-items: flex-start;
    background: linear-gradient(135deg, #fff8e8, #ffffff);
    border: 1px solid rgba(176, 106, 0, 0.22);
    border-left: 5px solid var(--gold);
    border-radius: 8px;
    box-shadow: 0 20px 45px -34px rgba(16, 32, 25, 0.45);
    display: flex;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
  }

  .mpc-decree p {
    color: #654510;
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .mpc-decree-icon {
    align-items: center;
    background: var(--gold);
    border-radius: 999px;
    color: #fff;
    display: inline-flex;
    flex: 0 0 auto;
    font-weight: 800;
    height: 1.75rem;
    justify-content: center;
    width: 1.75rem;
  }

  .mpc-map-section {
    padding: 3.25rem 0 2.2rem;
    text-align: center;
  }

  .mpc-label {
    color: var(--c1);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .mpc-map-section h2,
  .mpc-compare h2,
  .mpc-booking h2,
  .mpc-cta h2 {
    color: var(--mpc-ink);
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.08;
    margin-top: 0.55rem;
  }

  .mpc-desc {
    color: var(--mpc-muted);
    line-height: 1.7;
    margin-top: 0.75rem;
  }

  .mpc-circuit-grid {
    display: grid;
    gap: 1.35rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 2rem;
    text-align: left;
  }

  .mpc-circuit-card,
  .mpc-route-card,
  .mpc-booking article {
    background: var(--mpc-paper);
    border: 1px solid var(--mpc-line);
    border-radius: 8px;
    box-shadow: 0 24px 60px -42px rgba(16, 32, 25, 0.45);
    overflow: hidden;
  }

  .mpc-circuit-card {
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .mpc-circuit-card.c1 {
    border-top: 4px solid var(--c1);
  }

  .mpc-circuit-card.c2 {
    border-top: 4px solid var(--c2);
  }

  .mpc-circuit-card.c3 {
    border-top: 4px solid var(--c3);
  }

  .mpc-map-trigger {
    aspect-ratio: 16 / 10;
    background: #0b1611;
    border: 0;
    color: #fff;
    cursor: pointer;
    display: block;
    overflow: hidden;
    padding: 0;
    position: relative;
    width: 100%;
  }

  .mpc-map-trigger img {
    display: block;
    height: 100%;
    object-fit: cover;
    transition: scale 0.35s ease;
    width: 100%;
  }

  .mpc-map-trigger:hover img {
    scale: 1.04;
  }

  .mpc-card-badge,
  .mpc-card-overlay {
    position: absolute;
  }

  .mpc-card-badge {
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 800;
    left: 1rem;
    padding: 0.35rem 0.7rem;
    top: 1rem;
  }

  .c1 .mpc-card-badge,
  .c1 .mpc-card-cta,
  .c1 .mpc-route-map {
    background: var(--c1);
  }

  .c2 .mpc-card-badge,
  .c2 .mpc-card-cta,
  .c2 .mpc-route-map {
    background: var(--c2);
  }

  .c3 .mpc-card-badge,
  .c3 .mpc-card-cta,
  .c3 .mpc-route-map {
    background: var(--c3);
  }

  .gold .mpc-route-map {
    background: var(--gold);
  }

  .mpc-card-overlay {
    align-items: center;
    background: rgba(4, 10, 7, 0.68);
    display: flex;
    inset: 0;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .mpc-map-trigger:hover .mpc-card-overlay,
  .mpc-map-trigger:focus-visible .mpc-card-overlay {
    opacity: 1;
  }

  .mpc-card-body {
    display: flex;
    flex-direction: column;
    padding: 1.2rem;
  }

  .mpc-card-num {
    display: inline-flex;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .c1 .mpc-card-num {
    color: var(--c1);
  }

  .c2 .mpc-card-num {
    color: var(--c2);
  }

  .c3 .mpc-card-num {
    color: var(--c3);
  }

  .mpc-card-body h3 {
    font-size: 1.45rem;
    line-height: 1.15;
    margin-top: 0.35rem;
  }

  .mpc-route-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin-bottom: 1.1rem;
    margin-top: 1rem;
    padding: 0;
  }

  .mpc-route-tags li {
    background: var(--mpc-soft);
    border: 1px solid var(--mpc-line);
    border-radius: 999px;
    color: var(--mpc-muted);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.34rem 0.62rem;
  }

  .mpc-card-cta,
  .mpc-route-map,
  .mpc-cta a {
    border: 0;
    border-radius: 999px;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 800;
    justify-content: center;
    line-height: 1;
    padding: 0.78rem 1rem;
    text-decoration: none;
    transition:
      transform 0.18s ease,
      filter 0.18s ease;
  }

  .mpc-card-cta {
    margin-top: auto;
    width: 100%;
  }

  .mpc-card-cta:hover,
  .mpc-route-map:hover,
  .mpc-cta a:hover {
    filter: brightness(1.05);
    transform: translateY(-1px);
  }

  .mpc-tabs {
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(16, 32, 25, 0.1);
    border-radius: 0 0 8px 8px;
    box-shadow: 0 12px 26px -20px rgba(16, 32, 25, 0.5);
    display: flex;
    gap: 0.7rem;
    margin: 0 0 2.5rem;
    overflow-x: auto;
    padding: 0.65rem;
    position: sticky;
    top: 0;
    z-index: 8;
  }

  .mpc-tab {
    border-radius: 999px;
    color: var(--mpc-ink);
    flex: 1 0 max-content;
    font-size: 0.88rem;
    font-weight: 800;
    padding: 0.8rem 1rem;
    text-align: center;
    text-decoration: none;
  }

  .mpc-tab.c1 {
    background: var(--c1-soft);
    color: var(--c1);
  }

  .mpc-tab.c2 {
    background: var(--c2-soft);
    color: var(--c2);
  }

  .mpc-tab.c3 {
    background: var(--c3-soft);
    color: var(--c3);
  }

  .mpc-circuit-section {
    scroll-margin-top: 92px;
  }

  .mpc-circuit-section + .mpc-circuit-section {
    margin-top: 3rem;
  }

  .mpc-circuit-header {
    align-items: center;
    border-radius: 8px;
    color: #fff;
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    padding: 1.35rem;
  }

  .mpc-circuit-header.c1 {
    background: linear-gradient(135deg, var(--c1), #004b29);
  }

  .mpc-circuit-header.c2 {
    background: linear-gradient(135deg, var(--c2), #083b6d);
  }

  .mpc-circuit-header.c3 {
    background: linear-gradient(135deg, var(--c3), #4b247b);
  }

  .mpc-circuit-number {
    align-items: center;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    display: flex;
    flex: 0 0 auto;
    font-size: 1.6rem;
    font-weight: 900;
    height: 3.4rem;
    justify-content: center;
    width: 3.4rem;
  }

  .mpc-circuit-header h2 {
    color: #fff;
    font-size: clamp(1.55rem, 3vw, 2.2rem);
    font-weight: 850;
    line-height: 1.1;
  }

  .mpc-circuit-header p {
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.6;
    margin-top: 0.35rem;
  }

  .mpc-route-list {
    display: grid;
    gap: 1rem;
  }

  .mpc-route-card.c1 {
    border-top: 3px solid var(--c1);
  }

  .mpc-route-card.c2 {
    border-top: 3px solid var(--c2);
  }

  .mpc-route-card.c3 {
    border-top: 3px solid var(--c3);
  }

  .mpc-route-card.gold {
    border-top: 3px solid var(--gold);
  }

  .mpc-route-head {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding: 1rem 1.15rem;
  }

  .mpc-route-card.c1 .mpc-route-head {
    background: var(--c1-soft);
  }

  .mpc-route-card.c2 .mpc-route-head {
    background: var(--c2-soft);
  }

  .mpc-route-card.c3 .mpc-route-head {
    background: var(--c3-soft);
  }

  .mpc-route-card.gold .mpc-route-head {
    background: var(--gold-soft);
  }

  .mpc-route-head h3 {
    font-size: 1.2rem;
    font-weight: 850;
    line-height: 1.25;
  }

  .mpc-route-card.c1 h3 {
    color: var(--c1);
  }

  .mpc-route-card.c2 h3 {
    color: var(--c2);
  }

  .mpc-route-card.c3 h3 {
    color: var(--c3);
  }

  .mpc-route-card.gold h3 {
    color: #7a4a00;
  }

  .mpc-seasonal {
    background: #fff;
    border: 1px solid rgba(176, 106, 0, 0.2);
    border-radius: 999px;
    color: #7a4a00;
    display: inline-flex;
    font-size: 0.72rem;
    font-weight: 800;
    margin-top: 0.5rem;
    padding: 0.35rem 0.6rem;
  }

  .mpc-route-body {
    padding: 1.25rem;
  }

  .mpc-route-intro {
    color: var(--mpc-muted);
    line-height: 1.75;
    max-width: 82ch;
  }

  .mpc-details {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1.2rem;
  }

  .mpc-detail {
    background: var(--mpc-soft);
    border: 1px solid var(--mpc-line);
    border-radius: 8px;
    padding: 0.9rem;
  }

  .mpc-detail dt {
    color: var(--mpc-ink);
    font-size: 0.75rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .mpc-detail dd {
    color: var(--mpc-muted);
    line-height: 1.55;
    margin: 0.35rem 0 0;
  }

  .mpc-ideal {
    background: #fbfdfb;
    border: 1px solid var(--mpc-line);
    border-radius: 8px;
    margin-top: 1.2rem;
    padding: 1rem;
  }

  .mpc-ideal h4 {
    font-size: 1rem;
    font-weight: 850;
  }

  .mpc-ideal ul {
    color: var(--mpc-muted);
    line-height: 1.65;
    margin-top: 0.65rem;
    padding-left: 1.1rem;
  }

  .mpc-compare,
  .mpc-booking,
  .mpc-cta {
    margin-top: 3rem;
  }

  .mpc-table-wrap {
    border: 1px solid var(--mpc-line);
    border-radius: 8px;
    margin-top: 1rem;
    overflow-x: auto;
  }

  .mpc table {
    border-collapse: collapse;
    min-width: 760px;
    width: 100%;
  }

  .mpc caption {
    color: var(--mpc-muted);
    padding: 0.9rem;
    text-align: left;
  }

  .mpc th,
  .mpc td {
    border-top: 1px solid var(--mpc-line);
    padding: 0.85rem 1rem;
    text-align: left;
  }

