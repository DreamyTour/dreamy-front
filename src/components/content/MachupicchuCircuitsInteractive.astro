---
import {
  machupicchuCircuitsContent,
  type MachupicchuCircuitsLang,
} from "@/data/machupicchuCircuitsContent";

interface Props {
  lang?: MachupicchuCircuitsLang;
}

type Tone = "c1" | "c2" | "c3" | "gold";

const mapImage =
  "https://dreamy.tours/wp-content/uploads/Ruta-1-A-2048x1448.webp";

const selectedLang = Astro.props.lang ?? "es";
const content =
  machupicchuCircuitsContent[selectedLang] ?? machupicchuCircuitsContent.es;
const { circuits, routes, ui, compareRows, booking, cta, ctaHref } = content;

const toneStyles: Record<
  Tone,
  {
    border: string;
    badge: string;
    text: string;
    soft: string;
    header: string;
    button: string;
    dialog: string;
    title: string;
  }
> = {
  c1: {
    border: "border-t-[#007a3d]",
    badge: "bg-[#007a3d]",
    text: "text-[#007a3d]",
    soft: "bg-[#e8f7ef] text-[#007a3d]",
    header: "bg-gradient-to-br from-[#007a3d] to-[#004b29]",
    button: "bg-[#007a3d]",
    dialog: "bg-[#007a3d]",
    title: "text-[#007a3d]",
  },
  c2: {
    border: "border-t-[#1463a5]",
    badge: "bg-[#1463a5]",
    text: "text-[#1463a5]",
    soft: "bg-[#e7f1fb] text-[#1463a5]",
    header: "bg-gradient-to-br from-[#1463a5] to-[#083b6d]",
    button: "bg-[#1463a5]",
    dialog: "bg-[#1463a5]",
    title: "text-[#1463a5]",
  },
  c3: {
    border: "border-t-[#7a3db8]",
    badge: "bg-[#7a3db8]",
    text: "text-[#7a3db8]",
    soft: "bg-[#f0e8fb] text-[#7a3db8]",
    header: "bg-gradient-to-br from-[#7a3db8] to-[#4b247b]",
    button: "bg-[#7a3db8]",
    dialog: "bg-[#7a3db8]",
    title: "text-[#7a3db8]",
  },
  gold: {
    border: "border-t-[#b06a00]",
    badge: "bg-[#b06a00]",
    text: "text-[#7a4a00]",
    soft: "bg-[#fff4d9] text-[#7a4a00]",
    header: "bg-gradient-to-br from-[#b06a00] to-[#7a4a00]",
    button: "bg-[#b06a00]",
    dialog: "bg-[#b06a00]",
    title: "text-[#7a4a00]",
  },
};

const focusClass =
  "focus-visible:outline-[3px] focus-visible:outline-offset-[3px] focus-visible:outline-[#f2b84b]";
const pillButtonClass = `${focusClass} inline-flex cursor-pointer justify-center rounded-full border-0 px-4 py-3 text-sm font-extrabold leading-none text-white no-underline transition hover:-translate-y-0.5 hover:brightness-105`;
const cardClass =
  "overflow-hidden rounded-lg border border-[rgba(16,32,25,0.12)] bg-white shadow-[0_24px_60px_-42px_rgba(16,32,25,0.45)]";

const dialogs = [
  ...circuits.map((circuit) => ({
    id: circuit.dialogId,
    tone: circuit.tone as Tone,
    title: `${ui.officialMap} - ${ui.circuit} ${circuit.number} ${circuit.name}`,
    alt: circuit.alt,
    caption: `(c) Dreamy Tours - ${ui.officialMap} - ${ui.circuit} ${circuit.number} ${circuit.name} (${circuit.routes.join(", ")})`,
  })),
  ...routes.map((route) => ({
    id: route.modalId,
    tone: route.tone as Tone,
    title: `${ui.map} - ${route.title}`,
    alt: `${ui.officialMap} ${route.title}`,
    caption:
      route.id === "ruta-1a"
        ? `(c) Dreamy Tours - ${ui.officialMap} - ${route.title}`
        : `${ui.replaceImage} - ${route.title}`,
  })),
];
---

<section
  class="mpc mt-8 text-[#102019]"
  data-mpc-circuits
  aria-labelledby="mpc-heading"
>
  <div
    class="flex items-start gap-4 rounded-lg border border-l-4 border-[rgba(176,106,0,0.22)] border-l-[#b06a00] bg-gradient-to-br from-[#fff8e8] to-white p-5 shadow-[0_20px_45px_-34px_rgba(16,32,25,0.45)] max-sm:flex-col max-sm:items-stretch"
  >
    <span
      class="inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-[#b06a00] font-extrabold text-white"
      aria-hidden="true">!</span
    >
    <p class="m-0 text-[0.96rem] leading-7 text-[#654510]">{ui.decree}</p>
  </div>

  <section class="py-12 text-center" aria-labelledby="mpc-heading">
    <p
      class="m-0 text-xs font-extrabold tracking-[0.18em] text-[#007a3d] uppercase"
    >
      {ui.mapsLabel}
    </p>
    <h2
      id="mpc-heading"
      class="mt-2 mb-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-[#102019]"
    >
      {ui.mapsTitle}
    </h2>
    <p class="mx-auto mt-3 mb-0 leading-7 text-[#5d6a62]">
      {ui.mapsDescription}
    </p>

    <div class="mt-8 grid grid-cols-1 gap-5 text-left lg:grid-cols-3">
      {
        circuits.map((circuit) => {
          const tone = toneStyles[circuit.tone as Tone];

          return (
            <article class={`${cardClass} grid grid-rows-[auto_1fr] border-t-4 ${tone.border}`}>
              <button
                class={`${focusClass} group relative block aspect-[16/10] w-full cursor-pointer overflow-hidden border-0 bg-[#0b1611] p-0 text-white`}
                type="button"
                data-mpc-dialog={circuit.dialogId}
                aria-label={`${ui.viewFullMap}: ${ui.circuit} ${circuit.number} ${circuit.name}`}
              >
                <img
                  class="block h-full w-full object-cover transition group-hover:scale-105"
                  src={mapImage}
                  alt={circuit.alt}
                  width="1024"
                  height="724"
                  loading="lazy"
                />
                <span
                  class={`absolute top-4 left-4 rounded-full px-3 py-1.5 text-xs font-extrabold ${tone.badge}`}
                >
                  {ui.circuit} {circuit.number}
                </span>
                <span class="absolute inset-0 flex items-center justify-center bg-[rgba(4,10,7,0.68)] opacity-0 transition group-hover:opacity-100 group-focus-visible:opacity-100">
                  {ui.viewFullMap}
                </span>
              </button>
              <div class="flex flex-col p-5">
                <span
                  class={`inline-flex text-xs font-extrabold tracking-[0.14em] uppercase ${tone.text}`}
                >
                  {ui.circuit} {circuit.number}
                </span>
                <h3 class="mt-1 mb-0 text-2xl leading-tight font-extrabold">
                  {circuit.name}
                </h3>
                <ul
                  class="mt-4 mb-5 flex list-none flex-wrap gap-2 p-0"
                  aria-label={`${ui.routesAria} ${circuit.number}`}
                >
                  {circuit.routes.map((route) => (
                    <li class="rounded-full border border-[rgba(16,32,25,0.12)] bg-[#f4f7f4] px-2.5 py-1.5 text-xs font-bold text-[#5d6a62]">
                      {route}
                    </li>
                  ))}
                </ul>
                <button
                  class={`${pillButtonClass} mt-auto w-full ${tone.button}`}
                  type="button"
                  data-mpc-dialog={circuit.dialogId}
                >
                  {ui.viewCircuitMap}
                </button>
              </div>
            </article>
          );
        })
      }
    </div>
  </section>

  <nav
    class="sticky top-0 z-[8] mb-10 flex gap-3 overflow-x-auto rounded-b-lg border border-[rgba(16,32,25,0.1)] bg-white/95 p-2 shadow-[0_12px_26px_-20px_rgba(16,32,25,0.5)]"
    aria-label={ui.navLabel}
  >
    {
      circuits.map((circuit) => {
        const tone = toneStyles[circuit.tone as Tone];

        return (
          <a
            class={`${focusClass} flex-1 basis-[max-content] rounded-full px-4 py-3 text-center text-sm font-extrabold no-underline ${tone.soft}`}
            href={`#${circuit.id}`}
          >
            {ui.circuit} {circuit.number} - {circuit.name} (
            {circuit.routes.length} {ui.routes})
          </a>
        );
      })
    }
  </nav>

  <div>
    {
      circuits.map((circuit) => {
        const tone = toneStyles[circuit.tone as Tone];

        return (
          <section
            id={circuit.id}
            class="scroll-mt-24 not-first:mt-12"
            aria-labelledby={`${circuit.id}-title`}
          >
            <header
              class={`mb-4 flex items-center gap-5 rounded-lg p-5 text-white max-sm:flex-col max-sm:items-stretch ${tone.header}`}
            >
              <span
                class="flex h-14 w-14 flex-none items-center justify-center rounded-full border border-white/25 bg-white/15 text-2xl font-black"
                aria-hidden="true"
              >
                {circuit.number}
              </span>
              <div>
                <h2
                  id={`${circuit.id}-title`}
                  class="m-0 text-[clamp(1.55rem,3vw,2.2rem)] leading-tight font-extrabold text-white"
                >
                  {ui.circuit} {circuit.number} - {circuit.name}
                </h2>
                <p class="mt-1 mb-0 leading-7 text-white/80">
                  {circuit.summary}
                </p>
              </div>
            </header>

            <div class="grid gap-4">
              {routes
                .filter((route) => route.circuitId === circuit.id)
                .map((route) => {
                  const routeTone = toneStyles[route.tone as Tone];

                  return (
                    <article
                      id={route.id}
                      class={`${cardClass} border-t-[3px] ${routeTone.border}`}
                    >
                      <header
                        class={`flex items-center justify-between gap-4 p-4 max-sm:flex-col max-sm:items-stretch ${routeTone.soft}`}
                      >
                        <div>
                          <h3
                            class={`m-0 text-xl leading-tight font-extrabold ${routeTone.title}`}
                          >
                            {route.title}
                          </h3>
                          {route.seasonal && (
                            <span class="mt-2 inline-flex rounded-full border border-[rgba(176,106,0,0.2)] bg-white px-2.5 py-1.5 text-xs font-extrabold text-[#7a4a00]">
                              {route.seasonal}
                            </span>
                          )}
                        </div>
                        <button
                          class={`${pillButtonClass} ${routeTone.button} max-sm:w-full`}
                          type="button"
                          data-mpc-dialog={route.modalId}
                          aria-label={`${ui.viewRouteMap}: ${route.title}`}
                        >
                          {ui.viewRouteMap}
                        </button>
                      </header>

                      <div class="p-5">
                        <p class="m-0 max-w-[82ch] leading-7 text-[#5d6a62]">
                          {route.intro}
                        </p>
                        <dl class="mt-5 grid gap-3 md:grid-cols-2">
                          {route.details.map(([label, value]) => (
                            <div class="rounded-lg border border-[rgba(16,32,25,0.12)] bg-[#f4f7f4] p-4">
                              <dt class="text-xs font-extrabold tracking-[0.08em] text-[#102019] uppercase">
                                {label}
                              </dt>
                              <dd class="mt-1.5 mb-0 leading-6 text-[#5d6a62]">
                                {value}
                              </dd>
                            </div>
                          ))}
                        </dl>
                        <div class="mt-5 rounded-lg border border-[rgba(16,32,25,0.12)] bg-[#fbfdfb] p-4">
                          <h4 class="m-0 text-base font-extrabold">
                            {ui.idealTitle}
                          </h4>
                          <ul class="mt-3 mb-0 list-disc pl-5 leading-7 text-[#5d6a62]">
                            {route.ideal.map(([lead, text]) => (
                              <li>
                                <strong>{lead}</strong> - {text}
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </article>
                  );
                })}
            </div>
          </section>
        );
      })
    }
  </div>

  <section class="mt-12" aria-labelledby="mpc-compare-title">
    <h2
      id="mpc-compare-title"
      class="m-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-[#102019]"
    >
      {ui.compareTitle}
    </h2>
    <div
      class="mt-4 overflow-x-auto rounded-lg border border-[rgba(16,32,25,0.12)]"
    >
      <table class="w-full min-w-[760px] border-collapse">
        <caption class="p-4 text-left text-[#5d6a62]">
          {ui.compareCaption}
        </caption>
        <thead>
          <tr>
            <th class="border-t-0 bg-[#0b1611] p-4 text-left text-white" scope="col">
              {ui.detailHeader}
            </th>
            {
              circuits.map((circuit) => (
                <th class="border-t-0 bg-[#0b1611] p-4 text-left text-white" scope="col">
                  {ui.circuit} {circuit.number}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            compareRows.map(
              ([detail, circuitOne, circuitTwo, circuitThree]) => (
                <tr>
                  <th
                    class="border-t border-[rgba(16,32,25,0.12)] p-4 text-left font-extrabold text-[#102019]"
                    scope="row"
                  >
                    {detail}
                  </th>
                  <td class="border-t border-[rgba(16,32,25,0.12)] p-4 text-left">
                    {circuitOne}
                  </td>
                  <td class="border-t border-[rgba(16,32,25,0.12)] p-4 text-left">
                    {circuitTwo}
                  </td>
                  <td class="border-t border-[rgba(16,32,25,0.12)] p-4 text-left">
                    {circuitThree}
                  </td>
                </tr>
              ),
            )
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-12" aria-labelledby="mpc-booking-title">
    <h2
      id="mpc-booking-title"
      class="m-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-[#102019]"
    >
      {ui.bookingTitle}
    </h2>
    <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
      {
        booking.map((item) => (
          <article class={`${cardClass} p-5`}>
            <h3 class="m-0 text-lg font-extrabold">{item.title}</h3>
            <p class="mt-2 mb-0 leading-7 text-[#5d6a62]">{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <div
    class="mt-12 rounded-lg border border-[rgba(0,122,61,0.18)] bg-gradient-to-br from-[#e9f7ef] to-[#fffaf0] p-6"
  >
    <h2
      class="m-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-[#102019]"
    >
      {cta.title}
    </h2>
    <p class="mt-2 mb-0 leading-7 text-[#5d6a62]">{cta.text}</p>
    <a class={`${pillButtonClass} mt-4 bg-[#007a3d]`} href={ctaHref}>
      {cta.label}
    </a>
  </div>

  {
    dialogs.map((dialog) => {
      const tone = toneStyles[dialog.tone];

      return (
        <dialog
          id={dialog.id}
          class="mpc-dialog fixed inset-0 m-auto max-h-[calc(100dvh-2rem)] w-full max-w-[min(92vw,1040px)] overflow-clip border-0 bg-transparent p-0 text-[#102019] max-sm:max-h-[calc(100dvh-1rem)] max-sm:max-w-[94vw]"
          aria-labelledby={`${dialog.id}-title`}
          closedby="any"
        >
          <div class="grid max-h-[calc(100dvh-2rem)] grid-rows-[auto_minmax(0,1fr)] overflow-hidden rounded-lg border border-white/15 bg-[#f7faf8] shadow-[0_30px_90px_rgba(0,0,0,0.38)] max-sm:max-h-[calc(100dvh-1rem)]">
            <header
              class={`flex items-center justify-between gap-4 p-4 text-white ${tone.dialog}`}
            >
              <h2
                id={`${dialog.id}-title`}
                class="m-0 text-lg leading-tight font-extrabold text-white"
              >
                {dialog.title}
              </h2>
              <form method="dialog">
                <button
                  class={`${focusClass} inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-white/20 bg-white/15 text-xl leading-none text-white`}
                  type="submit"
                  aria-label={ui.closeMap}
                >
                  x
                </button>
              </form>
            </header>
            <figure class="grid min-h-0 grid-rows-[minmax(0,1fr)_auto] p-4">
              <img
                class="block h-full max-h-[min(68dvh,620px)] w-full rounded-md bg-[#e8ede9] object-contain max-sm:max-h-[58dvh]"
                src={mapImage}
                alt={dialog.alt}
                width="1024"
                height="724"
                loading="lazy"
              />
              <figcaption class="mt-3 text-center text-sm leading-6 text-[#5d6a62]">
                {dialog.caption}
              </figcaption>
            </figure>
          </div>
        </dialog>
      );
    })
  }
</section>

<script>
  /**
   * @typedef {HTMLElement & { __mpcCircuitController?: AbortController }} CircuitRoot
   */

  const initMachupicchuCircuitDialogs = () => {
    document.querySelectorAll("[data-mpc-circuits]").forEach((root) => {
      const circuitRoot = /** @type {CircuitRoot} */ (root);
      const existingController = circuitRoot.__mpcCircuitController;
      existingController?.abort();

      const controller = new AbortController();
      circuitRoot.__mpcCircuitController = controller;

      circuitRoot.querySelectorAll("[data-mpc-dialog]").forEach((trigger) => {
        trigger.addEventListener(
          "click",
          () => {
            const dialogId = trigger.getAttribute("data-mpc-dialog");
            if (!dialogId) return;

            const dialog = circuitRoot.querySelector(
              `#${CSS.escape(dialogId)}`,
            );
            if (dialog instanceof HTMLDialogElement && !dialog.open) {
              dialog.showModal();
            }
          },
          { signal: controller.signal },
        );
      });

      circuitRoot.querySelectorAll("dialog").forEach((dialog) => {
        if (!("closedBy" in HTMLDialogElement.prototype)) {
          dialog.addEventListener(
            "click",
            (event) => {
              if (event.target !== dialog) return;

              const rect = dialog.getBoundingClientRect();
              const clickedInside =
                rect.top <= event.clientY &&
                event.clientY <= rect.top + rect.height &&
                rect.left <= event.clientX &&
                event.clientX <= rect.left + rect.width;

              if (!clickedInside) dialog.close();
            },
            { signal: controller.signal },
          );
        }
      });
    });
  };

  document.addEventListener("astro:page-load", initMachupicchuCircuitDialogs);

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      initMachupicchuCircuitDialogs,
      {
        once: true,
      },
    );
  } else {
    initMachupicchuCircuitDialogs();
  }
</script>

<style>
  .mpc-dialog::backdrop {
    background: rgba(4, 10, 7, 0.78);
    backdrop-filter: blur(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .mpc *,
    .mpc *::before,
    .mpc *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
