---
import {
  machupicchuCircuitsContent,
  type MachupicchuCircuitsLang,
} from "@/data/machupicchuCircuitsContent";
import { getPlanTripHref } from "@/lib/planTrip";
import { MapPinned } from "lucide-react";

interface Props {
  lang?: MachupicchuCircuitsLang;
}

type Tone = "c1" | "c2" | "c3" | "gold";

const selectedLang = Astro.props.lang ?? "es";
const content =
  machupicchuCircuitsContent[selectedLang] ?? machupicchuCircuitsContent.es;
const { circuits, routes, ui, compareRows, booking, cta } = content;
const ctaHref = getPlanTripHref(selectedLang);

const circuitMapImages: Record<string, string> = {
  circuito1: "/imagenes/circuitos/mapa-del-circuito-uno-machupicchu.webp",
  circuito2: "/imagenes/circuitos/mapa-circuito-dos-machupicchu.webp",
  circuito3: "/imagenes/circuitos/mapa-circuito-tres-machupicchu.webp",
};

const routeMapImages: Record<string, string> = {
  "ruta-1a": "/imagenes/circuitos/ruta-1-a.webp",
  "ruta-1b": "/imagenes/circuitos/ruta-1-b.webp",
  "ruta-1c": "/imagenes/circuitos/ruta-1-c.webp",
  "ruta-1d": "/imagenes/circuitos/ruta-1-d.webp",
  "ruta-2a": "/imagenes/circuitos/ruta-2-a.webp",
  "ruta-2b": "/imagenes/circuitos/ruta-2-b.webp",
  "ruta-3a": "/imagenes/circuitos/ruta-3-a.webp",
  "ruta-3b": "/imagenes/circuitos/ruta-3-b.webp",
  "ruta-3c": "/imagenes/circuitos/ruta-3-c.webp",
  "ruta-3d": "/imagenes/circuitos/ruta-3-d.webp",
};

const toneStyles: Record<
  Tone,
  {
    border: string;
    badge: string;
    text: string;
    soft: string;
    header: string;
    button: string;
    dialog: string;
    title: string;
  }
> = {
  c1: {
    border: "border-t-primary",
    badge: "bg-primary",
    text: "text-primary",
    soft: "bg-primary/10 text-primary",
    header:
      "bg-[linear-gradient(135deg,var(--primary),color-mix(in_oklab,var(--primary)_72%,black))]",
    button: "bg-primary",
    dialog: "bg-primary",
    title: "text-primary",
  },
  c2: {
    border: "border-t-[#244237]",
    badge: "bg-[#244237]",
    text: "text-[#244237]",
    soft: "bg-[color-mix(in_oklab,var(--primary)_8%,white)] text-[#244237]",
    header: "bg-[linear-gradient(135deg,#244237,#1f2d29)]",
    button: "bg-[#244237]",
    dialog: "bg-[#244237]",
    title: "text-[#244237]",
  },
  c3: {
    border: "border-t-secondary",
    badge: "bg-secondary",
    text: "text-secondary",
    soft: "bg-secondary/10 text-secondary",
    header:
      "bg-[linear-gradient(135deg,var(--secondary),color-mix(in_oklab,var(--secondary)_68%,#1f2d29))]",
    button: "bg-secondary",
    dialog: "bg-secondary",
    title: "text-secondary",
  },
  gold: {
    border: "border-t-accent-warm",
    badge: "bg-accent-warm text-accent-warm-foreground",
    text: "text-accent-warm-foreground",
    soft: "bg-[color-mix(in_oklab,var(--accent-warm)_28%,white)] text-accent-warm-foreground",
    header:
      "bg-[linear-gradient(135deg,var(--accent-warm),color-mix(in_oklab,var(--accent-warm)_72%,var(--primary)))] text-accent-warm-foreground",
    button: "bg-[#244237]",
    dialog: "bg-[#244237]",
    title: "text-accent-warm-foreground",
  },
};

const focusClass =
  "focus-visible:outline-[3px] focus-visible:outline-offset-[3px] focus-visible:outline-ring";
const pillButtonClass = `${focusClass} inline-flex cursor-pointer items-center justify-center gap-2 rounded-full border-0 px-4 py-3 text-sm font-extrabold leading-none text-white no-underline transition hover:-translate-y-0.5 hover:brightness-105`;
const cardClass =
  "overflow-hidden rounded-lg border border-border bg-white shadow-[0_24px_60px_-42px_color-mix(in_oklab,var(--foreground)_45%,transparent)]";

const dialogs = [
  ...circuits.map((circuit) => ({
    id: circuit.dialogId,
    tone: circuit.tone as Tone,
    image: circuitMapImages[circuit.id],
    title: `${ui.officialMap} - ${ui.circuit} ${circuit.number} ${circuit.name}`,
    alt: circuit.alt,
    caption: `(c) Dreamy Tours - ${ui.officialMap} - ${ui.circuit} ${circuit.number} ${circuit.name} (${circuit.routes.join(", ")})`,
  })),
  ...routes.map((route) => ({
    id: route.modalId,
    tone:
      (circuits.find((circuit) => circuit.id === route.circuitId)?.tone as
        | Tone
        | undefined) ?? (route.tone as Tone),
    image: routeMapImages[route.id],
    title: `${ui.map} - ${route.title}`,
    alt: `${ui.officialMap} - ${route.title}`,
    caption: `(c) Dreamy Tours - ${ui.officialMap} - ${route.title}`,
  })),
];
---

<section
  class="mpc mt-8 text-foreground"
  data-mpc-circuits
  aria-labelledby="mpc-heading"
>
  <div
    class="flex items-start gap-4 rounded-lg border border-l-4 border-accent-warm/35 border-l-accent-warm bg-[linear-gradient(135deg,color-mix(in_oklab,var(--accent-warm)_18%,white),white)] p-5 shadow-[0_20px_45px_-34px_color-mix(in_oklab,var(--foreground)_45%,transparent)] max-sm:flex-col max-sm:items-stretch"
  >
    <span
      class="inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-accent-warm font-extrabold text-accent-warm-foreground"
      aria-hidden="true">!</span
    >
    <p class="m-0 text-[0.96rem] leading-7 text-accent-warm-foreground">
      {ui.decree}
    </p>
  </div>

  <section class="py-12 text-center" aria-labelledby="mpc-heading">
    <p
      class="m-0 text-xs font-extrabold tracking-[0.18em] text-primary uppercase"
    >
      {ui.mapsLabel}
    </p>
    <h2
      id="mpc-heading"
      class="mt-2 mb-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-foreground"
    >
      {ui.mapsTitle}
    </h2>
    <p class="mx-auto mt-3 mb-0 leading-7 text-muted-foreground">
      {ui.mapsDescription}
    </p>

    <div class="mt-8 grid grid-cols-1 gap-5 text-left lg:grid-cols-3">
      {
        circuits.map((circuit) => {
          const tone = toneStyles[circuit.tone as Tone];

          return (
            <article
              class={`${cardClass} grid grid-rows-[auto_1fr] border-t-4 ${tone.border}`}
            >
              <button
                class={`${focusClass} group relative block aspect-[16/10] w-full cursor-pointer overflow-hidden border-0 bg-[#1f2d29] p-0 text-white`}
                type="button"
                data-mpc-dialog={circuit.dialogId}
                aria-label={`${ui.viewFullMap}: ${ui.circuit} ${circuit.number} ${circuit.name}`}
              >
                <img
                  class="block h-full w-full object-cover transition group-hover:scale-105"
                  src={circuitMapImages[circuit.id]}
                  alt={circuit.alt}
                  width="1024"
                  height="724"
                  loading="lazy"
                />
                <span
                  class={`absolute top-4 left-4 rounded-full px-3 py-1.5 text-xs font-extrabold ${tone.badge}`}
                >
                  {ui.circuit} {circuit.number}
                </span>
                <span class="absolute inset-0 flex items-center justify-center bg-[color-mix(in_oklab,var(--foreground)_72%,transparent)] opacity-0 transition group-hover:opacity-100 group-focus-visible:opacity-100">
                  {ui.viewFullMap}
                </span>
              </button>
              <div class="flex flex-col p-5">
                <span
                  class={`inline-flex text-xs font-extrabold tracking-[0.14em] uppercase ${tone.text}`}
                >
                  {ui.circuit} {circuit.number}
                </span>
                <h3 class="mt-1 mb-0 text-2xl leading-tight font-extrabold">
                  {circuit.name}
                </h3>
                <ul
                  class="mt-4 mb-5 flex list-none flex-wrap gap-2 p-0"
                  aria-label={`${ui.routesAria} ${circuit.number}`}
                >
                  {circuit.routes.map((route) => (
                    <li class="rounded-full border border-border bg-muted px-2.5 py-1.5 text-xs font-bold text-muted-foreground">
                      {route}
                    </li>
                  ))}
                </ul>
                <button
                  class={`${pillButtonClass} mt-auto w-full ${tone.button}`}
                  type="button"
                  data-mpc-dialog={circuit.dialogId}
                >
                  {ui.viewCircuitMap}
                </button>
              </div>
            </article>
          );
        })
      }
    </div>
  </section>

  <nav
    class="sticky top-0 z-[8] mb-10 flex gap-3 overflow-x-auto rounded-b-lg border border-border bg-white/95 p-2 shadow-[0_12px_26px_-20px_color-mix(in_oklab,var(--foreground)_50%,transparent)]"
    aria-label={ui.navLabel}
  >
    {
      circuits.map((circuit) => {
        const tone = toneStyles[circuit.tone as Tone];

        return (
          <a
            class={`${focusClass} flex-1 basis-[max-content] rounded-full px-4 py-3 text-center text-sm font-extrabold no-underline ${tone.soft}`}
            href={`#${circuit.id}`}
          >
            {ui.circuit} {circuit.number} - {circuit.name} (
            {circuit.routes.length} {ui.routes})
          </a>
        );
      })
    }
  </nav>

  <div>
    {
      circuits.map((circuit) => {
        const tone = toneStyles[circuit.tone as Tone];

        return (
          <section
            id={circuit.id}
            class="scroll-mt-24 not-first:mt-12"
            aria-labelledby={`${circuit.id}-title`}
          >
            <header
              class={`mb-4 flex items-center gap-5 rounded-lg p-5 text-white max-sm:flex-col max-sm:items-stretch ${tone.header}`}
            >
              <span
                class="flex h-14 w-14 flex-none items-center justify-center rounded-full border border-white/25 bg-white/15 text-2xl font-black"
                aria-hidden="true"
              >
                {circuit.number}
              </span>
              <div>
                <h2
                  id={`${circuit.id}-title`}
                  class="m-0 text-[clamp(1.55rem,3vw,2.2rem)] leading-tight font-extrabold text-white"
                >
                  {ui.circuit} {circuit.number} - {circuit.name}
                </h2>
                <p class="mt-1 mb-0 leading-7 text-white/80">
                  {circuit.summary}
                </p>
              </div>
            </header>

            <div class="grid gap-4">
              {routes
                .filter((route) => route.circuitId === circuit.id)
                .map((route) => {
                  const routeTone = tone;

                  return (
                    <article
                      id={route.id}
                      class={`${cardClass} border-t-[3px] ${routeTone.border}`}
                    >
                      <header
                        class={`flex items-center justify-between gap-4 p-4 max-sm:flex-col max-sm:items-stretch ${routeTone.soft}`}
                      >
                        <div>
                          <h3
                            class={`m-0 text-xl leading-tight font-extrabold ${routeTone.title}`}
                          >
                            {route.title}
                          </h3>
                          {"seasonal" in route && route.seasonal && (
                            <span class="mt-2 inline-flex rounded-full border border-accent-warm/35 bg-white px-2.5 py-1.5 text-xs font-extrabold text-accent-warm-foreground">
                              {route.seasonal}
                            </span>
                          )}
                        </div>
                        <button
                          class={`${pillButtonClass} ${routeTone.button} max-sm:w-full`}
                          type="button"
                          data-mpc-dialog={route.modalId}
                          aria-label={`${ui.viewRouteMap}: ${route.title}`}
                        >
                          <span class="inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-white/20 ring-1 ring-white/25">
                            <MapPinned className="h-4 w-4" aria-hidden="true" />
                          </span>
                          <span>{ui.viewRouteMap}</span>
                        </button>
                      </header>

                      <div class="p-5">
                        <p class="m-0 max-w-[82ch] leading-7 text-muted-foreground">
                          {route.intro}
                        </p>
                        <dl class="mt-5 grid gap-3 md:grid-cols-2">
                          {route.details.map(([label, value]) => (
                            <div class="rounded-lg border border-border bg-muted p-4">
                              <dt class="text-xs font-extrabold tracking-[0.08em] text-foreground uppercase">
                                {label}
                              </dt>
                              <dd class="mt-1.5 mb-0 leading-6 text-muted-foreground">
                                {value}
                              </dd>
                            </div>
                          ))}
                        </dl>
                        <div class="mt-5 rounded-lg border border-border bg-[color-mix(in_oklab,var(--primary)_4%,white)] p-4">
                          <h4 class="m-0 text-base font-extrabold">
                            {ui.idealTitle}
                          </h4>
                          <ul class="mt-3 mb-0 list-disc pl-5 leading-7 text-muted-foreground">
                            {route.ideal.map(([lead, text]) => (
                              <li>
                                <strong>{lead}</strong> - {text}
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </article>
                  );
                })}
            </div>
          </section>
        );
      })
    }
  </div>

  <section class="mt-12" aria-labelledby="mpc-compare-title">
    <h2
      id="mpc-compare-title"
      class="m-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-foreground"
    >
      {ui.compareTitle}
    </h2>
    <div class="mt-4 overflow-x-auto rounded-lg border border-border">
      <table class="w-full min-w-[760px] border-collapse">
        <caption class="p-4 text-left text-muted-foreground">
          {ui.compareCaption}
        </caption>
        <thead>
          <tr>
            <th
              class="border-t-0 bg-[#1f2d29] p-4 text-left text-white"
              scope="col"
            >
              {ui.detailHeader}
            </th>
            {
              circuits.map((circuit) => (
                <th
                  class="border-t-0 bg-[#1f2d29] p-4 text-left text-white"
                  scope="col"
                >
                  {ui.circuit} {circuit.number}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            compareRows.map(
              ([detail, circuitOne, circuitTwo, circuitThree]) => (
                <tr>
                  <th
                    class="border-t border-border p-4 text-left font-extrabold text-foreground"
                    scope="row"
                  >
                    {detail}
                  </th>
                  <td class="border-t border-border p-4 text-left">
                    {circuitOne}
                  </td>
                  <td class="border-t border-border p-4 text-left">
                    {circuitTwo}
                  </td>
                  <td class="border-t border-border p-4 text-left">
                    {circuitThree}
                  </td>
                </tr>
              ),
            )
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-12" aria-labelledby="mpc-booking-title">
    <h2
      id="mpc-booking-title"
      class="m-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-foreground"
    >
      {ui.bookingTitle}
    </h2>
    <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-3">
      {
        booking.map((item) => (
          <article class={`${cardClass} p-5`}>
            <h3 class="m-0 text-lg font-extrabold">{item.title}</h3>
            <p class="mt-2 mb-0 leading-7 text-muted-foreground">{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <div
    class="mt-12 rounded-lg border border-primary/20 bg-[linear-gradient(135deg,color-mix(in_oklab,var(--primary)_10%,white),color-mix(in_oklab,var(--accent-warm)_18%,white))] p-6"
  >
    <h2
      class="m-0 text-[clamp(1.8rem,4vw,2.75rem)] leading-[1.08] font-extrabold tracking-normal text-foreground"
    >
      {cta.title}
    </h2>
    <p class="mt-2 mb-0 leading-7 text-muted-foreground">{cta.text}</p>
    <a class={`${pillButtonClass} mt-4 bg-primary`} href={ctaHref}>
      {cta.label}
    </a>
  </div>

  {
    dialogs.map((dialog) => {
      const tone = toneStyles[dialog.tone];

      return (
        <dialog
          id={dialog.id}
          class="mpc-dialog fixed inset-0 m-auto max-h-[calc(100dvh-2rem)] w-full max-w-[min(92vw,1040px)] overflow-clip border-0 bg-transparent p-0 text-foreground max-sm:max-h-[calc(100dvh-1rem)] max-sm:max-w-[94vw]"
          aria-labelledby={`${dialog.id}-title`}
          closedby="any"
        >
          <div class="grid max-h-[calc(100dvh-2rem)] grid-rows-[auto_minmax(0,1fr)] overflow-hidden rounded-lg border border-white/15 bg-[color-mix(in_oklab,var(--primary)_4%,white)] shadow-[0_30px_90px_rgba(0,0,0,0.38)] max-sm:max-h-[calc(100dvh-1rem)]">
            <header
              class={`flex items-center justify-between gap-4 p-4 text-white ${tone.dialog}`}
            >
              <h2
                id={`${dialog.id}-title`}
                class="m-0 text-lg leading-tight font-extrabold text-white"
              >
                {dialog.title}
              </h2>
              <form method="dialog">
                <button
                  class={`${focusClass} inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-white/20 bg-white/15 text-xl leading-none text-white`}
                  type="submit"
                  aria-label={ui.closeMap}
                >
                  x
                </button>
              </form>
            </header>
            <figure class="grid min-h-0 grid-rows-[minmax(0,1fr)_auto] p-4">
              <img
                class="block h-full max-h-[min(68dvh,620px)] w-full rounded-md bg-muted object-contain max-sm:max-h-[58dvh]"
                src={dialog.image}
                alt={dialog.alt}
                width="1024"
                height="724"
                loading="lazy"
              />
              <figcaption class="mt-3 text-center text-sm leading-6 text-muted-foreground">
                {dialog.caption}
              </figcaption>
            </figure>
          </div>
        </dialog>
      );
    })
  }
</section>

<script>
  const circuitControllers = new WeakMap<Element, AbortController>();

  const initMachupicchuCircuitDialogs = () => {
    document.querySelectorAll("[data-mpc-circuits]").forEach((root) => {
      const circuitRoot = root;
      const existingController = circuitControllers.get(circuitRoot);
      existingController?.abort();

      const controller = new AbortController();
      circuitControllers.set(circuitRoot, controller);

      circuitRoot.querySelectorAll("[data-mpc-dialog]").forEach((trigger) => {
        trigger.addEventListener(
          "click",
          () => {
            const dialogId = trigger.getAttribute("data-mpc-dialog");
            if (!dialogId) return;

            const dialog = circuitRoot.querySelector(
              `#${CSS.escape(dialogId)}`,
            );
            if (dialog instanceof HTMLDialogElement && !dialog.open) {
              dialog.showModal();
            }
          },
          { signal: controller.signal },
        );
      });

      circuitRoot.querySelectorAll("dialog").forEach((dialog) => {
        if (!("closedBy" in HTMLDialogElement.prototype)) {
          dialog.addEventListener(
            "click",
            (event) => {
              if (event.target !== dialog) return;

              const rect = dialog.getBoundingClientRect();
              const clickedInside =
                rect.top <= event.clientY &&
                event.clientY <= rect.top + rect.height &&
                rect.left <= event.clientX &&
                event.clientX <= rect.left + rect.width;

              if (!clickedInside) dialog.close();
            },
            { signal: controller.signal },
          );
        }
      });
    });
  };

  document.addEventListener("astro:page-load", initMachupicchuCircuitDialogs);

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      initMachupicchuCircuitDialogs,
      {
        once: true,
      },
    );
  } else {
    initMachupicchuCircuitDialogs();
  }
</script>

<style>
  .mpc-dialog::backdrop {
    background: rgba(4, 10, 7, 0.78);
    backdrop-filter: blur(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .mpc *,
    .mpc *::before,
    .mpc *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
