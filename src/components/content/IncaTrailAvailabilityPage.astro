import { fetchAllStrapi } from "@/lib/strapi";
import { dedupeLocalizedDocuments } from "@/lib/utils";
import type { Lang } from "@/lib/i18n";
import type { SEOProps } from "@/components/layout/SEO.astro";
import type { Tour, Category as TourCategory } from "@/types/tours";
import { serializeJsonForHtml } from "@/lib/html";
import { incaTrailAvailabilitySlugMap } from "@/data/incaTrailAvailabilityPage";

interface Props {
