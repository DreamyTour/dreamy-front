} as const;

const copy = copyByLang[lang];
const now = new Date();
const calendarYear = 2026;
const initialMonth =
  calendarYear === now.getFullYear() ? now.getMonth() + 1 : 1;
const initialRoad = "1";
const calendarRoadLabelsByLang = {
  es: {
    "1": "Camino Inca 4 dias",
    "5": "Camino Inca 2 dias",
  },
  en: {
    "1": "Classic Inca Trail 4 Days",
    "5": "Short Inca Trail 2 Days",
  },
  pt: {
    "1": "Trilha Inca Classica 4 dias",
    "5": "Trilha Inca Curta 2 dias",
  },
} as const;

const normalizeText = (value: string | undefined) =>
  (value || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/\p{Diacritic}/gu, "");

const categoryAliases = [
  "inca trail",
  "camino inca",
  "trilha inca",
  "trilha-inca",
  "inca-trail",
  "camino-inca",
];

function isIncaTrailCategory(category: TourCategory) {
  const source = `${category.slug} ${category.nombre}`;
  const normalized = normalizeText(source).replaceAll("-", " ");

  return categoryAliases.some((alias) =>
    normalized.includes(alias.replaceAll("-", " ")),
  );
}

const toursRaw = await fetchAllStrapi<Tour>({
  endpoint: "tours",
  locale: lang,
});

const tours = dedupeLocalizedDocuments(Array.isArray(toursRaw) ? toursRaw : [])
  .filter((tour) => tour.categories?.some(isIncaTrailCategory))
  .sort((a, b) => (a.titulo || "").localeCompare(b.titulo || ""));
---

<PageLayout seo={seo} lang={lang}>
  <script
    is:inline
    id="page-slug-map"
    type="application/json"
    set:html={serializeJsonForHtml(incaTrailAvailabilitySlugMap)}
  />

  <div class="bg-background">
    <section class="border-b border-border bg-muted/40">
      <div
        class="mx-auto grid max-w-8xl gap-10 px-4 py-12 md:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-16"
      >
        <div class="max-w-3xl">
          <div
            class="inline-flex items-center gap-2 rounded-sm border border-secondary/20 bg-white px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-secondary"
          >
            <span class="h-2 w-2 rounded-full bg-secondary"></span>
            {copy.eyebrow}
          </div>
          <h1
            class="mt-6 text-4xl font-semibold tracking-tight text-foreground sm:text-5xl lg:text-6xl"
          >
            {copy.title}
          </h1>
          <p
            class="mt-6 max-w-2xl text-base leading-8 text-muted-foreground md:text-lg"
          >
            {copy.intro}
          </p>
        </div>

        <div
          class="self-start overflow-hidden rounded-lg border border-[#d8e3dc] bg-white shadow-[0_24px_70px_-48px_rgba(15,53,35,0.55)]"
        >
          <div
            class="grid divide-y divide-[#e6eee9] sm:grid-cols-3 sm:divide-x sm:divide-y-0 lg:grid-cols-1 lg:divide-x-0 lg:divide-y"
          >
            {
              copy.stats.map((stat, index) => (
                <div class="p-5">
                  <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-secondary">
                    {copy.statsKickers[index]}
                  </p>
                  <p class="mt-2 text-3xl font-semibold leading-none text-primary">
                    {copy.statsValues[index]}
                  </p>
                  <p class="mt-2 text-sm leading-6 text-muted-foreground">
                    {stat}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-8xl px-4 py-12 md:px-6 lg:px-8">
      <section class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <h2 class="text-3xl font-semibold tracking-tight text-foreground">
            {copy.availabilityTitle}
          </h2>
          <div class="mt-6 space-y-5 text-base leading-8 text-muted-foreground">
            <div>
              <h3 class="text-lg font-semibold text-foreground">
                {copy.regulationsTitle}
              </h3>
              <p class="mt-2">{copy.regulations}</p>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-foreground">
                {copy.seasonsTitle}
              </h3>
              <ul class="mt-2 space-y-2">
                {copy.seasons.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-foreground">
                {copy.requirementsTitle}
              </h3>
              <p class="mt-2">{copy.requirementsIntro}</p>
              <ul class="mt-3 space-y-2">
                {
                  copy.requirements.map((item) => (
                    <li class="flex gap-3">
                      <span class="mt-3 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" />
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <div
          class="relative overflow-hidden rounded-lg border border-[#ead9c7] bg-[#fffdf8] p-4 shadow-[0_28px_90px_-48px_rgba(70,45,23,0.58)] md:p-5"
        >
          <div
            class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-[linear-gradient(90deg,#244237,#db5b24,#c49a42)]"
          >
          </div>
          <div class="mb-5">
            <div>
              <span
                class="inline-flex items-center rounded-full border border-[#db5b24]/25 bg-[#fff4ec] px-3 py-1 text-[0.68rem] font-bold uppercase tracking-[0.18em] text-[#8f3513]"
              >
                {copy.calendarBadge}
              </span>
              <h2
                class="mt-3 text-2xl font-semibold tracking-tight text-foreground"
              >
                {copy.calendarTitle}
              </h2>
              <p class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">
                {copy.calendarIntro}
              </p>
            </div>
          </div>
          <IncaTrailAvailabilityCalendarIsland
            server:defer
            lang={lang}
            year={calendarYear}
            initialMonth={initialMonth}
            initialRoad={initialRoad}
            roadLabels={calendarRoadLabelsByLang[lang]}
          >
            <div
              slot="fallback"
              class="min-h-[430px] overflow-hidden rounded-lg border border-[#e8d8c9] bg-[#fffdf9] shadow-sm"
            >
              <div
                class="grid grid-cols-1 gap-3 border-b border-[#355548]/20 bg-[#244237] p-4 sm:grid-cols-2"
              >
                <div class="h-11 rounded-sm bg-white/20"></div>
                <div class="h-11 rounded-sm bg-white/20"></div>
              </div>
              <div class="mt-4 flex items-center justify-between px-3 py-3">
                <div class="h-9 w-9 rounded-full bg-[#f4eadf]"></div>
                <div class="h-5 w-32 rounded bg-[#e8d8c9]"></div>
                <div class="h-9 w-9 rounded-full bg-[#f4eadf]"></div>
              </div>
              <div
                class="mt-3 grid grid-cols-7 gap-px overflow-hidden rounded-sm bg-[#efe3d6]"
              >
                {
                  Array.from({ length: 35 }).map(() => (
                    <div class="h-16 bg-[#fffaf4]" />
                  ))
                }
              </div>
            </div>
          </IncaTrailAvailabilityCalendarIsland>
        </div>
      </section>

      <section class="py-14 md:py-16">
        <div
          class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between"
        >
          <div>
            <span
              class="text-xs font-semibold uppercase tracking-[0.24em] text-secondary"
            >
              {copy.categoryLabel}
            </span>
            <h2
              class="mt-2 text-3xl font-semibold tracking-tight text-foreground"
            >
              {copy.toursTitle}
            </h2>
          </div>
          <p class="max-w-2xl text-sm leading-6 text-muted-foreground">
            {copy.toursIntro}
          </p>
        </div>

        {
          tours.length > 0 ? (
            <div class="grid grid-cols-1 gap-x-2 gap-y-8 md:grid-cols-3 lg:grid-cols-4">
              {tours.map((tour) => (
                <TourCard tour={tour} lang={lang} />
              ))}
            </div>
          ) : (
            <div class="rounded-sm border border-dashed border-border bg-muted/40 p-8 text-center text-muted-foreground">
              {copy.noTours}
            </div>
          )
        }
      </section>

      <section class="border-t border-border py-12">
        <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr]">
          <div>
            <h2 class="text-3xl font-semibold tracking-tight text-foreground">
              {copy.paymentTitle}
            </h2>
            <p class="mt-4 text-base leading-8 text-muted-foreground">
              {copy.paymentIntro}
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-sm border border-border bg-white p-6">
              <h3 class="text-lg font-semibold text-foreground">
                {copy.depositTitle}
              </h3>
              <ul
                class="mt-4 space-y-3 text-sm leading-6 text-muted-foreground"
              >
                {
                  copy.depositItems.map((item) => (
                    <li class="flex gap-3">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" />
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="rounded-sm border border-border bg-white p-6">
              <h3 class="text-lg font-semibold text-foreground">
                {copy.conditionsTitle}
              </h3>
              <p class="mt-4 text-sm leading-6 text-muted-foreground">
                {copy.conditions}
              </p>
            </div>

            <div class="rounded-sm border border-border bg-white p-6">
              <h3 class="text-lg font-semibold text-foreground">
                {copy.methodsTitle}
              </h3>
              <ul
                class="mt-4 space-y-3 text-sm leading-6 text-muted-foreground"
              >
                {
                  copy.methods.map((item) => (
                    <li class="flex gap-3">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary" />
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="rounded-sm border border-border bg-white p-6">
              <h3 class="text-lg font-semibold text-foreground">
                {copy.confirmationTitle}
              </h3>
              <p class="mt-4 text-sm leading-6 text-muted-foreground">
                {copy.confirmation}
              </p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</PageLayout>
