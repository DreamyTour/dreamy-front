---
import fetchApi from "@/lib/strapi";
import type { GaleriaResponse, GaleriaItem } from "@/types/galeria";
import { getImageSrcSet, getImageUrl } from "@/lib/helpers";
import { ZoomIcon, ArrowLeftIcon, ArrowRightIcon } from "@/components/icons/NavigationIcons";

interface Props {
  totalImages?: number;
  lang?: string;
}

const props = Astro.props;
const totalImages = props.totalImages || 20;
const lang = props.lang || "en";

// Fetch de Strapi - obtener varias entradas para tener todas las imágenes
const galleryData = await fetchApi<GaleriaResponse>({
  endpoint: "client-galleries",
  locale: lang,
  query: {
    sort: "createdAt:desc",
    "pagination[limit]": "10",
  },
});

// Extraer las imágenes del array galeria
const galeriaItems = galleryData?.data?.[0]?.galeria || [];
const validItems: { img: string; srcSet: string; fullImg: string; alt: string }[] = [];

galeriaItems.forEach((item: GaleriaItem) => {
  if (item.imagen && item.imagen.length > 0) {
    const img = getImageUrl(item.imagen[0], "small") || "";
    const srcSet = getImageSrcSet(item.imagen[0], ["thumbnail", "small", "medium"]);
    const fullImg = getImageUrl(item.imagen[0], "large") || img;
    if (img) {
      validItems.push({
        img,
        srcSet,
        fullImg,
        alt: item.alt || "",
      });
    }
  }
});

// Limitar al número de imágenes solicitado
validItems.splice(totalImages);
---

{
  validItems.length > 0 ? (
    <div class="grid grid-cols-3 gap-3 mb-12">
      {validItems.map((item) => (
        <button
          type="button"
          class="relative overflow-hidden group cursor-pointer rounded-sm aspect-square w-full !p-0 border-0"
          data-src={item.fullImg}
          data-alt={item.alt}
          data-lightbox-btn
          aria-label={`Abrir imagen de galería${item.alt ? `: ${item.alt}` : ""}`}
        >
          <img
            src={item.img}
            srcset={item.srcSet || undefined}
            sizes="(max-width: 767px) 33vw, (max-width: 1023px) 25vw, 180px"
            alt={item.alt}
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />

          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="w-12 h-12 rounded-full bg-white/25 backdrop-blur-sm flex items-center justify-center">
              <ZoomIcon className="w-6 h-6 text-white" />
            </div>
          </div>
        </button>
      ))}
    </div>
  ) : (
    <div class="text-center py-12 text-muted-foreground">
      <p>Gallery coming soon...</p>
    </div>
  )
}

<div
  id="lightbox"
  class="fixed inset-0 bg-black/95 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lightbox-title"
>
  <h2 id="lightbox-title" class="sr-only">Imagen de galería</h2>
  <button
    type="button"
    class="absolute top-4 right-4 text-white/80 hover:text-white text-5xl font-light hover:scale-110 transition-all cursor-pointer z-50 w-12 h-12 flex items-center justify-center"
    id="lightbox-close"
    aria-label="Close lightbox"
  >
    &times;
  </button>

  <button
    type="button"
    class="absolute left-4 text-white/60 hover:text-white p-3 hover:bg-white/10 rounded-full transition-all z-50"
    id="lightbox-prev"
    aria-label="Previous image"
  >
    <ArrowLeftIcon className="w-8 h-8" />
  </button>

  <button
    type="button"
    class="absolute right-4 text-white/60 hover:text-white p-3 hover:bg-white/10 rounded-full transition-all z-50"
    id="lightbox-next"
    aria-label="Next image"
  >
    <ArrowRightIcon className="w-8 h-8" />
  </button>

  <img
    id="lightbox-img"
    src=""
    alt=""
    class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg shadow-2xl"
  />

  <div
    class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm"
    id="lightbox-counter"
  >
  </div>
</div>

<script is:inline>
  let currentIndex = 0;

  function getTotalImages() {
    return document.querySelectorAll("[data-lightbox-btn]").length;
  }

  document.addEventListener("astro:page-load", function () {
    const buttons = document.querySelectorAll("[data-lightbox-btn]");
    buttons.forEach(function (btn, index) {
      btn.addEventListener("click", function () {
        openLightbox(index);
      });
    });

    document
      .getElementById("lightbox-close")
      .addEventListener("click", closeLightbox);
    document
      .getElementById("lightbox-prev")
      .addEventListener("click", function () {
        navigateLightbox(-1);
      });
    document
      .getElementById("lightbox-next")
      .addEventListener("click", function () {
        navigateLightbox(1);
      });
  });

  function openLightbox(index) {
    currentIndex = index;
    const button = document.querySelectorAll("[data-lightbox-btn]")[index];
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img");
    const counter = document.getElementById("lightbox-counter");

    if (button && lightbox && lightboxImg) {
      const src = button.getAttribute("data-src") || "";
      const alt = button.getAttribute("data-alt") || "";
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      if (counter) counter.textContent = index + 1 + " / " + getTotalImages();
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.style.overflow = "hidden";
    }
  }

  function closeLightbox() {
    const lightbox = document.getElementById("lightbox");
    if (lightbox) {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.overflow = "";
    }
  }

  function navigateLightbox(direction) {
    const totalImages = getTotalImages();
    if (totalImages === 0) return;
    currentIndex = (currentIndex + direction + totalImages) % totalImages;
    openLightbox(currentIndex);
  }

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") navigateLightbox(-1);
    if (e.key === "ArrowRight") navigateLightbox(1);
  });
</script>
