---
import { WhatsAppIcon } from "@/components/icons/SocialContactIcons";

interface Props {
  phoneNumber?: string;
  message?: string;
  label?: string;
}

const {
  phoneNumber = "51969787221",
  message = "Hola, quisiera más información sobre sus tours.",
  label = "Escribinos por WhatsApp",
} = Astro.props;

const cleanPhone = phoneNumber.replace(/\D/g, "");
const href = `https://wa.me/${cleanPhone}${message ? `?text=${encodeURIComponent(message)}` : ""}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  title={label}
  class="group fixed bottom-4 right-4 z-50 inline-flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-3 text-white shadow-lg shadow-green-950/20 ring-1 ring-white/20 transition-all duration-300 hover:-translate-y-0.5 hover:scale-[1.02] hover:bg-[#20c35a] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#25D366] focus-visible:ring-offset-2 focus-visible:ring-offset-background md:bottom-24 md:right-6"
>
  <span
    class="flex size-10 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 group-hover:rotate-6"
  >
    <WhatsAppIcon className="size-5" />
  </span>

  <span class="hidden pr-1 text-sm font-semibold tracking-wide sm:inline">
    WhatsApp
  </span>
</a>
