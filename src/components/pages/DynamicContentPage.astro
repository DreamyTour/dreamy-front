---
import Layout from "@/layouts/main.astro";
import TourLayout from "@/layouts/TourLayout.astro";
import PageContent from "@/components/content/PageContent.astro";
import TourHero from "@/components/tours/TourHero.astro";
import TourTabs from "@/components/tours/TourTabs";
import ContactForm from "@/components/tours/ContactForm.astro";
import BookingFormFallback from "@/components/tours/BookingFormFallback.astro";
import BookingFormIsland from "@/components/tours/BookingFormIsland.astro";
import RelatedTours from "@/components/tours/RelatedTours.astro";
import type { Tour } from "@/types/tours";
import type { Page } from "@/types/page";
import { DEFAULT_LANG, type Lang } from "@/lib/i18n";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import type { ManualSEO } from "@/lib/seo";
import { buildSEOProps } from "@/lib/seo";
import {
  generateDescription,
  getImageAlt,
  getImageSrcSet,
  getImageUrl,
} from "@/lib/helpers";
import { serializeJsonForHtml } from "@/lib/html";
import { getIncaTrailBookingConfig } from "@/lib/incaTrailBooking";
import { buildTourSchemas } from "@/lib/tourSchema";
import { buildCollectionSchemas } from "@/lib/collectionSchema";
import { buildFaqPageSchema, buildStaticPageSchemas } from "@/lib/pageSchema";

interface MdxFrontmatter {
  title: string;
  description?: string;
  lang: Lang;
  seo?: ManualSEO;
  heroImage?: string;
  heroImageAlt?: string;
}

interface Props {
  type: "mdx" | "tour" | "page";
  lang: Lang;
  tour?: Tour;
  tourPageCategory?: { title: string; slug: string };
  page?: Page;
  slugMap?: Record<string, string>;
  pageSlugMap?: Record<string, string>;
  mdxComponent?: { default?: AstroComponentFactory };
  mdxFrontmatter?: MdxFrontmatter;
  toursRelated?: Tour[];
  toursByCategory?: Tour[];
}

const {
  type,
  lang,
  tour,
  tourPageCategory,
  page,
  slugMap,
  pageSlugMap,
  mdxComponent,
  mdxFrontmatter,
  toursRelated = [],
  toursByCategory = [],
} = Astro.props;

const siteUrl = Astro.site?.origin || "https://dreamy.tours";
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const tourFeaturedImages =
  type === "tour" && tour
    ? Array.isArray(tour.imagenDestacada)
      ? tour.imagenDestacada
      : tour.imagenDestacada
        ? [tour.imagenDestacada]
        : []
    : [];
const tourPrimaryImage = tourFeaturedImages[0];
const tourLcpImage = tourFeaturedImages[tourFeaturedImages.length - 1];

const hasIncaTrailBookingCalendar = Boolean(
  getIncaTrailBookingConfig(tour?.slug),
);

const seoProps =
  type === "mdx" && mdxFrontmatter
    ? buildSEOProps({
        seo: mdxFrontmatter.seo,
        fallbackTitle: mdxFrontmatter.title || "Pagina",
        fallbackDescription: mdxFrontmatter.description || "",
        fallbackImage: mdxFrontmatter.heroImage,
        fallbackImageAlt: mdxFrontmatter.heroImageAlt,
        type: "website",
        lang,
        slugMap: pageSlugMap,
        schemas: buildStaticPageSchemas({
          canonicalUrl,
          siteUrl,
          lang,
          title:
            mdxFrontmatter.seo?.metaTitle || mdxFrontmatter.title || "Pagina",
          description:
            mdxFrontmatter.seo?.metaDescription ||
            mdxFrontmatter.description ||
            "",
          imageUrl: mdxFrontmatter.heroImage,
          pathname: Astro.url.pathname,
        }),
      })
    : type === "tour" && tour
      ? (() => {
          const tourDescription = generateDescription(tour.content);
          const tourImage = tourPrimaryImage
            ? getImageUrl(tourPrimaryImage, "large")
            : undefined;
          const tourImageAlt = tourPrimaryImage
            ? getImageAlt(tourPrimaryImage, tour.titulo)
            : tour.titulo;
          const tourSchemaImage = tour.seo?.metaImage
            ? getImageUrl(tour.seo.metaImage, "large")
            : tourImage;

          return buildSEOProps({
            seo: tour.seo,
            fallbackTitle: tour.titulo || "Tour",
            fallbackDescription: tourDescription,
            fallbackImage: tourImage,
            fallbackImageAlt: tourImageAlt,
            type: "website",
            lang,
            slugMap,
            schemas: buildTourSchemas({
              tour,
              canonicalUrl,
              siteUrl,
              lang,
              description: tour.seo?.metaDescription || tourDescription,
              imageUrl: tourSchemaImage,
            }),
          });
        })()
      : type === "page" && page
        ? (() => {
            const pageDescription = generateDescription(page.content);
            const pageFaqSchema = buildFaqPageSchema({
              canonicalUrl,
              questions: page.preguntasAcordeon,
            });
            const pageSchemas =
              toursByCategory.length > 0
                ? buildCollectionSchemas({
                    page,
                    tours: toursByCategory,
                    canonicalUrl,
                    siteUrl,
                    lang,
                    description: pageDescription,
                  })
                : buildStaticPageSchemas({
                    canonicalUrl,
                    siteUrl,
                    lang,
                    title: page.seo?.metaTitle || page.titulo || "Pagina",
                    description:
                      page.seo?.metaDescription || pageDescription || "",
                    imageUrl: page.seo?.metaImage
                      ? getImageUrl(page.seo.metaImage, "large")
                      : undefined,
                    pathname: Astro.url.pathname,
                  });

            if (pageFaqSchema) {
              pageSchemas.push(pageFaqSchema);
            }

            return buildSEOProps({
              seo: page.seo,
              fallbackTitle: page.titulo || "Pagina",
              fallbackDescription: pageDescription,
              type: "website",
              lang,
              slugMap: pageSlugMap,
              schemas: pageSchemas,
            });
          })()
        : undefined;

const tourLcpImageUrl = tourLcpImage
  ? getImageUrl(tourLcpImage, "medium")
  : undefined;
const tourLcpImageSrcSet = tourLcpImage
  ? getImageSrcSet(tourLcpImage, ["small", "medium", "large"])
  : undefined;

const mdxUiCopy = {
  es: { eyebrow: "Guia Dreamy" },
  en: { eyebrow: "Dreamy Guide" },
  pt: { eyebrow: "Guia Dreamy" },
} as const;

const mdxCopy = mdxUiCopy[lang] ?? mdxUiCopy[DEFAULT_LANG];
const heroImage =
  (mdxFrontmatter?.heroImage as string | undefined) ||
  "/imagenes/sobre_nosotros.avif";
const heroImageAlt =
  (mdxFrontmatter?.heroImageAlt as string | undefined) || "Dreamy Tours";
const MdxContent = mdxComponent?.default;
---

{
  type === "mdx" && MdxContent && mdxFrontmatter && (
    <Layout seo={seoProps} lang={lang}>
      <script
        is:inline
        id="page-slug-map"
        type="application/json"
        set:html={serializeJsonForHtml(pageSlugMap || {})}
      />
      <div class="content-shell content-shell--mdx w-full mx-auto">
        <section class="content-hero content-hero--mdx relative isolate overflow-hidden h-[400px] md:h-[450px] lg:h-[500px] flex flex-col justify-center">
          <img
            src={heroImage}
            alt={heroImageAlt}
            class="hero-bg-img"
            loading="eager"
            fetchpriority="high"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent"
            aria-hidden="true"
          />

          <div class="relative w-full px-6 py-10 text-center md:px-10 md:py-14 lg:px-14 lg:py-16">
            <div class="mx-auto max-w-4xl">
              <p class="inline-flex items-center gap-3 rounded-sm border border-white/20 bg-black/50 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.34em] text-white shadow-sm backdrop-blur-sm">
                <span
                  class="h-2 w-2 rounded-full bg-secondary shadow-[0_0_0_4px_rgba(220,123,66,0.16)]"
                  aria-hidden="true"
                />
                <span>{mdxCopy.eyebrow}</span>
              </p>

              <h1 class="content-hero-title mt-6 text-white text-4xl font-semibold tracking-[-0.04em] sm:text-5xl lg:text-[4.1rem] lg:leading-[0.95]">
                {mdxFrontmatter.title}
              </h1>

              {mdxFrontmatter.description && (
                <p class="mx-auto mt-6 max-w-3xl text-base leading-8 text-white/80 md:text-lg lg:text-[1.08rem]">
                  {mdxFrontmatter.description}
                </p>
              )}

              <div
                class="mt-8 flex items-center justify-center gap-3"
                aria-hidden="true"
              >
                <div class="h-px w-16 bg-gradient-to-r from-transparent to-secondary/70" />
                <div class="relative h-1.5 w-12 rounded-full bg-secondary">
                  <div class="absolute left-1/2 top-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-secondary" />
                </div>
                <div class="h-px w-16 bg-gradient-to-l from-transparent to-secondary/70" />
              </div>
            </div>
          </div>
        </section>

        <div class="relative mx-auto mt-4 max-w-7xl">
          <article class="content-article mdx-text max-w-none px-6 md:px-10 lg:px-12 py-8 md:py-10 lg:py-12">
            <MdxContent />
          </article>
        </div>
      </div>
    </Layout>
  )
}

{
  type === "tour" && tour && (
    <TourLayout
      seo={seoProps}
      slugMap={slugMap}
      lang={lang}
      lcpImageUrl={tourLcpImageUrl}
      lcpImageSrcSet={tourLcpImageSrcSet}
    >
      <div class="max-w-8xl mx-auto px-4 md:px-6 lg:px-8 pb-12">
        <TourHero
          tour={tour}
          lang={lang}
          badges={tour.badge}
          pageCategory={tourPageCategory}
        />

        <section
          class="w-full mt-8"
          aria-label={
            lang === "en"
              ? "Tour details"
              : lang === "pt"
                ? "Detalhes do tour"
                : "Detalles del tour"
          }
        >
          <TourTabs tour={tour} lang={lang} client:visible>
            {hasIncaTrailBookingCalendar ? (
              <BookingFormIsland
                server:defer
                tourId={tour.documentId}
                tourName={tour.titulo}
                basePrice={tour.priceTour}
                tourSlug={tour.slug}
                lang={lang}
              >
                <BookingFormFallback slot="fallback" />
              </BookingFormIsland>
            ) : (
              <ContactForm tourName={tour.titulo} lang={lang} />
            )}
          </TourTabs>
        </section>

        <RelatedTours tours={toursRelated} lang={lang} />
      </div>
    </TourLayout>
  )
}

{
  type === "page" && page && (
    <PageContent
      page={page}
      toursByCategory={toursByCategory}
      pageSlugMap={pageSlugMap ?? {}}
      lang={lang}
      seoProps={seoProps!}
    />
  )
}
