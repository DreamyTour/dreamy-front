---
import Layout from "@/layouts/main.astro";
import fetchApi from "@/lib/strapi";
import type { Home } from "@/types/home";
import Hero from "@/components/sections/Hero.astro";
import HomeStats from "@/components/sections/HomeStats.astro";
import About from "@/components/sections/About.astro";
import Certifications from "@/components/sections/Certifications.astro";
import TourPackagesSection from "@/components/sections/TourPackagesSection.astro";
import PeruGuide from "@/components/sections/PeruGuide.astro";
import HomePost from "@/components/sections/HomePost.astro";
import ReviewsWall from "@/components/sections/ReviewsWall.astro";
import type { Lang } from "@/lib/i18n";
import { DEFAULT_SEO_IMAGE, buildSEOProps } from "@/lib/seo";
import backgroundImageMobile from "@/assets/backgroundImageMobile.webp";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const homeData = await fetchApi<Home>({
  endpoint: "home",
  wrappedByKey: "data",
  query: {
    locale: lang,
    populate: "*",
  },
});

const seoProps = {
  ...buildSEOProps({
    seo: homeData?.seo,
    fallbackTitle: "Turismo Peru Bolivia - Tours y Paquetes Turisticos",
    fallbackDescription:
      "Organiza tu viaje a Peru y Bolivia con los mejores tours: Machu Picchu, Lago Titicaca, Salar de Uyuni y mas. Paquetes turisticos completos.",
    type: "website",
    lang,
  }),
  image: DEFAULT_SEO_IMAGE,
  imageAlt: "Dreamy Tours - tours y paquetes turisticos en Peru y Bolivia",
};
---

<Layout seo={seoProps} lang={lang} lcpImageUrl={backgroundImageMobile.src}>
  <Hero data={homeData?.hero} lang={lang} />
  <HomeStats lang={lang} />
  <About data={homeData?.about} lang={lang} />
  <Certifications data={homeData?.premios?.premios} lang={lang} />
  <TourPackagesSection
    data={homeData?.sectionMapi}
    lang={lang}
    sectionId="machupicchu"
    titleId="machupicchu-title"
    href={`/${homeData?.sectionMapi?.category?.slug || "machu-picchu"}`}
    defaultLimit={10}
    highlighted
    ctaLabelKey="section.verMasPaquetes"
  />
  <TourPackagesSection
    data={homeData?.peruPaquetes}
    lang={lang}
    titleId="peru-packages-title"
    href={{
      es: "/paquetes-peru",
      en: "/peru-packages",
      pt: "/pacotes-peru",
    }[lang] || "/peru-packages"}
    surface="white"
  />
  <PeruGuide lang={lang} />
  <TourPackagesSection
    data={homeData?.boliviaPaquetes}
    lang={lang}
    titleId="bolivia-packages-title"
    href="/bolivia"
  />
  <HomePost data={homeData?.cardPost} lang={lang} />
  <ReviewsWall lang={lang} />
</Layout>